{# layouts/app.html.twig — Main app shell with sidebar + topbar #}
{% extends 'base.html.twig' %}

{% block body_page %}dashboard{% endblock %}

{# Apply dark/light before paint so admin pages don't flash #}
{% block head %}
{{ parent() }}
<script>
(function(){
    var t = localStorage.getItem('theme');
    var d = t ? t === 'dark' : window.matchMedia('(prefers-color-scheme: dark)').matches;
    if (d) document.documentElement.classList.add('dark');
    else document.documentElement.classList.remove('dark');
})();
</script>
{% endblock %}

{% set current_route = app.request.attributes.get('_route') %}

{% block body %}
<div class="flex h-screen overflow-hidden" x-data="{ sidebarOpen: true }">
    {# ===== Sidebar ===== #}
    <aside
        x-show="sidebarOpen"
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="-translate-x-full"
        x-transition:enter-end="translate-x-0"
        x-transition:leave="transition ease-in duration-150"
        x-transition:leave-start="translate-x-0"
        x-transition:leave-end="-translate-x-full"
        class="flex w-64 shrink-0 flex-col border-r border-sidebar-border bg-sidebar text-sidebar-foreground"
    >
        {# Logo #}
        <div class="flex h-14 items-center gap-2 border-b border-sidebar-border px-4">
            <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-sidebar-primary text-sidebar-primary-foreground text-sm font-bold">
                S
            </div>
            <span class="text-lg font-semibold tracking-tight">Skilora</span>
        </div>

        {# Navigation #}
        <nav class="flex-1 overflow-y-auto px-3 py-4 space-y-1">
            {% block sidebar_nav %}
            {% set user_role = app.user ? app.user.role : '' %}

            {# Dashboard route depends on role #}
            {% if user_role == 'ADMIN' %}
                {% set dashboard_route = 'app_dashboard' %}
            {% elseif user_role == 'EMPLOYER' %}
                {% set dashboard_route = 'app_employer_dashboard' %}
            {% elseif user_role == 'TRAINER' %}
                {% set dashboard_route = 'app_trainer_dashboard' %}
            {% else %}
                {% set dashboard_route = 'app_workspace' %}
            {% endif %}

            {# Common items for all authenticated users #}
            {% set nav_items = [
                { label: 'Dashboard', route: dashboard_route, icon: 'home', enabled: true },
            ] %}

            {# Role-specific items #}
            {% if user_role == 'ADMIN' %}
                {% set nav_items = nav_items|merge([
                    { label: 'Users Management', route: 'app_admin_user_index', icon: 'users', enabled: true },
                    { label: 'separator' },
                    { label: 'Recruitment', route: 'admin_recruitment_index', icon: 'briefcase', enabled: true },
                    { label: 'Formations', route: 'app_formation_index', icon: 'graduation-cap', enabled: true },
                    { label: 'Manage Formations', route: 'app_admin_formation_index', icon: 'book-open', enabled: true },
                    { label: 'separator' },
                    { label: 'Finance', route: 'admin_finance_index', icon: 'wallet', enabled: true },
                    { label: 'separator' },
                    { label: 'Support Tickets', route: 'admin_support_index', icon: 'life-buoy', enabled: true },
                    { label: 'Feedback', route: 'admin_support_avis_index', icon: 'message-square', enabled: true },
                    { label: 'separator' },
                    { label: 'Community', route: 'admin_community_index', icon: 'message-circle', enabled: true },
                ]) %}
            {% elseif user_role == 'EMPLOYER' %}
                {% set nav_items = nav_items|merge([
                    { label: 'separator' },
                    { label: 'Job Offers', route: 'app_employer_job_offer_index', icon: 'briefcase', enabled: true },
                    { label: 'Post a Job', route: 'app_employer_job_offer_new', icon: 'plus-circle', enabled: true },
                    { label: 'Applications', route: 'app_employer_applications', icon: 'inbox', enabled: true },
                    { label: 'Interviews', route: 'app_employer_interviews', icon: 'video', enabled: true },
                    { label: 'separator' },
                    { label: 'Community', route: 'app_community_posts', icon: 'message-circle', enabled: true },
                    { label: 'Support', route: 'support_index', icon: 'life-buoy', enabled: true },
                ]) %}
            {% elseif user_role == 'TRAINER' %}
                {% set nav_items = nav_items|merge([
                    { label: 'My Formations', route: 'app_trainer_formations', icon: 'graduation-cap', enabled: true },
                    { label: 'separator' },
                    { label: 'Community', route: 'app_community_posts', icon: 'message-circle', enabled: true },
                    { label: 'Support', route: 'support_index', icon: 'life-buoy', enabled: true },
                ]) %}
            {% else %}
                {# USER / FREELANCER #}
                {% set nav_items = nav_items|merge([
                    { label: 'separator' },
                    { label: 'Job Feed', route: 'app_candidate_offres_index', icon: 'search', enabled: true },
                    { label: 'My Applications', route: 'app_candidate_area_applications', icon: 'file-text', enabled: true },
                    { label: 'separator' },
                    { label: 'Formations', route: 'app_formation_index', icon: 'graduation-cap', enabled: true },
                    { label: 'My Formations', route: 'app_my_formations', icon: 'book-open', enabled: true },
                    { label: 'My Certificates', route: 'app_my_certificates', icon: 'award', enabled: true },
                    { label: 'separator' },
                    { label: 'Community', route: 'app_community_posts', icon: 'message-circle', enabled: true },
                    { label: 'Network', route: 'app_community_network', icon: 'users', enabled: true },
                    { label: 'Support', route: 'support_index', icon: 'life-buoy', enabled: true },
                ]) %}
            {% endif %}



            {% for item in nav_items %}
                {% if item.label == 'separator' %}
                    <div class="my-3 border-t border-sidebar-border"></div>
                {% else %}
                    <a href="{{ item.enabled|default(false) ? path(item.route) : '#' }}"
                       class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium transition-colors
                              {% set is_active = (current_route is defined and current_route == item.route) or (current_route is defined and current_route starts with item.route|split('_index')[0] ~ '_') %}
                              {{ is_active
                                  ? 'bg-sidebar-accent text-sidebar-accent-foreground'
                                  : 'text-sidebar-foreground/70 hover:bg-sidebar-accent hover:text-sidebar-accent-foreground' }}
                              {{ item.enabled|default(false) ? '' : 'opacity-50 pointer-events-none' }}">
                        <i data-lucide="{{ item.icon|default('circle') }}" class="h-4 w-4"></i>
                        {{ item.label }}
                    </a>
                {% endif %}
            {% endfor %}
            {% endblock %}
        </nav>

        {# User section — Profile dropdown #}
        <div class="border-t border-sidebar-border p-3">
            {% if app.user %}
            <div x-data="{ profileOpen: false }" class="relative">
                <button @click="profileOpen = !profileOpen"
                        class="flex w-full items-center gap-3 rounded-lg px-3 py-2 hover:bg-sidebar-accent transition-colors">
                    <div class="flex h-8 w-8 items-center justify-center rounded-full bg-sidebar-primary text-sidebar-primary-foreground text-xs font-medium">
                        {{ app.user.displayName|first|upper }}
                    </div>
                    <div class="flex-1 text-left truncate">
                        <p class="text-sm font-medium truncate">{{ app.user.displayName }}</p>
                        <p class="text-xs text-sidebar-foreground/50 truncate">{{ app.user.roleDisplayName }}</p>
                    </div>
                    <svg class="h-4 w-4 text-sidebar-foreground/50 transition-transform" :class="profileOpen && 'rotate-180'" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/>
                    </svg>
                </button>

                {# Dropdown #}
                <div x-show="profileOpen"
                     @click.outside="profileOpen = false"
                     x-transition:enter="transition ease-out duration-100"
                     x-transition:enter-start="opacity-0 -translate-y-1"
                     x-transition:enter-end="opacity-100 translate-y-0"
                     x-transition:leave="transition ease-in duration-75"
                     x-transition:leave-start="opacity-100 translate-y-0"
                     x-transition:leave-end="opacity-0 -translate-y-1"
                     x-cloak
                     class="absolute bottom-full left-0 right-0 mb-2 overflow-hidden rounded-lg border border-sidebar-border bg-popover text-popover-foreground shadow-lg">
                    <div class="px-3 py-2 border-b border-border">
                        <p class="text-sm font-medium">{{ app.user.displayName }}</p>
                        <p class="text-xs text-muted-foreground truncate">{{ app.user.email }}</p>
                    </div>
                    <div class="p-1">
                        <a href="{{ path('app_profile') }}"
                           class="flex items-center gap-2 rounded-md px-2 py-1.5 text-sm hover:bg-accent hover:text-accent-foreground transition-colors">
                            <i data-lucide="user" class="h-4 w-4"></i>
                            My Profile
                        </a>
                        <a href="{{ path('app_settings') }}"
                           class="flex items-center gap-2 rounded-md px-2 py-1.5 text-sm hover:bg-accent hover:text-accent-foreground transition-colors">
                            <i data-lucide="settings" class="h-4 w-4"></i>
                            Account Settings
                        </a>
                        <button @click="window.toggleTheme()"
                                class="flex w-full items-center gap-2 rounded-md px-2 py-1.5 text-sm hover:bg-accent hover:text-accent-foreground transition-colors">
                            <i data-lucide="sun-moon" class="h-4 w-4"></i>
                            Toggle Theme
                        </button>
                    </div>
                    <div class="border-t border-border p-1">
                        <a href="{{ path('app_logout') }}"
                           class="flex items-center gap-2 rounded-md px-2 py-1.5 text-sm text-destructive hover:bg-destructive/10 transition-colors">
                            <i data-lucide="log-out" class="h-4 w-4"></i>
                            Sign Out
                        </a>
                    </div>
                </div>
            </div>
            {% endif %}
        </div>
    </aside>

    {# ===== Main content area ===== #}
    <div class="flex flex-1 flex-col overflow-hidden">
        {# Topbar #}
        <header class="flex h-14 items-center gap-4 border-b border-border bg-background px-6">
            <button @click="sidebarOpen = !sidebarOpen"
                    class="inline-flex items-center justify-center rounded-md p-2 text-muted-foreground hover:bg-accent hover:text-accent-foreground focus-ring">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 12h18M3 6h18M3 18h18"/>
                </svg>
            </button>

            <h1 class="text-lg font-semibold">{% block page_title %}Dashboard{% endblock %}</h1>

            <div class="ml-auto flex items-center gap-2">
                {% block topbar_actions %}{% endblock %}

                {# Theme toggle #}
                <button x-data
                        @click="window.toggleTheme()"
                        class="inline-flex items-center justify-center rounded-md p-2 text-muted-foreground hover:bg-accent hover:text-accent-foreground focus-ring">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
                    </svg>
                </button>
            </div>
        </header>

        {# Page content #}
        <main class="flex-1 overflow-y-auto p-6">
            {% block content %}{% endblock %}
        </main>
    </div>
</div>

{# Global edit/update dialog — available on all dashboard pages #}
{{ include('components/edit-dialog.html.twig') }}
{% endblock %}
