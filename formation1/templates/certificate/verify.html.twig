{% extends 'base.html.twig' %}

{% block title %}Certificate Verification · Skilora{% endblock %}

{% block body %}
<main class="min-h-screen bg-background text-foreground flex items-center justify-center px-4 py-10">
    <section class="w-full max-w-3xl rounded-2xl border border-emerald-500/30 bg-card/95 p-8 shadow-xl">
        <div class="flex flex-wrap items-center justify-between gap-3">
            <h1 class="text-2xl font-bold tracking-tight">Certificate Verification</h1>
            <span class="inline-flex items-center rounded-full bg-emerald-500/15 px-4 py-1.5 text-sm font-semibold text-emerald-400 ring-1 ring-emerald-500/40">
                Verified Certificate ✅
            </span>
        </div>

        <div class="mt-6 grid gap-4 sm:grid-cols-2">
            <div class="rounded-xl border border-border bg-background/70 p-4">
                <p class="text-xs uppercase tracking-wider text-muted-foreground">Learner</p>
                <p class="mt-1 text-lg font-semibold">{{ certificate.user.fullName ?: certificate.user.username }}</p>
            </div>
            <div class="rounded-xl border border-border bg-background/70 p-4">
                <p class="text-xs uppercase tracking-wider text-muted-foreground">Course</p>
                <p class="mt-1 text-lg font-semibold">{{ certificate.course.title }}</p>
            </div>
            <div class="rounded-xl border border-border bg-background/70 p-4 sm:col-span-2">
                <p class="text-xs uppercase tracking-wider text-muted-foreground">Issued date</p>
                <p class="mt-1 text-lg font-semibold">{{ certificate.issuedAt|date('d/m/Y') }}</p>
            </div>
        </div>

        <p class="mt-6 text-sm text-muted-foreground">
            Verification ID:
            <span class="font-mono text-foreground">{{ certificate.verificationId }}</span>
        </p>
    </section>
</main>
{% endblock %}
