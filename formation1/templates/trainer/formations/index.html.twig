{% extends 'layouts/app.html.twig' %}

{% block title %}My Formations · Trainer{% endblock %}
{% block page_title %}My Formations{% endblock %}

{% block topbar_actions %}
    <button @click="$dispatch('open-edit-dialog', {
                title: 'New Formation',
                description: 'Fill in the fields to create a new formation.',
                url: '{{ path('app_trainer_formation_new') }}',
                size: 'lg'
            })"
            class="inline-flex h-9 items-center justify-center rounded-md bg-white px-4 text-xs font-semibold text-zinc-950 shadow hover:bg-zinc-100 dark:bg-white dark:text-zinc-950">
        + Add Formation
    </button>
{% endblock %}

{% block content %}
<div class="max-w-6xl space-y-6">
    <div>
        <h2 class="text-xl font-semibold tracking-tight">My Formations</h2>
        <p class="text-sm text-muted-foreground mt-1">Create and manage your training programs.</p>
    </div>

    <form method="get" action="{{ path('app_trainer_formations') }}" class="flex flex-wrap items-end gap-3">
        <div class="flex-1 min-w-[220px] max-w-md space-y-1">
            <label for="q" class="text-xs font-medium text-muted-foreground">Search</label>
            <input type="search" id="q" name="q" value="{{ q|e('html_attr') }}" placeholder="Title or description…" maxlength="200" autocomplete="off"
                   class="flex h-9 w-full rounded-md border border-input bg-background px-3 py-1 text-sm shadow-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring">
        </div>
        <button type="submit" class="inline-flex h-9 items-center rounded-md border border-input bg-background px-4 text-sm font-medium shadow-sm hover:bg-accent">Search</button>
        {% if q %}
            <a href="{{ path('app_trainer_formations') }}" class="inline-flex h-9 items-center rounded-md px-3 text-sm text-destructive hover:underline">Clear</a>
        {% endif %}
    </form>

    {% for message in app.flashes('success') %}
        <div class="rounded-md border border-green-500/30 bg-green-500/10 px-4 py-3 text-sm text-green-800 dark:text-green-300">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="rounded-md border border-destructive/30 bg-destructive/10 px-4 py-3 text-sm text-destructive">{{ message }}</div>
    {% endfor %}

    <div class="rounded-xl border border-border bg-card shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-border bg-muted/40">
                        <th class="h-10 px-3 sm:px-4 text-left font-medium text-muted-foreground w-14">ID</th>
                        <th class="h-10 px-3 sm:px-4 text-left font-medium text-muted-foreground min-w-[8rem]">Title</th>
                        <th class="h-10 px-3 sm:px-4 text-left font-medium text-muted-foreground">Category</th>
                        <th class="h-10 px-3 sm:px-4 text-left font-medium text-muted-foreground">Level</th>
                        <th class="h-10 px-3 sm:px-4 text-left font-medium text-muted-foreground">Price</th>
                        <th class="h-10 px-3 sm:px-4 text-right font-medium text-muted-foreground whitespace-nowrap">Duration (h)</th>
                        <th class="h-10 px-4 text-right font-medium text-muted-foreground w-28">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for formation in formations %}
                        <tr class="border-b border-border hover:bg-muted/30 transition-colors">
                            <td class="p-3 sm:p-4 text-muted-foreground font-mono text-xs">{{ formation.id }}</td>
                            <td class="p-3 sm:p-4 font-medium">{{ formation.title }}</td>
                            <td class="p-3 sm:p-4">
                                <span class="inline-flex max-w-[10rem] truncate rounded-full border border-border bg-muted/50 px-2 py-0.5 text-xs">{{ formation.categoryLabelFr }}</span>
                            </td>
                            <td class="p-3 sm:p-4 text-muted-foreground text-xs sm:text-sm">{{ formation.levelLabelFr }}</td>
                            <td class="p-3 sm:p-4 text-muted-foreground tabular-nums text-xs sm:text-sm">{{ formation.priceDisplayFr }}</td>
                            <td class="p-3 sm:p-4 text-right tabular-nums">{{ formation.duration }}</td>
                            <td class="p-3 sm:p-4 text-right">
                                <div class="flex items-center justify-end gap-1">
                                    <button @click="$dispatch('open-edit-dialog', {
                                                title: 'Edit Formation',
                                                description: '{{ formation.title|e('js') }}',
                                                url: '{{ path('app_trainer_formation_edit', { id: formation.id }) }}',
                                                size: 'lg'
                                            })"
                                            class="inline-flex items-center justify-center rounded-lg p-2 text-muted-foreground hover:bg-accent hover:text-foreground transition-colors"
                                            title="Edit">
                                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                                    </button>
                                    <form method="post"
                                          action="{{ path('app_trainer_formation_delete', {id: formation.id}) }}"
                                          onsubmit="return confirm('Are you sure you want to delete &quot;{{ formation.title|e('html_attr') }}&quot;? This action cannot be undone.');"
                                          class="inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('formation_delete_' ~ formation.id) }}">
                                        <button type="submit"
                                                class="inline-flex items-center justify-center rounded-lg p-2 text-destructive/70 hover:bg-destructive/10 hover:text-destructive transition-colors"
                                                title="Delete">
                                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="p-10 text-center text-muted-foreground">
                                No formations yet. Click <strong>+ Add Formation</strong> to create one.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {% if pageCount > 1 or total > 0 %}
        <div class="flex flex-wrap items-center justify-between gap-4 text-sm">
            <p class="text-muted-foreground">
                Showing {{ formations|length }} of {{ total }}
                {% if pageCount > 1 %}(page {{ currentPage }}/{{ pageCount }}){% endif %}
            </p>
            {% if pageCount > 1 %}
                <nav class="flex flex-wrap items-center justify-center gap-2" aria-label="Pagination">
                    {% set baseQuery = q ? { q: q } : {} %}
                    <a href="{{ path('app_trainer_formations', baseQuery|merge({ page: currentPage - 1 })) }}"
                       class="inline-flex h-8 items-center rounded-md border px-3 text-xs {{ currentPage <= 1 ? 'pointer-events-none opacity-50' : '' }}">Previous</a>
                    {% for p in 1..pageCount %}
                        <a href="{{ path('app_trainer_formations', baseQuery|merge({ page: p })) }}"
                           class="inline-flex h-8 w-8 items-center justify-center rounded-md text-xs font-medium {{ p == currentPage ? 'bg-primary text-primary-foreground' : 'border hover:bg-accent' }}">{{ p }}</a>
                    {% endfor %}
                    <a href="{{ path('app_trainer_formations', baseQuery|merge({ page: currentPage + 1 })) }}"
                       class="inline-flex h-8 items-center rounded-md border px-3 text-xs {{ currentPage >= pageCount ? 'pointer-events-none opacity-50' : '' }}">Next</a>
                </nav>
            {% endif %}
        </div>
    {% endif %}
</div>
{% include 'admin/formation/_signature_zone_script.html.twig' %}
{% endblock %}
