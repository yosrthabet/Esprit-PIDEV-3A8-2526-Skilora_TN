{# components/table.html.twig — ShadCN Data Table #}
{#
  Usage: {{ include('components/table.html.twig', {
      columns: [
          { key: 'name', label: 'Name' },
          { key: 'email', label: 'Email' },
          { key: 'role', label: 'Role' },
          { key: 'actions', label: '', align: 'right' },
      ],
      rows: [
          { name: 'John', email: 'john@test.com', role: '<span class="...">Admin</span>', actions: '...' },
      ],
      empty_message: 'No results found.',
  }) }}
#}
{% set empty_message = empty_message|default('No results.') %}

<div class="relative w-full overflow-hidden rounded-2xl border border-border bg-card shadow-sm transition-shadow hover:shadow-md {{ class|default('') }}">
    <div class="overflow-x-auto w-full">
        <table class="w-full caption-bottom text-sm">
            <thead class="[&_tr]:border-b bg-muted/10">
                <tr class="border-b border-border/50 text-xs uppercase tracking-wider text-muted-foreground/80">
                    {% for col in columns %}
                        <th class="h-12 px-5 text-{{ col.align|default('left') }} align-middle font-semibold [&:has([role=checkbox])]:pr-0">
                            {{ col.label }}
                        </th>
                    {% endfor %}
                </tr>
            </thead>
            <tbody class="[&_tr:last-child]:border-0 divide-y divide-border/50">
                {% if rows|default([])|length == 0 %}
                    <tr>
                        <td colspan="{{ columns|length }}" class="h-32 text-center text-muted-foreground">
                            <div class="flex flex-col items-center justify-center space-y-2">
                                <svg class="h-8 w-8 text-muted-foreground/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
                                </svg>
                                <span>{{ empty_message }}</span>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    {% for row in rows %}
                    <tr class="transition-colors hover:bg-muted/30 group">
                        {% for col in columns %}
                            <td class="px-5 py-4 align-middle text-{{ col.align|default('left') }} [&:has([role=checkbox])]:pr-0">
                                {{ attribute(row, col.key)|default('')|raw }}
                            </td>
                        {% endfor %}
                    </tr>
                    {% endfor %}
                {% endif %}
            </tbody>
        </table>
    </div>
</div>
