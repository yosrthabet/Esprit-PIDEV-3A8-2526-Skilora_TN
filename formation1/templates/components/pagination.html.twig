{# components/pagination.html.twig — ShadCN-style pagination #}
{#
  Usage: {{ include('components/pagination.html.twig', {
      current_page: 1,
      total_pages: 10,
      base_url: '/users?page=',
  }) }}
#}
{% set current_page = current_page|default(1) %}
{% set total_pages = total_pages|default(1) %}
{% set base_url = base_url|default('?page=') %}

{% if total_pages > 1 %}
<nav class="flex items-center justify-center gap-1 {{ class|default('') }}" aria-label="Pagination">
    {# Previous #}
    <a href="{{ current_page > 1 ? base_url ~ (current_page - 1) : '#' }}"
       class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-input bg-background text-sm shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground {{ current_page <= 1 ? 'pointer-events-none opacity-50' : '' }}">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
    </a>

    {# Page numbers #}
    {% set start = current_page - 2 %}
    {% if start < 1 %}{% set start = 1 %}{% endif %}
    {% set end = current_page + 2 %}
    {% if end > total_pages %}{% set end = total_pages %}{% endif %}

    {% if start > 1 %}
        <a href="{{ base_url }}1" class="inline-flex h-9 w-9 items-center justify-center rounded-md text-sm transition-colors hover:bg-accent">1</a>
        {% if start > 2 %}
            <span class="inline-flex h-9 w-9 items-center justify-center text-sm text-muted-foreground">...</span>
        {% endif %}
    {% endif %}

    {% for page in start..end %}
        <a href="{{ base_url }}{{ page }}"
           class="inline-flex h-9 w-9 items-center justify-center rounded-md text-sm transition-colors {{ page == current_page ? 'border border-input bg-background shadow-sm font-medium' : 'hover:bg-accent' }}">
            {{ page }}
        </a>
    {% endfor %}

    {% if end < total_pages %}
        {% if end < total_pages - 1 %}
            <span class="inline-flex h-9 w-9 items-center justify-center text-sm text-muted-foreground">...</span>
        {% endif %}
        <a href="{{ base_url }}{{ total_pages }}" class="inline-flex h-9 w-9 items-center justify-center rounded-md text-sm transition-colors hover:bg-accent">{{ total_pages }}</a>
    {% endif %}

    {# Next #}
    <a href="{{ current_page < total_pages ? base_url ~ (current_page + 1) : '#' }}"
       class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-input bg-background text-sm shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground {{ current_page >= total_pages ? 'pointer-events-none opacity-50' : '' }}">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
    </a>
</nav>
{% endif %}
