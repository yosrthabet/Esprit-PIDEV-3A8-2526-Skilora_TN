{# components/sidebar.html.twig — ShadCN Sidebar / Navigation

   Usage: {{ include('components/sidebar.html.twig', {
       brand: 'Skilora',
       brand_href: '/',
       sections: [
           {
               label: 'Main',
               items: [
                   { label: 'Dashboard', href: '/dashboard', icon: 'home', active: true },
                   { label: 'Jobs', href: '/jobs', icon: 'briefcase' },
                   { label: 'Messages', href: '/messages', icon: 'mail', badge: '3' },
               ]
           },
           {
               label: 'Settings',
               items: [
                   { label: 'Profile', href: '/profile', icon: 'user' },
                   { label: 'Billing', href: '/billing', icon: 'credit-card' },
               ]
           },
       ],
       footer_content: '<div>...</div>',
   }) }}
#}

<aside class="flex h-full w-64 flex-col border-r border-border bg-background {{ class|default('') }}">
    {# Brand #}
    {% if brand is defined %}
    <div class="flex h-14 items-center border-b border-border px-4">
        <a href="{{ brand_href|default('/') }}" class="flex items-center gap-2 font-bold text-lg tracking-tight text-foreground">
            {{ brand }}
        </a>
    </div>
    {% endif %}

    {# Navigation #}
    <nav class="flex-1 overflow-y-auto p-3 space-y-6">
        {% for section in sections|default([]) %}
            <div>
                {% if section.label is defined %}
                    <p class="mb-2 px-2 text-xs font-semibold uppercase tracking-wider text-muted-foreground">{{ section.label }}</p>
                {% endif %}
                <ul class="space-y-1">
                    {% for item in section.items|default([]) %}
                        <li>
                            <a
                                href="{{ item.href|default('#') }}"
                                class="flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium transition-colors
                                    {{ item.active|default(false) ? 'bg-accent text-accent-foreground' : 'text-muted-foreground hover:bg-accent hover:text-accent-foreground' }}"
                            >
                                {% if item.icon is defined %}
                                    <i data-lucide="{{ item.icon }}" class="h-4 w-4"></i>
                                {% endif %}
                                <span class="flex-1">{{ item.label }}</span>
                                {% if item.badge is defined %}
                                    <span class="inline-flex items-center rounded-full bg-primary/10 px-2 py-0.5 text-xs font-medium text-primary">{{ item.badge }}</span>
                                {% endif %}
                            </a>
                        </li>
                    {% endfor %}
                </ul>
            </div>
        {% endfor %}
    </nav>

    {# Footer #}
    {% if footer_content is defined %}
    <div class="border-t border-border p-3">
        {{ footer_content|raw }}
    </div>
    {% endif %}
</aside>
