{# components/navigation-menu.html.twig — ShadCN Navigation Menu (horizontal top nav)

   Usage: {{ include('components/navigation-menu.html.twig', {
       items: [
           { label: 'Dashboard', href: '/dashboard' },
           {
               label: 'Features',
               children: [
                   { label: 'Jobs', href: '/jobs', description: 'Browse open positions' },
                   { label: 'Training', href: '/training', description: 'Boost your skills' },
               ]
           },
           { label: 'Pricing', href: '/pricing' },
       ],
   }) }}
#}

<nav class="flex items-center gap-1 {{ class|default('') }}">
    {% for item in items|default([]) %}
        {% if item.children is defined %}
            {# Dropdown item #}
            <div x-data="{ open: false }" @mouseleave="open = false" class="relative">
                <button
                    @mouseenter="open = true"
                    @click="open = !open"
                    class="group inline-flex h-9 w-max items-center justify-center rounded-md bg-background px-4 py-2 text-sm font-medium transition-colors hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground focus:outline-none"
                >
                    {{ item.label }}
                    <svg class="relative top-[1px] ml-1 h-3 w-3 transition-transform duration-200" :class="open && 'rotate-180'" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                    </svg>
                </button>

                <div
                    x-show="open"
                    @mouseenter="open = true"
                    x-transition:enter="transition ease-out duration-200"
                    x-transition:enter-start="opacity-0 -translate-y-1"
                    x-transition:enter-end="opacity-100 translate-y-0"
                    x-transition:leave="transition ease-in duration-150"
                    x-transition:leave-start="opacity-100"
                    x-transition:leave-end="opacity-0"
                    x-cloak
                    class="absolute left-0 top-full mt-1.5 w-64 rounded-md border border-border bg-popover p-2 text-popover-foreground shadow-lg"
                >
                    {% for child in item.children %}
                        <a
                            href="{{ child.href|default('#') }}"
                            class="block select-none rounded-md p-3 leading-none no-underline outline-none transition-colors hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground"
                        >
                            <div class="text-sm font-medium leading-none">{{ child.label }}</div>
                            {% if child.description is defined %}
                                <p class="line-clamp-2 text-sm leading-snug text-muted-foreground mt-1">{{ child.description }}</p>
                            {% endif %}
                        </a>
                    {% endfor %}
                </div>
            </div>
        {% else %}
            {# Simple link #}
            <a
                href="{{ item.href|default('#') }}"
                class="inline-flex h-9 items-center justify-center rounded-md px-4 py-2 text-sm font-medium transition-colors hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground {{ item.active|default(false) ? 'bg-accent/50' : '' }}"
            >
                {{ item.label }}
            </a>
        {% endif %}
    {% endfor %}
</nav>
