{# Formation form: metadata (section 1) + certificate branding / signature (section 2) #}
{% set formation_entity = (formation is defined and formation is not null) ? formation : form.vars.data %}

<div class="space-y-8">
    <div class="rounded-xl border border-border/70 bg-background/70 p-4">
        <div class="flex items-center justify-between gap-3">
            <div class="flex items-center gap-2">
                <span class="inline-flex h-7 w-7 items-center justify-center rounded-full text-xs font-semibold"
                      :class="step === 1 ? 'bg-primary text-primary-foreground' : 'bg-emerald-500/20 text-emerald-300 border border-emerald-500/40'">1</span>
                <span class="text-sm font-medium" :class="step === 1 ? 'text-foreground' : 'text-muted-foreground'">Détails</span>
            </div>
            <div class="h-px flex-1 bg-border/70"></div>
            <div class="flex items-center gap-2">
                <span class="inline-flex h-7 w-7 items-center justify-center rounded-full text-xs font-semibold"
                      :class="step === 2 ? 'bg-primary text-primary-foreground' : 'bg-secondary text-secondary-foreground border border-border'">2</span>
                <span class="text-sm font-medium" :class="step === 2 ? 'text-foreground' : 'text-muted-foreground'">Signature</span>
            </div>
        </div>
        <div class="mt-3 h-1.5 overflow-hidden rounded-full bg-border/50">
            <div class="h-full rounded-full bg-gradient-to-r from-indigo-500 via-violet-500 to-fuchsia-500 transition-all duration-300"
                 :style="`width: ${step === 1 ? 50 : 100}%`"></div>
        </div>
    </div>

    {# —— Section 1: catalogue metadata —— #}
    <div class="space-y-4" x-show="step === 1" x-transition.opacity.duration.150ms>
        <div class="flex flex-wrap items-end justify-between gap-2 border-b border-border/80 pb-3">
            <div>
                <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-muted-foreground/90">Étape 1</p>
                <h3 class="text-sm font-semibold text-foreground">Informations de la formation</h3>
                <p class="mt-0.5 text-xs text-muted-foreground">Métadonnées du catalogue (contenu pédagogique et taxonomie).</p>
            </div>
        </div>

        <div class="space-y-5">
            <div class="space-y-2">
                {{ form_label(form.title) }}
                {{ form_widget(form.title, {
                    attr: form.title.vars.attr|merge({
                        class: (form.title.vars.attr.class|default('')) ~ ((form.title.vars.errors|length > 0) ? ' is-invalid' : '')
                    })
                }) }}
            </div>

            <div
                class="space-y-2"
                x-data="{ count: {{ form.description.vars.value|default('')|length }} }"
            >
                {{ form_label(form.description) }}
                {{ form_widget(form.description, {
                    attr: form.description.vars.attr|merge({
                        class: (form.description.vars.attr.class|default('')) ~ ((form.description.vars.errors|length > 0) ? ' is-invalid' : ''),
                        '@input': 'count = $event.target.value.length',
                    }),
                }) }}
                <p class="text-right text-xs text-muted-foreground -mt-1">
                    <span x-text="count">0</span> / 500
                </p>
            </div>

            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
                <div class="space-y-2">
                    {{ form_label(form.price) }}
                    {{ form_widget(form.price, {
                        attr: form.price.vars.attr|merge({
                            class: (form.price.vars.attr.class|default('')) ~ ((form.price.vars.errors|length > 0) ? ' is-invalid' : '')
                        })
                    }) }}
                </div>
                <div class="space-y-2">
                    {{ form_label(form.duration) }}
                    {{ form_widget(form.duration, {
                        attr: form.duration.vars.attr|merge({
                            class: (form.duration.vars.attr.class|default('')) ~ ((form.duration.vars.errors|length > 0) ? ' is-invalid' : '')
                        })
                    }) }}
                </div>
                <div class="space-y-2">
                    {{ form_label(form.lessonsCount) }}
                    {{ form_widget(form.lessonsCount, {
                        attr: form.lessonsCount.vars.attr|merge({
                            class: (form.lessonsCount.vars.attr.class|default('')) ~ ((form.lessonsCount.vars.errors|length > 0) ? ' is-invalid' : '')
                        })
                    }) }}
                </div>
                <div class="space-y-2">
                    {{ form_label(form.level) }}
                    {{ form_widget(form.level, {
                        attr: form.level.vars.attr|merge({
                            class: (form.level.vars.attr.class|default('')) ~ ((form.level.vars.errors|length > 0) ? ' is-invalid' : '')
                        })
                    }) }}
                </div>
            </div>

            <div class="space-y-2">
                {{ form_label(form.category) }}
                {{ form_widget(form.category, {
                    attr: form.category.vars.attr|merge({
                        class: (form.category.vars.attr.class|default('')) ~ ((form.category.vars.errors|length > 0) ? ' is-invalid' : '')
                    })
                }) }}
            </div>
        </div>
    </div>

    {# —— Section 2: certificate branding (isolated from catalogue domain) —— #}
    <div class="space-y-4 rounded-xl border border-indigo-500/25 bg-gradient-to-b from-background to-secondary/10 p-5 shadow-inner"
         x-show="step === 2"
         x-transition.opacity.duration.150ms
         x-data="skiloraFormationSignatureZone({
            existingUrl: {% if formation_entity.id and formation_entity.certificateSignatureFilename -%}
                {% if is_granted('ROLE_ADMIN') %}'{{ path('app_admin_formation_signature_preview', { id: formation_entity.id })|e('js') }}'{% else %}'{{ path('app_trainer_formation_signature_preview', { id: formation_entity.id })|e('js') }}'{% endif %}
            {%- else %}null{% endif %}
         })"
         x-init="init()">
        <div class="flex flex-wrap items-end justify-between gap-2 border-b border-border/60 pb-3">
            <div>
                <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-indigo-400/90">Étape 2</p>
                <h3 class="text-sm font-semibold text-foreground">Signature &amp; image de marque (certificat)</h3>
                <p class="mt-0.5 text-xs text-muted-foreground">
                    Actif PDF : fichier PNG haute définition, fond transparent. Stockage privé hors web root.
                </p>
            </div>
        </div>

        <div class="grid gap-6 lg:grid-cols-[1fr_220px]">
            <div class="space-y-3">
                <div class="space-y-1">
                    <label class="text-sm font-medium text-foreground">Signature digitale</label>
                    <p class="text-xs text-muted-foreground">Dessinez la signature directement. Le rendu est exporte en PNG transparent pour le moteur de certificat.</p>
                </div>

                <div class="overflow-hidden rounded-xl border border-border/80 bg-gradient-to-b from-zinc-900 to-zinc-950 shadow-[0_0_0_1px_rgba(99,102,241,0.08)] transition-all duration-300 hover:border-indigo-500/50 hover:shadow-[0_0_0_1px_rgba(99,102,241,0.2),0_16px_40px_rgba(0,0,0,0.35)]">
                    <div class="flex items-center justify-between border-b border-border/70 px-4 py-3">
                        <div>
                            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-indigo-300/90">Signature Pad</p>
                            <p class="mt-0.5 text-[11px] text-muted-foreground">Trait clair sur fond sombre, temps reel.</p>
                        </div>
                        <button type="button"
                                class="inline-flex h-8 items-center justify-center rounded-md border border-border bg-background px-3 text-xs font-medium text-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
                                @click="clearPad()">
                            Clear
                        </button>
                    </div>
                    <div class="p-4">
                        <div class="rounded-lg border border-dashed border-border/70 bg-zinc-900/90 p-2 transition-colors duration-300"
                             :class="hasError ? 'border-rose-500/70 shadow-[0_0_0_1px_rgba(244,63,94,0.2)]' : 'hover:border-indigo-500/40'">
                            <canvas x-ref="signaturePadCanvas"
                                    class="block h-[220px] max-h-[250px] w-full rounded-md bg-zinc-800/70 sm:h-[230px] lg:h-[240px]"
                                    aria-label="Canvas de signature"></canvas>
                        </div>
                        <p class="mt-2 text-[11px] text-muted-foreground">
                            Dessinez avec la souris ou le tactile. La soumission est bloquee tant que la signature est vide.
                        </p>
                    </div>
                </div>

                {{ form_widget(form.signatureData, {
                    attr: form.signatureData.vars.attr|merge({
                        class: 'sr-only',
                    })
                }) }}
                {% if form.signatureData.vars.errors|length > 0 %}
                    <p class="text-xs font-medium text-rose-400" x-init="hasError = true">{{ form.signatureData.vars.errors|first.message }}</p>
                {% endif %}

                {% if form.removeCertificateSignature is defined %}
                    <div class="flex items-center gap-2 pt-1">
                        {{ form_widget(form.removeCertificateSignature) }}
                        {{ form_label(form.removeCertificateSignature) }}
                    </div>
                {% endif %}
            </div>

            <div class="space-y-2">
                <p class="text-xs font-medium text-muted-foreground">Prévisualisation</p>
                <div class="flex aspect-[4/3] max-h-[200px] items-center justify-center overflow-hidden rounded-lg border border-border bg-black/40 p-3">
                    <img x-show="previewUrl"
                         x-bind:src="previewUrl"
                         alt="Signature"
                         class="max-h-full max-w-full object-contain">
                    <span x-show="!previewUrl" class="text-center text-[11px] text-muted-foreground">Aucune signature capturee</span>
                </div>
                <p class="text-[11px] text-muted-foreground" x-show="existingUrl && !previewUrl">La signature deja enregistree sera conservee si vous ne dessinez pas une nouvelle version.</p>
            </div>
        </div>
    </div>

    <p class="text-xs font-medium text-rose-400" x-show="stepError" x-text="stepError"></p>
</div>
