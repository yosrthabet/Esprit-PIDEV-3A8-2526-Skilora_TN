{# dashboard/employer.html.twig — Employer Dashboard (Upwork Client-like) #}
{% extends 'layouts/app.html.twig' %}

{% block page_title %}Employer Dashboard{% endblock %}

{% block content %}
<div class="space-y-6 animate-fade-in pb-6">

    {# ── Welcome Banner ── #}
    <div class="rounded-xl border border-border bg-gradient-to-r from-sky-500/10 via-cyan-500/5 to-transparent p-6">
        <div class="flex flex-col sm:flex-row justify-between items-start gap-4">
            <div>
                <h2 class="text-xl font-semibold tracking-tight text-foreground">
                    Welcome back, {{ app.user.displayName }}
                </h2>
                <p class="text-sm text-muted-foreground mt-1">Manage your hiring pipeline and find top talent.</p>
            </div>
            <div class="flex items-center gap-2">
                <a href="#"
                   class="inline-flex h-9 items-center gap-2 rounded-md bg-primary px-4 text-xs font-semibold text-primary-foreground shadow hover:bg-primary/90 transition-colors">
                    <i data-lucide="plus" class="h-3.5 w-3.5"></i>
                    Post a Job
                </a>
                <span class="inline-flex items-center gap-1.5 rounded-lg border border-border bg-card px-3 py-1.5 text-xs font-medium text-muted-foreground shadow-sm">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                    {{ "now"|date("M d, Y") }}
                </span>
            </div>
        </div>
    </div>

    {# ── Stat Cards ── #}
    <div class="hidden bg-sky-500 bg-violet-500 bg-emerald-500 bg-amber-500"></div>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        {% set empIcons = {
            'briefcase': '<path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0"/>',
            'file-text': '<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>',
            'users': '<path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>',
            'calendar': '<path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>'
        } %}
        {% for stat in stats %}
        <div class="rounded-xl border border-border bg-card p-5 shadow-sm">
            <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-medium uppercase tracking-wider text-muted-foreground">{{ stat.label }}</span>
                <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-{{ stat.color }}-500 text-white shadow-sm">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">{{ empIcons[stat.icon]|default('')|raw }}</svg>
                </div>
            </div>
            <p class="text-2xl font-bold tracking-tight text-foreground">{{ stat.value }}</p>
        </div>
        {% endfor %}
    </div>

    {# ── Main Content ── #}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        {# Left: Hiring Pipeline #}
        <div class="lg:col-span-2 space-y-4">

            {# Pipeline Overview #}
            <div class="rounded-xl border border-border bg-card shadow-sm">
                <div class="flex items-center justify-between border-b border-border px-5 py-4">
                    <div>
                        <h3 class="text-sm font-semibold text-foreground">Hiring Pipeline</h3>
                        <p class="text-xs text-muted-foreground mt-0.5">Track your recruitment progress</p>
                    </div>
                </div>
                <div class="p-6">
                    {# Pipeline Stages #}
                    <div class="grid grid-cols-4 gap-3">
                        {% set stages = [
                            { label: 'Open Jobs', count: 0, color: 'sky', icon: 'briefcase' },
                            { label: 'Reviewing', count: 0, color: 'amber', icon: 'eye' },
                            { label: 'Interviews', count: 0, color: 'violet', icon: 'video' },
                            { label: 'Offers Sent', count: 0, color: 'emerald', icon: 'check-circle' }
                        ] %}
                        {% for stage in stages %}
                        <div class="text-center">
                            <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-{{ stage.color }}-500/10 text-{{ stage.color }}-500 mx-auto mb-2">
                                <i data-lucide="{{ stage.icon }}" class="h-6 w-6"></i>
                            </div>
                            <p class="text-xl font-bold text-foreground">{{ stage.count }}</p>
                            <p class="text-[11px] text-muted-foreground mt-0.5">{{ stage.label }}</p>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>

            {# Recent Activity #}
            <div class="rounded-xl border border-border bg-card shadow-sm">
                <div class="flex items-center justify-between border-b border-border px-5 py-4">
                    <div>
                        <h3 class="text-sm font-semibold text-foreground">Recent Activity</h3>
                        <p class="text-xs text-muted-foreground mt-0.5">Your latest hiring updates</p>
                    </div>
                </div>
                <div class="px-5 py-10 text-center">
                    <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-muted mx-auto mb-3">
                        <i data-lucide="inbox" class="h-5 w-5 text-muted-foreground"></i>
                    </div>
                    <p class="text-sm font-medium text-foreground">No recent activity</p>
                    <p class="text-xs text-muted-foreground mt-1">Post a job to start receiving applications</p>
                    <a href="#" class="inline-flex items-center gap-1 mt-3 text-xs font-medium text-primary hover:underline">
                        Post your first job
                        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                    </a>
                </div>
            </div>
        </div>

        {# Right Column #}
        <div class="space-y-4">

            {# Quick Actions #}
            <div class="rounded-xl border border-border bg-card shadow-sm">
                <div class="border-b border-border px-5 py-4">
                    <h3 class="text-sm font-semibold text-foreground">Quick Actions</h3>
                </div>
                <div class="p-3 space-y-1">
                    <a href="#" class="flex items-center gap-3 rounded-lg px-3 py-2.5 hover:bg-muted/50 transition-colors">
                        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary/10 text-primary">
                            <i data-lucide="plus-circle" class="h-4 w-4"></i>
                        </div>
                        <div>
                            <p class="text-sm font-medium text-foreground">Post a Job</p>
                            <p class="text-[11px] text-muted-foreground">Create a new listing</p>
                        </div>
                    </a>
                    <a href="#" class="flex items-center gap-3 rounded-lg px-3 py-2.5 hover:bg-muted/50 transition-colors">
                        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-sky-500/10 text-sky-500">
                            <i data-lucide="search" class="h-4 w-4"></i>
                        </div>
                        <div>
                            <p class="text-sm font-medium text-foreground">Find Talent</p>
                            <p class="text-[11px] text-muted-foreground">Browse freelancers</p>
                        </div>
                    </a>
                    <a href="#" class="flex items-center gap-3 rounded-lg px-3 py-2.5 hover:bg-muted/50 transition-colors">
                        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-emerald-500/10 text-emerald-500">
                            <i data-lucide="file-text" class="h-4 w-4"></i>
                        </div>
                        <div>
                            <p class="text-sm font-medium text-foreground">Active Offers</p>
                            <p class="text-[11px] text-muted-foreground">Manage job listings</p>
                        </div>
                    </a>
                    <a href="#" class="flex items-center gap-3 rounded-lg px-3 py-2.5 hover:bg-muted/50 transition-colors">
                        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-amber-500/10 text-amber-500">
                            <i data-lucide="message-square" class="h-4 w-4"></i>
                        </div>
                        <div>
                            <p class="text-sm font-medium text-foreground">Messages</p>
                            <p class="text-[11px] text-muted-foreground">Chat with candidates</p>
                        </div>
                    </a>
                </div>
            </div>

            {# Tips card #}
            <div class="rounded-xl border border-border bg-gradient-to-b from-sky-500/5 to-transparent p-5 shadow-sm">
                <div class="flex items-start gap-3">
                    <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-sky-500/10 text-sky-500">
                        <i data-lucide="lightbulb" class="h-4 w-4"></i>
                    </div>
                    <div>
                        <p class="text-sm font-semibold text-foreground">Hiring Tip</p>
                        <p class="text-xs text-muted-foreground mt-1 leading-relaxed">
                            Write clear job descriptions with specific requirements to attract the right candidates and reduce screening time.
                        </p>
                    </div>
                </div>
            </div>

            {# Profile Card #}
            <div class="rounded-xl border border-border bg-card p-5 shadow-sm">
                <div class="flex items-center gap-3 mb-4">
                    <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary text-primary-foreground text-lg font-bold">
                        {{ app.user.displayName|first|upper }}
                    </div>
                    <div>
                        <p class="text-sm font-semibold text-foreground">{{ app.user.displayName }}</p>
                        <p class="text-xs text-muted-foreground">{{ app.user.roleDisplayName }}</p>
                    </div>
                </div>
                <div class="grid grid-cols-3 gap-3 text-center">
                    <div>
                        <p class="text-lg font-bold text-foreground">0</p>
                        <p class="text-[10px] text-muted-foreground uppercase tracking-wider">Jobs</p>
                    </div>
                    <div>
                        <p class="text-lg font-bold text-foreground">0</p>
                        <p class="text-[10px] text-muted-foreground uppercase tracking-wider">Hires</p>
                    </div>
                    <div>
                        <p class="text-lg font-bold text-foreground">0</p>
                        <p class="text-[10px] text-muted-foreground uppercase tracking-wider">Active</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>
{% endblock %}
