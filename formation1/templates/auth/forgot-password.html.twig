{# auth/forgot-password.html.twig — Password reset request #}
{% extends 'layouts/auth.html.twig' %}

{% block title %}Reset Password — Skilora{% endblock %}

{% block auth_quote %}"Security is not a product, but a process."{% endblock %}
{% block auth_attribution %}— Skilora Security Team{% endblock %}

{% block content %}
<div class="space-y-6">
    {% if submitted %}
        {# Success state — always shown to prevent user enumeration #}
        <div class="flex flex-col items-center text-center space-y-4 py-4">
            <div class="flex h-14 w-14 items-center justify-center rounded-full bg-primary/10">
                <i data-lucide="mail-check" class="h-7 w-7 text-primary"></i>
            </div>
            <div class="space-y-2">
                <h1 class="text-2xl font-bold tracking-tight">Check your email</h1>
                <p class="text-sm text-muted-foreground max-w-sm">
                    If an account exists with that email, we've sent a password reset link. Check your inbox and spam folder.
                </p>
            </div>
            <a href="{{ path('app_login') }}" class="inline-flex items-center gap-1 text-sm font-medium text-primary hover:underline mt-2">
                <i data-lucide="arrow-left" class="h-4 w-4"></i>
                Back to sign in
            </a>
        </div>
    {% else %}
        {# Request form #}
        <div class="space-y-2">
            <h1 class="text-2xl font-bold tracking-tight">Forgot your password?</h1>
            <p class="text-sm text-muted-foreground">Enter your email and we'll send you a reset link</p>
        </div>

        <form method="post" action="{{ path('app_forgot_password') }}" class="space-y-4">
            <div class="space-y-2">
                {{ include('components/label.html.twig', { for: 'email', text: 'Email', required: true }) }}
                {{ include('components/input.html.twig', {
                    type: 'email',
                    name: 'email',
                    id: 'email',
                    placeholder: 'you@example.com',
                    required: true,
                    autofocus: true,
                }) }}
            </div>

            {{ include('components/button.html.twig', {
                type: 'submit',
                label: 'Send Reset Link',
                variant: 'default',
                size: 'lg',
                class: 'w-full',
            }) }}
        </form>

        <p class="text-center text-sm text-muted-foreground">
            Remember your password?
            <a href="{{ path('app_login') }}" class="font-medium text-primary hover:underline">Sign in</a>
        </p>
    {% endif %}
</div>
{% endblock %}
