{% extends 'layouts/app.html.twig' %}

{% block title %}My Support Tickets · Skilora{% endblock %}

{% block page_title %}Support{% endblock %}

{% block content %}
<div class="space-y-6 animate-fade-in pb-6" x-data="{ filter: 'ALL' }">

    {# ── Hero Banner ── #}
    <div class="relative overflow-hidden rounded-2xl border border-border bg-gradient-to-br from-primary/5 via-card to-accent/10 p-6 shadow-sm sm:p-8">
        <div class="absolute -right-12 -top-12 h-48 w-48 rounded-full bg-primary/5 blur-3xl"></div>
        <div class="absolute -bottom-8 -left-8 h-32 w-32 rounded-full bg-accent/10 blur-2xl"></div>
        <div class="relative flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
            <div>
                <div class="inline-flex items-center gap-2 rounded-full border border-border bg-background/80 px-3 py-1 text-xs font-medium text-muted-foreground backdrop-blur-sm">
                    <span class="h-1.5 w-1.5 rounded-full bg-green-500 animate-pulse"></span>
                    Support Center
                </div>
                <h2 class="mt-3 text-2xl font-bold tracking-tight text-foreground sm:text-3xl">My Tickets</h2>
                <p class="mt-1 text-sm text-muted-foreground">Create, manage, and track your support requests in real time.</p>
            </div>
            <button @click="$dispatch('open-edit-dialog', {title: 'New Ticket', description: 'Create a new support ticket.', url: '{{ path('support_new') }}', size: 'lg'})"
               class="inline-flex h-9 shrink-0 items-center gap-2 rounded-md bg-primary px-4 text-xs font-semibold text-primary-foreground shadow hover:bg-primary/90 transition-colors">
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14m-7-7h14"/></svg>
                New Ticket
            </button>
        </div>
    </div>

    {# ── Filter Pills ── #}
    <div class="flex flex-wrap gap-2">
        {% set filters = [
            { key: 'ALL', label: 'All' },
            { key: 'OPEN', label: 'Open' },
            { key: 'IN_PROGRESS', label: 'In Progress' },
            { key: 'CLOSED', label: 'Closed' },
            { key: 'RESOLVED', label: 'Resolved' },
        ] %}
        {% for f in filters %}
            <button @click="filter='{{ f.key }}'"
                    :class="filter==='{{ f.key }}'
                        ? 'bg-primary text-primary-foreground shadow-sm'
                        : 'bg-card text-muted-foreground border border-border hover:bg-muted/50 hover:text-foreground'"
                    class="rounded-full px-4 py-1.5 text-xs font-semibold transition-all duration-200">
                {{ f.label }}
            </button>
        {% endfor %}
    </div>

    {# ── Tickets Grid ── #}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {% for ticket in tickets %}
            <a href="{{ path('support_show', {id: ticket.id}) }}"
                     x-show="filter === 'ALL' || filter === '{{ ticket.status }}'"
                     x-transition:enter="transition duration-300 ease-out"
                     x-transition:enter-start="opacity-0 translate-y-2 scale-95"
                     x-transition:enter-end="opacity-100 translate-y-0 scale-100"
                     class="group relative flex flex-col overflow-hidden rounded-xl border border-border bg-card shadow-sm transition-all duration-300 hover:shadow-md hover:border-primary/20 hover:-translate-y-0.5 cursor-pointer no-underline">

                {# Accent top bar #}
                <div class="h-1 w-full bg-gradient-to-r
                    {% if ticket.status == 'OPEN' %}from-emerald-500 to-green-400
                    {% elseif ticket.status == 'IN_PROGRESS' %}from-blue-500 to-sky-400
                    {% elseif ticket.status == 'RESOLVED' %}from-teal-500 to-emerald-400
                    {% else %}from-zinc-400 to-zinc-300 dark:from-zinc-600 dark:to-zinc-500{% endif %}"></div>

                <div class="p-5 flex flex-col gap-3 flex-1">
                    {# Badges #}
                    <div class="flex flex-wrap gap-1.5">
                        <span class="inline-flex items-center rounded-full bg-violet-500/10 px-2.5 py-0.5 text-[11px] font-semibold text-violet-600 dark:text-violet-400 ring-1 ring-inset ring-violet-500/20">
                            {{ ticket.category }}
                        </span>
                        <span class="inline-flex items-center rounded-full bg-amber-500/10 px-2.5 py-0.5 text-[11px] font-semibold text-amber-600 dark:text-amber-400 ring-1 ring-inset ring-amber-500/20">
                            {{ ticket.priority }}
                        </span>
                        <span class="inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-[11px] font-semibold ring-1 ring-inset
                            {% if ticket.status == 'OPEN' %}bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 ring-emerald-500/20
                            {% elseif ticket.status == 'IN_PROGRESS' %}bg-blue-500/10 text-blue-600 dark:text-blue-400 ring-blue-500/20
                            {% elseif ticket.status == 'RESOLVED' %}bg-teal-500/10 text-teal-600 dark:text-teal-400 ring-teal-500/20
                            {% else %}bg-zinc-500/10 text-zinc-600 dark:text-zinc-400 ring-zinc-500/20{% endif %}">
                            <span class="h-1.5 w-1.5 rounded-full
                                {% if ticket.status == 'OPEN' %}bg-emerald-500
                                {% elseif ticket.status == 'IN_PROGRESS' %}bg-blue-500
                                {% elseif ticket.status == 'RESOLVED' %}bg-teal-500
                                {% else %}bg-zinc-500{% endif %}"></span>
                            {{ ticket.status|replace({'_':' '}) }}
                        </span>
                    </div>

                    {# Content #}
                    <h3 class="text-sm font-semibold text-foreground leading-snug line-clamp-2 group-hover:text-primary transition-colors">
                        {{ ticket.subject }}
                    </h3>
                    <p class="text-xs text-muted-foreground leading-relaxed line-clamp-2">
                        {{ ticket.description }}
                    </p>

                    {# Footer: date + arrow #}
                    <div class="flex items-center justify-between mt-auto pt-2">
                        <p class="text-[11px] text-muted-foreground/70">
                            {{ ticket.createdDate ? ticket.createdDate|date('d M Y') : '-' }}
                        </p>
                        <span class="inline-flex items-center gap-1 text-[11px] font-medium text-muted-foreground group-hover:text-primary transition-colors">
                            Open
                            <svg class="h-3 w-3 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                        </span>
                    </div>
                </div>
            </a>
        {% else %}
            <div class="col-span-full flex flex-col items-center justify-center rounded-xl border border-dashed border-border bg-card px-6 py-16 text-center">
                <div class="flex h-14 w-14 items-center justify-center rounded-xl bg-muted mb-4">
                    <svg class="h-6 w-6 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6m-4 5H8m4 4H8m8-8H8"/></svg>
                </div>
                <p class="text-sm font-medium text-foreground">No tickets yet</p>
                <p class="mt-1 text-xs text-muted-foreground">Click <strong>New Ticket</strong> to get started.</p>
                <button @click="$dispatch('open-edit-dialog', {title: 'New Ticket', description: 'Create a new support ticket.', url: '{{ path('support_new') }}', size: 'lg'})" class="mt-4 inline-flex items-center gap-1.5 text-xs font-medium text-primary hover:underline">
                    Create your first ticket
                    <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                </button>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
