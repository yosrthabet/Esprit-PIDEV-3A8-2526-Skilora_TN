<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Bulletin de paie #{{ p.id }}</title>
  <style>
    body { background: #0d1117; color: #e8edf2; font-family: DejaVu Sans, Arial, sans-serif; font-size: 11px; margin: 0; padding: 36px; }
    h1 { font-family: DejaVu Serif, Georgia, serif; color: #00c4a7; font-size: 22px; margin: 0 0 8px 0; }
    .meta { color: #6a7f96; margin-bottom: 24px; font-size: 10px; text-transform: uppercase; letter-spacing: 1px; }
    table { width: 100%; border-collapse: collapse; margin: 16px 0; }
    th, td { border: 1px solid #1e2d3d; padding: 8px 10px; text-align: left; }
    th { background: #111820; color: #00c4a7; font-size: 10px; text-transform: uppercase; letter-spacing: 1px; }
    .big { font-size: 16px; font-weight: bold; color: #00c4a7; }
    .net { font-size: 18px; font-weight: bold; color: #e8edf2; }
    .footer { margin-top: 32px; padding-top: 16px; border-top: 1px solid #1e2d3d; color: #6a7f96; font-size: 9px; text-align: center; }
  </style>
</head>
<body>
<h1>Bulletin de paie</h1>
<p class="meta">Skilora — {{ employee_name }} — Période {{ '%02d'|format(p.month) }}/{{ p.year }} — Réf. #{{ p.id }}</p>
<p class="meta">Émis le {{ generated_at|date('d/m/Y H:i') }} — Devise {{ p.currency }}</p>

<table>
  <tr><th>Ligne</th><th>Montant (TND)</th></tr>
  <tr><td>Salaire de base</td><td>{{ p.baseSalary|number_format(2, '.', ' ') }}</td></tr>
  <tr><td>Heures sup. (total)</td><td>{{ p.overtimeTotal|default(0)|number_format(2, '.', ' ') }}</td></tr>
  <tr><td>Primes</td><td>{{ p.bonuses|default(0)|number_format(2, '.', ' ') }}</td></tr>
  <tr><td><strong>Brut</strong></td><td class="big">{{ calc.gross|number_format(2, '.', ' ') }}</td></tr>
  <tr><td>CNSS (9,18 %)</td><td>- {{ calc.cnss|number_format(2, '.', ' ') }}</td></tr>
  <tr><td>IRPP (26 % de la base après CNSS)</td><td>- {{ calc.irpp|number_format(2, '.', ' ') }}</td></tr>
  <tr><td>Autres retenues</td><td>- {{ calc.other_deductions|number_format(2, '.', ' ') }}</td></tr>
  <tr><td><strong>Total retenues</strong></td><td>- {{ calc.total_deductions|number_format(2, '.', ' ') }}</td></tr>
  <tr><td><strong>Net à payer</strong></td><td class="net">{{ calc.net|number_format(2, '.', ' ') }}</td></tr>
</table>
<p><strong>Statut :</strong> {{ p.status }}</p>
<div class="footer">Document confidentiel — Skilora Finance</div>
</body>
</html>
