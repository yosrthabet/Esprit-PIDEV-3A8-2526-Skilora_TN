{% extends 'layouts/app.html.twig' %}

{% block title %}{{ formation.title }} · Skilora{% endblock %}
{% block page_title %}{{ formation.title }}{% endblock %}
{% block head %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
{% endblock %}

{% block content %}
{% set lvl = formation.level.value %}
{% set levelMod = lvl == 'BEGINNER' ? 'beginner' : (lvl == 'INTERMEDIATE' ? 'intermediate' : 'advanced') %}
{% set levelColor = {
    'beginner':     'bg-emerald-500/10 text-emerald-700 ring-emerald-600/20',
    'intermediate': 'bg-amber-500/10 text-amber-700 ring-amber-600/20',
    'advanced':     'bg-rose-500/10 text-rose-700 ring-rose-600/20',
} %}
{% set fwConfig = {
    id: formation.id,
    lessonsCount: formation.lessonsCount ?? 0,
    title: formation.title,
    userId: app.user ? app.user.id : null,
} %}

<div x-data="formationWorkspace({{ fwConfig|json_encode|raw }})"
     x-init="init()"
     class="space-y-6 animate-fade-in">
    {# ── Breadcrumb + title ── #}
    <div>
        <nav class="mb-3 text-xs text-muted-foreground" aria-label="Fil d'Ariane">
            <a href="{{ path('app_formation_index') }}" class="hover:text-foreground hover:underline">Formations</a>
            <span class="mx-1">/</span>
            <span class="text-foreground">{{ formation.title }}</span>
        </nav>
        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
            <div>
                <h1 class="text-2xl font-bold tracking-tight text-foreground sm:text-3xl">{{ formation.title }}</h1>
                <div class="mt-2 flex flex-wrap items-center gap-2">
                    <span class="inline-flex items-center rounded-md px-2.5 py-1 text-xs font-medium ring-1 ring-inset bg-secondary/50 text-secondary-foreground ring-border">{{ formation.categoryLabelFr }}</span>
                    <span class="inline-flex items-center rounded-md px-2.5 py-1 text-xs font-medium ring-1 ring-inset {{ levelColor[levelMod] }}">{{ formation.levelLabelFr }}</span>
                </div>
            </div>
            <a href="{{ path('app_formation_index') }}"
               class="inline-flex h-9 items-center justify-center rounded-md border border-input bg-background px-4 text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground">
                <i data-lucide="arrow-left" class="mr-2 h-4 w-4"></i> Retour au catalogue
            </a>
        </div>
    </div>

    {# ── Stats + live progress ── #}
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-border bg-card p-5 shadow-sm">
            <div class="flex items-center gap-2 text-xs font-medium text-muted-foreground">
                <i data-lucide="clock" class="h-4 w-4"></i> Durée
            </div>
            <p class="mt-2 text-2xl font-bold text-card-foreground">{{ formation.duration }}<span class="ml-1 text-sm font-normal text-muted-foreground">h</span></p>
        </div>
        <div class="rounded-xl border border-border bg-card p-5 shadow-sm">
            <div class="flex items-center gap-2 text-xs font-medium text-muted-foreground">
                <i data-lucide="book-open" class="h-4 w-4"></i> Leçons
            </div>
            <p class="mt-2 text-2xl font-bold text-card-foreground">{{ formation.lessonsCount }}</p>
        </div>
        <div class="rounded-xl border border-border bg-card p-5 shadow-sm">
            <div class="flex items-center gap-2 text-xs font-medium text-muted-foreground">
                <i data-lucide="folder" class="h-4 w-4"></i> Catégorie
            </div>
            <p class="mt-2 text-sm font-semibold text-card-foreground">{{ formation.categoryLabelFr }}</p>
        </div>
        <div class="rounded-xl border border-border bg-card p-5 shadow-sm">
            <div class="flex items-center gap-2 text-xs font-medium text-muted-foreground">
                <i data-lucide="banknote" class="h-4 w-4"></i> Tarif
            </div>
            <p class="mt-2 text-2xl font-bold text-card-foreground">
                {% if formation.price is null %}
                    <span class="text-muted-foreground">—</span>
                {% elseif formation.price <= 0 %}
                    <span class="text-emerald-600">Gratuit</span>
                {% else %}
                    {{ formation.priceDisplayFr }} <span class="ml-1 text-sm font-normal text-muted-foreground">TND</span>
                {% endif %}
            </p>
        </div>
    </div>

    {# ── Rating analytics (formation reviews) ── #}
    {% set rs = review_stats %}
    {% set dist = rs.distribution %}
    <div class="rounded-2xl border border-border/70 bg-gradient-to-b from-card to-card/90 p-6 shadow-[0_14px_34px_rgba(0,0,0,0.35)]">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
            <div>
                <h2 class="text-lg font-semibold text-card-foreground flex items-center gap-2">
                    <i data-lucide="star" class="h-5 w-5 text-[#FFD700]"></i> Avis
                </h2>
                <p class="mt-1 text-xs text-muted-foreground">Basé sur les avis laissés par les apprenants pour cette formation.</p>
            </div>
            <div class="text-left sm:text-right rounded-xl border border-white/10 bg-black/20 px-4 py-3 shadow-inner">
                <p class="text-5xl font-black tracking-tight tabular-nums text-card-foreground leading-none">
                    {{ rs.average|number_format(1, ',', ' ') }}<span class="text-2xl font-semibold text-muted-foreground">/5</span>
                </p>
                <p class="mt-1 text-sm text-muted-foreground">{{ rs.total }} avis</p>
            </div>
        </div>

        {% if rs.total > 0 %}
            <div class="mt-6 grid gap-5 lg:grid-cols-[0.95fr_1.8fr]">
                <div class="rounded-xl border border-white/10 bg-black/20 p-4">
                    <div class="flex items-center justify-between text-xs text-muted-foreground">
                        <span>Recommandation (4–5★)</span>
                        <span class="font-semibold text-foreground tabular-nums">{{ rs.likePercentage }}%</span>
                    </div>
                    <div class="mt-2 h-3 w-full max-w-[320px] overflow-hidden rounded-full bg-white/10 ring-1 ring-white/10 mx-auto sm:mx-0">
                        <div class="h-full rounded-full transition-[width] duration-700 ease-out"
                             style="width: {{ rs.likePercentage }}%; background: linear-gradient(90deg, #34d399 0%, #10b981 100%); box-shadow: 0 0 20px rgba(16,185,129,0.45);"></div>
                    </div>
                    <p class="mt-2 text-xs text-muted-foreground">Pourcentage d'apprenants ayant donné 4★ ou 5★.</p>
                </div>

                <div class="rounded-xl border border-white/10 bg-black/20 p-4">
                    <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-muted-foreground/90">Répartition</p>
                    <div class="mt-2 w-full max-w-[400px] space-y-2.5">
                        {% for stars in [5, 4, 3, 2, 1] %}
                            {% set cnt = dist[stars] %}
                            {% set pct = rs.total > 0 ? (100 * cnt / rs.total) : 0 %}
                            <div class="flex items-center gap-2.5 text-xs">
                                <span class="w-10 shrink-0 tabular-nums text-sm font-bold tracking-[0.1em] text-foreground">{{ stars }}★</span>
                                <div class="h-1.5 w-[300px] shrink-0 overflow-hidden rounded-full bg-white/10 ring-1 ring-white/10">
                                    <div class="h-full rounded-full transition-[width] duration-700 ease-out"
                                         style="width: {{ pct }}%; background: linear-gradient(90deg, rgba(255,215,0,0.92) 0%, rgba(245,158,11,0.86) 100%); box-shadow: 0 0 10px rgba(255,215,0,0.25);"></div>
                                </div>
                                <span class="w-7 shrink-0 text-right tabular-nums font-medium tracking-[0.06em] text-muted-foreground">{{ cnt }}</span>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        {% endif %}

        {% if app.user and enrollment and enrollment.completed %}
            <div class="mt-6 rounded-xl border border-border bg-background/60 p-4 shadow-sm" x-data="{ rating: {{ my_review ? my_review.rating : 0 }}, hover: 0 }">
                <h3 class="text-sm font-semibold text-foreground">Laisser un avis</h3>
                <p class="mt-1 text-xs text-muted-foreground">Votre retour aide les autres apprenants.</p>
                <form class="mt-3 space-y-3" method="post" action="{{ path('app_formation_review_submit', { id: formation.id }) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('formation_review_' ~ formation.id) }}">
                    <input type="hidden" name="rating" :value="rating">
                    <div class="flex items-center gap-1">
                        {% for star in [1, 2, 3, 4, 5] %}
                            <button type="button"
                                    @mouseenter="hover = {{ star }}"
                                    @mouseleave="hover = 0"
                                    @click="rating = {{ star }}"
                                    :aria-label="'{{ star }} stars'"
                                    class="rounded p-1 transition-all duration-200 hover:scale-110">
                                <svg class="h-7 w-7 transition-all duration-200" viewBox="0 0 24 24" fill="none"
                                     :fill="(hover >= {{ star }} || rating >= {{ star }}) ? 'currentColor' : 'none'"
                                     :class="(hover >= {{ star }} || rating >= {{ star }}) ? 'text-[#FFD700] drop-shadow-[0_0_6px_rgba(255,215,0,0.8)] scale-110' : 'text-muted-foreground/50'">
                                    <path d="M12 3.5l2.8 5.67 6.26.91-4.53 4.42 1.07 6.24L12 17.77l-5.6 2.97 1.07-6.24-4.53-4.42 6.26-.91L12 3.5z"
                                          stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                                </svg>
                            </button>
                        {% endfor %}
                    </div>
                    <textarea name="comment" rows="3" maxlength="1500"
                              class="w-full rounded-md border border-input bg-background px-3 py-2 text-sm text-foreground placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
                              placeholder="Votre commentaire (optionnel)...">{{ my_review and my_review.comment ? my_review.comment : '' }}</textarea>
                    <button type="submit"
                            class="inline-flex h-9 items-center justify-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow-sm transition-colors hover:bg-primary/90">
                        {{ my_review ? 'Mettre à jour mon avis' : 'Publier mon avis' }}
                    </button>
                </form>
            </div>
        {% elseif app.user and enrollment and not enrollment.completed %}
            <p class="mt-4 text-sm text-muted-foreground">Terminez la formation pour laisser un avis.</p>
        {% endif %}

        <div class="mt-6 space-y-3">
            {% if reviews is not empty %}
                {% for review in reviews %}
                    <article class="rounded-xl border border-border/80 bg-background/50 p-4 shadow-sm"
                             x-data="{
                                useful: {{ review.usefulCount }},
                                notUseful: {{ review.notUsefulCount }},
                                userVote: {{ review_votes[review.id]|default(0) }},
                                pending: false,
                                debounceTimer: null,
                                voteDebounced(type) {
                                    clearTimeout(this.debounceTimer);
                                    this.debounceTimer = setTimeout(() => this.vote(type), 280);
                                },
                                async vote(type) {
                                    if (this.pending) return;
                                    this.pending = true;
                                    const fd = new FormData();
                                    fd.append('_token', '{{ csrf_token('formation_review_vote_' ~ review.id) }}');
                                    fd.append('vote', type);
                                    const res = await fetch('{{ path('app_formation_review_vote', { id: review.id }) }}', {
                                        method: 'POST',
                                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                                        body: fd,
                                    });
                                    this.pending = false;
                                    if (!res.ok) return;
                                    const data = await res.json();
                                    this.useful = data.usefulCount;
                                    this.notUseful = data.notUsefulCount;
                                    this.userVote = data.userVote;
                                }
                             }">
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <p class="text-sm font-medium text-foreground">{{ review.user.displayName }}</p>
                                <div class="mt-1 flex items-center gap-1 text-amber-400">
                                    {% for i in 1..5 %}
                                        <i data-lucide="{{ i <= review.rating ? 'star' : 'star' }}" class="h-3.5 w-3.5 {{ i <= review.rating ? '' : 'opacity-30' }}"></i>
                                    {% endfor %}
                                </div>
                            </div>
                            <span class="text-xs text-muted-foreground">{{ review.createdAt ? review.createdAt|date('d/m/Y') : '' }}</span>
                        </div>
                        {% if review.comment %}
                            <p class="mt-2 text-sm text-muted-foreground whitespace-pre-line">{{ review.comment }}</p>
                        {% endif %}

                        <div class="mt-3 flex flex-wrap items-center gap-3 border-t border-border/60 pt-3">
                            <button type="button"
                                    @click="voteDebounced('helpful')"
                                    :disabled="pending"
                                    :class="userVote === 1 ? 'border-blue-400/60 bg-blue-500/15 text-blue-300' : 'border-border bg-background text-foreground hover:bg-accent'"
                                    class="inline-flex items-center gap-1.5 rounded-md px-2.5 py-1.5 text-xs font-medium transition-colors disabled:opacity-60">
                                <i class="fa-solid fa-thumbs-up h-3.5 w-3.5"></i>
                                Utile
                                <span class="tabular-nums" x-text="useful"></span>
                            </button>
                            <button type="button"
                                    @click="voteDebounced('not_helpful')"
                                    :disabled="pending"
                                    :class="userVote === -1 ? 'border-red-400/60 bg-red-500/15 text-red-300' : 'border-border bg-background text-foreground hover:bg-accent'"
                                    class="inline-flex items-center gap-1.5 rounded-md px-2.5 py-1.5 text-xs font-medium transition-colors disabled:opacity-60">
                                <i class="fa-solid fa-thumbs-down h-3.5 w-3.5"></i>
                                Pas utile
                                <span class="tabular-nums" x-text="notUseful"></span>
                            </button>
                            <span class="ml-auto text-xs text-muted-foreground">
                                <span class="font-medium text-foreground tabular-nums" x-text="useful"></span>
                                people found this helpful
                                ·
                                <span class="font-semibold text-foreground tabular-nums"
                                      x-text="(useful + notUseful) > 0 ? ((100 * useful / (useful + notUseful)).toFixed(1) + '%') : '0.0%'"></span>
                            </span>
                        </div>
                    </article>
                {% endfor %}
            {% else %}
                <p class="text-sm text-muted-foreground">Aucun avis pour le moment.</p>
            {% endif %}
        </div>
    </div>

    {# ── Content + engineering workspace ── #}
    <div class="grid gap-6 lg:grid-cols-[minmax(0,2fr)_minmax(320px,1.1fr)] xl:grid-cols-[minmax(0,2.3fr)_minmax(360px,1fr)]">
        {# Description + technical notes #}
        <div class="space-y-4">
            <div class="rounded-xl border border-border bg-card p-6 shadow-sm">
                <h2 class="text-lg font-semibold text-card-foreground">À propos de cette formation</h2>
                <div class="mt-4 text-sm leading-relaxed text-muted-foreground whitespace-pre-line">{{ formation.description }}</div>
            </div>

            <div class="rounded-xl border border-border/70 bg-gradient-to-br from-background/90 via-card/95 to-background/90 p-6 shadow-sm">
                <div class="flex items-center justify-between gap-2">
                    <div>
                        <h3 class="text-sm font-semibold text-card-foreground">Détails techniques</h3>
                        <p class="mt-1 text-xs text-muted-foreground">Structure du cursus et paramètres pédagogiques.</p>
                    </div>
                    <span class="inline-flex items-center rounded-full bg-secondary/60 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-[0.14em] text-secondary-foreground">
                        Dashboard
                    </span>
                </div>
                <dl class="mt-4 grid gap-4 text-xs text-muted-foreground sm:grid-cols-3">
                    <div>
                        <dt class="font-medium text-foreground/80">Durée totale</dt>
                        <dd class="mt-0.5 tabular-nums">
                            {{ formation.duration ?? '—' }} h estimées
                        </dd>
                    </div>
                    <div>
                        <dt class="font-medium text-foreground/80">Nombre de leçons</dt>
                        <dd class="mt-0.5 tabular-nums">
                            {{ formation.lessonsCount ?? '—' }}
                        </dd>
                    </div>
                    <div>
                        <dt class="font-medium text-foreground/80">Fournisseur</dt>
                        <dd class="mt-0.5">
                            {{ formation.provider ?? 'Skilora' }}
                        </dd>
                    </div>
                </dl>
            </div>
        </div>

        {# Workspace sidebar (curriculum + progress + actions) #}
        <aside class="space-y-4">
            <section class="rounded-xl border border-border/70 bg-gradient-to-b from-background/95 via-card/95 to-background/95 p-5 shadow-sm">
                <header class="flex items-center justify-between gap-3">
                    <div>
                        <h2 class="text-sm font-semibold text-card-foreground">Espace de travail</h2>
                        <p class="mt-1 text-xs text-muted-foreground">Suivi temps réel de votre progression.</p>
                    </div>
                    <div class="text-right">
                        <p class="text-xs font-medium text-muted-foreground">Progression</p>
                        <p class="text-lg font-semibold text-card-foreground tabular-nums" x-text="progressPercentLabel"></p>
                    </div>
                </header>
                <div class="mt-3 h-2 w-full overflow-hidden rounded-full bg-border/40">
                    <div class="h-full rounded-full bg-gradient-to-r from-emerald-400 via-sky-400 to-indigo-500 shadow-[0_0_16px_rgba(45,212,191,0.6)] transition-all duration-500 ease-out"
                         :style="`width: ${progressPercent}%;`"></div>
                </div>
                <p class="mt-2 text-[11px] text-muted-foreground">
                    <span class="font-medium text-foreground" x-text="completedLessons"></span>
                    / <span class="tabular-nums" x-text="totalLessons"></span> leçons marquées comme terminées.
                </p>
            </section>

            <section class="rounded-xl border border-border bg-card/95 p-4 shadow-sm">
                <header class="mb-2 flex items-center justify-between gap-2">
                    <div>
                        <h3 class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground/80">Curriculum</h3>
                        <p class="mt-1 text-[11px] text-muted-foreground">Découpage modulaire généré automatiquement.</p>
                    </div>
                    <button type="button"
                            class="inline-flex items-center rounded-md border border-border bg-background px-2.5 py-1 text-[11px] font-medium text-foreground shadow-sm hover:bg-accent hover:text-accent-foreground"
                            @click="resetProgress">
                        Réinitialiser
                    </button>
                </header>

                <div class="max-h-[320px] space-y-2 overflow-y-auto pr-1 text-xs"
                     x-show="sections.length > 0"
                     x-collapse>
                    <template x-for="(section, sIndex) in sections" :key="section.id">
                        <div class="rounded-lg border border-border/70 bg-background/80 p-3">
                            <div class="flex items-center justify-between gap-2">
                                <div>
                                    <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-muted-foreground/80" x-text="section.label"></p>
                                    <p class="mt-0.5 text-[11px] text-muted-foreground">
                                        <span class="tabular-nums" x-text="section.completedCount"></span>
                                        / <span class="tabular-nums" x-text="section.lessons.length"></span> leçons
                                    </p>
                                </div>
                                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold"
                                      :class="section.completedCount === section.lessons.length && section.lessons.length > 0
                                              ? 'bg-emerald-500/15 text-emerald-400 border border-emerald-500/40'
                                              : 'bg-slate-800/80 text-slate-200 border border-slate-700/80'">
                                    <span x-text="section.completedCount === section.lessons.length && section.lessons.length > 0 ? 'Terminé' : 'En cours'"></span>
                                </span>
                            </div>
                            <ul class="mt-3 space-y-1.5">
                                <template x-for="(lesson, lIndex) in section.lessons" :key="lesson.id">
                                    <li>
                                        <button type="button"
                                                class="flex w-full items-center justify-between gap-2 rounded-md px-2 py-1.5 text-left transition-colors hover:bg-accent/60 hover:text-accent-foreground"
                                                @click="toggleLesson(section.id, lesson.id)">
                                            <div class="flex items-center gap-2">
                                                <span class="inline-flex h-4 w-4 items-center justify-center rounded border text-[9px] font-semibold"
                                                      :class="lesson.completed ? 'border-emerald-400 bg-emerald-500/20 text-emerald-300' : 'border-border text-muted-foreground'">
                                                    <span x-text="lesson.index"></span>
                                                </span>
                                                <span class="truncate" x-text="lesson.label"></span>
                                            </div>
                                            <span class="inline-flex h-5 w-5 items-center justify-center rounded-full border border-border text-[10px]"
                                                  :class="lesson.completed ? 'bg-emerald-500/20 border-emerald-400 text-emerald-300' : 'bg-background text-muted-foreground'">
                                                <i :data-lucide="lesson.completed ? 'check' : 'circle'" class="h-3 w-3"></i>
                                            </span>
                                        </button>
                                    </li>
                                </template>
                            </ul>
                        </div>
                    </template>
                </div>

                <p class="mt-2 text-[11px] text-muted-foreground" x-show="sections.length === 0">
                    Aucun découpage disponible pour cette formation.
                </p>
            </section>

            <section class="rounded-xl border border-border bg-card p-5 shadow-sm">
                {% if app.user %}
                    {% if enrollment %}
                        {% if enrollment.completed %}
                            <div class="flex items-center gap-2 rounded-lg bg-emerald-500/10 px-4 py-3 text-sm font-medium text-emerald-700">
                                <i data-lucide="check-circle" class="h-5 w-5"></i>
                                Formation terminée
                            </div>
                            {% if certificate %}
                                <a href="{{ path('app_certificate_pdf', { id: certificate.id }) }}"
                                   class="mt-3 inline-flex h-10 w-full items-center justify-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow-sm transition-colors hover:bg-primary/90">
                                    <i data-lucide="download" class="mr-2 h-4 w-4"></i> Télécharger le PDF
                                </a>
                            {% endif %}
                        {% else %}
                            <p class="mb-3 text-sm font-medium text-foreground">Déjà inscrit</p>
                            <form method="post" action="{{ path('app_formation_complete', { id: formation.id }) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('formation_complete_' ~ formation.id) }}">
                                <button type="submit"
                                        class="inline-flex h-10 w-full items-center justify-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow-sm transition-colors hover:bg-primary/90">
                                    Marquer comme terminée
                                </button>
                            </form>
                        {% endif %}
                    {% else %}
                        <form method="post" action="{{ path('app_formation_enroll', { id: formation.id }) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('formation_enroll_' ~ formation.id) }}">
                            <button type="submit"
                                    class="inline-flex h-10 w-full items-center justify-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow-sm transition-colors hover:bg-primary/90">
                                S'inscrire maintenant
                            </button>
                        </form>
                    {% endif %}
                {% else %}
                    <a href="{{ path('app_login') }}"
                       class="inline-flex h-10 w-full items-center justify-center rounded-md border border-input bg-background px-4 text-sm font-medium text-foreground shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground">
                        Connexion pour s'inscrire
                    </a>
                {% endif %}

                <div class="mt-4 space-y-2">
                    <a href="{{ path('app_formation_index') }}"
                       class="inline-flex h-9 w-full items-center justify-center rounded-md border border-input bg-background px-4 text-sm font-medium text-foreground shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground">
                        <i data-lucide="arrow-left" class="mr-2 h-4 w-4"></i> Retour au catalogue
                    </a>
                    {% if app.user %}
                        <a href="{{ path('app_my_formations') }}"
                           class="inline-flex h-9 w-full items-center justify-center rounded-md border border-input bg-background px-4 text-sm font-medium text-foreground shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground">
                            Mes formations
                        </a>
                    {% endif %}
                </div>
            </section>
        </aside>
    </div>
</div>

<script>
    window.formationWorkspace = function formationWorkspace(config) {
        const totalLessons = Math.max(0, config.lessonsCount || 0);
        const storageKey = [
            'skilora_fw_progress',
            config.userId || 'guest',
            config.id
        ].join(':');

        // Simple modularisation of lessons into sections, respecting ordering
        const sections = [];
        if (totalLessons > 0) {
            const targetSections = Math.min(6, Math.max(2, Math.round(totalLessons / 4)));
            const baseSize = Math.max(1, Math.floor(totalLessons / targetSections));
            let remaining = totalLessons;
            let currentIndex = 1;

            for (let i = 0; i < targetSections; i++) {
                const size = i === targetSections - 1 ? remaining : Math.min(baseSize, remaining);
                if (size <= 0) {
                    continue;
                }
                const lessons = [];
                for (let j = 0; j < size; j++) {
                    const absoluteIndex = currentIndex++;
                    lessons.push({
                        id: `L${absoluteIndex}`,
                        index: absoluteIndex,
                        label: `Leçon ${absoluteIndex}`,
                        completed: false
                    });
                }
                remaining -= size;
                sections.push({
                    id: `S${i + 1}`,
                    label: `Module ${i + 1}`,
                    lessons,
                    completedCount: 0
                });
                if (remaining <= 0) {
                    break;
                }
            }
        }

        return {
            config,
            storageKey,
            sections,
            completedLessons: 0,
            totalLessons: totalLessons,

            get progressPercent() {
                if (!this.totalLessons) {
                    return 0;
                }
                return Math.min(100, Math.round((this.completedLessons / this.totalLessons) * 100));
            },

            get progressPercentLabel() {
                return this.totalLessons ? `${this.progressPercent}%` : 'N/A';
            },

            init() {
                this.restore();
                this.recomputeSectionCounts();
            },

            restore() {
                try {
                    const raw = window.localStorage.getItem(this.storageKey);
                    if (!raw) {
                        this.completedLessons = 0;
                        return;
                    }
                    const payload = JSON.parse(raw);
                    const completedSet = new Set(payload.completedIds || []);
                    let count = 0;
                    this.sections.forEach((section) => {
                        section.lessons.forEach((lesson) => {
                            lesson.completed = completedSet.has(lesson.id);
                            if (lesson.completed) {
                                count++;
                            }
                        });
                    });
                    this.completedLessons = count;
                } catch (e) {
                    this.completedLessons = 0;
                }
            },

            persist() {
                try {
                    const completedIds = [];
                    this.sections.forEach((section) => {
                        section.lessons.forEach((lesson) => {
                            if (lesson.completed) {
                                completedIds.push(lesson.id);
                            }
                        });
                    });
                    const payload = {
                        v: 1,
                        formationId: this.config.id,
                        userId: this.config.userId || null,
                        completedIds
                    };
                    window.localStorage.setItem(this.storageKey, JSON.stringify(payload));
                } catch (e) {
                    // ignore persistence errors (e.g., private browsing)
                }
            },

            recomputeSectionCounts() {
                let total = 0;
                this.sections.forEach((section) => {
                    let sectionCount = 0;
                    section.lessons.forEach((lesson) => {
                        if (lesson.completed) {
                            sectionCount++;
                        }
                    });
                    section.completedCount = sectionCount;
                    total += sectionCount;
                });
                this.completedLessons = total;
            },

            toggleLesson(sectionId, lessonId) {
                for (const section of this.sections) {
                    if (section.id !== sectionId) continue;
                    for (const lesson of section.lessons) {
                        if (lesson.id !== lessonId) continue;
                        lesson.completed = !lesson.completed;
                        break;
                    }
                }
                this.recomputeSectionCounts();
                this.persist();
            },

            resetProgress() {
                this.sections.forEach((section) => {
                    section.lessons.forEach((lesson) => {
                        lesson.completed = false;
                    });
                    section.completedCount = 0;
                });
                this.completedLessons = 0;
                try {
                    window.localStorage.removeItem(this.storageKey);
                } catch (e) {
                    // ignore
                }
            }
        };
    };
</script>
{% endblock %}
