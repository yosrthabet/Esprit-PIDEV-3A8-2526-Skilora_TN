{% extends 'layouts/app.html.twig' %}

{% block title %}Formations · Skilora{% endblock %}
{% block page_title %}Formations{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/chatbot.css') }}?v={{ 'now'|date('U') }}">
{% endblock %}

{% block content %}
<div class="space-y-6 animate-fade-in"
     data-formation-page="catalog"
     data-filter-cat="{{ filter_cat|e('html_attr') }}"
     data-filter-q="{{ filter_q|e('html_attr') }}"
     data-filter-lvl="{{ filter_lvl|e('html_attr') }}">
    {# ── Hero banner ── #}
    <div class="relative overflow-hidden rounded-xl border border-border bg-gradient-to-br from-primary/5 via-card to-accent/10 px-6 py-8 shadow-sm sm:px-8 sm:py-10">
        <div class="pointer-events-none absolute -right-16 -top-16 h-64 w-64 rounded-full bg-primary/5 blur-3xl" aria-hidden="true"></div>
        <div class="relative">
            <p class="text-xs font-semibold uppercase tracking-widest text-primary">Catalogue</p>
            <h1 class="mt-2 text-2xl font-bold tracking-tight text-foreground sm:text-3xl">Explore Formations</h1>
            <p class="mt-2 max-w-2xl text-sm text-muted-foreground">
                Parcours structurés, filtres rapides et fiches détaillées — pensé comme une plateforme e-learning professionnelle.
            </p>
            {% if formations is not empty %}
                <p class="mt-3 inline-flex items-center gap-2 rounded-full border border-border bg-card/80 px-3 py-1.5 text-xs font-medium text-foreground shadow-sm backdrop-blur-sm">
                    <span class="relative flex h-2 w-2"><span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span><span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span></span>
                    <strong>{{ formations|length }}</strong> programme{{ formations|length > 1 ? 's' : '' }} disponible{{ formations|length > 1 ? 's' : '' }}
                </p>
            {% endif %}
        </div>
    </div>

    {# ── Search & Filters ── #}
    <div class="rounded-xl border border-border bg-card p-4 shadow-sm sm:p-6">
        <form method="get" action="{{ path('app_formation_index') }}" class="flex flex-col gap-4 sm:flex-row sm:flex-wrap sm:items-end">
            <div class="flex-1 min-w-[200px]">
                <label for="catalog-q" class="mb-1.5 block text-xs font-medium text-muted-foreground">Recherche</label>
                <div class="relative">
                    <i data-lucide="search" class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-muted-foreground"></i>
                    <input type="search" name="q" id="catalog-q" value="{{ filter_q }}" placeholder="Titre, mot-clé, description…"
                           class="h-10 w-full rounded-md border border-input bg-background pl-9 pr-3 text-sm text-foreground placeholder:text-muted-foreground focus:border-ring focus:outline-none focus:ring-2 focus:ring-ring/20" autocomplete="off">
                </div>
            </div>
            <div class="min-w-[140px]">
                <label for="catalog-cat" class="mb-1.5 block text-xs font-medium text-muted-foreground">Catégorie</label>
                <select name="cat" id="catalog-cat" class="h-10 w-full rounded-md border border-input bg-background px-3 text-sm text-foreground focus:border-ring focus:outline-none focus:ring-2 focus:ring-ring/20">
                    <option value="">Toutes</option>
                    {% for key, label in category_labels %}
                        <option value="{{ key }}" {{ filter_cat == key ? 'selected' : '' }}>{{ label }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="min-w-[120px]">
                <label for="catalog-lvl" class="mb-1.5 block text-xs font-medium text-muted-foreground">Niveau</label>
                <select name="lvl" id="catalog-lvl" class="h-10 w-full rounded-md border border-input bg-background px-3 text-sm text-foreground focus:border-ring focus:outline-none focus:ring-2 focus:ring-ring/20">
                    <option value="">Tous</option>
                    {% for opt in level_options %}
                        <option value="{{ opt.value }}" {{ filter_lvl == opt.value ? 'selected' : '' }}>{{ opt.label }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="flex gap-2">
                <button type="submit" class="inline-flex h-10 items-center justify-center rounded-md bg-primary px-5 text-sm font-medium text-primary-foreground shadow-sm transition-colors hover:bg-primary/90">
                    Appliquer
                </button>
                <a href="{{ path('app_formation_index') }}" class="inline-flex h-10 items-center justify-center rounded-md border border-input bg-background px-4 text-sm font-medium text-foreground shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground">
                    Réinitialiser
                </a>
            </div>
        </form>
    </div>

    {# ── Formation grid ── #}
    {% if formations is empty %}
        <div class="rounded-xl border border-dashed border-border bg-card p-12 text-center shadow-sm">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-muted">
                <i data-lucide="book-open" class="h-6 w-6 text-muted-foreground"></i>
            </div>
            <h2 class="text-sm font-semibold text-foreground">Aucune formation pour l'instant</h2>
            <p class="mt-1 text-sm text-muted-foreground">Modifiez les filtres ou la recherche, ou revenez plus tard.</p>
        </div>
    {% else %}
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3" data-formation-grid>
            {% for f in formations %}
                {% include 'formation/_card.html.twig' %}
            {% endfor %}
        </div>
    {% endif %}
</div>
{% include 'components/_chatbot.html.twig' with {
    endpoint: path('app_chatbot_ask'),
    formations: formations,
    activeCategory: filter_cat,
    searchQuery: filter_q,
    filterLevel: filter_lvl
} %}
{% endblock %}
