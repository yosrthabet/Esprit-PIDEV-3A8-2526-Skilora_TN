#!/bin/bash
# bin/dev — Start Symfony dev server + Tailwind CSS watcher
# Usage: ./bin/dev

trap 'kill 0; exit 0' SIGINT SIGTERM

echo "Starting Skilora dev environment..."
echo "  Symfony  → http://127.0.0.1:8000"
echo "  Tailwind → watching for changes"
echo ""
echo "Press Ctrl+C to stop."
echo ""

# Start Tailwind CSS watcher in background
npx @tailwindcss/cli -i assets/app.css -o public/css/app.css --watch &
TW_PID=$!

sleep 1

# Start Symfony server
symfony server:start --no-tls &
SYMFONY_PID=$!

wait -n $TW_PID $SYMFONY_PID 2>/dev/null
kill $TW_PID $SYMFONY_PID 2>/dev/null
wait 2>/dev/null
