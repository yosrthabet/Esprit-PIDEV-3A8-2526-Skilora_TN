{# layouts/app.html.twig — Main app shell with sidebar + topbar #}
{% extends 'base.html.twig' %}

{% set current_route = app.request.attributes.get('_route') %}

{% block body %}
<div class="flex h-screen overflow-hidden" x-data="{ sidebarOpen: true }">
    {# ===== Sidebar ===== #}
    <aside
        x-show="sidebarOpen"
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="-translate-x-full"
        x-transition:enter-end="translate-x-0"
        x-transition:leave="transition ease-in duration-150"
        x-transition:leave-start="translate-x-0"
        x-transition:leave-end="-translate-x-full"
        class="flex w-64 shrink-0 flex-col border-r border-sidebar-border bg-sidebar text-sidebar-foreground"
    >
        {# Logo #}
        <div class="flex h-14 items-center gap-2 border-b border-sidebar-border px-4">
            <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-sidebar-primary text-sidebar-primary-foreground text-sm font-bold">
                S
            </div>
            <span class="text-lg font-semibold tracking-tight">Skilora</span>
        </div>

        {# Navigation #}
        <nav class="flex-1 overflow-y-auto px-3 py-4 space-y-1">
            {% block sidebar_nav %}
            {% set nav_items = [
                { label: 'Dashboard', route: 'app_dashboard', icon: 'home' },
                { label: 'Recruitment', route: 'app_recruitment', icon: 'briefcase' },
                { label: 'Formations', route: 'app_formations', icon: 'graduation-cap' },
                { label: 'Finance', route: 'app_finance', icon: 'wallet' },
                { label: 'Community', route: 'app_community', icon: 'users' },
                { label: 'Support', route: 'app_support', icon: 'life-buoy' },
            ] %}

            {% for item in nav_items %}
                <a href="#"
                   class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium transition-colors
                          {{ current_route starts with item.route
                              ? 'bg-sidebar-accent text-sidebar-accent-foreground'
                              : 'text-sidebar-foreground/70 hover:bg-sidebar-accent hover:text-sidebar-accent-foreground' }}">
                    {% include 'components/icons/' ~ item.icon ~ '.html.twig' ignore missing %}
                    {{ item.label }}
                </a>
            {% endfor %}
            {% endblock %}
        </nav>

        {# User section #}
        <div class="border-t border-sidebar-border p-3">
            {% if app.user %}
            <div class="flex items-center gap-3 rounded-lg px-3 py-2">
                <div class="flex h-8 w-8 items-center justify-center rounded-full bg-sidebar-primary text-sidebar-primary-foreground text-xs font-medium">
                    {{ app.user.email|first|upper }}
                </div>
                <div class="flex-1 truncate">
                    <p class="text-sm font-medium truncate">{{ app.user.email }}</p>
                </div>
            </div>
            {% endif %}
        </div>
    </aside>

    {# ===== Main content area ===== #}
    <div class="flex flex-1 flex-col overflow-hidden">
        {# Topbar #}
        <header class="flex h-14 items-center gap-4 border-b border-border bg-background px-6">
            <button @click="sidebarOpen = !sidebarOpen"
                    class="inline-flex items-center justify-center rounded-md p-2 text-muted-foreground hover:bg-accent hover:text-accent-foreground focus-ring">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 12h18M3 6h18M3 18h18"/>
                </svg>
            </button>

            <h1 class="text-lg font-semibold">{% block page_title %}Dashboard{% endblock %}</h1>

            <div class="ml-auto flex items-center gap-2">
                {% block topbar_actions %}{% endblock %}

                {# Theme toggle #}
                <button x-data
                        @click="document.documentElement.classList.toggle('dark')"
                        class="inline-flex items-center justify-center rounded-md p-2 text-muted-foreground hover:bg-accent hover:text-accent-foreground focus-ring">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
                    </svg>
                </button>
            </div>
        </header>

        {# Page content #}
        <main class="flex-1 overflow-y-auto p-6">
            {% block content %}{% endblock %}
        </main>
    </div>
</div>
{% endblock %}
