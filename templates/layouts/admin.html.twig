{# layouts/admin.html.twig — Espace administrateur : menu formations, publication, certificats #}
{% extends 'base.html.twig' %}

{% set current_route = app.request.attributes.get('_route') %}

{% block body %}
<div class="flex h-screen overflow-hidden" x-data="{ sidebarOpen: true }">
    <aside
        x-show="sidebarOpen"
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="-translate-x-full"
        x-transition:enter-end="translate-x-0"
        x-transition:leave="transition ease-in duration-150"
        x-transition:leave-start="translate-x-0"
        x-transition:leave-end="-translate-x-full"
        class="flex w-64 shrink-0 flex-col border-r border-sidebar-border bg-sidebar text-sidebar-foreground"
    >
        <div class="flex h-14 items-center gap-2 border-b border-sidebar-border px-4">
            <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-sidebar-primary text-sidebar-primary-foreground text-xs font-bold">
                ADM
            </div>
            <div class="min-w-0">
                <p class="text-lg font-semibold tracking-tight truncate">Administration</p>
                <p class="text-[10px] text-sidebar-foreground/60 uppercase tracking-wide">Skilora</p>
            </div>
        </div>

        <nav class="flex-1 overflow-y-auto px-3 py-4 space-y-1" aria-label="Navigation admin">
            {% set admin_nav = [
                {
                    label: 'Tableau de bord',
                    href: path('app_admin_dashboard'),
                    active: current_route == 'app_admin_dashboard',
                    icon: 'home',
                },
                {
                    label: 'Formations (catalogue)',
                    href: path('app_formation_index'),
                    active: current_route == 'app_formation_index',
                    icon: 'globe',
                },
                {
                    label: 'Publier une formation',
                    href: path('app_admin_formation_new'),
                    active: current_route == 'app_admin_formation_new',
                    icon: 'plus',
                },
                {
                    label: 'Gestion des formations',
                    href: path('app_admin_formation_index'),
                    active: current_route == 'app_admin_formation_index' or current_route == 'app_admin_formation_edit',
                    icon: 'graduation',
                },
                {
                    label: 'Utilisateurs',
                    href: path('app_database_users'),
                    active: current_route == 'app_database_users',
                    icon: 'users',
                },
                {
                    label: 'Certificats',
                    href: path('app_admin_certificates_index'),
                    active: current_route starts with 'app_admin_certificate',
                    icon: 'award',
                },
            ] %}

            {% for item in admin_nav %}
                <a href="{{ item.href }}"
                   class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium transition-colors
                          {{ item.active
                              ? 'bg-sidebar-accent text-sidebar-accent-foreground'
                              : 'text-sidebar-foreground/70 hover:bg-sidebar-accent hover:text-sidebar-accent-foreground' }}">
                    {% if item.icon == 'home' %}
                        {% include 'components/icons/home.html.twig' %}
                    {% elseif item.icon == 'graduation' %}
                        {% include 'components/icons/graduation-cap.html.twig' %}
                    {% elseif item.icon == 'globe' %}
                        <svg class="h-4 w-4 shrink-0 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
                    {% elseif item.icon == 'plus' %}
                        <svg class="h-4 w-4 shrink-0 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                    {% elseif item.icon == 'users' %}
                        {% include 'components/icons/users.html.twig' %}
                    {% elseif item.icon == 'award' %}
                        <svg class="h-4 w-4 shrink-0 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
                    {% endif %}
                    <span class="truncate">{{ item.label }}</span>
                </a>
            {% endfor %}
        </nav>

        <div class="border-t border-sidebar-border p-3 space-y-2">
            <a href="{{ path('app_home') }}"
               class="flex w-full items-center justify-center rounded-md px-3 py-2 text-center text-xs font-medium text-sidebar-foreground/80 transition-colors hover:bg-sidebar-accent hover:text-sidebar-accent-foreground">
                ← Site public
            </a>
            {% if app.user %}
            <div class="flex flex-col gap-2 rounded-lg px-2 py-1">
                <div class="flex items-center gap-3 px-2 py-1">
                    <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-sidebar-primary text-sidebar-primary-foreground text-xs font-medium">
                        {{ app.user.userIdentifier|first|upper }}
                    </div>
                    <div class="min-w-0 flex-1">
                        <p class="truncate text-sm font-medium text-sidebar-foreground">{{ app.user.userIdentifier }}</p>
                        <p class="text-[10px] text-sidebar-foreground/60">Administrateur</p>
                    </div>
                </div>
                <a href="{{ path('app_logout') }}"
                   class="flex w-full items-center justify-center rounded-md px-3 py-2 text-center text-xs font-semibold text-sidebar-foreground/80 transition-colors hover:bg-sidebar-accent hover:text-sidebar-accent-foreground">
                    Déconnexion
                </a>
            </div>
            {% endif %}
        </div>
    </aside>

    <div class="flex flex-1 flex-col overflow-hidden">
        <header class="flex h-14 items-center gap-4 border-b border-border bg-background px-6">
            <button type="button" @click="sidebarOpen = !sidebarOpen"
                    class="inline-flex items-center justify-center rounded-md p-2 text-muted-foreground hover:bg-accent hover:text-accent-foreground focus-ring">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 12h18M3 6h18M3 18h18"/>
                </svg>
            </button>

            <h1 class="text-lg font-semibold">{% block page_title %}Admin{% endblock %}</h1>

            <div class="ml-auto flex items-center gap-2">
                {% block topbar_actions %}{% endblock %}

                <button type="button" x-data
                        @click="document.documentElement.classList.toggle('dark')"
                        class="inline-flex items-center justify-center rounded-md p-2 text-muted-foreground hover:bg-accent hover:text-accent-foreground focus-ring">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
                    </svg>
                </button>
            </div>
        </header>

        <main class="flex-1 overflow-y-auto p-6">
            {% block content %}{% endblock %}
        </main>
    </div>
</div>
{% endblock %}
