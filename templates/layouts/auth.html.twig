{# layouts/auth.html.twig — Centered card layout for login/register/forgot-password #}
{% extends 'base.html.twig' %}

{# Force light theme on auth pages — dark/light is for logged-in users only #}
{% block head %}
{{ parent() }}
<script>document.documentElement.classList.remove('dark');</script>
{% endblock %}

{% block body %}
<div class="flex min-h-screen">
    {# Left hero panel #}
    <div class="relative hidden lg:flex lg:w-1/2 flex-col justify-between bg-zinc-950 p-10 text-white overflow-hidden">
        {# Video Background #}
        <video class="absolute inset-0 w-full h-full object-cover opacity-40 mix-blend-lighten z-0 pointer-events-none" autoplay muted loop playsinline preload="auto">
            <source src="https://videos.pexels.com/video-files/7101913/7101913-uhd_2560_1440_25fps.mp4" type="video/mp4">
        </video>
        
        {# Overlay gradient for text readability #}
        <div class="absolute inset-0 z-[1] bg-gradient-to-t from-zinc-950 via-zinc-950/20 to-zinc-950/40 pointer-events-none"></div>

        <div class="relative z-10">
            <a href="{{ path('app_home') }}" class="flex w-fit items-center gap-2 transition-opacity hover:opacity-80">
                <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-white text-zinc-950 text-sm font-bold">
                    S
                </div>
                <span class="text-lg font-semibold border-none">Skilora</span>
            </a>
        </div>

        <div class="relative z-10 space-y-4 max-w-lg">
            <blockquote class="text-xl font-medium leading-relaxed">
                {% block auth_quote %}
                "Connecting Tunisia's youth to global opportunities."
                {% endblock %}
            </blockquote>
            <p class="text-sm text-zinc-400">
                {% block auth_attribution %}Skilora — Secure, Intelligent, Limitless{% endblock %}
            </p>
        </div>
    </div>

    {# Right form panel #}
    <div class="flex w-full lg:w-1/2 items-center justify-center p-6 sm:p-12">
        <div class="w-full max-w-md space-y-6">
            {# Mobile logo #}
            <a href="{{ path('app_home') }}" class="flex items-center gap-2 lg:hidden transition-opacity hover:opacity-80">
                <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary text-primary-foreground text-sm font-bold">
                    S
                </div>
                <span class="text-lg font-semibold">Skilora</span>
            </a>

            {% block content %}{% endblock %}
        </div>
    </div>
</div>
{% endblock %}
