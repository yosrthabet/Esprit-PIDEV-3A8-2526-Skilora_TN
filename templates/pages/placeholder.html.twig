{# pages/placeholder.html.twig — Coming-soon placeholder for dashboard nav pages #}
{% extends 'layouts/app.html.twig' %}

{% block page_title %}{{ page_title }}{% endblock %}

{% block content %}
<div class="flex flex-col items-center justify-center min-h-[60vh] animate-fade-in">
    <div class="flex flex-col items-center text-center max-w-md space-y-6">
        {# Icon #}
        <div class="flex h-20 w-20 items-center justify-center rounded-2xl bg-muted">
            <i data-lucide="{{ page_icon|default('layout-grid') }}" class="h-10 w-10 text-muted-foreground"></i>
        </div>

        {# Heading #}
        <div class="space-y-2">
            <h2 class="text-3xl font-bold tracking-tight">{{ page_title }}</h2>
            <p class="text-muted-foreground">{{ page_description|default('This module is under development.') }}</p>
        </div>

        {# Status badge #}
        {{ include('components/badge.html.twig', {
            label: 'Coming Soon',
            variant: 'secondary'
        }) }}

        {# Progress bar #}
        <div class="w-full max-w-xs space-y-2">
            <div class="flex justify-between text-xs text-muted-foreground">
                <span>Development Progress</span>
                <span>15%</span>
            </div>
            {{ include('components/progress.html.twig', { value: 15 }) }}
        </div>

        {# Back button #}
        <a href="{{ path('app_dashboard') }}">
            {{ include('components/button.html.twig', {
                label: 'Back to Dashboard',
                variant: 'outline',
                size: 'sm'
            }) }}
        </a>
    </div>
</div>
{% endblock %}
