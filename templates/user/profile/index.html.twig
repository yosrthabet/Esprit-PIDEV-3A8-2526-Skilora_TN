{# templates/profile/index.html.twig — Own profile edit page #}
{% extends 'layouts/app.html.twig' %}

{% block page_title %}My Profile{% endblock %}

{% block content %}
<div class="grid gap-6 lg:grid-cols-3">

    {# ===== LEFT COLUMN (2/3) ===== #}
    <div class="lg:col-span-2 space-y-6">

        {# --- Profile Info Card --- #}
        <div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm">
            <div class="flex flex-col space-y-1.5 p-6">
                <h3 class="font-semibold leading-none tracking-tight">Profile Information</h3>
                <p class="text-sm text-muted-foreground">Update your personal details</p>
            </div>
            <div class="p-6 pt-0">
                <form action="{{ path('app_profile_update') }}" method="post" class="space-y-4">
                    <input type="hidden" name="_token" value="{{ csrf_token('profile_update') }}">

                    <div class="grid gap-4 sm:grid-cols-2">
                        {{ include('components/input.html.twig', {
                            name: 'first_name', label: 'First Name', type: 'text',
                            placeholder: 'John', value: profile.firstName
                        }) }}
                        {{ include('components/input.html.twig', {
                            name: 'last_name', label: 'Last Name', type: 'text',
                            placeholder: 'Doe', value: profile.lastName
                        }) }}
                    </div>

                    {{ include('components/input.html.twig', {
                        name: 'headline', label: 'Headline', type: 'text',
                        placeholder: 'Full-Stack Developer | Open Source Enthusiast',
                        value: profile.headline
                    }) }}

                    <div class="space-y-2">
                        {{ include('components/label.html.twig', { for: 'bio', text: 'Bio' }) }}
                        <textarea
                            id="bio" name="bio" rows="4"
                            placeholder="Tell us about yourself..."
                            class="flex min-h-[80px] w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm shadow-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
                        >{{ profile.bio }}</textarea>
                    </div>

                    <div class="grid gap-4 sm:grid-cols-2">
                        {{ include('components/input.html.twig', {
                            name: 'phone', label: 'Phone', type: 'tel',
                            placeholder: '+216 XX XXX XXX', value: profile.phone
                        }) }}
                        {{ include('components/input.html.twig', {
                            name: 'location', label: 'Location', type: 'text',
                            placeholder: 'Tunis, Tunisia', value: profile.location
                        }) }}
                    </div>

                    <div class="grid gap-4 sm:grid-cols-2">
                        {{ include('components/input.html.twig', {
                            name: 'website', label: 'Website', type: 'url',
                            placeholder: 'https://yoursite.com', value: profile.website
                        }) }}
                        {{ include('components/input.html.twig', {
                            name: 'birth_date', label: 'Date of Birth', type: 'date',
                            value: profile.birthDate ? profile.birthDate|date('Y-m-d') : ''
                        }) }}
                    </div>

                    <div class="flex justify-end">
                        {{ include('components/button.html.twig', { label: 'Save Changes', type: 'submit', variant: 'default' }) }}
                    </div>
                </form>
            </div>
        </div>

        {# --- Skills Section --- #}
        <div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm">
            <div class="flex flex-col space-y-1.5 p-6">
                <h3 class="font-semibold leading-none tracking-tight">Skills</h3>
                <p class="text-sm text-muted-foreground">Manage your technical and professional skills</p>
            </div>
            <div class="p-6 pt-0 space-y-4">
                {# Existing skills #}
                {% if skills|length > 0 %}
                <div class="flex flex-wrap gap-2">
                    {% for skill in skills %}
                    <div class="inline-flex items-center gap-1.5 rounded-md border border-border bg-secondary/50 px-2.5 py-1 text-xs font-medium">
                        <span>{{ skill.skillName }}</span>
                        {% if skill.proficiencyLevel %}
                            <span class="text-muted-foreground">· {{ skill.proficiencyLevel|lower|capitalize }}</span>
                        {% endif %}
                        {% if skill.yearsExperience %}
                            <span class="text-muted-foreground">· {{ skill.yearsExperience }}y</span>
                        {% endif %}
                        <form action="{{ path('app_profile_skill_delete', { id: skill.id }) }}" method="post" class="inline">
                            <button type="submit" class="ml-1 text-muted-foreground hover:text-destructive transition-colors" title="Remove skill">
                                <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                                </svg>
                            </button>
                        </form>
                    </div>
                    {% endfor %}
                </div>
                {% else %}
                <p class="text-sm text-muted-foreground">No skills added yet.</p>
                {% endif %}

                {# Add skill form #}
                <div class="shrink-0 bg-border h-[1px] w-full"></div>
                <form action="{{ path('app_profile_skill_add') }}" method="post" class="space-y-3">
                    <p class="text-sm font-medium">Add a Skill</p>
                    <div class="grid gap-3 sm:grid-cols-3">
                        {{ include('components/input.html.twig', {
                            name: 'skill_name', type: 'text',
                            placeholder: 'e.g. PHP, React, Docker', required: true
                        }) }}
                        {{ include('components/select.html.twig', {
                            name: 'proficiency_level',
                            placeholder: 'Level',
                            options: [
                                { value: 'BEGINNER', label: 'Beginner' },
                                { value: 'INTERMEDIATE', label: 'Intermediate' },
                                { value: 'ADVANCED', label: 'Advanced' },
                                { value: 'EXPERT', label: 'Expert' },
                            ]
                        }) }}
                        {{ include('components/input.html.twig', {
                            name: 'years_experience', type: 'number',
                            placeholder: 'Years'
                        }) }}
                    </div>
                    <div class="flex justify-end">
                        {{ include('components/button.html.twig', { label: 'Add Skill', type: 'submit', variant: 'outline', size: 'sm' }) }}
                    </div>
                </form>
            </div>
        </div>

        {# --- Experience Section --- #}
        <div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm">
            <div class="flex flex-col space-y-1.5 p-6">
                <h3 class="font-semibold leading-none tracking-tight">Experience</h3>
                <p class="text-sm text-muted-foreground">Your work history and professional experience</p>
            </div>
            <div class="p-6 pt-0 space-y-4">
                {# Existing experiences #}
                {% if experiences|length > 0 %}
                <div class="space-y-3">
                    {% for exp in experiences %}
                    <div class="flex items-start justify-between rounded-lg border border-border p-4">
                        <div class="space-y-1">
                            <p class="font-medium text-sm">{{ exp.position }}</p>
                            <p class="text-sm text-muted-foreground">{{ exp.company }}</p>
                            <p class="text-xs text-muted-foreground">
                                {{ exp.startDate ? exp.startDate|date('M Y') : '?' }}
                                —
                                {{ exp.currentJob ? 'Present' : (exp.endDate ? exp.endDate|date('M Y') : '?') }}
                            </p>
                            {% if exp.description %}
                                <p class="text-sm text-muted-foreground mt-1">{{ exp.description|length > 150 ? exp.description|slice(0, 150) ~ '…' : exp.description }}</p>
                            {% endif %}
                        </div>
                        <form action="{{ path('app_profile_experience_delete', { id: exp.id }) }}" method="post">
                            {{ include('components/button.html.twig', { label: '✕', type: 'submit', variant: 'ghost', size: 'icon', class: 'h-7 w-7 text-muted-foreground hover:text-destructive' }) }}
                        </form>
                    </div>
                    {% endfor %}
                </div>
                {% else %}
                <p class="text-sm text-muted-foreground">No experience added yet.</p>
                {% endif %}

                {# Add experience form #}
                <div class="shrink-0 bg-border h-[1px] w-full"></div>
                <form action="{{ path('app_profile_experience_add') }}" method="post" class="space-y-3">
                    <p class="text-sm font-medium">Add Experience</p>
                    <div class="grid gap-3 sm:grid-cols-2">
                        {{ include('components/input.html.twig', {
                            name: 'company', type: 'text',
                            placeholder: 'Company name', required: true
                        }) }}
                        {{ include('components/input.html.twig', {
                            name: 'position', type: 'text',
                            placeholder: 'Job title', required: true
                        }) }}
                    </div>
                    <div class="grid gap-3 sm:grid-cols-2">
                        {{ include('components/input.html.twig', {
                            name: 'start_date', label: 'Start Date', type: 'date', required: true
                        }) }}
                        {{ include('components/input.html.twig', {
                            name: 'end_date', label: 'End Date', type: 'date'
                        }) }}
                    </div>
                    <div class="space-y-2">
                        <textarea
                            id="description" name="description" rows="3"
                            placeholder="Describe your responsibilities and achievements..."
                            class="flex min-h-[80px] w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm shadow-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
                        ></textarea>
                    </div>
                    {{ include('components/checkbox.html.twig', { name: 'current_job', label: 'I currently work here' }) }}
                    <div class="flex justify-end">
                        {{ include('components/button.html.twig', { label: 'Add Experience', type: 'submit', variant: 'outline', size: 'sm' }) }}
                    </div>
                </form>
            </div>
        </div>

        {# --- Portfolio Section --- #}
        <div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm">
            <div class="flex flex-col space-y-1.5 p-6">
                <h3 class="font-semibold leading-none tracking-tight">Portfolio</h3>
                <p class="text-sm text-muted-foreground">Showcase your best work</p>
            </div>
            <div class="p-6 pt-0 space-y-4">
                {# Existing portfolio items #}
                {% if portfolioItems|length > 0 %}
                <div class="grid gap-4 sm:grid-cols-2">
                    {% for item in portfolioItems %}
                    <div class="rounded-lg border border-border overflow-hidden">
                        {% if item.imageUrl %}
                        <div class="aspect-video bg-muted overflow-hidden">
                            <img src="{{ item.imageUrl }}" alt="{{ item.title }}" class="h-full w-full object-cover">
                        </div>
                        {% endif %}
                        <div class="p-4 space-y-2">
                            <div class="flex items-start justify-between">
                                <div>
                                    <p class="font-medium text-sm">{{ item.title }}</p>
                                    {% if item.description %}
                                        <p class="text-xs text-muted-foreground mt-0.5">{{ item.description|length > 100 ? item.description|slice(0, 100) ~ '…' : item.description }}</p>
                                    {% endif %}
                                </div>
                                <form action="{{ path('app_profile_portfolio_delete', { id: item.id }) }}" method="post">
                                    <button type="submit" class="text-muted-foreground hover:text-destructive transition-colors">
                                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                                        </svg>
                                    </button>
                                </form>
                            </div>
                            {% if item.technologies %}
                            <div class="flex flex-wrap gap-1">
                                {% for tech in item.technologies|split(',') %}
                                    {{ include('components/badge.html.twig', { label: tech|trim, variant: 'secondary' }) }}
                                {% endfor %}
                            </div>
                            {% endif %}
                            {% if item.projectUrl %}
                            <a href="{{ item.projectUrl }}" target="_blank" rel="noopener noreferrer"
                               class="inline-flex items-center gap-1 text-xs text-primary hover:underline">
                                View Project →
                            </a>
                            {% endif %}
                        </div>
                    </div>
                    {% endfor %}
                </div>
                {% else %}
                <p class="text-sm text-muted-foreground">No portfolio items yet.</p>
                {% endif %}

                {# Add portfolio form #}
                <div class="shrink-0 bg-border h-[1px] w-full"></div>
                <form action="{{ path('app_profile_portfolio_add') }}" method="post" class="space-y-3">
                    <p class="text-sm font-medium">Add Portfolio Item</p>
                    <div class="grid gap-3 sm:grid-cols-2">
                        {{ include('components/input.html.twig', {
                            name: 'title', type: 'text',
                            placeholder: 'Project title', required: true
                        }) }}
                        {{ include('components/input.html.twig', {
                            name: 'project_url', type: 'url',
                            placeholder: 'https://github.com/...'
                        }) }}
                    </div>
                    <div class="space-y-2">
                        <textarea
                            id="portfolio_description" name="description" rows="2"
                            placeholder="Brief description of the project..."
                            class="flex min-h-[80px] w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm shadow-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
                        ></textarea>
                    </div>
                    <div class="grid gap-3 sm:grid-cols-2">
                        {{ include('components/input.html.twig', {
                            name: 'image_url', type: 'url',
                            placeholder: 'Image URL (optional)'
                        }) }}
                        {{ include('components/input.html.twig', {
                            name: 'technologies', type: 'text',
                            placeholder: 'PHP, Symfony, React (comma-separated)'
                        }) }}
                    </div>
                    <div class="flex justify-end">
                        {{ include('components/button.html.twig', { label: 'Add Portfolio Item', type: 'submit', variant: 'outline', size: 'sm' }) }}
                    </div>
                </form>
            </div>
        </div>
    </div>

    {# ===== RIGHT COLUMN (1/3) — Profile Preview ===== #}
    <div class="space-y-6">
        <div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm sticky top-6">
            <div class="p-6 space-y-4">
                {# Avatar + photo upload #}
                <div class="flex flex-col items-center space-y-3" x-data="profilePhoto()">
                    {% set initials = ((profile.firstName ?? '')|first|upper) ~ ((profile.lastName ?? '')|first|upper) %}

                    {# Clickable avatar area #}
                    <div class="relative group cursor-pointer" @click="$refs.fileInput.click()">
                        <span class="relative flex shrink-0 overflow-hidden rounded-full h-20 w-20 text-xl ring-2 ring-transparent group-hover:ring-primary/50 transition-all">
                            {% if profile.photoUrl %}
                                <img
                                    :src="currentPhoto || '{{ profile.photoUrl }}'"
                                    alt="Profile photo"
                                    class="aspect-square h-full w-full object-cover"
                                    onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                                />
                                <span class="hidden items-center justify-center h-full w-full rounded-full bg-muted font-medium text-muted-foreground">
                                    {{ initials ?: '?' }}
                                </span>
                            {% else %}
                                <template x-if="currentPhoto">
                                    <img :src="currentPhoto" alt="Profile photo" class="aspect-square h-full w-full object-cover" />
                                </template>
                                <span x-show="!currentPhoto" class="flex items-center justify-center h-full w-full rounded-full bg-muted font-medium text-muted-foreground">
                                    {{ initials ?: '?' }}
                                </span>
                            {% endif %}
                        </span>

                        {# Hover overlay #}
                        <div class="absolute inset-0 rounded-full bg-black/50 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                            <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0z"/>
                            </svg>
                        </div>
                    </div>

                    <input type="file" x-ref="fileInput" @change="onFileSelected" accept="image/jpeg,image/png,image/webp,image/gif" class="hidden" />

                    <div class="flex items-center gap-2">
                        <button @click="$refs.fileInput.click()" type="button"
                                class="text-xs text-primary hover:underline font-medium">
                            Change photo
                        </button>
                        <template x-if="currentPhoto">
                            <button @click="removePhoto()" type="button"
                                    class="text-xs text-destructive hover:underline font-medium">
                                Remove
                            </button>
                        </template>
                    </div>

                    {# Upload status #}
                    <template x-if="uploading">
                        <div class="flex items-center gap-2 text-xs text-muted-foreground">
                            <svg class="animate-spin h-3 w-3" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
                            Uploading...
                        </div>
                    </template>

                    <div class="text-center">
                        <p class="font-semibold">{{ profile.fullName ?: app.user.displayName }}</p>
                        {% if profile.headline %}
                            <p class="text-sm text-muted-foreground">{{ profile.headline }}</p>
                        {% endif %}
                    </div>

                    {# ===== Crop Modal ===== #}
                    <div x-show="showCropper" x-cloak
                         class="fixed inset-0 z-[100] flex items-center justify-center bg-black/60 backdrop-blur-sm"
                         @keydown.escape.window="cancelCrop()">
                        <div class="bg-card rounded-xl shadow-2xl border border-border w-full max-w-lg mx-4 overflow-hidden"
                             @click.outside="cancelCrop()">
                            <div class="flex items-center justify-between p-4 border-b border-border">
                                <h3 class="font-semibold">Crop Profile Photo</h3>
                                <button @click="cancelCrop()" type="button" class="text-muted-foreground hover:text-foreground transition-colors">
                                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                                </button>
                            </div>
                            <div class="p-4">
                                <div class="relative w-full" style="max-height: 400px;">
                                    <img x-ref="cropImage" :src="cropImageSrc" class="max-w-full" style="display: block;" />
                                </div>
                            </div>
                            <div class="flex items-center justify-between p-4 border-t border-border">
                                <div class="flex gap-2">
                                    <button @click="rotateCrop(-90)" type="button" class="inline-flex items-center justify-center rounded-md text-sm font-medium h-8 w-8 border border-input bg-background hover:bg-accent transition-colors" title="Rotate left">
                                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3"/></svg>
                                    </button>
                                    <button @click="rotateCrop(90)" type="button" class="inline-flex items-center justify-center rounded-md text-sm font-medium h-8 w-8 border border-input bg-background hover:bg-accent transition-colors" title="Rotate right">
                                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 15l6-6m0 0l-6-6m6 6H9a6 6 0 000 12h3"/></svg>
                                    </button>
                                    <button @click="resetCrop()" type="button" class="inline-flex items-center justify-center rounded-md text-sm font-medium h-8 px-2 border border-input bg-background hover:bg-accent transition-colors text-xs" title="Reset">
                                        Reset
                                    </button>
                                </div>
                                <div class="flex gap-2">
                                    <button @click="cancelCrop()" type="button"
                                            class="inline-flex items-center justify-center rounded-md text-sm font-medium border border-input bg-background shadow-sm hover:bg-accent h-9 px-4">
                                        Cancel
                                    </button>
                                    <button @click="applyCrop()" type="button"
                                            class="inline-flex items-center justify-center rounded-md text-sm font-medium bg-primary text-primary-foreground shadow hover:bg-primary/90 h-9 px-4">
                                        Apply & Upload
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="shrink-0 bg-border h-[1px] w-full"></div>

                {# Location #}
                {% if profile.location %}
                <div class="flex items-center gap-2 text-sm text-muted-foreground">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z"/>
                    </svg>
                    {{ profile.location }}
                </div>
                {% endif %}

                {# Bio preview #}
                {% if profile.bio %}
                <p class="text-sm text-muted-foreground">{{ profile.bio|length > 120 ? profile.bio|slice(0, 120) ~ '…' : profile.bio }}</p>
                {% endif %}

                {# Skill badges #}
                {% if skills|length > 0 %}
                <div class="flex flex-wrap gap-1.5">
                    {% for skill in skills|slice(0, 8) %}
                        {{ include('components/badge.html.twig', { label: skill.skillName, variant: 'secondary' }) }}
                    {% endfor %}
                    {% if skills|length > 8 %}
                        <span class="text-xs text-muted-foreground self-center">+{{ skills|length - 8 }} more</span>
                    {% endif %}
                </div>
                {% endif %}

                {# View public profile link #}
                <a href="{{ path('app_profile_public', { username: app.user.username }) }}"
                   class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium transition-colors focus-ring border border-input bg-background shadow-sm hover:bg-accent hover:text-accent-foreground h-9 px-4 py-2 w-full">
                    View Public Profile
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block head %}
{{ parent() }}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" />
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
<script>
document.addEventListener('alpine:init', () => {
    Alpine.data('profilePhoto', () => ({
        currentPhoto: {{ profile.photoUrl ? ("'" ~ profile.photoUrl ~ "'")|raw : 'null' }},
        showCropper: false,
        cropImageSrc: '',
        cropper: null,
        uploading: false,

        onFileSelected(e) {
            const file = e.target.files[0];
            if (!file) return;

            // Validate client-side
            const allowed = ['image/jpeg', 'image/png', 'image/webp', 'image/gif'];
            if (!allowed.includes(file.type)) {
                alert('Please select a JPG, PNG, WebP, or GIF image.');
                return;
            }
            if (file.size > 10 * 1024 * 1024) {
                alert('Image must be under 10MB.');
                return;
            }

            const reader = new FileReader();
            reader.onload = (ev) => {
                this.cropImageSrc = ev.target.result;
                this.showCropper = true;

                this.$nextTick(() => {
                    const img = this.$refs.cropImage;
                    if (this.cropper) {
                        this.cropper.destroy();
                    }
                    this.cropper = new Cropper(img, {
                        aspectRatio: 1,
                        viewMode: 1,
                        dragMode: 'move',
                        autoCropArea: 0.9,
                        cropBoxResizable: true,
                        cropBoxMovable: true,
                        guides: true,
                        center: true,
                        highlight: false,
                        background: false,
                    });
                });
            };
            reader.readAsDataURL(file);
            // Reset so same file can be re-selected
            e.target.value = '';
        },

        rotateCrop(deg) {
            if (this.cropper) this.cropper.rotate(deg);
        },

        resetCrop() {
            if (this.cropper) this.cropper.reset();
        },

        cancelCrop() {
            this.showCropper = false;
            if (this.cropper) {
                this.cropper.destroy();
                this.cropper = null;
            }
            this.cropImageSrc = '';
        },

        async applyCrop() {
            if (!this.cropper) return;

            const canvas = this.cropper.getCroppedCanvas({
                width: 400,
                height: 400,
                imageSmoothingEnabled: true,
                imageSmoothingQuality: 'high',
            });

            const base64 = canvas.toDataURL('image/jpeg', 0.9);

            this.showCropper = false;
            this.cropper.destroy();
            this.cropper = null;
            this.cropImageSrc = '';
            this.uploading = true;

            try {
                const formData = new FormData();
                formData.append('_token', '{{ csrf_token('profile_photo') }}');
                formData.append('cropped_image', base64);

                const resp = await fetch('{{ path('app_profile_photo_upload') }}', {
                    method: 'POST',
                    body: formData,
                });

                const data = await resp.json();
                if (data.success) {
                    // Cache-bust the new photo URL
                    this.currentPhoto = data.photoUrl + '?t=' + Date.now();
                } else {
                    alert(data.error || 'Upload failed.');
                }
            } catch (err) {
                console.error('Photo upload error:', err);
                alert('Upload failed. Please try again.');
            } finally {
                this.uploading = false;
            }
        },

        async removePhoto() {
            if (!confirm('Remove your profile photo?')) return;

            this.uploading = true;
            try {
                const formData = new FormData();
                formData.append('_token', '{{ csrf_token('profile_photo') }}');

                const resp = await fetch('{{ path('app_profile_photo_delete') }}', {
                    method: 'POST',
                    body: formData,
                });

                const data = await resp.json();
                if (data.success) {
                    this.currentPhoto = null;
                } else {
                    alert(data.error || 'Failed to remove photo.');
                }
            } catch (err) {
                console.error('Photo delete error:', err);
                alert('Failed to remove photo.');
            } finally {
                this.uploading = false;
            }
        },
    }));
});
</script>
{% endblock %}
