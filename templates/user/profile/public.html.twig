{# templates/profile/public.html.twig — Public profile view #}
{% extends 'layouts/app.html.twig' %}

{% block page_title %}{{ profile ? profile.fullName : profileUser.displayName }}{% endblock %}

{% block content %}
<div class="mx-auto max-w-4xl space-y-6">

    {# ===== Hero Header ===== #}
    <div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm">
        <div class="p-6">
            <div class="flex flex-col items-center gap-4 sm:flex-row sm:items-start">
                {# Avatar #}
                {% if profile %}
                    {% set initials = ((profile.firstName ?? '')|first|upper) ~ ((profile.lastName ?? '')|first|upper) %}
                {% else %}
                    {% set initials = profileUser.displayName|first|upper %}
                {% endif %}
                {{ include('components/avatar.html.twig', {
                    initials: initials ?: '?',
                    src: profile ? profile.photoUrl : profileUser.photoUrl,
                    size: 'lg'
                }) }}

                <div class="flex-1 text-center sm:text-left space-y-1">
                    <h2 class="text-xl font-bold">{{ profile ? profile.fullName : profileUser.displayName }}</h2>
                    {% if profile and profile.headline %}
                        <p class="text-sm text-muted-foreground">{{ profile.headline }}</p>
                    {% endif %}
                    <div class="flex flex-wrap items-center justify-center gap-3 sm:justify-start text-sm text-muted-foreground">
                        {% if profile and profile.location %}
                        <span class="flex items-center gap-1">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z"/>
                            </svg>
                            {{ profile.location }}
                        </span>
                        {% endif %}
                        {% if profile and profile.website %}
                        <a href="{{ profile.website }}" target="_blank" rel="noopener noreferrer"
                           class="flex items-center gap-1 text-primary hover:underline">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.86-3.03a4.5 4.5 0 00-1.242-7.244l-4.5-4.5a4.5 4.5 0 00-6.364 6.364L4.34 8.374"/>
                            </svg>
                            {{ profile.website|replace({'https://': '', 'http://': ''})|trim('/') }}
                        </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ===== About Section ===== #}
    {% if profile and profile.bio %}
    <div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm">
        <div class="flex flex-col space-y-1.5 p-6">
            <h3 class="font-semibold leading-none tracking-tight">About</h3>
        </div>
        <div class="p-6 pt-0">
            <p class="text-sm text-muted-foreground whitespace-pre-line">{{ profile.bio }}</p>
        </div>
    </div>
    {% endif %}

    {# ===== Skills Section ===== #}
    {% if skills|length > 0 %}
    <div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm">
        <div class="flex flex-col space-y-1.5 p-6">
            <h3 class="font-semibold leading-none tracking-tight">Skills</h3>
        </div>
        <div class="p-6 pt-0">
            <div class="flex flex-wrap gap-2">
                {% for skill in skills %}
                <div class="inline-flex items-center gap-1.5 rounded-md border border-transparent bg-secondary text-secondary-foreground px-2.5 py-1 text-xs font-semibold">
                    {{ skill.skillName }}
                    {% if skill.proficiencyLevel %}
                        <span class="text-muted-foreground font-normal">· {{ skill.proficiencyLevel|lower|capitalize }}</span>
                    {% endif %}
                    {% if skill.yearsExperience %}
                        <span class="text-muted-foreground font-normal">· {{ skill.yearsExperience }}y</span>
                    {% endif %}
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
    {% endif %}

    {# ===== Experience Section (Timeline) ===== #}
    {% if experiences|length > 0 %}
    <div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm">
        <div class="flex flex-col space-y-1.5 p-6">
            <h3 class="font-semibold leading-none tracking-tight">Experience</h3>
        </div>
        <div class="p-6 pt-0">
            <div class="relative space-y-0">
                {% for exp in experiences %}
                <div class="relative pl-8 pb-6 {{ not loop.last ? 'border-l-2 border-border' : '' }} ml-2">
                    {# Timeline dot #}
                    <div class="absolute -left-[9px] top-0 h-4 w-4 rounded-full border-2 border-primary bg-background"></div>

                    <div class="space-y-1">
                        <p class="font-medium text-sm">{{ exp.position }}</p>
                        <p class="text-sm text-muted-foreground">{{ exp.company }}</p>
                        <p class="text-xs text-muted-foreground">
                            {{ exp.startDate ? exp.startDate|date('M Y') : '' }}
                            {% if exp.startDate %} — {% endif %}
                            {{ exp.currentJob ? 'Present' : (exp.endDate ? exp.endDate|date('M Y') : '') }}
                        </p>
                        {% if exp.description %}
                            <p class="text-sm text-muted-foreground pt-1">{{ exp.description }}</p>
                        {% endif %}
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
    {% endif %}

    {# ===== Portfolio Section ===== #}
    {% if portfolioItems|length > 0 %}
    <div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm">
        <div class="flex flex-col space-y-1.5 p-6">
            <h3 class="font-semibold leading-none tracking-tight">Portfolio</h3>
        </div>
        <div class="p-6 pt-0">
            <div class="grid gap-4 sm:grid-cols-2">
                {% for item in portfolioItems %}
                <div class="rounded-lg border border-border overflow-hidden">
                    {% if item.imageUrl %}
                    <div class="aspect-video bg-muted overflow-hidden">
                        <img src="{{ item.imageUrl }}" alt="{{ item.title }}" class="h-full w-full object-cover">
                    </div>
                    {% endif %}
                    <div class="p-4 space-y-2">
                        <p class="font-medium text-sm">{{ item.title }}</p>
                        {% if item.description %}
                            <p class="text-xs text-muted-foreground">{{ item.description }}</p>
                        {% endif %}
                        {% if item.technologies %}
                        <div class="flex flex-wrap gap-1">
                            {% for tech in item.technologies|split(',') %}
                                {{ include('components/badge.html.twig', { label: tech|trim, variant: 'secondary' }) }}
                            {% endfor %}
                        </div>
                        {% endif %}
                        {% if item.projectUrl %}
                        <a href="{{ item.projectUrl }}" target="_blank" rel="noopener noreferrer"
                           class="inline-flex items-center gap-1 text-xs text-primary hover:underline">
                            View Project →
                        </a>
                        {% endif %}
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
    {% endif %}

    {# Empty state if nothing at all #}
    {% if (not profile or not profile.bio) and skills|length == 0 and experiences|length == 0 and portfolioItems|length == 0 %}
    <div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm p-12 text-center">
        <p class="text-muted-foreground">This user hasn't set up their profile yet.</p>
    </div>
    {% endif %}

</div>
{% endblock %}
