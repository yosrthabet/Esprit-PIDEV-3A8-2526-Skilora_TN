{% block javascripts %}
{{ parent() }}
<script>
function passkeyManager() {
    return {
        supported: !!window.PublicKeyCredential,
        passkeys: [],
        loading: true,
        registering: false,
        error: null,
        successMsg: null,

        init() {
            if (this.supported) this.loadPasskeys();
        },

        async loadPasskeys() {
            this.loading = true;
            try {
                const res = await fetch('{{ path("passkey_list") }}');
                this.passkeys = await res.json();
            } catch (e) {
                // silently fail
            }
            this.loading = false;
        },

        async register() {
            this.error = null;
            this.successMsg = null;
            this.registering = true;

            try {
                // 1. Get options
                const optRes = await fetch('{{ path("passkey_register_options") }}', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                });
                const options = await optRes.json();

                // 2. Convert fields
                options.challenge = this._b64ToBuffer(options.challenge);
                options.user.id = this._b64ToBuffer(options.user.id);
                if (options.excludeCredentials) {
                    options.excludeCredentials = options.excludeCredentials.map(c => {
                        c.id = this._b64ToBuffer(c.id);
                        return c;
                    });
                }

                // 3. Create credential
                const cred = await navigator.credentials.create({ publicKey: options });

                // 4. Send to server
                const credential = {
                    id: cred.id,
                    rawId: this._bufferToB64(cred.rawId),
                    type: cred.type,
                    response: {
                        attestationObject: this._bufferToB64(cred.response.attestationObject),
                        clientDataJSON: this._bufferToB64(cred.response.clientDataJSON),
                        transports: cred.response.getTransports ? cred.response.getTransports() : [],
                    },
                };

                const deviceName = this._detectDeviceName();

                const verifyRes = await fetch('{{ path("passkey_register_verify") }}', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ credential, name: deviceName }),
                });

                const result = await verifyRes.json();
                if (result.success) {
                    this.successMsg = 'Passkey "' + result.passkey.name + '" registered successfully!';
                    await this.loadPasskeys();
                } else {
                    throw new Error(result.error || 'Registration failed');
                }
            } catch (e) {
                if (e.name !== 'NotAllowedError') {
                    this.error = e.message || 'Failed to register passkey';
                }
            }
            this.registering = false;
        },

        async deletePasskey(id) {
            if (!confirm('Remove this passkey? You will no longer be able to sign in with it.')) return;
            this.error = null;
            this.successMsg = null;

            try {
                const res = await fetch('/passkey/delete/' + id, { method: 'DELETE' });
                const data = await res.json();
                if (data.success) {
                    this.successMsg = 'Passkey removed.';
                    await this.loadPasskeys();
                } else {
                    throw new Error('Failed to remove passkey');
                }
            } catch (e) {
                this.error = e.message;
            }
        },

        _detectDeviceName() {
            const ua = navigator.userAgent;
            if (/Macintosh/.test(ua)) return 'Mac Touch ID';
            if (/Windows/.test(ua)) return 'Windows Hello';
            if (/iPhone|iPad/.test(ua)) return 'iPhone Face ID';
            if (/Android/.test(ua)) return 'Android Biometric';
            return 'Security Key';
        },

        _b64ToBuffer(b64url) {
            const b64 = b64url.replace(/-/g, '+').replace(/_/g, '/');
            const pad = b64.length % 4 === 0 ? '' : '='.repeat(4 - (b64.length % 4));
            const bin = atob(b64 + pad);
            const buf = new Uint8Array(bin.length);
            for (let i = 0; i < bin.length; i++) buf[i] = bin.charCodeAt(i);
            return buf.buffer;
        },

        _bufferToB64(buf) {
            const bytes = new Uint8Array(buf);
            let binary = '';
            for (let i = 0; i < bytes.length; i++) binary += String.fromCharCode(bytes[i]);
            return btoa(binary).replace(/\+/g, '-').replace(/\//g, '_').replace(/=/g, '');
        },
    };
}
</script>
