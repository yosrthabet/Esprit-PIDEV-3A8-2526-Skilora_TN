                    {# Master enable/disable toggle #}
                    <div class="flex items-center justify-between rounded-lg border p-4" :class="gestureEnabled ? 'border-primary/30 bg-primary/5' : 'border-border bg-muted/30'">
                        <div>
                            <p class="text-sm font-semibold" x-text="gestureEnabled ? 'Gesture Control is ON' : 'Gesture Control is OFF'"></p>
                            <p class="text-xs text-muted-foreground" x-text="gestureEnabled ? 'Camera will start in standby mode on every page' : 'Camera is not used — enable to use hand gestures'"></p>
                        </div>
                        <button @click="toggleGesture()"
