                            </table>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Tab: Preferences #}
        <div x-show="tab === 'preferences'" x-cloak class="space-y-6">

            {# ── Hand Gesture Control ────────────────────────────── #}
            <div x-data="{
                    gestureEnabled: localStorage.getItem('skilora_gesture_enabled') === '1',
                    sensitivity: 5,
                    showPreview: true,
                    init() {
                        try {
                            const p = JSON.parse(localStorage.getItem('skilora_gesture_prefs') || '{}');
                            if (p.sensitivity) this.sensitivity = p.sensitivity;
                            if (p.showPreview !== undefined) this.showPreview = p.showPreview;
                        } catch (_) {}
                    },
                    toggleGesture() {
                        this.gestureEnabled = !this.gestureEnabled;
                        if (this.gestureEnabled) {
                            localStorage.setItem('skilora_gesture_enabled', '1');
                            if (window.SkiloraGestureUI) {
                                window.SkiloraGestureUI.startStandby();
                            }
                        } else {
                            localStorage.removeItem('skilora_gesture_enabled');
                            localStorage.removeItem('skilora_gesture_active');
                            if (window.SkiloraGesture) {
                                window.SkiloraGesture.stop();
                                window.SkiloraGesture.stopStandby();
                            }
                        }
                    },
                    save() {
                        localStorage.setItem('skilora_gesture_prefs', JSON.stringify({
                            sensitivity: this.sensitivity,
                            showPreview: this.showPreview
                        }));
                    },
                    reset() {
                        localStorage.removeItem('skilora_gesture_prefs');
                        localStorage.removeItem('skilora_gesture_tutorial_seen');
                        localStorage.removeItem('skilora_gesture_enabled');
                        localStorage.removeItem('skilora_gesture_active');
                        this.gestureEnabled = false;
                        this.sensitivity = 5;
                        this.showPreview = true;
                        if (window.SkiloraGesture) {
                            window.SkiloraGesture.stop();
                            window.SkiloraGesture.stopStandby();
                        }
                    }
                }"
                 class="rounded-xl border border-border bg-card text-card-foreground shadow-sm">
                <div class="flex flex-col space-y-1.5 p-6">
                    <div class="flex items-center gap-2">
                        <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
