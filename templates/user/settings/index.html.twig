                            </div>
                            <div class="flex items-center gap-2.5 rounded-lg border border-border/50 bg-muted/30 px-3 py-2">
                                <span class="text-lg">✌️</span>
                                <div>
                                    <p class="text-xs font-semibold">Peace Sign</p>
