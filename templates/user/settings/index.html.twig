{% extends 'layouts/app.html.twig' %}

{% block page_title %}Settings{% endblock %}

{% block head %}
    {{ parent() }}
{% endblock %}

{% block content %}
<div class="mx-auto max-w-2xl space-y-6">

    {# Flash messages #}
    {% for msg in app.flashes('success') %}
        {{ include('components/alert.html.twig', { variant: 'default', title: 'Success', body: msg }) }}
    {% endfor %}
    {% for msg in app.flashes('error') %}
        {{ include('components/alert.html.twig', { variant: 'destructive', title: 'Error', body: msg }) }}
    {% endfor %}

    {# Tabs #}
    <div x-data="{ tab: '{{ tab|default('account') }}' }">
        {# Tab triggers #}
        <div class="inline-flex h-9 items-center justify-center rounded-lg bg-muted p-1 text-muted-foreground mb-6">
            <button @click="tab = 'account'"
                    :class="tab === 'account' ? 'bg-background text-foreground shadow-sm' : ''"
                    class="inline-flex items-center justify-center whitespace-nowrap rounded-md px-3 py-1 text-sm font-medium ring-offset-background transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2">
                Account
            </button>
            <button @click="tab = 'password'"
                    :class="tab === 'password' ? 'bg-background text-foreground shadow-sm' : ''"
                    class="inline-flex items-center justify-center whitespace-nowrap rounded-md px-3 py-1 text-sm font-medium ring-offset-background transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2">
                Password
            </button>
            <button @click="tab = 'security'"
                    :class="tab === 'security' ? 'bg-background text-foreground shadow-sm' : ''"
                    class="inline-flex items-center justify-center whitespace-nowrap rounded-md px-3 py-1 text-sm font-medium ring-offset-background transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2">
                <i data-lucide="shield" class="mr-1.5 h-3.5 w-3.5"></i>
                Security
            </button>
            <button @click="tab = 'preferences'"
                    :class="tab === 'preferences' ? 'bg-background text-foreground shadow-sm' : ''"
                    class="inline-flex items-center justify-center whitespace-nowrap rounded-md px-3 py-1 text-sm font-medium ring-offset-background transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2">
                Preferences
            </button>
        </div>

        {# Tab: Account #}
        <div x-show="tab === 'account'" x-cloak>
            <div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm">
                <div class="flex flex-col space-y-1.5 p-6">
                    <h3 class="font-semibold leading-none tracking-tight">Account Information</h3>
                    <p class="text-sm text-muted-foreground">Update your name and email address.</p>
                </div>
                <form action="{{ path('app_settings_profile') }}" method="post">
                    <input type="hidden" name="_token" value="{{ csrf_token('settings_profile') }}">
                    <div class="p-6 pt-0 space-y-4">
                        {{ include('components/input.html.twig', {
                            name: 'full_name',
                            label: 'Full Name',
                            type: 'text',
                            value: app.user.fullName,
                            placeholder: 'Your full name',
                        }) }}
                        {{ include('components/input.html.twig', {
                            name: 'email',
                            label: 'Email',
                            type: 'email',
                            value: app.user.email,
                            placeholder: 'you@example.com',
                        }) }}
                    </div>
                    <div class="flex items-center p-6 pt-0">
                        {{ include('components/button.html.twig', { label: 'Save Changes', type: 'submit' }) }}
                    </div>
                </form>
            </div>
        </div>

        {# Tab: Password #}
        <div x-show="tab === 'password'" x-cloak>
            <div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm">
                <div class="flex flex-col space-y-1.5 p-6">
                    <h3 class="font-semibold leading-none tracking-tight">Change Password</h3>
                    <p class="text-sm text-muted-foreground">Update your password. Use at least 6 characters.</p>
                </div>
                <form action="{{ path('app_settings_password') }}" method="post">
                    <input type="hidden" name="_token" value="{{ csrf_token('settings_password') }}">
                    <div class="p-6 pt-0 space-y-4">
                        {{ include('components/password-input.html.twig', {
                            name: 'current_password',
                            label: 'Current Password',
                            placeholder: 'Current password',
                            required: true,
                        }) }}
                        {{ include('components/password-input.html.twig', {
                            name: 'new_password',
                            label: 'New Password',
                            placeholder: 'New password',
                            required: true,
                        }) }}
                        {{ include('components/password-input.html.twig', {
                            name: 'confirm_password',
                            label: 'Confirm Password',
                            placeholder: 'Confirm new password',
                            required: true,
                        }) }}
                    </div>
                    <div class="flex items-center p-6 pt-0">
                        {{ include('components/button.html.twig', { label: 'Update Password', type: 'submit' }) }}
                    </div>
                </form>
            </div>
        </div>

        {# Tab: Security #}
        <div x-show="tab === 'security'" x-cloak class="space-y-6">

            {# ── Two-Factor Authentication ───────────────────────── #}
            <div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm">
                <div class="flex flex-col space-y-1.5 p-6">
                    <div class="flex items-center gap-2">
                        <i data-lucide="shield-check" class="h-5 w-5 text-primary"></i>
                        <h3 class="font-semibold leading-none tracking-tight">Two-Factor Authentication</h3>
                    </div>
                    <p class="text-sm text-muted-foreground">Add an extra layer of security with TOTP authenticator apps.</p>
                </div>
                <div class="p-6 pt-0 space-y-4">
                    {% if user.twoFactorEnabled %}
                        <div class="flex items-center gap-3 rounded-lg border border-green-500/20 bg-green-500/10 p-4">
                            <i data-lucide="check-circle-2" class="h-5 w-5 text-green-500 shrink-0"></i>
                            <div>
                                <p class="text-sm font-medium text-green-600 dark:text-green-400">2FA is enabled</p>
                                {% if user.twoFactorEnabledAt %}
                                    <p class="text-xs text-muted-foreground">Enabled on {{ user.twoFactorEnabledAt|date('M j, Y \\a\\t H:i') }}</p>
                                {% endif %}
                            </div>
                        </div>
                        <form action="{{ path('app_settings_2fa_disable') }}" method="post">
                            <input type="hidden" name="_token" value="{{ csrf_token('2fa_disable') }}">
                            <button type="submit"
                                    onclick="return confirm('Are you sure? You will need to set up 2FA again.')"
                                    class="inline-flex h-9 items-center justify-center rounded-md border border-destructive bg-transparent px-4 text-sm font-medium text-destructive shadow-sm transition-colors hover:bg-destructive hover:text-destructive-foreground">
                                <i data-lucide="shield-off" class="mr-2 h-3.5 w-3.5"></i>
                                Disable 2FA
                            </button>
                        </form>

                    {% elseif totp_qr_content %}
                        {# Setup in progress — show QR + verify form #}
                        <div id="2fa-verify" class="space-y-4">
                            <p class="text-sm text-muted-foreground">Scan this QR code with your authenticator app (Google Authenticator, Authy, etc.):</p>

                            <div class="flex justify-center rounded-lg border border-border bg-white p-4">
                                <img src="{{ totp_qr_data_uri }}" alt="2FA QR Code" width="200" height="200">
                            </div>

                            <form action="{{ path('app_settings_2fa_verify') }}" method="post" class="space-y-3">
                                <input type="hidden" name="_token" value="{{ csrf_token('2fa_verify') }}">
                                <label for="2fa_code" class="text-sm font-medium leading-none">Enter the 6-digit code from your app</label>
                                <div class="flex gap-3">
                                    <input type="text" id="2fa_code" name="code" maxlength="6" pattern="[0-9]{6}" inputmode="numeric" autocomplete="one-time-code" required
                                           class="flex h-10 w-40 rounded-md border border-input bg-transparent px-3 py-2 text-sm tracking-[0.3em] text-center ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
                                           placeholder="000000">
                                    <button type="submit"
                                            class="inline-flex h-10 items-center justify-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90">
                                        Verify &amp; Enable
                                    </button>
                                </div>
                            </form>
                        </div>

                    {% else %}
                        {# Not enabled — offer to set up #}
                        <div class="flex items-center gap-3 rounded-lg border border-border bg-muted/50 p-4">
                            <i data-lucide="shield-alert" class="h-5 w-5 text-muted-foreground shrink-0"></i>
                            <p class="text-sm text-muted-foreground">Two-factor authentication is not enabled. We recommend enabling it for enhanced security.</p>
                        </div>
                        <form action="{{ path('app_settings_2fa_enable') }}" method="post">
                            <input type="hidden" name="_token" value="{{ csrf_token('2fa_enable') }}">
                            <button type="submit"
                                    class="inline-flex h-9 items-center justify-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90">
                                <i data-lucide="shield-plus" class="mr-2 h-3.5 w-3.5"></i>
                                Set up 2FA
                            </button>
                        </form>
                    {% endif %}
                </div>
            </div>

            {# ── Connected Accounts ──────────────────────────────── #}
            <div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm">
                <div class="flex flex-col space-y-1.5 p-6">
                    <div class="flex items-center gap-2">
                        <i data-lucide="link" class="h-5 w-5 text-primary"></i>
                        <h3 class="font-semibold leading-none tracking-tight">Connected Accounts</h3>
                    </div>
                    <p class="text-sm text-muted-foreground">Manage third-party login providers linked to your account.</p>
                </div>
                <div class="p-6 pt-0 space-y-3">
                    {# GitHub #}
                    <div class="flex items-center justify-between rounded-lg border border-border p-4">
                        <div class="flex items-center gap-3">
                            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
                            <div>
                                <p class="text-sm font-medium">GitHub</p>
                                <p class="text-xs text-muted-foreground">
                                    {% if user.githubId %}Connected{% else %}Not connected{% endif %}
                                </p>
                            </div>
                        </div>
                        {% if user.githubId %}
                            <form action="{{ path('app_settings_oauth_unlink', {provider: 'github'}) }}" method="post">
                                <input type="hidden" name="_token" value="{{ csrf_token('unlink_github') }}">
                                <button type="submit" class="inline-flex h-8 items-center justify-center rounded-md border border-input bg-background px-3 text-xs font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground">
                                    Unlink
                                </button>
                            </form>
                        {% else %}
                            <a href="{{ path('app_oauth_connect', {provider: 'github'}) }}"
                               class="inline-flex h-8 items-center justify-center rounded-md bg-primary px-3 text-xs font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90">
                                Connect
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>

            {# ── Active Sessions ─────────────────────────────────── #}
            <div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm">

            {# ── Passkeys / Biometric Login ──────────────────────── #}
            <div x-data="passkeyManager()" class="rounded-xl border border-border bg-card text-card-foreground shadow-sm">
                <div class="flex flex-col space-y-1.5 p-6">
                    <div class="flex items-center gap-2">
                        <i data-lucide="fingerprint" class="h-5 w-5 text-primary"></i>
                        <h3 class="font-semibold leading-none tracking-tight">Passkeys &amp; Biometric Login</h3>
                    </div>
                    <p class="text-sm text-muted-foreground">Sign in with Face ID, Touch ID, Windows Hello, or a security key. No password needed.</p>
                </div>
                <div class="p-6 pt-0 space-y-4">
                    <template x-if="!supported">
                        <div class="rounded-lg border border-amber-500/20 bg-amber-500/10 p-4">
                            <p class="text-sm text-amber-600 dark:text-amber-400">Your browser does not support passkeys/WebAuthn.</p>
                        </div>
                    </template>

                    <template x-if="supported">
                        <div class="space-y-4">
                            {# List existing passkeys #}
                            <template x-if="passkeys.length === 0 && !loading">
                                <div class="flex items-center gap-3 rounded-lg border border-border bg-muted/50 p-4">
                                    <i data-lucide="key-round" class="h-5 w-5 text-muted-foreground shrink-0"></i>
                                    <p class="text-sm text-muted-foreground">No passkeys registered yet. Add one to enable biometric login.</p>
                                </div>
                            </template>

                            <template x-for="pk in passkeys" :key="pk.id">
                                <div class="flex items-center justify-between rounded-lg border border-border p-4">
                                    <div class="flex items-center gap-3">
                                        <i data-lucide="fingerprint" class="h-5 w-5 text-muted-foreground shrink-0"></i>
                                        <div>
                                            <p class="text-sm font-medium" x-text="pk.name"></p>
                                            <p class="text-xs text-muted-foreground">
                                                Added <span x-text="pk.createdAt"></span>
                                                <template x-if="pk.lastUsedAt"> · Last used <span x-text="pk.lastUsedAt"></span></template>
                                            </p>
                                        </div>
                                    </div>
                                    <button @click="deletePasskey(pk.id)"
                                            class="inline-flex h-8 items-center justify-center rounded-md border border-destructive bg-transparent px-3 text-xs font-medium text-destructive shadow-sm transition-colors hover:bg-destructive hover:text-destructive-foreground">
                                        Remove
                                    </button>
                                </div>
                            </template>

                            {# Add new passkey #}
                            <div x-show="!registering" class="flex items-center gap-3">
                                <button @click="register()"
                                        class="inline-flex h-9 items-center justify-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90">
                                    <i data-lucide="plus" class="mr-2 h-3.5 w-3.5"></i>
                                    Add Passkey
                                </button>
                            </div>

                            <div x-show="registering" class="flex items-center gap-3 rounded-lg border border-primary/30 bg-primary/5 p-4">
                                <svg class="h-5 w-5 animate-spin text-primary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                                </svg>
                                <p class="text-sm text-primary">Waiting for your device... Follow the prompts from your browser.</p>
                            </div>

                            <template x-if="error">
                                <div class="rounded-lg border border-destructive/20 bg-destructive/10 p-3">
                                    <p class="text-sm text-destructive" x-text="error"></p>
                                </div>
                            </template>

                            <template x-if="successMsg">
                                <div class="rounded-lg border border-green-500/20 bg-green-500/10 p-3">
                                    <p class="text-sm text-green-600 dark:text-green-400" x-text="successMsg"></p>
                                </div>
                            </template>
                        </div>
                    </template>
                </div>
            </div>

            {# ── Active Sessions (continued) ────────────────────── #}
                <div class="flex flex-col space-y-1.5 p-6">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-2">
                            <i data-lucide="monitor-smartphone" class="h-5 w-5 text-primary"></i>
                            <h3 class="font-semibold leading-none tracking-tight">Active Sessions</h3>
                        </div>
                        {% if sessions|length > 1 %}
                            <form action="{{ path('app_settings_sessions_revoke') }}" method="post">
                                <input type="hidden" name="_token" value="{{ csrf_token('revoke_sessions') }}">
                                <button type="submit"
                                        onclick="return confirm('Log out all other sessions?')"
                                        class="inline-flex h-8 items-center justify-center rounded-md border border-destructive bg-transparent px-3 text-xs font-medium text-destructive shadow-sm transition-colors hover:bg-destructive hover:text-destructive-foreground">
                                    <i data-lucide="log-out" class="mr-1.5 h-3 w-3"></i>
                                    Revoke all others
                                </button>
                            </form>
                        {% endif %}
                    </div>
                    <p class="text-sm text-muted-foreground">Devices and browsers where you're currently signed in.</p>
                </div>
                <div class="p-6 pt-0">
                    {% if sessions is empty %}
                        <p class="text-sm text-muted-foreground text-center py-4">No active sessions found.</p>
                    {% else %}
                        <div class="space-y-3">
                            {% for session in sessions %}
                                <div class="flex items-center justify-between rounded-lg border border-border p-4 {{ session.sessionId == current_session_id ? 'border-primary/30 bg-primary/5' : '' }}">
                                    <div class="flex items-center gap-3">
                                        {% if session.deviceType == 'Mobile' %}
                                            <i data-lucide="smartphone" class="h-5 w-5 text-muted-foreground shrink-0"></i>
                                        {% else %}
                                            <i data-lucide="monitor" class="h-5 w-5 text-muted-foreground shrink-0"></i>
                                        {% endif %}
                                        <div>
                                            <p class="text-sm font-medium">
                                                {{ session.browserName }}
                                                {% if session.sessionId == current_session_id %}
                                                    <span class="ml-1.5 inline-flex items-center rounded-full bg-primary/10 px-2 py-0.5 text-[10px] font-medium text-primary">This device</span>
                                                {% endif %}
                                            </p>
                                            <p class="text-xs text-muted-foreground">{{ session.ip }} · Last active {{ session.lastActivity|date('M j, H:i') }}</p>
                                        </div>
                                    </div>
                                    {% if session.sessionId != current_session_id %}
                                        <form action="{{ path('app_settings_session_revoke_one', {id: session.id}) }}" method="post">
                                            <input type="hidden" name="_token" value="{{ csrf_token('revoke_session_' ~ session.id) }}">
                                            <button type="submit" class="inline-flex h-8 items-center justify-center rounded-md border border-input bg-background px-3 text-xs font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground">
                                                Revoke
                                            </button>
                                        </form>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            </div>

            {# ── Login History ───────────────────────────────────── #}
            <div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm">
                <div class="flex flex-col space-y-1.5 p-6">
                    <div class="flex items-center gap-2">
                        <i data-lucide="history" class="h-5 w-5 text-primary"></i>
                        <h3 class="font-semibold leading-none tracking-tight">Login History</h3>
                    </div>
                    <p class="text-sm text-muted-foreground">Recent sign-in activity on your account.</p>
                </div>
                <div class="p-6 pt-0">
                    {% if login_history is empty %}
                        <p class="text-sm text-muted-foreground text-center py-4">No login history yet.</p>
                    {% else %}
                        <div class="overflow-x-auto">
                            <table class="w-full text-sm">
                                <thead>
                                    <tr class="border-b border-border">
                                        <th class="pb-2 text-left font-medium text-muted-foreground">Status</th>
                                        <th class="pb-2 text-left font-medium text-muted-foreground">Method</th>
                                        <th class="pb-2 text-left font-medium text-muted-foreground">IP Address</th>
                                        <th class="pb-2 text-left font-medium text-muted-foreground">Date</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-border">
                                    {% for entry in login_history %}
                                        <tr>
                                            <td class="py-2.5">
                                                {% if entry.status == 'success' %}
                                                    <span class="inline-flex items-center gap-1 rounded-full bg-green-500/10 px-2 py-0.5 text-xs font-medium text-green-600 dark:text-green-400">
                                                        <i data-lucide="check" class="h-3 w-3"></i> Success
                                                    </span>
                                                {% else %}
                                                    <span class="inline-flex items-center gap-1 rounded-full bg-red-500/10 px-2 py-0.5 text-xs font-medium text-red-600 dark:text-red-400">
                                                        <i data-lucide="x" class="h-3 w-3"></i> Failed
                                                    </span>
                                                {% endif %}
                                            </td>
                                            <td class="py-2.5">
                                                <span class="inline-flex items-center gap-1 text-xs text-muted-foreground capitalize">
                                                    {% if entry.method == 'google' %}
                                                        <svg class="h-3 w-3" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
                                                    {% elseif entry.method == 'github' %}
