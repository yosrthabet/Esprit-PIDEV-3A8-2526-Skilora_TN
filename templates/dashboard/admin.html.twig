{# dashboard/admin.html.twig — Admin Dashboard #}
{% extends 'layouts/app.html.twig' %}

{% block page_title %}Overview{% endblock %}

{% block content %}
<div class="space-y-6 animate-fade-in pb-6">

    {# ── Header ── #}
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div>
            <h2 class="text-xl font-semibold tracking-tight text-foreground">
                Welcome back, {{ app.user.displayName }}
            </h2>
            <p class="text-sm text-muted-foreground mt-0.5">Here's what's happening on your platform today.</p>
        </div>
        <div class="flex items-center gap-2">
            <span class="inline-flex items-center gap-1.5 rounded-lg border border-border bg-card px-3 py-1.5 text-xs font-medium text-muted-foreground shadow-sm">
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                {{ "now"|date("M d, Y") }}
            </span>
        </div>
    </div>

    {# ── Stat Cards ── #}
    {% set statColors = ['bg-indigo-500', 'bg-sky-500', 'bg-emerald-500', 'bg-rose-500'] %}
    {% set statIcons = [
        '<path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0z" />',
        '<path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z" />',
        '<path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342" />',
        '<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />'
    ] %}
    {# Force Tailwind to keep these classes by adding them to a hidden div #}
    <div class="hidden bg-indigo-500 bg-sky-500 bg-emerald-500 bg-rose-500"></div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
        {% for stat in stats %}
        <div class="rounded-xl border border-border bg-card p-4 sm:p-5 shadow-sm">
            <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-medium uppercase tracking-wider text-muted-foreground">{{ stat.label }}</span>
                <div class="flex h-8 w-8 items-center justify-center rounded-lg {{ statColors[loop.index0] }} text-white shadow-sm">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">{{ statIcons[loop.index0] | raw }}</svg>
                </div>
            </div>
            <p class="text-2xl font-bold tracking-tight text-foreground">{{ stat.value }}</p>
            <div class="mt-1 flex items-center gap-1.5">
                {% if stat.trend == 'up' %}
                    <span class="inline-flex items-center gap-0.5 text-xs font-medium text-emerald-600 dark:text-emerald-400">
                        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/></svg>
                        {{ stat.change }}
                    </span>
                {% else %}
                    <span class="inline-flex items-center gap-0.5 text-xs font-medium text-rose-600 dark:text-rose-400">
                        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 4.5l-15 15m0 0h11.25m-11.25 0V8.25"/></svg>
                        {{ stat.change }}
                    </span>
                {% endif %}
                <span class="text-xs text-muted-foreground">vs last month</span>
            </div>
        </div>
        {% endfor %}
    </div>

    {# ── Charts ── #}
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-3 sm:gap-4">
        {# Line Chart #}
        <div class="lg:col-span-3 rounded-xl border border-border bg-card shadow-sm">
            <div class="flex items-center justify-between border-b border-border px-5 py-4">
                <div>
                    <h3 class="text-sm font-semibold text-foreground">Growth Overview</h3>
                    <p class="text-xs text-muted-foreground mt-0.5">Monthly registrations trend</p>
                </div>
                <select class="h-8 rounded-lg border border-input bg-background px-2.5 text-xs text-foreground shadow-sm focus:outline-none focus:ring-1 focus:ring-ring">
                    <option>Last 7 months</option>
                    <option>This Year</option>
                </select>
            </div>
            <div class="p-5" style="height:320px">
                <canvas id="mainGrowthChart"></canvas>
            </div>
        </div>

        {# Donut Chart #}
        <div class="lg:col-span-2 rounded-xl border border-border bg-card shadow-sm">
            <div class="border-b border-border px-5 py-4">
                <h3 class="text-sm font-semibold text-foreground">User Demographics</h3>
                <p class="text-xs text-muted-foreground mt-0.5">Breakdown by role</p>
            </div>
            <div class="flex items-center justify-center p-5 relative" style="height:320px">
                <canvas id="roleDonutChart"></canvas>
                <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none" style="margin-bottom:40px">
                    <span class="text-2xl font-bold text-foreground">{{ stats[0].value }}</span>
                    <span class="text-[10px] font-medium uppercase tracking-widest text-muted-foreground">Total</span>
                </div>
            </div>
        </div>
    </div>

    {# ── Bottom Row ── #}
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-3 sm:gap-4">

        {# Recent Users #}
        <div class="lg:col-span-3 rounded-xl border border-border bg-card shadow-sm">
            <div class="flex items-center justify-between border-b border-border px-5 py-4">
                <div>
                    <h3 class="text-sm font-semibold text-foreground">Recent Signups</h3>
                    <p class="text-xs text-muted-foreground mt-0.5">Latest platform registrations</p>
                </div>
                <a href="{{ path('app_admin_user_index') }}" class="inline-flex items-center gap-1 text-xs font-medium text-primary hover:underline">
                    View all
                    <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
                </a>
            </div>
            <div class="divide-y divide-border">
                {% for u in recent_users|slice(0, 5) %}
                <div class="flex items-center justify-between px-5 py-3 hover:bg-muted/40 transition-colors">
                    <div class="flex items-center gap-3 min-w-0">
                        <div class="relative flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-muted text-muted-foreground text-xs font-semibold">
                            {{ u.name|split(' ')|map(w => w|first)|join('') }}
                            <span class="absolute -bottom-0.5 -right-0.5 h-2.5 w-2.5 rounded-full border-2 border-card {{ u.status == 'Active' ? 'bg-emerald-500' : 'bg-zinc-400' }}"></span>
                        </div>
                        <div class="min-w-0">
                            <p class="text-sm font-medium text-foreground truncate">{{ u.name }}</p>
                            <p class="text-xs text-muted-foreground truncate">{{ u.email }}</p>
                        </div>
                    </div>
                    <span class="ml-4 shrink-0 inline-flex items-center rounded-md border border-border bg-muted/50 px-2 py-0.5 text-[11px] font-medium text-muted-foreground">
                        {{ u.role }}
                    </span>
                </div>
                {% else %}
                <div class="px-5 py-10 text-center text-sm text-muted-foreground">No recent signups.</div>
                {% endfor %}
            </div>
        </div>

        {# Right Column #}
        <div class="lg:col-span-2 flex flex-col gap-4">

            {# Quick Actions #}
            <div class="rounded-xl border border-border bg-card shadow-sm">
                <div class="border-b border-border px-5 py-4">
                    <h3 class="text-sm font-semibold text-foreground">Quick Actions</h3>
                </div>
                <div class="grid grid-cols-2 divide-x divide-y divide-border">
                    <a href="{{ path('app_admin_user_index') }}" class="group flex items-center gap-3 px-4 py-3.5 hover:bg-muted/40 transition-colors">
                        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-500">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
                        </div>
                        <div>
                            <p class="text-xs font-medium text-foreground">Users</p>
                            <p class="text-[10px] text-muted-foreground">Manage users</p>
                        </div>
                    </a>
                    <a href="#" class="group flex items-center gap-3 px-4 py-3.5 hover:bg-muted/40 transition-colors">
                        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-sky-500/10 text-sky-500">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21" /></svg>
                        </div>
                        <div>
                            <p class="text-xs font-medium text-foreground">Post Job</p>
                            <p class="text-[10px] text-muted-foreground">Recruitment</p>
                        </div>
                    </a>
                    <a href="{{ path('app_admin_formation_index') }}" class="group flex items-center gap-3 px-4 py-3.5 hover:bg-muted/40 transition-colors">
                        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-emerald-500/10 text-emerald-500">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347" /></svg>
                        </div>
                        <div>
                            <p class="text-xs font-medium text-foreground">Formations</p>
                            <p class="text-[10px] text-muted-foreground">Manage catalog</p>
                        </div>
                    </a>
                    <a href="#" class="group flex items-center gap-3 px-4 py-3.5 hover:bg-muted/40 transition-colors">
                        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-amber-500/10 text-amber-500">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>
                        </div>
                        <div>
                            <p class="text-xs font-medium text-foreground">Analytics</p>
                            <p class="text-[10px] text-muted-foreground">Reports</p>
                        </div>
                    </a>
                </div>
            </div>

            {# System Health #}
            <div class="rounded-xl border border-border bg-card p-5 shadow-sm">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-sm font-semibold text-foreground">System Status</h3>
                    <span class="relative flex h-2.5 w-2.5">
                        <span class="absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75 animate-ping"></span>
                        <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-emerald-500"></span>
                    </span>
                </div>
                <div class="space-y-4">
                    <div>
                        <div class="flex items-center justify-between text-xs mb-1.5">
                            <span class="font-medium text-foreground">API Response</span>
                            <span class="font-semibold text-emerald-500">98%</span>
                        </div>
                        <div class="h-1.5 w-full rounded-full bg-secondary overflow-hidden">
                            <div class="h-full rounded-full bg-emerald-500" style="width:98%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex items-center justify-between text-xs mb-1.5">
                            <span class="font-medium text-foreground">Storage</span>
                            <span class="font-semibold text-amber-500">64%</span>
                        </div>
                        <div class="h-1.5 w-full rounded-full bg-secondary overflow-hidden">
                            <div class="h-full rounded-full bg-amber-500" style="width:64%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex items-center justify-between text-xs mb-1.5">
                            <span class="font-medium text-foreground">Uptime</span>
                            <span class="font-semibold text-emerald-500">99.9%</span>
                        </div>
                        <div class="h-1.5 w-full rounded-full bg-secondary overflow-hidden">
                            <div class="h-full rounded-full bg-emerald-500" style="width:99.9%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js" defer></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Wait slightly to ensure ChartJS is fully decoded
    setTimeout(() => {
        if (typeof Chart === 'undefined') return;

        Chart.defaults.font.family = "'Inter', 'sans-serif'";
        
        const isDark = document.documentElement.classList.contains('dark') || 
            (localStorage.getItem('theme') === 'dark') || 
            window.matchMedia('(prefers-color-scheme: dark)').matches;
            
        const gridColor = isDark ? 'rgba(255, 255, 255, 0.07)' : 'rgba(0, 0, 0, 0.05)';
        const textColor = isDark ? '#a1a1aa' : '#6b7280';
        const primaryCol = '#4f46e5'; // brand color

        // ----- Main Growth Chart ----- //
        const canvasMain = document.getElementById('mainGrowthChart');
        if (canvasMain) {
            const ctxMain = canvasMain.getContext('2d');
            
            let bgGradient = ctxMain.createLinearGradient(0, 0, 0, 350);
            bgGradient.addColorStop(0, 'rgba(79, 70, 229, 0.25)');   
            bgGradient.addColorStop(1, 'rgba(79, 70, 229, 0.0)');

            new Chart(ctxMain, {
                type: 'line',
                data: {
                    labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul'],
                    datasets: [{
                        label: 'Registrations',
                        data: [65, 84, 115, 142, 110, 165, 210],
                        borderColor: primaryCol,
                        backgroundColor: bgGradient,
                        borderWidth: 2.5,
                        tension: 0.4,
                        fill: true,
                        pointBackgroundColor: isDark ? '#1f2937' : '#ffffff',
                        pointBorderColor: primaryCol,
                        pointBorderWidth: 2,
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        hitRadius: 10
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: isDark ? 'rgba(15, 23, 42, 0.95)' : 'rgba(255, 255, 255, 0.9)',
                            titleColor: isDark ? '#f8fafc' : '#111827',
                            bodyColor: isDark ? '#cbd5e1' : '#4b5563',
                            borderColor: gridColor,
                            borderWidth: 1,
                            padding: 12,
                            boxPadding: 6,
                            usePointStyle: true,
                            cornerRadius: 8,
                            titleFont: { size: 13, weight: 'bold' },
                            bodyFont: { size: 13 }
                        }
                    },
                    interaction: { mode: 'index', intersect: false },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: gridColor, drawBorder: false },
                            border: { display: false },
                            ticks: { color: textColor, padding: 12, maxTicksLimit: 6 }
                        },
                        x: {
                            grid: { display: false, drawBorder: false },
                            border: { display: false },
                            ticks: { color: textColor, padding: 12 }
                        }
                    }
                }
            });
        }

        // ----- Demographics Donut Chart ----- //
        const canvasDonut = document.getElementById('roleDonutChart');
        if (canvasDonut) {
            const ctxDonut = canvasDonut.getContext('2d');
            new Chart(ctxDonut, {
                type: 'doughnut',
                data: {
                    labels: ['Freelancers', 'Trainers', 'Clients', 'Admins'],
                    datasets: [{
                        data: [60, 20, 15, 5],
                        backgroundColor: [
                            '#4f46e5', // indigo-600
                            '#0ea5e9', // sky-500
                            '#10b981', // emerald-500
                            '#8b5cf6', // purple-500
                        ],
                        borderWidth: isDark ? 2 : 2,
                        borderColor: isDark ? '#020817' : '#ffffff',
                        hoverOffset: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '74%', 
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                color: textColor,
                                usePointStyle: true,
                                padding: 25,
                                font: { size: 12 },
                                pointStyle: 'circle'
                            }
                        },
                        tooltip: {
                            backgroundColor: isDark ? 'rgba(15, 23, 42, 0.95)' : 'rgba(255, 255, 255, 0.95)',
                            titleColor: isDark ? '#f8fafc' : '#111827',
                            bodyColor: isDark ? '#cbd5e1' : '#4b5563',
                            borderColor: gridColor,
                            borderWidth: 1,
                            padding: 10,
                            cornerRadius: 8,
                            displayColors: true,
                            boxPadding: 4,
                            callbacks: {
                                label: function(context) {
                                    return ' ' + context.label + ': ' + context.raw + '%';
                                }
                            }
                        }
                    }
                }
            });
        }
    }, 500);
});
</script>

{% endblock %}
