{# dashboard/freelancer.html.twig — Freelancer Workspace (Fiverr-like) #}
{% extends 'layouts/app.html.twig' %}

{% block page_title %}Workspace{% endblock %}

{% block content %}
<div class="space-y-6 animate-fade-in pb-6">

    {# ── Welcome Banner ── #}
    <div class="rounded-xl border border-border bg-gradient-to-r from-indigo-500/10 via-purple-500/5 to-transparent p-6">
        <div class="flex flex-col sm:flex-row justify-between items-start gap-4">
            <div>
                <h2 class="text-xl font-semibold tracking-tight text-foreground">
                    Welcome back, {{ app.user.displayName }}
                </h2>
                <p class="text-sm text-muted-foreground mt-1">Track your learning journey and explore new formations.</p>
            </div>
            <div class="flex items-center gap-2">
                <a href="{{ path('app_formation_index') }}"
                   class="inline-flex h-9 items-center gap-2 rounded-md bg-primary px-4 text-xs font-semibold text-primary-foreground shadow hover:bg-primary/90 transition-colors">
                    <i data-lucide="compass" class="h-3.5 w-3.5"></i>
                    Explore Catalog
                </a>
                <span class="inline-flex items-center gap-1.5 rounded-lg border border-border bg-card px-3 py-1.5 text-xs font-medium text-muted-foreground shadow-sm">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                    {{ "now"|date("M d, Y") }}
                </span>
            </div>
        </div>
    </div>

    {# ── Stat Cards ── #}
    <div class="hidden bg-indigo-500 bg-sky-500 bg-amber-500 bg-emerald-500"></div>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        {% set statIcons = {
            'book-open': '<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>',
            'bookmark': '<path stroke-linecap="round" stroke-linejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0111.186 0z"/>',
            'play-circle': '<path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15.91 11.672a.375.375 0 010 .656l-5.603 3.113a.375.375 0 01-.557-.328V8.887c0-.286.307-.466.557-.327l5.603 3.112z"/>',
            'check-circle': '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>'
        } %}
        {% for stat in stats %}
        <div class="rounded-xl border border-border bg-card p-5 shadow-sm">
            <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-medium uppercase tracking-wider text-muted-foreground">{{ stat.label }}</span>
                <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-{{ stat.color }}-500 text-white shadow-sm">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">{{ statIcons[stat.icon]|default('')|raw }}</svg>
                </div>
            </div>
            <p class="text-2xl font-bold tracking-tight text-foreground">{{ stat.value }}</p>
        </div>
        {% endfor %}
    </div>

    {# ── Main Content ── #}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        {# Left: Continue Learning #}
        <div class="lg:col-span-2 space-y-4">

            {# In Progress #}
            <div class="rounded-xl border border-border bg-card shadow-sm">
                <div class="flex items-center justify-between border-b border-border px-5 py-4">
                    <div>
                        <h3 class="text-sm font-semibold text-foreground">Continue Learning</h3>
                        <p class="text-xs text-muted-foreground mt-0.5">Pick up where you left off</p>
                    </div>
                    <a href="{{ path('app_my_formations') }}" class="inline-flex items-center gap-1 text-xs font-medium text-primary hover:underline">
                        View all
                        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
                    </a>
                </div>
                <div class="divide-y divide-border">
                    {% for enrollment in in_progress|slice(0, 5) %}
                    <a href="{{ path('app_formation_show', { id: enrollment.formation.id }) }}"
                       class="flex items-center gap-4 px-5 py-4 hover:bg-muted/40 transition-colors group">
                        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-indigo-500/10 text-indigo-500 group-hover:bg-indigo-500/20 transition-colors">
                            <i data-lucide="play" class="h-5 w-5"></i>
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-medium text-foreground truncate group-hover:text-primary transition-colors">{{ enrollment.formation.title }}</p>
                            <p class="text-xs text-muted-foreground mt-0.5">
                                {{ enrollment.formation.categoryLabelFr }} · {{ enrollment.formation.duration }} h · {{ enrollment.formation.levelLabelFr }}
                            </p>
                        </div>
                        <span class="shrink-0 inline-flex items-center gap-1 rounded-full border border-amber-500/30 bg-amber-500/10 px-2.5 py-0.5 text-[11px] font-medium text-amber-600 dark:text-amber-400">
                            <span class="h-1.5 w-1.5 rounded-full bg-amber-500"></span>
                            In Progress
                        </span>
                    </a>
                    {% else %}
                    <div class="px-5 py-10 text-center">
                        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-muted mx-auto mb-3">
                            <i data-lucide="book-open" class="h-5 w-5 text-muted-foreground"></i>
                        </div>
                        <p class="text-sm font-medium text-foreground">No formations in progress</p>
                        <p class="text-xs text-muted-foreground mt-1">Explore the catalog to start learning</p>
                        <a href="{{ path('app_formation_index') }}" class="inline-flex items-center gap-1 mt-3 text-xs font-medium text-primary hover:underline">
                            Browse formations
                            <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                        </a>
                    </div>
                    {% endfor %}
                </div>
            </div>

            {# Recent Formations on Platform #}
            {% if latest_formations is not empty %}
            <div class="rounded-xl border border-border bg-card shadow-sm">
                <div class="flex items-center justify-between border-b border-border px-5 py-4">
                    <div>
                        <h3 class="text-sm font-semibold text-foreground">New on Skilora</h3>
                        <p class="text-xs text-muted-foreground mt-0.5">Latest formations added</p>
                    </div>
                    <a href="{{ path('app_formation_index') }}" class="inline-flex items-center gap-1 text-xs font-medium text-primary hover:underline">
                        See all
                        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
                    </a>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-px bg-border">
                    {% for f in latest_formations %}
                    <a href="{{ path('app_formation_show', { id: f.id }) }}" class="flex items-center gap-3 bg-card px-5 py-4 hover:bg-muted/40 transition-colors group">
                        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-{{ loop.index0 is even ? 'emerald' : 'purple' }}-500/10 text-{{ loop.index0 is even ? 'emerald' : 'purple' }}-500">
                            <i data-lucide="graduation-cap" class="h-4 w-4"></i>
                        </div>
                        <div class="min-w-0">
                            <p class="text-sm font-medium text-foreground truncate group-hover:text-primary transition-colors">{{ f.title }}</p>
                            <p class="text-xs text-muted-foreground">{{ f.categoryLabelFr }} · {{ f.duration }} h</p>
                        </div>
                    </a>
                    {% endfor %}
                </div>
            </div>
            {% endif %}
        </div>

        {# Right Column #}
        <div class="space-y-4">

            {# Quick Actions #}
            <div class="rounded-xl border border-border bg-card shadow-sm">
                <div class="border-b border-border px-5 py-4">
                    <h3 class="text-sm font-semibold text-foreground">Quick Actions</h3>
                </div>
                <div class="p-3 space-y-1">
                    <a href="{{ path('app_formation_index') }}" class="flex items-center gap-3 rounded-lg px-3 py-2.5 hover:bg-muted/50 transition-colors">
                        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-500">
                            <i data-lucide="search" class="h-4 w-4"></i>
                        </div>
                        <div>
                            <p class="text-sm font-medium text-foreground">Explore Formations</p>
                            <p class="text-[11px] text-muted-foreground">Browse the catalog</p>
                        </div>
                    </a>
                    <a href="{{ path('app_my_formations') }}" class="flex items-center gap-3 rounded-lg px-3 py-2.5 hover:bg-muted/50 transition-colors">
                        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-emerald-500/10 text-emerald-500">
                            <i data-lucide="book-open" class="h-4 w-4"></i>
                        </div>
                        <div>
                            <p class="text-sm font-medium text-foreground">My Formations</p>
                            <p class="text-[11px] text-muted-foreground">Continue learning</p>
                        </div>
                    </a>
                    <a href="{{ path('app_my_certificates') }}" class="flex items-center gap-3 rounded-lg px-3 py-2.5 hover:bg-muted/50 transition-colors">
                        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-amber-500/10 text-amber-500">
                            <i data-lucide="award" class="h-4 w-4"></i>
                        </div>
                        <div>
                            <p class="text-sm font-medium text-foreground">My Certificates</p>
                            <p class="text-[11px] text-muted-foreground">Download & share</p>
                        </div>
                    </a>
                    <a href="{{ path('app_jobs') }}" class="flex items-center gap-3 rounded-lg px-3 py-2.5 hover:bg-muted/50 transition-colors">
                        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-sky-500/10 text-sky-500">
                            <i data-lucide="briefcase" class="h-4 w-4"></i>
                        </div>
                        <div>
                            <p class="text-sm font-medium text-foreground">Job Feed</p>
                            <p class="text-[11px] text-muted-foreground">Find opportunities</p>
                        </div>
                    </a>
                </div>
            </div>

            {# Certificates #}
            <div class="rounded-xl border border-border bg-card shadow-sm">
                <div class="flex items-center justify-between border-b border-border px-5 py-4">
                    <h3 class="text-sm font-semibold text-foreground">My Certificates</h3>
                    <a href="{{ path('app_my_certificates') }}" class="text-xs font-medium text-primary hover:underline">View all</a>
                </div>
                <div class="divide-y divide-border">
                    {% for cert in certificates|slice(0, 3) %}
                    <div class="flex items-center gap-3 px-5 py-3">
                        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-emerald-500/10 text-emerald-500">
                            <i data-lucide="award" class="h-4 w-4"></i>
                        </div>
                        <div class="min-w-0 flex-1">
                            <p class="text-sm font-medium text-foreground truncate">{{ cert.formation.title }}</p>
                            <p class="text-[11px] text-muted-foreground">{{ cert.issuedAt|date('M d, Y') }}</p>
                        </div>
                        <a href="{{ path('app_certificate_pdf', { id: cert.id }) }}" class="shrink-0 text-muted-foreground hover:text-primary transition-colors" title="Download PDF">
                            <i data-lucide="download" class="h-4 w-4"></i>
                        </a>
                    </div>
                    {% else %}
                    <div class="px-5 py-6 text-center text-xs text-muted-foreground">
                        Complete formations to earn certificates.
                    </div>
                    {% endfor %}
                </div>
            </div>

            {# Profile Card #}
            <div class="rounded-xl border border-border bg-card p-5 shadow-sm">
                <div class="flex items-center gap-3 mb-4">
                    <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary text-primary-foreground text-lg font-bold">
                        {{ app.user.displayName|first|upper }}
                    </div>
                    <div>
                        <p class="text-sm font-semibold text-foreground">{{ app.user.displayName }}</p>
                        <p class="text-xs text-muted-foreground">{{ app.user.roleDisplayName }}</p>
                    </div>
                </div>
                <div class="grid grid-cols-3 gap-3 text-center">
                    <div>
                        <p class="text-lg font-bold text-foreground">{{ enrollments|length }}</p>
                        <p class="text-[10px] text-muted-foreground uppercase tracking-wider">Enrolled</p>
                    </div>
                    <div>
                        <p class="text-lg font-bold text-foreground">{{ certificates|length }}</p>
                        <p class="text-[10px] text-muted-foreground uppercase tracking-wider">Certs</p>
                    </div>
                    <div>
                        <p class="text-lg font-bold text-foreground">
                            {% set total_hours = 0 %}
                            {% for e in enrollments %}
                                {% if e.completed %}
                                    {% set total_hours = total_hours + (e.formation.duration ?? 0) %}
                                {% endif %}
                            {% endfor %}
                            {{ total_hours }}h
                        </p>
                        <p class="text-[10px] text-muted-foreground uppercase tracking-wider">Hours</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>
{% endblock %}
