{# dashboard/index.html.twig — Skilora Dashboard showcasing ShadCN components #}
{% extends 'layouts/app.html.twig' %}

{% block page_title %}Dashboard{% endblock %}

{% block content %}
<div class="space-y-6 animate-fade-in">

    {# ===== Stat Cards ===== #}
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {% for stat in stats %}
        <div class="rounded-xl border border-border bg-card p-6 text-card-foreground shadow-sm">
            <div class="flex items-center justify-between">
                <p class="text-sm font-medium text-muted-foreground">{{ stat.label }}</p>
                {% if stat.trend == 'up' %}
                    <svg class="h-4 w-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M7 17l5-5 5 5M7 7l5 5 5-5"/>
                    </svg>
                {% else %}
                    <svg class="h-4 w-4 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 7l-5 5-5-5m0 10l5-5 5 5"/>
                    </svg>
                {% endif %}
            </div>
            <div class="mt-2">
                <p class="text-2xl font-bold">{{ stat.value }}</p>
                <p class="text-xs {{ stat.trend == 'up' ? 'text-green-500' : 'text-red-500' }}">
                    {{ stat.change }} from last month
                </p>
            </div>
        </div>
        {% endfor %}
    </div>

    {# ===== Main content row ===== #}
    <div class="grid gap-6 lg:grid-cols-3">

        {# Recent Users table (2/3 width) #}
        <div class="lg:col-span-2 rounded-xl border border-border bg-card text-card-foreground shadow-sm">
            <div class="flex items-center justify-between p-6 pb-4">
                <div>
                    <h3 class="font-semibold leading-none tracking-tight">Recent Users</h3>
                    <p class="text-sm text-muted-foreground mt-1">Latest registrations on Skilora</p>
                </div>
                {{ include('components/button.html.twig', {
                    label: 'View All',
                    variant: 'outline',
                    size: 'sm'
                }) }}
            </div>
            <div class="px-6 pb-6">
                {{ include('components/table.html.twig', {
                    columns: [
                        { key: 'user', label: 'User' },
                        { key: 'role', label: 'Role' },
                        { key: 'status', label: 'Status' },
                        { key: 'actions', label: '', align: 'right' },
                    ],
                    rows: recent_users|map(u => {
                        user: '<div class="flex items-center gap-3">' ~
                              include('components/avatar.html.twig', { initials: u.name|split(' ')|map(w => w|first)|join(''), size: 'sm' }) ~
                              '<div><p class="text-sm font-medium">' ~ u.name ~ '</p><p class="text-xs text-muted-foreground">' ~ u.email ~ '</p></div></div>',
                        role: include('components/badge.html.twig', { label: u.role, variant: 'secondary' }),
                        status: include('components/badge.html.twig', {
                            label: u.status,
                            variant: u.status == 'Active' ? 'success' : (u.status == 'Pending' ? 'warning' : 'outline')
                        }),
                        actions: include('components/dropdown-menu.html.twig', {
                            items: [
                                { label: 'View Profile', href: '#' },
                                { label: 'Edit', href: '#' },
                                { type: 'separator' },
                                { label: 'Delete', href: '#', variant: 'destructive' },
                            ]
                        })
                    })
                }) }}
            </div>
        </div>

        {# Sidebar cards (1/3 width) #}
        <div class="space-y-6">

            {# Quick Actions #}
            <div class="rounded-xl border border-border bg-card p-6 text-card-foreground shadow-sm">
                <h3 class="font-semibold leading-none tracking-tight mb-4">Quick Actions</h3>
                <div class="grid grid-cols-2 gap-2">
                    {{ include('components/button.html.twig', { label: 'New Job', variant: 'outline', size: 'sm', class: 'w-full justify-start' }) }}
                    {{ include('components/button.html.twig', { label: 'Add User', variant: 'outline', size: 'sm', class: 'w-full justify-start' }) }}
                    {{ include('components/button.html.twig', { label: 'Formation', variant: 'outline', size: 'sm', class: 'w-full justify-start' }) }}
                    {{ include('components/button.html.twig', { label: 'Reports', variant: 'outline', size: 'sm', class: 'w-full justify-start' }) }}
                </div>
            </div>

            {# Profile Completion #}
            <div class="rounded-xl border border-border bg-card p-6 text-card-foreground shadow-sm">
                <h3 class="font-semibold leading-none tracking-tight mb-1">Platform Health</h3>
                <p class="text-sm text-muted-foreground mb-4">System status overview</p>

                <div class="space-y-4">
                    <div>
                        <div class="flex justify-between text-sm mb-1">
                            <span>Server Uptime</span>
                            <span class="text-muted-foreground">99.8%</span>
                        </div>
                        {{ include('components/progress.html.twig', { value: 99.8 }) }}
                    </div>
                    <div>
                        <div class="flex justify-between text-sm mb-1">
                            <span>Storage Used</span>
                            <span class="text-muted-foreground">64%</span>
                        </div>
                        {{ include('components/progress.html.twig', { value: 64 }) }}
                    </div>
                    <div>
                        <div class="flex justify-between text-sm mb-1">
                            <span>API Response</span>
                            <span class="text-muted-foreground">92%</span>
                        </div>
                        {{ include('components/progress.html.twig', { value: 92 }) }}
                    </div>
                </div>
            </div>

            {# Alert #}
            {{ include('components/alert.html.twig', {
                title: 'Interviews Today',
                body: 'You have <strong>3 interviews</strong> scheduled for today. Check the recruitment calendar.',
            }) }}

        </div>
    </div>

</div>
{% endblock %}
