{# support/client/_dialog_form.html.twig — Form fragment for new/edit ticket dialog #}
<form method="post"
      id="dialog-ticket-form"
      action="{{ ticket ? path('support_edit', {id: ticket.id}) : path('support_new') }}"
      @submit.prevent="
          const fd = new FormData($el);
          try {
              const res = await fetch($el.action, {
                  method: 'POST',
                  headers: { 'X-Requested-With': 'XMLHttpRequest' },
                  body: fd
              });
              const data = await res.json();
              if (data.success) {
                  Alpine.store('toast').success(data.message);
                  $dispatch('close-edit-dialog');
                  window.location.reload();
              } else {
                  Alpine.store('toast').error(data.message || 'An error occurred.');
              }
          } catch (e) {
              Alpine.store('toast').error('Network error. Please try again.');
          }
      "
      class="space-y-4">

    <div>
        <label class="block text-sm font-medium text-foreground mb-1">{{ form.subject.vars.label }}</label>
        <div class="flex gap-2">
            {{ form_widget(form.subject, {attr: {id: 'dlg_ticket_subject', class: 'w-full rounded-md border border-border bg-background px-3 py-2 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring'}}) }}
            <button type="button" id="dlg-btn-suggest"
                    class="shrink-0 inline-flex items-center gap-1.5 rounded-md border border-violet-500/30 bg-violet-500/10 px-2.5 py-1.5 text-[11px] font-semibold text-violet-700 hover:bg-violet-500/20 transition-colors"
                    title="AI will suggest a subject based on your description">
                <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
                <span>AI Suggest</span>
            </button>
        </div>
        {{ form_errors(form.subject) }}
        <div id="dlg-error-subject" class="text-xs text-destructive mt-1"></div>
    </div>

    <div class="grid grid-cols-2 gap-4">
        <div>
            <label class="block text-sm font-medium text-foreground mb-1">{{ form.category.vars.label }}</label>
            {{ form_widget(form.category, {attr: {class: 'w-full rounded-md border border-border bg-background px-3 py-2 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-ring'}}) }}
            {{ form_errors(form.category) }}
        </div>
        <div>
            <label class="block text-sm font-medium text-foreground mb-1">{{ form.priority.vars.label }}</label>
            {{ form_widget(form.priority, {attr: {class: 'w-full rounded-md border border-border bg-background px-3 py-2 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-ring'}}) }}
            {{ form_errors(form.priority) }}
        </div>
    </div>

    <div>
        <label class="block text-sm font-medium text-foreground mb-1">{{ form.description.vars.label }}</label>
        {{ form_widget(form.description, {attr: {id: 'dlg_ticket_description', class: 'w-full rounded-md border border-border bg-background px-3 py-2 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring', rows: 5}}) }}
        {{ form_errors(form.description) }}
        <div id="dlg-error-description" class="text-xs text-destructive mt-1"></div>
        <div class="flex flex-wrap gap-2 mt-2">
            <button type="button" id="dlg-btn-correct"
                    class="inline-flex items-center gap-1.5 rounded-md border border-blue-500/30 bg-blue-500/10 px-2.5 py-1.5 text-[11px] font-semibold text-blue-700 hover:bg-blue-500/20 transition-colors"
                    title="AI will correct grammar and spelling">
                <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                <span>AI Correct</span>
            </button>
            <button type="button" id="dlg-btn-mic"
                    class="inline-flex items-center gap-1.5 rounded-md border border-red-500/30 bg-red-500/10 px-2.5 py-1.5 text-[11px] font-semibold text-red-700 hover:bg-red-500/20 transition-colors"
                    title="Dictate your description using your microphone">
                <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
                <span>Dictate</span>
            </button>
        </div>
    </div>

    {{ form_rest(form) }}

    <div class="flex justify-end gap-3 pt-2 border-t border-border">
        <button type="button" @click="$dispatch('close-edit-dialog')"
                class="inline-flex h-9 items-center rounded-md border border-border bg-background px-4 text-sm font-medium text-muted-foreground hover:bg-muted/50 transition-colors">
            Cancel
        </button>
        <button type="submit"
                class="inline-flex h-9 items-center rounded-md bg-primary px-4 text-sm font-semibold text-primary-foreground shadow hover:bg-primary/90 transition-colors">
            {{ ticket ? 'Update Ticket' : 'Create Ticket' }}
        </button>
    </div>
</form>

<script>
(function() {
    var subjectInput = document.getElementById('dlg_ticket_subject');
    var descInput = document.getElementById('dlg_ticket_description');
    var suggestBtn = document.getElementById('dlg-btn-suggest');
    var correctBtn = document.getElementById('dlg-btn-correct');
    var micBtn = document.getElementById('dlg-btn-mic');
    if (!subjectInput || !descInput) return;

    var badWords = ['badword1', 'badword2', 'offensive', 'spam', 'scam', 'hate', 'stupid', 'idiot'];

    function validateField(input, errorId, minLen, label) {
        var errorDiv = document.getElementById(errorId);
        if (!errorDiv) return true;
        var value = input.value.trim();
        var errors = [];
        if (value.length === 0) errors.push(label + ' cannot be empty.');
        else if (value.length < minLen) errors.push(label + ' must be at least ' + minLen + ' characters.');
        var foundBad = badWords.filter(function(w) { return new RegExp('\\b' + w + '\\b', 'i').test(value); });
        if (foundBad.length > 0) errors.push('Please avoid offensive language: ' + foundBad.join(', '));
        if (label === 'Subject' && value.length > 0 && !/[a-zA-Z]/.test(value)) errors.push('Subject must contain at least one letter.');
        if (errors.length > 0) {
            errorDiv.innerHTML = errors.map(function(e) { return '<p>' + e + '</p>'; }).join('');
            input.classList.add('border-destructive');
            return false;
        }
        errorDiv.innerHTML = '';
        input.classList.remove('border-destructive');
        return true;
    }

    subjectInput.addEventListener('input', function() { validateField(subjectInput, 'dlg-error-subject', 4, 'Subject'); });
    descInput.addEventListener('input', function() { validateField(descInput, 'dlg-error-description', 10, 'Description'); });

    // AI Suggest Subject
    if (suggestBtn) suggestBtn.addEventListener('click', function() {
        var desc = descInput.value;
        if (!desc || desc.trim().length < 10) { alert('Please write a description first (at least 10 characters).'); return; }
        suggestBtn.querySelector('span').textContent = 'Analyzing…';
        suggestBtn.disabled = true;
        suggestBtn.classList.add('opacity-50', 'pointer-events-none');

        fetch('{{ path("support_ai_suggest_subject") }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            body: JSON.stringify({ description: desc })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.suggestion) { subjectInput.value = data.suggestion.replace(/^"|"$/g, ''); validateField(subjectInput, 'dlg-error-subject', 4, 'Subject'); }
            else alert(data.error || 'Could not generate suggestion');
        })
        .catch(function() { alert('AI suggestion failed'); })
        .finally(function() { suggestBtn.querySelector('span').textContent = 'AI Suggest'; suggestBtn.disabled = false; suggestBtn.classList.remove('opacity-50', 'pointer-events-none'); });
    });

    // AI Correct Text
    if (correctBtn) correctBtn.addEventListener('click', function() {
        if (!descInput.value || descInput.value.trim().length < 5) { alert('Please write some text first.'); return; }
        correctBtn.querySelector('span').textContent = 'Polishing…';
        correctBtn.disabled = true;
        correctBtn.classList.add('opacity-50', 'pointer-events-none');

        fetch('{{ path("support_ai_correct_text") }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            body: JSON.stringify({ text: descInput.value })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.correction) { descInput.value = data.correction; validateField(descInput, 'dlg-error-description', 10, 'Description'); }
            else alert(data.error || 'Could not correct text');
        })
        .catch(function() { alert('AI correction failed'); })
        .finally(function() { correctBtn.querySelector('span').textContent = 'AI Correct'; correctBtn.disabled = false; correctBtn.classList.remove('opacity-50', 'pointer-events-none'); });
    });

    // Speech-to-Text
    if (micBtn) {
        if (!('webkitSpeechRecognition' in window) && !('SpeechRecognition' in window)) { micBtn.style.display = 'none'; return; }
        var SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        var recognition = new SpeechRecognition();
        recognition.continuous = true; recognition.interimResults = true; recognition.lang = 'en-US';
        var isRecording = false;

        micBtn.addEventListener('click', function() { if (isRecording) { recognition.stop(); return; } recognition.start(); });
        recognition.onstart = function() { isRecording = true; micBtn.classList.remove('border-red-500/30', 'bg-red-500/10'); micBtn.classList.add('border-red-500', 'bg-red-500/30', 'animate-pulse'); micBtn.querySelector('span').textContent = 'Listening…'; };
        recognition.onresult = function(event) {
            var finalTranscript = '';
            for (var i = event.resultIndex; i < event.results.length; ++i) { if (event.results[i].isFinal) finalTranscript += event.results[i][0].transcript; }
            if (finalTranscript) { var cur = descInput.value; descInput.value = cur + (cur.endsWith(' ') || cur === '' ? '' : ' ') + finalTranscript; validateField(descInput, 'dlg-error-description', 10, 'Description'); }
        };
        recognition.onerror = function(event) { resetMic(); if (event.error !== 'no-speech') alert('Microphone error: ' + event.error); };
        recognition.onend = function() { resetMic(); };
        function resetMic() { isRecording = false; micBtn.classList.add('border-red-500/30', 'bg-red-500/10'); micBtn.classList.remove('border-red-500', 'bg-red-500/30', 'animate-pulse'); micBtn.querySelector('span').textContent = 'Dictate'; }
    }
})();
</script>
