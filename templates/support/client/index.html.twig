{% extends 'base.html.twig' %}

{% block title %}My Support Tickets · Skilora{% endblock %}

{% block html_class %}dark{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* Same tokens as support/client/show.html.twig */
        :root {
            --chat-bg: #09090b;
            --panel-raised: #18181b;
            --panel-raised2: #27272a;
            --panel-edge: rgba(255,255,255,0.06);
            --accent-glow: rgba(108,99,255,0.12);
            --text-bright: #fafafa;
            --text-body: #d4d4d8;
            --text-muted-light: #a1a1aa;
            --text-muted-dark: #71717a;
        }

        .support-shell { background: var(--chat-bg); min-height: 100vh; padding-top: 96px; }

        .support-hero {
            background: var(--panel-raised);
            border: 1px solid var(--panel-edge);
            border-radius: 20px;
            padding: 28px 32px;
            position: relative;
            overflow: hidden;
            margin-bottom: 24px;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.55);
        }
        .support-hero::before {
            content: '';
            position: absolute;
            top: -80px;
            right: -80px;
            width: 220px;
            height: 220px;
            background: var(--accent-glow);
            border-radius: 50%;
            filter: blur(56px);
            pointer-events: none;
        }
        .hero-label {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--text-muted-light);
            margin-bottom: 6px;
        }
        .hero-title {
            font-size: 24px;
            font-weight: 800;
            color: var(--text-bright);
            margin-bottom: 4px;
        }
        .hero-sub { font-size: 13.5px; color: var(--text-body); }

        .filter-pills { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 18px; }
        .fp {
            padding: 6px 16px;
            border-radius: 999px;
            border: 1px solid var(--panel-edge);
            background: var(--panel-raised2);
            color: var(--text-muted-light);
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: all .2s;
        }
        .fp:hover { border-color: rgba(255,255,255,.15); color: var(--text-bright); }
        .fp.active {
            background: #fafafa;
            border-color: #fafafa;
            color: #09090b;
        }

        .btn-new {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 10px 20px;
            border-radius: 999px;
            background: #fafafa;
            color: #09090b;
            font-size: 13px;
            font-weight: 700;
            text-decoration: none;
            box-shadow: 0 10px 40px rgba(0,0,0,.45);
            transition: opacity .2s, transform .15s;
        }
        .btn-new:hover { opacity: .95; transform: translateY(-1px); }

        .tickets-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(310px, 1fr));
            gap: 16px;
        }

        .ticket-card {
            background: var(--panel-raised);
            border: 1px solid var(--panel-edge);
            border-radius: 20px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: transform .25s, border-color .25s, box-shadow .25s;
            animation: cardIn .35s ease both;
        }
        .ticket-card:hover {
            transform: translateY(-4px);
            border-color: rgba(255,255,255,.12);
            box-shadow: 0 20px 50px rgba(0,0,0,.5);
        }
        @keyframes cardIn { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }

        .card-accent-bar { height: 3px; background: linear-gradient(90deg, #52525b, #71717a, #a1a1aa); }
        .card-body { padding: 18px 20px; flex: 1; display: flex; flex-direction: column; gap: 10px; }
        .card-subject { font-size: 15px; font-weight: 700; color: var(--text-bright); line-height: 1.4; word-break: break-word; }
        .card-desc {
            font-size: 12.5px;
            color: var(--text-body);
            line-height: 1.5;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .card-badges { display: flex; flex-wrap: wrap; gap: 6px; }
        .cbadge {
            padding: 3px 10px;
            border-radius: 999px;
            font-size: 10.5px;
            font-weight: 700;
            letter-spacing: .04em;
        }
        .cbadge-cat  { background: rgba(139,92,246,.12); color: #c4b5fd; border: 1px solid rgba(139,92,246,.25); }
        .cbadge-prio { background: rgba(245,158,11,.12); color: #fcd34d; border: 1px solid rgba(245,158,11,.25); }
        .cbadge-open     { background: rgba(34,197,94,.12); color: #4ade80; border: 1px solid rgba(34,197,94,.25); }
        .cbadge-progress { background: rgba(59,130,246,.12); color: #93c5fd; border: 1px solid rgba(59,130,246,.25); }
        .cbadge-closed   { background: rgba(113,113,122,.2); color: #d4d4d8; border: 1px solid rgba(255,255,255,.1); }
        .cbadge-resolved { background: rgba(16,185,129,.12); color: #6ee7b7; border: 1px solid rgba(16,185,129,.25); }

        .card-date { font-size: 11px; color: var(--text-muted-dark); margin-top: auto; }

        .card-footer {
            padding: 14px 20px;
            border-top: 1px solid var(--panel-edge);
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--panel-raised2);
        }
        .btn-view {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 9px 14px;
            border-radius: 10px;
            background: rgba(255,255,255,.08);
            border: 1px solid var(--panel-edge);
            color: var(--text-bright);
            font-size: 12px;
            font-weight: 700;
            text-decoration: none;
            transition: all .2s;
        }
        .btn-view:hover { background: rgba(255,255,255,.12); border-color: rgba(255,255,255,.15); }
        .btn-edit-sm {
            display: flex;
            align-items: center;
            gap: 4px;
            padding: 9px 12px;
            border-radius: 10px;
            border: 1px solid var(--panel-edge);
            background: transparent;
            color: var(--text-muted-light);
            font-size: 12px;
            font-weight: 600;
            text-decoration: none;
            transition: all .2s;
        }
        .btn-edit-sm:hover { border-color: rgba(255,255,255,.2); color: var(--text-bright); }
        .btn-del-sm {
            display: flex;
            align-items: center;
            gap: 4px;
            padding: 9px 12px;
            border-radius: 10px;
            border: none;
            background: transparent;
            color: var(--text-muted-dark);
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: all .2s;
        }
        .btn-del-sm:hover { color: #fca5a5; background: rgba(127,29,29,.35); }

        .empty-state {
            grid-column: 1 / -1;
            text-align: center;
            padding: 60px 20px;
            background: var(--panel-raised);
            border: 1px dashed var(--panel-edge);
            border-radius: 20px;
            color: var(--text-muted-light);
        }
        .empty-state svg { opacity: .25; margin: 0 auto 16px; display: block; color: var(--text-muted-light); }
        .empty-state p { font-size: 14px; }
        .empty-state strong { color: var(--text-bright); font-weight: 700; }
    </style>
{% endblock %}

{% block body %}
{% include 'home/sections/_header.html.twig' %}

<div class="support-shell">
    <div class="mx-auto w-full max-w-6xl px-4 pb-12" x-data="{ filter: 'ALL' }">

        {# Hero bar #}
        <div class="support-hero">
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom: 24px;">
                <div>
                    <p class="hero-label">Support Center</p>
                    <h1 class="hero-title">My Tickets</h1>
                    <p class="hero-sub">Create, manage, and track your support requests in real time.</p>
                </div>
                <a href="{{ path('support_new') }}" class="btn-new">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 5v14m-7-7h14"/></svg>
                    New Ticket
                </a>
            </div>

            <div style="display:flex; flex-wrap:wrap; align-items:center; gap:20px; padding-top: 20px; border-top: 1px solid var(--panel-edge);">
                <div class="filter-pills" style="margin-top:0;">
                    <button class="fp" :class="filter==='ALL'?'active':''" @click="filter='ALL'">All</button>
                    <button class="fp" :class="filter==='OPEN'?'active':''" @click="filter='OPEN'">Open</button>
                    <button class="fp" :class="filter==='IN_PROGRESS'?'active':''" @click="filter='IN_PROGRESS'">In Progress</button>
                    <button class="fp" :class="filter==='CLOSED'?'active':''" @click="filter='CLOSED'">Closed</button>
                    <button class="fp" :class="filter==='RESOLVED'?'active':''" @click="filter='RESOLVED'">Resolved</button>
                </div>
                
                <div style="flex:1; min-width:300px; position:relative;">
                    <svg class="absolute left-4 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                    <input type="text" id="clientSearch" oninput="doSearch()" placeholder="Search by subject, category, or description..." 
                           class="w-full bg-black/40 border border-white/5 rounded-2xl py-3 pl-11 pr-4 text-[13px] text-white outline-none focus:border-white/20 focus:ring-4 focus:ring-white/5 transition-all shadow-inner"
                           value="{{ search_query }}">
                </div>
            </div>
        </div>

        {# Grid Wrapper for AJAX #}
        <div id="tickets-grid-wrapper">
            {% include 'support/client/_ticket_grid.html.twig' %}
        </div>

    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        let searchTimeout;
        function doSearch() {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => {
                const query = document.getElementById('clientSearch').value;
                const wrapper = document.getElementById('tickets-grid-wrapper');
                
                wrapper.style.opacity = '0.4';
                
                fetch(`{{ path('support_index') }}?q=${query}`, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(res => res.text())
                .then(html => {
                    wrapper.innerHTML = html;
                    wrapper.style.opacity = '1';
                });
            }, 300);
        }
    </script>
{% endblock %}
