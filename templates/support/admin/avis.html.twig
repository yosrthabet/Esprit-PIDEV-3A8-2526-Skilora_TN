{% extends 'layouts/app.html.twig' %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        function changeAvisPage(page) {
            fetch(`{{ path('admin_support_avis_index') }}?page=${page}`, {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
            .then(res => res.text())
            .then(html => {
                document.getElementById('avis-grid-wrapper').innerHTML = html;
            });
        }

        document.addEventListener('DOMContentLoaded', () => {
            const ctxDist = document.getElementById('ratingDistChart').getContext('2d');
            new Chart(ctxDist, {
                type: 'bar',
                data: {
                    labels: ['1★', '2★', '3★', '4★', '5★'],
                    datasets: [{
                        label: 'Reviews',
                        data: Object.values({{ rating_dist|json_encode|raw }}),
                        backgroundColor: '#10b981',
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    indexAxis: 'y',
                    scales: { x: { beginAtZero: true, grid: { display: false } }, y: { grid: { display: false } } },
                    plugins: { legend: { display: false } }
                }
            });
        });
    </script>
{% endblock %}

{% block content %}
<div class="mx-auto w-full max-w-7xl space-y-6">
    {# Header Banner #}
    <div class="rounded-3xl border border-border/70 bg-gradient-to-r from-emerald-500/10 via-card to-card p-6 shadow-sm">
        <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
                <p class="text-xs font-semibold uppercase tracking-wide text-emerald-500">Service Evaluation</p>
                <h2 class="mt-1 text-2xl font-bold tracking-tight">Customer Feedback</h2>
                <p class="mt-2 text-sm text-muted-foreground">Monitor client satisfaction and support ratings across all resolved tickets.</p>
            </div>
            
            <div class="flex items-center gap-4">
                <div class="flex flex-col items-end">
                    <span class="text-xs font-semibold uppercase tracking-wide text-muted-foreground">Average Rating</span>
                    <div class="flex items-center gap-1 mt-1">
                        <span class="text-2xl font-bold text-emerald-400">{{ avg_rating|number_format(1) }}</span>
                        <svg class="h-5 w-5 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Feedbacks Grid #}
    <div id="avis-grid-wrapper">
        {% include 'support/admin/_avis_grid.html.twig' %}
    </div>

    {# Analytics Section below grid #}
    <div class="rounded-3xl border border-border bg-card p-8 shadow-sm">
        <h4 class="text-lg font-bold mb-2">Rating Distribution</h4>
        <p class="text-sm text-muted-foreground mb-8">Comprehensive breakdown of customer satisfaction scores.</p>
        <div style="height: 300px; width: 100%;">
            <canvas id="ratingDistChart"></canvas>
        </div>
    </div>
</div>
{% endblock %}
