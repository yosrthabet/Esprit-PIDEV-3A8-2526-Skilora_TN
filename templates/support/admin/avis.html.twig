{% extends 'layouts/app.html.twig' %}

{% block page_title %}Customer Feedback & Avis{% endblock %}

{% block content %}
<div class="mx-auto w-full max-w-7xl space-y-6">
    {# Header Banner #}
    <div class="rounded-3xl border border-border/70 bg-gradient-to-r from-emerald-500/10 via-card to-card p-6 shadow-sm">
        <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
                <p class="text-xs font-semibold uppercase tracking-wide text-emerald-500">Service Evaluation</p>
                <h2 class="mt-1 text-2xl font-bold tracking-tight">Customer Feedback</h2>
                <p class="mt-2 text-sm text-muted-foreground">Monitor client satisfaction and support ratings across all resolved tickets.</p>
            </div>
            
            <div class="flex items-center gap-4">
                <div class="flex flex-col items-end">
                    <span class="text-xs font-semibold uppercase tracking-wide text-muted-foreground">Average Rating</span>
                    <div class="flex items-center gap-1 mt-1">
                        <span class="text-2xl font-bold text-emerald-400">{{ avg_rating|number_format(1) }}</span>
                        <svg class="h-5 w-5 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Feedbacks Grid #}
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {% for feedback in feedbacks %}
            <div class="rounded-2xl border border-border bg-card shadow-sm transition hover:-translate-y-1 hover:shadow-md hover:border-emerald-500/30 flex flex-col">
                {# Card Header #}
                <div class="flex items-start justify-between border-b border-border/70 p-5 bg-muted/20">
                    <div>
                        <div class="flex items-center gap-2">
                            <span class="rounded-full bg-primary/10 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-primary">
                                Ticket #{{ feedback.ticket.id }}
                            </span>
                            <span class="text-xs text-muted-foreground">
                                • Client #{{ feedback.ticket.utilisateurId }}
                            </span>
                        </div>
                        <p class="mt-1 text-xs text-muted-foreground">{{ feedback.dateCreation|date('M d, Y · H:i') }}</p>
                    </div>
                    <a href="{{ path('admin_support_show', {id: feedback.ticket.id}) }}" class="text-xs font-semibold text-primary hover:text-emerald-400 transition-colors">
                        View Ticket &rarr;
                    </a>
                </div>
                
                {# Card Body #}
                <div class="p-5 flex-1 flex flex-col">
                    {# Stars #}
                    <div class="flex gap-1 mb-4">
                        {% for i in 1..5 %}
                            <svg class="h-5 w-5 {{ i <= feedback.rating ? 'text-yellow-400' : 'text-zinc-700' }}" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                            </svg>
                        {% endfor %}
                    </div>
                    
                    {# Comment #}
                    {% if feedback.comment %}
                        <p class="text-sm text-muted-foreground leading-relaxed italic">
                            "{{ feedback.comment }}"
                        </p>
                    {% else %}
                        <p class="text-sm text-zinc-600 italic">No comment provided.</p>
                    {% endif %}
                </div>
            </div>
        {% else %}
            <div class="col-span-full rounded-2xl border border-dashed border-border p-12 text-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-4 text-muted-foreground/50"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                <h3 class="mt-2 text-lg font-semibold text-foreground">No Feedback Yet</h3>
                <p class="mt-1 text-sm text-muted-foreground">Clients haven't left any reviews on their resolved tickets yet.</p>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
