<div id="avis-grid-container">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {% for feedback in feedbacks %}
            <div class="group relative rounded-3xl border border-border/60 bg-gradient-to-b from-card to-muted/10 p-6 shadow-sm transition-all hover:shadow-md hover:border-emerald-500/40 flex flex-col justify-between overflow-hidden">
                <div class="absolute right-0 top-0 h-16 w-16 opacity-[0.03] group-hover:opacity-10 transition-opacity">
                    <svg class="h-full w-full rotate-12" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                </div>
                <div>
                    <div class="flex items-start justify-between mb-4 relative z-10">
                        <div class="flex flex-col gap-1.5">
                            {% if feedback.ticket %}
                                <a href="{{ path('admin_support_show', {id: feedback.ticket.id}) }}" class="inline-flex items-center gap-1.5 rounded-full bg-emerald-500/10 px-2.5 py-1 hover:bg-emerald-500/20 transition-colors">
                                    <span class="text-[10px] font-bold uppercase tracking-wider text-emerald-600 dark:text-emerald-400">
                                        Ref #{{ feedback.ticket.id }}
                                    </span>
                                </a>
                            {% else %}
                                <span class="inline-flex items-center rounded-full bg-muted px-2.5 py-1">
                                    <span class="text-[10px] font-bold uppercase tracking-wider text-muted-foreground">General</span>
                                </span>
                            {% endif %}
                            <div class="flex items-center text-xs text-muted-foreground font-medium pl-1 gap-1">
                                <svg class="w-3.5 h-3.5 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                                Client ID: <span class="text-foreground">{{ feedback.ticket ? feedback.ticket.userId : 'N/A' }}</span>
                            </div>
                        </div>
                        <div class="text-right text-xs text-muted-foreground/80 font-medium">
                            {{ feedback.createdDate|date('M d, Y') }}<br>
                            {{ feedback.createdDate|date('H:i') }}
                        </div>
                    </div>
                    
                    <div class="flex gap-1 mb-4 relative z-10">
                        {% for i in 1..5 %}
                            <svg class="h-4 w-4 {{ i <= feedback.rating ? 'text-amber-400' : 'text-muted-foreground/30' }} transition-colors" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                            </svg>
                        {% endfor %}
                    </div>
                    
                    {% if feedback.comment %}
                        <p class="text-sm text-foreground/90 leading-relaxed font-medium relative z-10 italic">
                            "{{ feedback.comment }}"
                        </p>
                    {% else %}
                        <p class="text-sm text-muted-foreground/60 italic relative z-10">Rating submitted without comment.</p>
                    {% endif %}
                </div>
            </div>
        {% else %}
            <div class="col-span-full flex flex-col items-center justify-center rounded-3xl border border-dashed border-border/80 bg-muted/5 py-24 text-center">
                <div class="h-16 w-16 rounded-full bg-emerald-500/10 text-emerald-500 flex items-center justify-center mb-4">
                    <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
                </div>
                <h3 class="text-lg font-bold">No Feedback Available</h3>
                <p class="text-sm text-muted-foreground mt-1 max-w-md">There are currently no customer evaluations matching your query. Check back after more tickets are resolved.</p>
            </div>
        {% endfor %}
    </div>

    {# Pagination #}
    {% if total_pages > 1 %}
        <div class="mt-8 flex items-center justify-between border-t border-border/70 pt-6 px-2">
            <p class="text-xs font-medium text-muted-foreground">Page <span class="font-bold text-foreground">{{ current_page }}</span> of <span class="font-bold border px-1 rounded-sm">{{ total_pages }}</span></p>
            <div class="flex gap-2">
                {% if current_page > 1 %}
                    <button onclick="changeAvisPage({{ current_page - 1 }})" class="rounded-xl flex items-center justify-center border border-border px-3 py-1.5 text-xs font-semibold hover:bg-muted shadow-sm transition-colors text-foreground gap-1"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg> Prev</button>
                {% endif %}
                {% if current_page < total_pages %}
                    <button onclick="changeAvisPage({{ current_page + 1 }})" class="rounded-xl flex items-center justify-center border border-border px-3 py-1.5 text-xs font-semibold hover:bg-muted shadow-sm transition-colors text-foreground gap-1">Next <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></button>
                {% endif %}
            </div>
        </div>
    {% endif %}
</div>
