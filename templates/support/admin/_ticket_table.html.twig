<div id="ticket-table-container">
    <div class="overflow-x-auto">
        <table class="min-w-full table-fixed divide-y divide-border text-sm">
            <thead class="bg-muted/40 text-xs uppercase tracking-wide text-muted-foreground">
            <tr>
                <th class="w-[34%] px-5 py-3 text-left font-medium">Subject</th>
                <th class="w-[14%] px-5 py-3 text-left font-medium">Client</th>
                <th class="w-[14%] px-5 py-3 text-left font-medium">Priority</th>
                <th class="w-[16%] px-5 py-3 text-left font-medium">Status</th>
                <th class="w-[16%] px-5 py-3 text-left font-medium">Created</th>
                <th class="w-[6%] px-5 py-3 text-right font-medium">Action</th>
            </tr>
            </thead>
            <tbody class="divide-y divide-border">
            {% for ticket in tickets %}
                <tr class="transition hover:bg-muted/30">
                    <td class="px-5 py-4 align-top">
                        <p class="line-clamp-1 font-semibold leading-tight">{{ ticket.subject }}</p>
                        <p class="mt-1 text-xs text-muted-foreground">{{ ticket.categorie|title }}</p>
                    </td>
                    <td class="px-5 py-4 align-top text-muted-foreground">Client #{{ ticket.utilisateurId }}</td>
                    <td class="px-5 py-4 align-top">
                        <span class="rounded-full px-2.5 py-1 text-xs font-semibold
                            {{ ticket.priorite == 'URGENT' ? 'bg-red-500/15 text-red-600 dark:text-red-400' :
                               (ticket.priorite == 'HIGH' ? 'bg-orange-500/15 text-orange-600 dark:text-orange-400' :
                               (ticket.priorite == 'MEDIUM' ? 'bg-blue-500/15 text-blue-600 dark:text-blue-400' : 'bg-emerald-500/15 text-emerald-600 dark:text-emerald-400')) }}">
                            {{ ticket.priorite|title }}
                        </span>
                    </td>
                    <td class="px-5 py-4 align-top">
                        <span class="rounded-full px-2.5 py-1 text-xs font-semibold
                            {{ ticket.statut in ['RESOLVED', 'CLOSED'] ? 'bg-emerald-500/15 text-emerald-600 dark:text-emerald-400' :
                               (ticket.statut == 'IN_PROGRESS' ? 'bg-blue-500/15 text-blue-600 dark:text-blue-400' : 'bg-zinc-500/15 text-zinc-600 dark:text-zinc-300') }}">
                            {{ ticket.statut|replace({'_': ' '}) }}
                        </span>
                    </td>
                    <td class="px-5 py-4 align-top text-muted-foreground">{{ ticket.dateCreation ? ticket.dateCreation|date('d M Y, H:i') : '-' }}</td>
                    <td class="px-5 py-4 align-top text-right">
                        <a href="{{ path('admin_support_show', {id: ticket.id}) }}"
                           class="inline-flex items-center gap-1 rounded-lg border border-border px-3 py-1.5 text-xs font-semibold hover:bg-accent">
                            Open
                        </a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="px-5 py-12 text-center text-sm text-muted-foreground">No tickets in database.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    {# Pagination #}
    {% if total_pages > 1 %}
        <div class="flex items-center justify-between border-t border-border/70 px-5 py-4">
            <p class="text-xs text-muted-foreground">Page {{ current_page }} of {{ total_pages }}</p>
            <div class="flex gap-2">
                {% if current_page > 1 %}
                    <button onclick="changeTicketPage({{ current_page - 1 }})" class="rounded-lg border border-border px-3 py-1.5 text-xs font-semibold hover:bg-accent">Previous</button>
                {% endif %}
                {% if current_page < total_pages %}
                    <button onclick="changeTicketPage({{ current_page + 1 }})" class="rounded-lg border border-border px-3 py-1.5 text-xs font-semibold hover:bg-accent">Next</button>
                {% endif %}
            </div>
        </div>
    {% endif %}
</div>
