{% extends 'layouts/app.html.twig' %}

{% block page_title %}Support Admin{% endblock %}

{% block content %}
<div class="mx-auto w-full max-w-7xl space-y-6">
    <div class="rounded-3xl border border-border/70 bg-gradient-to-r from-primary/10 via-card to-card p-6 shadow-sm">
        <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
                <p class="text-xs font-semibold uppercase tracking-wide text-primary">Support Control Center</p>
                <h2 class="mt-1 text-2xl font-bold tracking-tight">Ticket Operations Dashboard</h2>
                <p class="mt-2 text-sm text-muted-foreground">Track priority, status, and SLA flow in one place.</p>
            </div>
            <span class="rounded-full border border-primary/20 bg-primary/10 px-3 py-1 text-xs font-semibold text-primary">
                {{ tickets|length }} active records
            </span>
        </div>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-2xl border border-border bg-card p-4 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
            <p class="text-xs uppercase tracking-wide text-muted-foreground">Open</p>
            <p class="mt-2 text-3xl font-bold">{{ status_stats['OPEN']|default(0) }}</p>
        </div>
        <div class="rounded-2xl border border-border bg-card p-4 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
            <p class="text-xs uppercase tracking-wide text-muted-foreground">In Progress</p>
            <p class="mt-2 text-3xl font-bold">{{ status_stats['IN_PROGRESS']|default(0) }}</p>
        </div>
        <div class="rounded-2xl border border-border bg-card p-4 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
            <p class="text-xs uppercase tracking-wide text-muted-foreground">Resolved</p>
            <p class="mt-2 text-3xl font-bold">{{ status_stats['RESOLVED']|default(0) }}</p>
        </div>
        <a href="{{ path('admin_support_avis_index') }}" class="block rounded-2xl border border-border bg-card p-4 shadow-sm transition hover:-translate-y-0.5 hover:-translate-x-0.5 hover:shadow-md hover:border-emerald-500/40 focus:outline-none focus:ring-2 focus:ring-emerald-500/40">
            <div class="flex justify-between items-center">
                <p class="text-xs uppercase tracking-wide text-muted-foreground">Average Satisfaction</p>
                <span class="text-[10px] uppercase font-bold text-emerald-500 tracking-wider">View All &rarr;</span>
            </div>
            <p class="mt-2 text-3xl font-bold">{{ avg_rating|number_format(2) }}<span class="text-base font-medium text-muted-foreground">/5</span></p>
        </a>
    </div>

    <div class="overflow-hidden rounded-3xl border border-border bg-card shadow-sm">
        <div class="border-b border-border/70 px-5 py-4">
            <h3 class="text-base font-semibold">Ticket Queue</h3>
            <p class="text-xs text-muted-foreground">Prioritize urgent requests and route them quickly.</p>
        </div>
        <div class="overflow-x-auto">
        <table class="min-w-full table-fixed divide-y divide-border text-sm">
            <thead class="bg-muted/40 text-xs uppercase tracking-wide text-muted-foreground">
            <tr>
                <th class="w-[34%] px-5 py-3 text-left font-medium">Subject</th>
                <th class="w-[14%] px-5 py-3 text-left font-medium">Client</th>
                <th class="w-[14%] px-5 py-3 text-left font-medium">Priority</th>
                <th class="w-[16%] px-5 py-3 text-left font-medium">Status</th>
                <th class="w-[16%] px-5 py-3 text-left font-medium">Created</th>
                <th class="w-[6%] px-5 py-3 text-right font-medium">Action</th>
            </tr>
            </thead>
            <tbody class="divide-y divide-border">
            {% for ticket in tickets %}
                <tr class="transition hover:bg-muted/30">
                    <td class="px-5 py-4 align-top">
                        <p class="line-clamp-1 font-semibold leading-tight">{{ ticket.subject }}</p>
                        <p class="mt-1 text-xs text-muted-foreground">{{ ticket.categorie|title }}</p>
                    </td>
                    <td class="px-5 py-4 align-top text-muted-foreground">Client #{{ ticket.utilisateurId }}</td>
                    <td class="px-5 py-4 align-top">
                        <span class="rounded-full px-2.5 py-1 text-xs font-semibold
                            {{ ticket.priorite == 'URGENT' ? 'bg-red-500/15 text-red-600 dark:text-red-400' :
                               (ticket.priorite == 'HIGH' ? 'bg-orange-500/15 text-orange-600 dark:text-orange-400' :
                               (ticket.priorite == 'MEDIUM' ? 'bg-blue-500/15 text-blue-600 dark:text-blue-400' : 'bg-emerald-500/15 text-emerald-600 dark:text-emerald-400')) }}">
                            {{ ticket.priorite|title }}
                        </span>
                    </td>
                    <td class="px-5 py-4 align-top">
                        <span class="rounded-full px-2.5 py-1 text-xs font-semibold
                            {{ ticket.statut in ['RESOLVED', 'CLOSED'] ? 'bg-emerald-500/15 text-emerald-600 dark:text-emerald-400' :
                               (ticket.statut == 'IN_PROGRESS' ? 'bg-blue-500/15 text-blue-600 dark:text-blue-400' : 'bg-zinc-500/15 text-zinc-600 dark:text-zinc-300') }}">
                            {{ ticket.statut|replace({'_': ' '}) }}
                        </span>
                    </td>
                    <td class="px-5 py-4 align-top text-muted-foreground">{{ ticket.dateCreation ? ticket.dateCreation|date('d M Y, H:i') : '-' }}</td>
                    <td class="px-5 py-4 align-top text-right">
                        <a href="{{ path('admin_support_show', {id: ticket.id}) }}"
                           class="inline-flex items-center gap-1 rounded-lg border border-border px-3 py-1.5 text-xs font-semibold hover:bg-accent">
                            Open
                        </a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="px-5 py-12 text-center text-sm text-muted-foreground">No tickets in database.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        </div>
    </div>
</div>
{% endblock %}
