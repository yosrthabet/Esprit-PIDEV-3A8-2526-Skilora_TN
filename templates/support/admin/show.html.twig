{% extends 'layouts/app.html.twig' %}

{% block page_title %}Ticket #{{ ticket.id }} · {{ ticket.subject }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* Premium Dark Theme ported from client site */
        :root {
            --panel-raised: #ffffff;
            --panel-raised2: #f8fafc;
            --panel-edge: rgba(0,0,0,0.08);
            --card-dark: #ffffff;
            --border-light: #e2e8f0;
            --border-dark: rgba(0,0,0,0.1);
            --text-bright: #0f172a;
            --text-body: #334155;
            --text-muted-light: #64748b;
            --text-muted-dark: #94a3b8;
            --accent-glow: rgba(99,102,241,0.05);
            --msg-scroll-bg: #f8fafc;
        }

        /* ONLY apply dark variables when the .dark class is explicitly present */
        .dark, [data-theme='dark'] {
            --panel-raised: #181b1e;
            --panel-raised2: #212529;
            --panel-edge: rgba(255,255,255,0.06);
            --card-dark: #181b1e;
            --border-light: #3f3f46;
            --border-dark: rgba(255,255,255,0.08);
            --text-bright: #fafafa;
            --text-body: #d4d4d8;
            --text-muted-light: #a1a1aa;
            --text-muted-dark: #71717a;
            --accent-glow: rgba(108,99,255,0.12);
            --msg-scroll-bg: #09090b;
        }

        .admin-support-layout {
            display: grid;
            grid-template-columns: 1fr 340px;
            gap: 24px;
            align-items: start;
        }

        @media (max-width: 1024px) {
            .admin-support-layout {
                grid-template-columns: 1fr;
            }
        }

        .admin-card {
            background: var(--panel-raised);
            border: 1px solid var(--panel-edge);
            border-radius: 16px;
            box-shadow: 0 10px 30px -10px rgba(0,0,0,0.5);
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .admin-card-header {
            padding: 20px 24px;
            border-bottom: 1px solid var(--panel-edge);
            background: var(--panel-raised2);
        }

        .admin-card-body {
            padding: 24px;
        }

        /* ── Ticket Detail Header ── */
        .ticket-header {
            background: var(--panel-raised);
            border: 1px solid var(--panel-edge);
            border-radius: 16px;
            padding: 24px;
            margin-bottom: 24px;
            position: relative;
        }
        .th-title {
            font-size: 20px;
            font-weight: 700;
            color: var(--text-bright);
            margin-bottom: 12px;
        }
        .th-desc {
            font-size: 14px;
            color: var(--text-body);
            line-height: 1.6;
            white-space: pre-wrap;
            word-break: break-word;
        }
        .th-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 16px;
            margin-top: 16px;
            padding-top: 16px;
            border-top: 1px solid var(--panel-edge);
            font-size: 12px;
            color: var(--text-muted-light);
        }
        .th-meta-item { display: flex; align-items: center; gap: 6px; }

        /* ── Conversation Timeline (Chat Bubbles) ── */
        .conv-card {
            background: var(--card-dark);
            border: 1px solid var(--border-dark);
            border-radius: 20px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
            margin-bottom: 24px;
        }
        .messages-scroll {
            max-height: 520px;
            min-height: 320px;
            overflow-y: auto;
            padding: 24px 20px;
            display: flex;
            flex-direction: column;
            gap: 16px;
            background: var(--msg-scroll-bg);
            scrollbar-width: thin;
            scrollbar-color: rgba(0,0,0,.1) transparent;
        }
        .messages-scroll::-webkit-scrollbar { width: 6px; }
        .messages-scroll::-webkit-scrollbar-thumb { background: rgba(0,0,0,.1); border-radius:4px; }
        .dark .messages-scroll::-webkit-scrollbar-thumb { background: rgba(255,255,255,.15); }
        .dark .messages-scroll { scrollbar-color: rgba(255,255,255,.2) transparent; }

        .msg-row { display: flex; align-items: flex-end; gap: 10px; animation: msgSlide .28s ease; }
        .msg-row.admin { flex-direction: row-reverse; } /* Admin is "Me" on the right */
        @keyframes msgSlide { from { opacity:0; transform:translateY(12px); } to { opacity:1; transform:translateY(0); } }

        .msg-avatar {
            width: 30px; height: 30px;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; font-weight: 700;
            flex-shrink: 0;
        }
        .avatar-client { background: #52525b; color: #fafafa; border: 1px solid #71717a; }
        .avatar-admin  { background: #27272a; color: #fafafa; border: 1px solid #3f3f46; }
        .avatar-internal { background: rgba(245, 158, 11, 0.2); color: #fbbf24; border: 1px solid rgba(245, 158, 11, 0.3); }

        .bubble-wrap { max-width: 72%; display: flex; flex-direction: column; gap: 4px; }
        .msg-row.admin .bubble-wrap { align-items: flex-end; }

        .bubble {
            padding: 12px 16px;
            border-radius: 18px;
            font-size: 13.5px;
            line-height: 1.55;
            white-space: pre-wrap;
            word-break: break-word;
            position: relative;
        }
        .bubble-client {
            background: #f1f5f9;
            color: #1e293b;
            border: 1px solid #e2e8f0;
            border-bottom-left-radius: 4px;
        }
        .dark .bubble-client {
            background: #27272a;
            color: #e4e4e7;
            border: 1px solid #3f3f46;
        }
        .bubble-admin {
            background: #0f172a;
            color: #ffffff;
            border: 1px solid #1e293b;
            border-bottom-right-radius: 4px;
            box-shadow: 0 4px 12px rgba(0,0,0,.1);
        }
        .dark .bubble-admin {
            background: #3f3f46;
            color: #fafafa;
            border: 1px solid #52525b;
            box-shadow: 0 8px 24px rgba(0,0,0,.4);
        }
        .bubble-internal {
            background: rgba(245, 158, 11, 0.08);
            color: #fbbf24;
            border: 1px solid rgba(245, 158, 11, 0.25);
            border-bottom-right-radius: 4px;
            box-shadow: 0 8px 24px rgba(245, 158, 11, .1);
        }

        .bubble-meta {
            font-size: 10.5px;
            color: var(--text-muted-dark);
            display: flex; align-items: center; gap: 5px;
            padding: 0 4px;
        }
        .msg-row.admin .bubble-meta { color: #a1a1aa; justify-content: flex-end; }
        .msg-row:not(.admin) .bubble-meta { color: #a1a1aa; }

        .bubble-actions {
            display: flex; align-items: center; gap: 8px;
            margin-top: 4px;
        }
        .msg-row.admin .bubble-actions { justify-content: flex-end; }
        .bact {
            display: inline-flex; align-items: center; gap: 4px;
            font-size: 11px; font-weight: 600;
            padding: 4px 10px; border-radius: 8px;
            border: none; cursor: pointer;
            transition: all .18s;
            text-decoration: none;
        }
        .bact-edit  { background: rgba(0,0,0,.05); color: #475569; border: 1px solid rgba(0,0,0,.1); }
        .bact-edit:hover { background: rgba(0,0,0,.1); }
        .dark .bact-edit  { background: rgba(255,255,255,.08); color: #e4e4e7; border: 1px solid rgba(255,255,255,.12); }
        .dark .bact-edit:hover { background: rgba(255,255,255,.14); }

        .bact-del   { background: rgba(239,68,68,.1); color: #ef4444; border: 1px solid rgba(239,68,68,.2); }
        .bact-del:hover { background: rgba(239,68,68,.2); }
        .dark .bact-del   { background: rgba(127,29,29,.4); color: #fecaca; border: 1px solid rgba(248,113,113,.3); }

        .bact-ai { background: rgba(99,102,241,0.08); color: #4f46e5; border: 1px solid rgba(99,102,241,0.15); }
        .bact-ai:hover { background: rgba(99,102,241,0.15); }
        .dark .bact-ai { background: rgba(108,99,255,0.1); color: #a5b4fc; border: 1px solid rgba(108,99,255,0.2); }

        .bact-mood { background: rgba(168,85,247,0.08); color: #9333ea; border: 1px solid rgba(168,85,247,0.15); }
        .bact-mood:hover { background: rgba(168,85,247,0.15); }
        .dark .bact-mood { background: rgba(168,85,247,0.1); color: #c084fc; border: 1px solid rgba(168,85,247,0.2); }

        .attachment-pill {
            display: inline-flex; align-items: center; gap: 5px;
            margin-top: 8px;
            padding: 5px 10px;
            border-radius: 8px;
            font-size: 11px; font-weight: 600;
        }
        .app-client { background: rgba(0,0,0,.2); color: #d4d4d8; border: 1px solid rgba(255,255,255,.1); }
        .app-admin  { background: #3f3f46; color: #d4d4d8; border: 1px solid #52525b; }
        .app-internal { background: rgba(245, 158, 11, 0.15); color: #fbbf24; border: 1px solid rgba(245, 158, 11, 0.2); }

        /* ── Forms inside Cards ── */
        .form-label-custom {
            display: block; font-size: 11px; font-weight: 700; letter-spacing: .05em;
            text-transform: uppercase; color: var(--text-muted-light); margin-bottom: 6px;
        }
        .form-input-custom {
            width: 100%; background: #ffffff; border: 1px solid var(--panel-edge);
            border-radius: 8px; color: var(--text-bright); font-size: 13.5px;
            padding: 10px 14px; outline: none; transition: border-color .2s;
            font-family: inherit;
        }
        .dark .form-input-custom { background: #0c0c0e; }
        .form-input-custom:focus { border-color: #3b82f6; }
        select.form-input-custom option { background: #ffffff; color: #000; }
        .dark select.form-input-custom option { background: #18181b; color: #fafafa; }

        .btn-custom {
            display: inline-flex; align-items: center; justify-content: center; gap: 6px;
            padding: 10px 16px; border-radius: 8px; font-size: 13px; font-weight: 600;
            cursor: pointer; transition: all .2s; text-decoration: none; border: none;
        }
        .btn-primary { background: #fafafa; color: #09090b; }
        .btn-primary:hover { opacity: .9; }
        
        .btn-secondary { background: rgba(255,255,255,0.08); color: var(--text-bright); border: 1px solid var(--panel-edge); }
        .btn-secondary:hover { background: rgba(255,255,255,0.12); }
        
        .btn-danger { background: rgba(239,68,68,0.1); color: #fca5a5; border: 1px solid rgba(239,68,68,0.2); }
        .btn-danger:hover { background: rgba(239,68,68,0.2); }

        /* ── Specific Reply Form ── */
        .reply-box {
            background: var(--panel-raised);
            border: 1px solid var(--panel-edge);
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }
        .reply-box-header {
            display: flex; gap: 16px; padding: 12px 16px; border-bottom: 1px solid var(--panel-edge);
            background: var(--panel-raised2);
        }
        .reply-tab {
            font-size: 13px; font-weight: 600; color: var(--text-muted-dark); cursor: pointer;
            padding: 4px 12px; border-radius: 6px; transition: all .2s;
        }
        .reply-tab.active { background: #fafafa; color: #09090b; }
        .reply-tab.internal.active { background: rgba(245, 158, 11, 0.2); color: #fbbf24; }

        .reply-body-inner { padding: 16px; display: flex; flex-direction: column; gap: 14px; }
        
        .internal-checkbox-wrap {
            display: flex; align-items: center; gap: 8px;
            padding: 10px 14px; border-radius: 8px;
            background: rgba(245, 158, 11, 0.08); border: 1px solid rgba(245, 158, 11, 0.15);
            margin-bottom: 10px;
        }
        .internal-checkbox-wrap input[type="checkbox"] { accent-color: #f59e0b; width: 16px; height: 16px; }
        .internal-checkbox-wrap label { font-size: 13px; color: #fbbf24; font-weight: 600; cursor: pointer; }
        form ul { list-style: none; padding: 0; margin: 6px 0 0; }
        form ul li { color: #ef4444; font-size: 11.5px; font-weight: 600; display: flex; align-items: center; gap: 5px; }
        form ul li::before { content: "⚠️"; font-size: 10px; }

        /* ── Modal Styles ── */
        .modal-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.85); backdrop-filter: blur(10px);
            display: flex; align-items: center; justify-content: center;
            z-index: 9999; opacity: 0; pointer-events: none;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .modal-overlay.active { opacity: 1; pointer-events: auto; }
        .modal-content {
            background: var(--panel-raised);
            border: 1px solid var(--panel-edge);
            border-radius: 24px;
            width: 100%; max-width: 550px;
            padding: 32px;
            position: relative;
            transform: scale(0.95) translateY(20px);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 50px 100px -20px rgba(0,0,0,0.8);
        }
        .modal-overlay.active .modal-content { transform: scale(1) translateY(0); }
        .modal-close {
            position: absolute; top: 20px; right: 20px;
            background: transparent; border: none; color: var(--text-muted-light);
            cursor: pointer; padding: 8px; border-radius: 50%;
            transition: all 0.2s;
        }
        .modal-close:hover { background: rgba(255,255,255,0.05); color: #fff; }

        .form-icon-btn {
            width: 34px; height: 34px; border-radius: 8px;
            background: var(--panel-raised2); border: 1px solid var(--panel-edge);
            display: flex; align-items: center; justify-content: center; color: #fff;
        }

    </style>
{% endblock %}

{% block content %}
<div class="admin-support-layout">
    
    {# ── LEFT COLUMN: Ticket info, Conversation, and Reply Form ── #}
    <div style="display:flex; flex-direction:column;">
        
        {# Ticket Info block #}
        <div class="ticket-header">
            <div class="flex items-center justify-between">
                <h2 class="th-title">{{ ticket.subject }}</h2>
            <div class="flex items-center gap-2">
                <a href="{{ path('admin_support_download_pdf', {id: ticket.id}) }}" class="btn-custom btn-primary" style="font-size: 11px; padding: 6px 14px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" x2="12" y2="3"/></svg>
                    Print Ticket
                </a>
                <div class="flex items-center gap-2 bg-white/5 p-1 rounded-lg border border-white/10">
                    <select id="targetLanguage" onchange="translateAllMessages()" class="bg-transparent text-[11px] font-bold text-muted-foreground outline-none border-none cursor-pointer px-2">
                        <option value="en">English</option>
                        <option value="fr">French</option>
                        <option value="ar">Arabic</option>
                        <option value="es">Spanish</option>
                        <option value="de">German</option>
                        <option value="it">Italian</option>
                    </select>
                    <button onclick="translateAllMessages()" class="btn-custom btn-secondary" style="font-size: 11px; padding: 6px 12px; border-radius: 6px;">
                        🌍 Translate All
                    </button>
                </div>
            </div>
            </div>
            <div class="th-desc">{{ ticket.description }}</div>
            
            <div class="th-meta">
                <div class="th-meta-item">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    Client #{{ ticket.utilisateurId }}
                </div>
                <div class="th-meta-item">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    Created on {{ ticket.dateCreation ? ticket.dateCreation|date('M d, Y H:i') : '-' }}
                </div>
                {% if ticket.dateResolution %}
                    <div class="th-meta-item text-green-400">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        Resolved on {{ ticket.dateResolution|date('M d, Y H:i') }}
                    </div>
                {% endif %}
            </div>
        </div>

        {# Timeline with Search #}
        <div class="conv-card">
            <div class="flex items-center justify-between border-b border-white/5 px-6 py-3 bg-white/5">
                <span class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Conversation</span>
                <div class="relative">
                    <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 h-3.5 w-3.5 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                    <input type="text" id="msgSearch" oninput="searchMessages()" placeholder="Search messages..." class="rounded-lg border border-white/10 bg-black/20 py-1.5 pl-8 pr-3 text-[11px] outline-none focus:border-white/20" value="{{ search_query }}">
                </div>
            </div>
            <div class="messages-scroll" id="adminMsgScroll">
                <div id="messages-list-wrapper">
                    {% include 'support/admin/_message_list.html.twig' %}
                </div>
            </div>
        </div>

        {# Reply form at the bottom (Zendesk style) #}
        <div class="reply-box" x-data="{ isInternal: false }">
            <div class="reply-box-header">
                <div class="reply-tab" :class="!isInternal ? 'active' : ''" @click="isInternal = false; document.getElementById('isInternalCheckbox').checked = false;">
                    💬 Public Reply
                </div>
                <div class="reply-tab internal" :class="isInternal ? 'active' : ''" @click="isInternal = true; document.getElementById('isInternalCheckbox').checked = true;">
                    🔒 Internal Note
                </div>
            </div>
            
            <div class="reply-body-inner" :style="isInternal ? 'background: rgba(245, 158, 11, 0.03);' : ''">
                {{ form_start(message_form, {attr: {novalidate: 'novalidate'}}) }}
                    
                    <div style="display:none;">
                        {{ form_widget(message_form.isInternal, { id: 'isInternalCheckbox' }) }}
                    </div>
                    
                    <div x-show="isInternal" class="internal-checkbox-wrap" x-transition>
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                        This note will only be visible to other administrators.
                    </div>

                    <div style="margin-bottom:14px;">
                        {{ form_widget(message_form.contenu, {attr: {class: 'form-input-custom', rows: 5, placeholder: 'Type your message here...', style: 'border-color: var(--panel-edge);'}}) }}
                        {{ form_errors(message_form.contenu) }}
                    </div>
                    
                    <div style="margin-bottom:14px;">
                        <label class="form-label-custom">Attachments JSON (Optional)</label>
                        {{ form_widget(message_form.attachmentsJson, {attr: {class: 'form-input-custom', rows: 1, placeholder: '["url1", "url2"]'}}) }}
                        {{ form_errors(message_form.attachmentsJson) }}
                    </div>
                    
                    <div style="display:flex; justify-content:flex-end;">
                        <button type="submit" class="btn-custom btn-primary" :style="isInternal ? 'background: #f59e0b; color: #fff;' : ''">
                            <span x-text="isInternal ? 'Add Internal Note' : 'Send Public Reply'"></span>
                        </button>
                    </div>
                {{ form_end(message_form) }}
            </div>
        </div>

    </div>

    {# ── RIGHT COLUMN: Ticket Properties Sidebar ── #}
    <aside style="position:sticky; top:24px; display:flex; flex-direction:column; gap:24px;">
        
        <div class="admin-card">
            <div class="admin-card-header">
                <h3 style="font-size:14px; font-weight:700; color:var(--text-bright);">Ticket Properties</h3>
            </div>
            <div class="admin-card-body">
                {{ form_start(admin_form, {attr: {style: 'display:flex; flex-direction:column; gap:16px;', novalidate: 'novalidate'}}) }}
                    
                    <div>
                        <label class="form-label-custom">Status</label>
                        {{ form_widget(admin_form.statut, {attr: {class: 'form-input-custom'}}) }}
                        {{ form_errors(admin_form.statut) }}
                    </div>
                    <div style="display:none;">
                        {{ form_widget(admin_form.priorite) }}
                        {{ form_widget(admin_form.agentId) }}
                    </div>

                    <div style="padding-top:8px; border-top:1px solid var(--panel-edge);">
                        <button type="submit" class="btn-custom btn-primary" style="width:100%;">
                            Update Status
                        </button>
                    </div>
                    
                {{ form_end(admin_form) }}
            </div>
        </div>

    </aside>

</div>

{# Admin Edit Message Modal #}
<div id="adminEditModal" class="modal-overlay">
    <div class="modal-content">
        <button class="modal-close" onclick="closeEditModal()">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
        
        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 24px;">
            <div class="form-icon-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            </div>
            <h3 style="font-size: 18px; font-weight: 700; color: #fff;">Modify Support Message</h3>
        </div>

        <form id="adminEditForm" method="POST" style="display:flex; flex-direction:column; gap:18px;">
            <div id="internalWrap" class="internal-checkbox-wrap" style="margin-bottom: 0;">
                <input type="checkbox" id="editIsInternal" name="message_ticket[isInternal]" value="1">
                <label for="editIsInternal">Internal Note (Private to Staff)</label>
            </div>

            <div>
                <label class="form-label-custom">Message Content</label>
