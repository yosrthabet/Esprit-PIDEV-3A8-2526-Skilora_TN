        // Find the best dictionary match for an element's text
        function dictTranslate(text, lang) {
            const dict = TRANSLATIONS[lang];
            if (!dict) return null;
            const trimmed = text.trim();
            if (dict[trimmed]) return dict[trimmed];
            // Partial match for texts that contain a known key
            for (const key in dict) {
                if (trimmed.includes(key) && key.length > 3) {
                    return trimmed.replace(key, dict[key]);
                }
            }
            return null;
        }

        // Translate all interface labels INSTANTLY using dictionary
        function translateInterface(lang) {
            // All translatable elements on the page
            const selectors = [
                '.th-title', '.th-desc',
                '.admin-card-header h3',
                '.form-label-custom',
                '.reply-tab',
                '.bact-edit', '.bact-ai', '.bact-mood', '.bact-del',
                '.btn-custom.btn-primary',
                '.btn-custom.btn-secondary',
                '.internal-checkbox-wrap label',
                '.bubble-meta span',
                '#msgSearch',
                '.modal-content h3',
                '.modal-content .form-label-custom',
                '.modal-content .btn-custom'
            ];

            selectors.forEach(sel => {
                document.querySelectorAll(sel).forEach(el => {
                    const original = el.tagName === 'INPUT' ? el.placeholder : el.innerText;
                    const translated = dictTranslate(original, lang);
                    if (translated) {
                        if (el.tagName === 'INPUT') {
                            el.placeholder = translated;
                        } else {
                            el.innerText = translated;
                        }
                    }
                });
            });

            // Translate the "Conversation" header label
            const convLabel = document.querySelector('.conv-card .uppercase');
            if (convLabel) {
                const t = dictTranslate(convLabel.innerText, lang);
                if (t) convLabel.innerText = t;
            }

            // Translate textarea placeholder
            const textarea = document.querySelector('textarea[placeholder]');
            if (textarea) {
                const t = dictTranslate(textarea.placeholder, lang);
                if (t) textarea.placeholder = t;
            }
        }

        // Translate dynamic content (ticket subject, description, messages) via API
        async function translateDynamicContent(lang) {
            // Translate ticket subject & description via API
            const titleEl = document.querySelector('.th-title');
            const descEl = document.querySelector('.th-desc');

            if (titleEl) {
                titleEl.style.opacity = '0.5';
                try {
                    const res = await fetch(`/admin/support/translate-text?text=${encodeURIComponent(titleEl.innerText.trim())}&target=${lang}`);
                    const data = await res.json();
                    if (data.translated) titleEl.innerText = data.translated;
                } catch(e) {}
                titleEl.style.opacity = '1';
            }

            if (descEl) {
                descEl.style.opacity = '0.5';
                try {
                    const res = await fetch(`/admin/support/translate-text?text=${encodeURIComponent(descEl.innerText.trim())}&target=${lang}`);
                    const data = await res.json();
                    if (data.translated) descEl.innerText = data.translated;
                } catch(e) {}
                descEl.style.opacity = '1';
            }

            // Then translate all messages
            const buttons = document.querySelectorAll('.bact-ai');
            buttons.forEach((btn, index) => {
                setTimeout(() => { btn.click(); }, index * 300);
            });
        }

        // MAIN: Translate everything
        window.translateAllMessages = function() {
            const lang = document.getElementById('targetLanguage').value;
            
            // Step 1: INSTANT dictionary translation for all labels
            translateInterface(lang);

            // Step 2: API-based translation for dynamic content (subject, desc, messages)
            translateDynamicContent(lang);
        };

        window.translateMessage = function(msgId, btn) {
            const originalText = btn.closest('.bubble-wrap').querySelector('.bubble');
            const originalBtnHtml = btn.innerHTML;
            const targetLang = document.getElementById('targetLanguage').value;
            
            btn.innerHTML = '⌛ ...';
            btn.disabled = true;

            fetch(`/admin/support/messages/${msgId}/translate?target=${targetLang}`, {
                method: 'GET',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
            .then(res => res.json())
            .then(data => {
                if (data.translatedText) {
                    originalText.innerHTML = `${data.translatedText}<br><br><small style="opacity:0.5; font-style:italic;">(Translated)</small>`;
                    btn.style.display = 'none';
                } else {
                    btn.innerHTML = originalBtnHtml;
                    btn.disabled = false;
                }
            })
            .catch(() => {
                btn.innerHTML = originalBtnHtml;
                btn.disabled = false;
            });
        };

        window.analyzeMood = function(msgId, btn) {
            const originalBtnHtml = btn.innerHTML;
            btn.innerHTML = '⌛ ...';
            btn.disabled = true;

            fetch(`/admin/support/messages/${msgId}/analyze-mood`, {
                method: 'POST',
                headers: { 
                    'X-Requested-With': 'XMLHttpRequest',
                    'Content-Type': 'application/json'
                }
            })
            .then(res => res.json())
            .then(data => {
                if (data.mood) {
                    searchMessages(); 
                } else {
                    alert('Analysis failed.');
                    btn.innerHTML = originalBtnHtml;
                    btn.disabled = false;
                }
            })
            .catch(() => {
                alert('Error connecting to AI service.');
                btn.innerHTML = originalBtnHtml;
                btn.disabled = false;
            });
        };
    </script>
