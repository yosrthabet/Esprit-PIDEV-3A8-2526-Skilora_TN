{% extends 'layouts/app.html.twig' %}

{% block page_title %}Edit Message{% endblock %}

{% block content %}
<div class="mx-auto w-full max-w-3xl">
    <div class="mb-4">
        <a href="{{ path('admin_support_show', {id: ticket.id}) }}" class="text-sm text-primary hover:underline">← Back to ticket</a>
    </div>

    <div class="rounded-3xl border border-border bg-card p-6 shadow-sm">
        <h2 class="text-lg font-semibold">Edit message</h2>
        <p class="mt-1 text-sm text-muted-foreground">Update the content or mark this message as internal.</p>

        {{ form_start(form, {attr: {class: 'mt-5 space-y-3'}}) }}
            <div>
                {{ form_label(form.contenu, null, {label_attr: {class: 'mb-1 block text-xs font-semibold uppercase tracking-wide text-muted-foreground'}}) }}
                {{ form_widget(form.contenu, {attr: {class: 'w-full rounded-xl border border-input bg-background px-3 py-2 text-sm', rows: 5}}) }}
                {{ form_errors(form.contenu) }}
            </div>
            <div>
                {{ form_label(form.attachmentsJson, null, {label_attr: {class: 'mb-1 block text-xs font-semibold uppercase tracking-wide text-muted-foreground'}}) }}
                {{ form_widget(form.attachmentsJson, {attr: {class: 'w-full rounded-xl border border-input bg-background px-3 py-2 text-sm', rows: 2}}) }}
                {{ form_errors(form.attachmentsJson) }}
            </div>
            <div class="rounded-xl border border-border px-3 py-2">
                <label class="flex items-center gap-2 text-sm font-medium">
                    {{ form_widget(form.isInternal) }}
                    <span>{{ form.isInternal.vars.label }}</span>
                </label>
                {{ form_errors(form.isInternal) }}
            </div>

            <div class="flex items-center justify-end gap-2 pt-2">
                <a href="{{ path('admin_support_show', {id: ticket.id}) }}"
                   class="rounded-lg border border-border px-4 py-2 text-sm font-semibold hover:bg-accent">Cancel</a>
                <button class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground hover:opacity-90">Save</button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
