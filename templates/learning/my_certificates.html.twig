{% extends 'layouts/app.html.twig' %}

{% block page_title %}Mes certificats{% endblock %}

{% block content %}
<div class="space-y-6 animate-fade-in">
    {# Header #}
    <div class="relative overflow-hidden rounded-2xl border border-border bg-gradient-to-br from-primary/5 via-card to-accent/10 p-6 shadow-sm sm:p-8">
        <div class="absolute -right-12 -top-12 h-40 w-40 rounded-full bg-primary/5 blur-3xl"></div>
        <div class="relative">
            <h2 class="text-2xl font-bold tracking-tight text-foreground sm:text-3xl">Mes certificats</h2>
            <p class="mt-1.5 max-w-xl text-sm text-muted-foreground">
                Certificats obtenus en complétant vos formations.
            </p>
        </div>
    </div>

    {% if certificates is empty %}
        <div class="rounded-2xl border border-dashed border-border p-12 text-center">
            <svg class="mx-auto h-12 w-12 text-muted-foreground/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/>
            </svg>
            <p class="mt-4 text-sm text-muted-foreground">Aucun certificat. Complétez une formation pour en obtenir un.</p>
            <a href="{{ path('app_formation_index') }}" class="mt-4 inline-flex h-9 items-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow hover:bg-primary/90">
                Parcourir le catalogue
            </a>
        </div>
    {% else %}
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {% for c in certificates %}
                <div class="rounded-xl border border-border bg-card shadow-sm hover:shadow-md hover:border-primary/30 transition">
                    <div class="p-5">
                        <div class="flex items-center gap-3 mb-3">
                            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-emerald-500/10 text-emerald-600">
                                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/>
                                </svg>
                            </div>
                            <div class="min-w-0">
                                <h3 class="text-sm font-semibold text-foreground truncate">{{ c.formation.title }}</h3>
                                <p class="text-xs text-muted-foreground">{{ c.user.fullName }}</p>
                            </div>
                        </div>
                        <div class="flex items-center justify-between border-t border-border pt-3">
                            <span class="text-xs text-muted-foreground">
                                {{ c.issuedAt|date('d/m/Y') }}
                            </span>
                            <a href="{{ path('app_certificate_pdf', { id: c.id }) }}"
                               class="inline-flex h-7 items-center gap-1.5 rounded-md bg-primary/10 px-2.5 text-xs font-medium text-primary hover:bg-primary/20 transition-colors">
                                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                                PDF
                            </a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
