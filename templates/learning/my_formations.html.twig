{% extends 'layouts/app.html.twig' %}

{% block page_title %}Mes formations{% endblock %}

{% block content %}
<div class="space-y-6 animate-fade-in">
    {# Header #}
    <div class="relative overflow-hidden rounded-2xl border border-border bg-gradient-to-br from-primary/5 via-card to-accent/10 p-6 shadow-sm sm:p-8">
        <div class="absolute -right-12 -top-12 h-40 w-40 rounded-full bg-primary/5 blur-3xl"></div>
        <div class="relative">
            <h2 class="text-2xl font-bold tracking-tight text-foreground sm:text-3xl">Mes formations</h2>
            <p class="mt-1.5 max-w-xl text-sm text-muted-foreground">
                Formations auxquelles vous êtes inscrit. Ouvrez une formation pour continuer ou la marquer comme terminée.
            </p>
        </div>
    </div>

    {% if enrollments is empty %}
        <div class="rounded-2xl border border-dashed border-border p-12 text-center">
            <svg class="mx-auto h-12 w-12 text-muted-foreground/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>
            </svg>
            <p class="mt-4 text-sm text-muted-foreground">Vous n'êtes inscrit à aucune formation.</p>
            <a href="{{ path('app_formation_index') }}" class="mt-4 inline-flex h-9 items-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow hover:bg-primary/90">
                Parcourir le catalogue
            </a>
        </div>
    {% else %}
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {% for e in enrollments %}
                <div class="group rounded-xl border border-border bg-card shadow-sm transition hover:-translate-y-0.5 hover:shadow-md hover:border-primary/30">
                    <div class="p-5">
                        <div class="flex items-start justify-between gap-3">
                            <h3 class="text-sm font-semibold text-foreground line-clamp-2 group-hover:text-primary transition-colors">
                                {{ e.formation.title }}
                            </h3>
                            {% if e.completed %}
                                <span class="inline-flex shrink-0 items-center gap-1 rounded-full bg-emerald-500/10 px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider text-emerald-600 ring-1 ring-inset ring-emerald-500/20">
                                    <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                                    Terminée
                                </span>
                            {% else %}
                                <span class="inline-flex shrink-0 items-center gap-1 rounded-full bg-blue-500/10 px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider text-blue-600 ring-1 ring-inset ring-blue-500/20">
                                    <span class="h-1.5 w-1.5 rounded-full bg-blue-500 animate-pulse"></span>
                                    En cours
                                </span>
                            {% endif %}
                        </div>
                        {% if e.formation.description %}
                            <p class="mt-2 text-xs text-muted-foreground line-clamp-2">{{ e.formation.description }}</p>
                        {% endif %}
                        <div class="mt-4 flex items-center gap-2">
                            <a href="{{ path('app_formation_show', { id: e.formation.id }) }}"
                               class="inline-flex h-8 items-center rounded-md bg-primary px-3 text-xs font-medium text-primary-foreground shadow-sm hover:bg-primary/90 transition-colors">
                                Ouvrir
                            </a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
