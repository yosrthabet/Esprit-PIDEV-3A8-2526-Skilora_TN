{# admin/formation/_dialog_form.html.twig — Form fragment loaded inside edit-dialog #}
{% set is_edit = formation is not null %}
{% set action_url = is_edit
    ? path('app_admin_formation_edit', { id: formation.id })
    : path('app_admin_formation_new')
%}

{{ form_start(form, {
    attr: {
        class: 'space-y-5',
        novalidate: 'novalidate',
        enctype: 'multipart/form-data',
        'x-data': 'Object.assign(skiloraFormationWorkflow(), { submitting: false })',
        '@submit.prevent': "
            submitting = true;
            try {
                const sigHost = $el.querySelector('[x-data*=\"skiloraFormationSignatureZone\"]');
                if (sigHost && window.Alpine && typeof Alpine.$data === 'function') {
                    try {
                        const z = Alpine.$data(sigHost);
                        if (z && typeof z.captureSignatureData === 'function') {
                            z.captureSignatureData();
                        }
                    } catch (e) { /* ignore */ }
                }
                const fd = new FormData($el);
                const dialogBody = $el.closest('[data-edit-dialog-body]') || $el.closest('.p-6');
                const res = await fetch('" ~ action_url ~ "', {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    body: fd
                });
                const ct = (res.headers.get('Content-Type') || '');
                const looksJson = /json/i.test(ct);
                if (res.ok && looksJson) {
                    const raw = await res.text();
                    let data = {};
                    try {
                        data = raw ? JSON.parse(raw) : {};
                    } catch (e) {
                        submitting = false;
                        console.error(e);
                        return;
                    }
                    submitting = false;
                    if (window.Alpine && Alpine.store && Alpine.store('toast')) {
                        Alpine.store('toast').success(data.message || 'Enregistré.');
                    }
                    $dispatch('close-edit-dialog');
                    window.location.reload();
                    return;
                }
                if ((res.status === 422 || res.status === 400) && dialogBody) {
                    const html = await res.text();
                    submitting = false;
                    dialogBody.innerHTML = html;
                    if (window.Alpine && typeof Alpine.initTree === 'function') {
                        Alpine.initTree(dialogBody);
                    }
                    if (window.lucide) {
                        lucide.createIcons({ nodes: dialogBody.querySelectorAll('[data-lucide]') });
                    }
                    return;
                }
                submitting = false;
                if (res.status === 403 && window.Alpine && Alpine.store && Alpine.store('toast')) {
                    Alpine.store('toast').error('Session ou jeton CSRF invalide. Rechargez la page.');
                } else if (res.ok && !looksJson && window.Alpine && Alpine.store && Alpine.store('toast')) {
                    Alpine.store('toast').error('Réponse serveur inattendue (pas de JSON).');
                } else if (!res.ok && window.Alpine && Alpine.store && Alpine.store('toast')) {
                    Alpine.store('toast').error('Erreur réseau ou serveur (' + res.status + ').');
                }
            } catch (e) {
                submitting = false;
                console.error(e);
                if (window.Alpine && Alpine.store && Alpine.store('toast')) {
                    Alpine.store('toast').error('Échec de l\\'envoi. Réessayez.');
                }
            }
        "
    }
}) }}
    {% include 'admin/formation/_form.html.twig' %}

    <div class="flex items-center justify-end gap-3 border-t border-border pt-4">
        <button type="button"
                @click="$dispatch('close-edit-dialog')"
                class="inline-flex h-9 items-center justify-center rounded-md border border-input bg-background px-4 text-sm font-medium shadow-sm hover:bg-accent">
            Annuler
        </button>
        <button type="button"
                @click="goBack()"
                x-show="step === 2"
                class="inline-flex h-9 items-center justify-center rounded-md border border-input bg-background px-4 text-sm font-medium shadow-sm hover:bg-accent">
            Retour
        </button>
        <button type="button"
                @click="goNext()"
                x-show="step === 1"
                class="inline-flex h-9 items-center justify-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow hover:bg-primary/90">
            Suivant
        </button>
        <button type="submit"
                x-show="step === 2"
                :disabled="submitting"
                class="inline-flex h-9 items-center justify-center gap-2 rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow hover:bg-primary/90 disabled:opacity-50">
            <template x-if="submitting">
                <svg class="h-4 w-4 animate-spin" viewBox="0 0 24 24" fill="none"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
            </template>
            {{ is_edit ? 'Enregistrer' : 'Créer' }}
        </button>
    </div>
{{ form_end(form) }}
