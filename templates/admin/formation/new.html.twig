{% extends 'layouts/admin.html.twig' %}

{% block title %}Nouvelle formation · Admin{% endblock %}
{% block page_title %}Nouvelle formation{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('app_admin_formation_index') }}"
       class="inline-flex h-8 items-center justify-center rounded-md border border-input bg-background px-3 text-xs font-medium shadow-sm hover:bg-accent">
        Retour à la liste
    </a>
{% endblock %}

{% block content %}
<div class="max-w-3xl space-y-8">
    <div>
        <h2 class="text-2xl font-bold tracking-tight">Créer une formation</h2>
        <p class="text-sm text-muted-foreground mt-1">Invalid submissions are blocked; messages appear below each field.</p>
    </div>

    {% for message in app.flashes('success') %}
        <div class="rounded-md border border-green-500/30 bg-green-500/10 px-4 py-3 text-sm text-green-800 dark:text-green-300">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="rounded-md border border-destructive/30 bg-destructive/10 px-4 py-3 text-sm text-destructive">{{ message }}</div>
    {% endfor %}

    {{ form_start(form, { attr: { class: 'space-y-6' } }) }}
        {# Global form errors (e.g. CSRF) #}
        {{ form_errors(form) }}

        {% if form.vars.submitted and not form.vars.valid %}
            <div class="rounded-md border border-amber-500/30 bg-amber-500/10 px-4 py-3 text-sm text-amber-900 dark:text-amber-200" role="alert">
                Please fix the errors below. Your input is kept.
            </div>
        {% endif %}

        {% include 'admin/formation/_form.html.twig' %}

        <div class="flex flex-wrap gap-3 pt-2 border-t border-border">
            <button type="submit" class="inline-flex h-10 items-center justify-center rounded-md bg-primary px-6 text-sm font-medium text-primary-foreground shadow hover:bg-primary/90">
                Enregistrer
            </button>
            <a href="{{ path('app_admin_formation_index') }}"
               class="inline-flex h-10 items-center justify-center rounded-md border border-input bg-background px-6 text-sm font-medium shadow-sm hover:bg-accent">
                Annuler
            </a>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}
