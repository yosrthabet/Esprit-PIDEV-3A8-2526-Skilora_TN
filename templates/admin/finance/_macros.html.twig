{% macro status_badge(value) %}
    {% set v = value|default('')|upper %}
    {% if v in ['ACTIVE', 'PAID', 'VERIFIED'] %}
        <span class="inline-flex rounded-full bg-green-100 px-2 py-0.5 text-xs font-medium text-green-800 dark:bg-green-900/40 dark:text-green-300">{{ value }}</span>
    {% elseif v in ['EXPIRED', 'TERMINATED', 'CANCELLED'] %}
        <span class="inline-flex rounded-full bg-red-100 px-2 py-0.5 text-xs font-medium text-red-800 dark:bg-red-900/40 dark:text-red-300">{{ value }}</span>
    {% elseif v in ['PENDING', 'DRAFT'] %}
        <span class="inline-flex rounded-full bg-amber-100 px-2 py-0.5 text-xs font-medium text-amber-800 dark:bg-amber-900/40 dark:text-amber-300">{{ value }}</span>
    {% else %}
        <span class="inline-flex rounded-full bg-muted px-2 py-0.5 text-xs font-medium text-muted-foreground">{{ value|default('—') }}</span>
    {% endif %}
{% endmacro %}
