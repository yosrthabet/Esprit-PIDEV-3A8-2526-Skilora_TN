{# edit_url, delete_path, token, list_url #}
<div class="flex flex-wrap items-center justify-end gap-2">
    <a href="{{ edit_url }}"
       class="inline-flex items-center gap-1.5 rounded-lg border-2 border-primary bg-primary px-4 py-2.5 text-sm font-bold text-primary-foreground shadow-md transition hover:opacity-95">
        <i data-lucide="pencil" class="h-4 w-4 shrink-0"></i>
        Modifier
    </a>
    {% include 'admin/finance/_delete_modal.html.twig' with {
        delete_path: delete_path,
        token: token,
    } only %}
    <a href="{{ list_url }}"
       class="inline-flex items-center gap-1.5 rounded-lg border border-border bg-background px-4 py-2.5 text-sm font-semibold text-foreground shadow-sm transition hover:bg-muted/80">
        <i data-lucide="arrow-left" class="h-4 w-4 shrink-0"></i>
        Retour à la liste
    </a>
</div>
