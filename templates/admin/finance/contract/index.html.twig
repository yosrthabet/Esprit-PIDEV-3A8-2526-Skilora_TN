{% extends 'admin/finance/layout.html.twig' %}
{% import 'admin/finance/_macros.html.twig' as fin %}

{% block finance_body %}
<div class="space-y-6">
    <div class="flex flex-col gap-4 rounded-2xl border border-border/80 bg-gradient-to-br from-card via-card to-muted/20 p-5 shadow-sm sm:flex-row sm:items-center sm:justify-between">
        <div>
            <p class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Contrats</p>
            <h2 class="text-xl font-bold tracking-tight text-foreground">Liste des contrats</h2>
        </div>
        <div class="flex flex-wrap items-center gap-2">
            <form method="get" action="{{ path('admin_finance_contract_index') }}" class="flex flex-wrap gap-2">
                <input type="search" name="q" value="{{ search_query }}"
                       placeholder="Rechercher un employé…"
                       class="min-w-[12rem] rounded-xl border border-input bg-background px-3 py-2 text-sm shadow-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring/50">
                <button type="submit" class="rounded-xl border border-border bg-background px-4 py-2 text-sm font-medium shadow-sm transition hover:bg-accent">Rechercher</button>
            </form>
            <a href="{{ path('admin_finance_contract_new') }}"
               class="inline-flex items-center gap-1.5 rounded-xl bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground shadow-md transition hover:opacity-95">
                <i data-lucide="plus" class="h-4 w-4"></i>
                Nouveau contrat
            </a>
        </div>
    </div>

    <div class="overflow-hidden rounded-2xl border border-border/80 bg-card shadow-md">
        <div class="overflow-x-auto">
            <table class="w-full min-w-[960px] text-left text-sm">
                <thead class="border-b border-border bg-muted/40 text-muted-foreground">
                    <tr>
                        <th class="px-4 py-3 font-medium">Employee</th>
                        <th class="px-4 py-3 font-medium">Company</th>
                        <th class="px-4 py-3 font-medium">Type</th>
                        <th class="px-4 py-3 font-medium">Position</th>
                        <th class="px-4 py-3 font-medium">Salary (TND)</th>
                        <th class="px-4 py-3 font-medium">Start</th>
                        <th class="px-4 py-3 font-medium">End</th>
                        <th class="px-4 py-3 font-medium">Status</th>
                        <th class="px-4 py-3 font-medium text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border">
                    {% for contract in contracts %}
                        <tr class="hover:bg-muted/30">
                            <td class="px-4 py-3">{{ contract.user ? (contract.user.fullName ?: contract.user.username) : '—' }}</td>
                            <td class="px-4 py-3">{{ contract.company ? contract.company.name : '—' }}</td>
                            <td class="px-4 py-3">{{ contract.type|default('—') }}</td>
                            <td class="px-4 py-3">{{ contract.position|default('—') }}</td>
                            <td class="px-4 py-3">{{ contract.salary is not null ? contract.salary|number_format(2, '.', ' ') : '—' }}</td>
                            <td class="px-4 py-3">{{ contract.startDate ? contract.startDate|date('Y-m-d') : '—' }}</td>
                            <td class="px-4 py-3">{{ contract.endDate ? contract.endDate|date('Y-m-d') : '—' }}</td>
                            <td class="px-4 py-3">{{ fin.status_badge(contract.status) }}</td>
                            <td class="px-4 py-3 text-right">
                                {% include 'admin/finance/_list_row_actions.html.twig' with {
                                    show_url: path('admin_finance_contract_show', {id: contract.id}),
                                    edit_url: path('admin_finance_contract_edit', {id: contract.id}),
                                    delete_path: path('admin_finance_contract_delete', {id: contract.id}),
                                    token: csrf_token('delete' ~ contract.id),
                                } only %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="9" class="px-4 py-8 text-center text-muted-foreground">No contracts found.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        <div class="border-t border-border px-4 py-2 text-right text-sm text-muted-foreground">
            Total: {{ contracts|length }}
        </div>
    </div>
</div>
{% endblock finance_body %}
