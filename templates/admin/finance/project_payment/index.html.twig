{% extends 'admin/finance/layout.html.twig' %}

{% block finance_body %}
<div class="mx-auto max-w-2xl space-y-6">
    <div>
        <h2 class="text-2xl font-bold tracking-tight text-foreground">Paiement Avance Projet</h2>
        <p class="mt-1 text-sm text-muted-foreground">
            Stripe (mode TEST) — Carte <span class="font-mono">4242 4242 4242 4242</span>
        </p>
    </div>

    {% if 'YOUR_KEY' in stripe_public_key %}
        <div class="rounded-xl border border-amber-500/50 bg-amber-500/10 px-4 py-3 text-sm text-amber-900 dark:text-amber-100">
            Définissez <code class="rounded bg-muted px-1">STRIPE_PUBLIC_KEY</code> et <code class="rounded bg-muted px-1">STRIPE_SECRET_KEY</code> dans <code class="rounded bg-muted px-1">.env.local</code>.
        </div>
    {% endif %}

    <div class="rounded-2xl border border-border bg-card p-6 shadow-sm">
        <form id="project-payment-form" class="space-y-5">
            <div>
                <label for="amount" class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Montant (USD)</label>
                <input type="number" step="0.01" min="0.01" name="amount" id="amount" required placeholder="Ex: 50.00"
                       class="mt-1 w-full max-w-xs rounded-lg border border-input bg-background px-3 py-2 text-sm ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
            </div>

            <div>
                <label for="projectRef" class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Référence Projet</label>
                <input type="text" id="projectRef" name="projectRef" required placeholder="Ex: PROJ-2026-001"
                       class="mt-1 w-full rounded-lg border border-input bg-background px-3 py-2 text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
            </div>

            <div>
                <label for="beneficiary" class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Nom Bénéficiaire</label>
                <select id="beneficiary" name="beneficiary" required
                        class="mt-1 w-full rounded-lg border border-input bg-background px-3 py-2 text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                    <option value="">— Choisir —</option>
                    {% for u in beneficiaries %}
                        <option value="{{ u.id }}">{{ u.fullName }} ({{ u.username }})</option>
                    {% endfor %}
                </select>
            </div>

            <div>
                <label for="whatsappTo" class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Numéro destinataire (WhatsApp/SMS)</label>
                <input type="text" id="whatsappTo" name="whatsappTo" required placeholder="whatsapp:+21625331458 ou +21625331458"
                       value="{{ twilio_whatsapp_to_default|default('') }}"
                       class="mt-1 w-full rounded-lg border border-input bg-background px-3 py-2 text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
            </div>

            <div class="border-t border-border pt-4">
                <p class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Carte bancaire</p>
                <div class="mt-3 space-y-3">
                    <div id="card-number" class="rounded-lg border border-input bg-background px-3 py-3"></div>
                    <div class="grid grid-cols-2 gap-3">
                        <div id="card-expiry" class="rounded-lg border border-input bg-background px-3 py-3"></div>
                        <div id="card-cvc" class="rounded-lg border border-input bg-background px-3 py-3"></div>
                    </div>
                </div>
                <p class="mt-2 text-xs text-muted-foreground">Carte test : 4242 4242 4242 4242 | 12/34 | 123</p>
            </div>

            <p id="pay-feedback" class="hidden text-sm text-destructive" role="alert"></p>
            <p id="pay-success" class="hidden text-sm text-green-600 dark:text-green-400" role="status"></p>

            <div class="flex justify-end pt-2">
                <button type="submit" id="pay-submit"
                        data-default-label="Payer Maintenant"
                        class="inline-flex min-w-[200px] items-center justify-center gap-2 rounded-xl border-2 border-primary bg-primary px-6 py-3 text-sm font-bold text-primary-foreground shadow-md transition hover:opacity-95 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-60">
                    <i data-lucide="credit-card" class="h-4 w-4 shrink-0" aria-hidden="true"></i>
                    <span id="pay-submit-label">Payer Maintenant</span>
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://js.stripe.com/v3/"></script>
    <script>
        (function () {
            const stripePublicKey = {{ stripe_public_key|json_encode|raw }};
            const csrfToken = {{ csrf_token|json_encode|raw }};
            const intentUrl = {{ path('admin_finance_project_payment_intent')|json_encode|raw }};
            const confirmUrl = {{ path('admin_finance_project_payment_confirm')|json_encode|raw }};

            const form = document.getElementById('project-payment-form');
            const feedback = document.getElementById('pay-feedback');
            const successEl = document.getElementById('pay-success');
            const submitBtn = document.getElementById('pay-submit');

            function showError(msg) {
                successEl.classList.add('hidden');
                let text = msg || 'Une erreur est survenue.';
                if (text.length > 1200) {
                    text = text.slice(0, 1200) + '…';
                }
                feedback.textContent = text;
                feedback.classList.remove('hidden');
            }
            function clearMsg() {
                feedback.classList.add('hidden');
                successEl.classList.add('hidden');
            }

            async function readJsonOrThrow(response, fallbackMessage) {
                const raw = await response.text();
                let data = null;
                try {
                    data = raw ? JSON.parse(raw) : null;
                } catch (e) {
                    if (response.redirected || (response.url && response.url.indexOf('/login') !== -1)) {
                        throw new Error('Session expirée. Reconnectez-vous puis réessayez.');
                    }
                    const excerpt = (raw || '').replace(/\s+/g, ' ').trim().slice(0, 220);
                    throw new Error(excerpt || fallbackMessage);
                }

                if (!response.ok) {
                    throw new Error((data && data.error) ? data.error : fallbackMessage);
                }

                return data;
            }

            if (!stripePublicKey || stripePublicKey.indexOf('YOUR_KEY') !== -1) {
                showError('Clés Stripe manquantes. Configurez STRIPE_PUBLIC_KEY dans .env.local.');
                submitBtn.disabled = true;
                return;
            }

            const stripe = Stripe(stripePublicKey);
            const elements = stripe.elements({
                appearance: {
                    theme: 'stripe',
                    variables: { colorPrimary: '#14b8a6', borderRadius: '8px' },
                },
            });
            const style = {
                base: {
                    fontSize: '16px',
                    color: 'hsl(var(--foreground))',
                    '::placeholder': { color: 'hsl(var(--muted-foreground))' },
                },
            };
            const cardNumber = elements.create('cardNumber', { style, placeholder: 'XXXX XXXX XXXX XXXX' });
            const cardExpiry = elements.create('cardExpiry', { style, placeholder: 'MM/YY' });
            const cardCvc = elements.create('cardCvc', { style, placeholder: '123' });
            cardNumber.mount('#card-number');
            cardExpiry.mount('#card-expiry');
            cardCvc.mount('#card-cvc');

            const submitLabel = document.getElementById('pay-submit-label');
            const defaultBtnLabel = submitBtn.getAttribute('data-default-label') || 'Payer Maintenant';

            function setLoading(loading) {
                submitBtn.disabled = loading;
                if (submitLabel) {
                    submitLabel.textContent = loading ? 'Paiement et notification en cours…' : defaultBtnLabel;
                }
            }

            form.addEventListener('submit', async function (e) {
                e.preventDefault();
                clearMsg();
                setLoading(true);

                const amount = parseFloat(document.getElementById('amount').value, 10);
                const currency = 'USD';
                const projectRef = document.getElementById('projectRef').value.trim();
                const beneficiaryId = parseInt(document.getElementById('beneficiary').value, 10);
                const whatsappTo = document.getElementById('whatsappTo').value.trim();
                const sel = document.getElementById('beneficiary');
                const beneficiaryLabel = sel.options[sel.selectedIndex] ? sel.options[sel.selectedIndex].text : '';

                if (!beneficiaryId || !projectRef || !whatsappTo) {
                    showError('Remplissez tous les champs obligatoires.');
                    setLoading(false);
                    return;
                }

                try {
                    const ir = await fetch(intentUrl, {
                        method: 'POST',
                        credentials: 'same-origin',
                        headers: {
                            'Accept': 'application/json',
                            'Content-Type': 'application/json',
                            'X-CSRF-TOKEN': csrfToken,
                            'X-Requested-With': 'XMLHttpRequest',
                        },
                        body: JSON.stringify({
                            amount,
                            currency,
                            projectRef,
                            beneficiaryId,
                            _token: csrfToken,
                        }),
                    });
                    const idata = await readJsonOrThrow(ir, 'Création du paiement impossible.');
                    const clientSecret = idata.clientSecret;

                    const { error, paymentIntent } = await stripe.confirmCardPayment(clientSecret, {
                        payment_method: {
                            card: cardNumber,
                            billing_details: { name: beneficiaryLabel },
                        },
                    });
                    if (error) {
                        throw new Error(error.message);
                    }
                    if (!paymentIntent || paymentIntent.status !== 'succeeded') {
                        throw new Error('Paiement non finalisé.');
                    }

                    const cr = await fetch(confirmUrl, {
                        method: 'POST',
                        credentials: 'same-origin',
                        headers: {
                            'Accept': 'application/json',
                            'Content-Type': 'application/json',
                            'X-CSRF-TOKEN': csrfToken,
                            'X-Requested-With': 'XMLHttpRequest',
                        },
                        body: JSON.stringify({
                            paymentIntentId: paymentIntent.id,
                            whatsappTo,
                            _token: csrfToken,
                        }),
                    });
                    const cdata = await readJsonOrThrow(cr, 'Réponse serveur invalide après paiement (notification).');
                    if (cdata.ok !== true || !cdata.whatsapp_sid) {
                        throw new Error(cdata.error || 'Réponse Twilio incomplète après paiement.');
                    }
                    successEl.textContent = cdata.sms_sid ? 'Paiement confirmé, WhatsApp et SMS envoyés.' : 'Paiement confirmé, notification WhatsApp envoyée.';
                    successEl.classList.remove('hidden');
                    if (window.Alpine && Alpine.store && Alpine.store('toast')) {
                        Alpine.store('toast').success('Paiement confirmé.');
                    }
                } catch (err) {
                    showError(err.message || String(err));
                } finally {
                    setLoading(false);
                }
            });
        })();
    </script>
{% endblock %}
