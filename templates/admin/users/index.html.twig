{% extends 'layouts/admin.html.twig' %}

{% block title %}Utilisateurs · Admin{% endblock %}
{% block page_title %}Utilisateurs{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('app_admin_dashboard') }}" class="inline-flex h-8 items-center rounded-md border border-input bg-background px-3 text-xs font-medium shadow-sm hover:bg-accent">Tableau de bord</a>
{% endblock %}

{% block content %}
<div class="max-w-6xl space-y-6">
    <p class="text-sm text-muted-foreground">
        Données issues de la table <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono">users</code>.
        Les mots de passe ne sont jamais affichés.
    </p>

    {% if users is empty %}
        <div class="rounded-xl border border-dashed border-border bg-muted/20 px-8 py-14 text-center text-sm text-muted-foreground">
            Aucun utilisateur trouvé en base.
        </div>
    {% else %}
        <div class="overflow-hidden rounded-xl border border-border bg-card shadow-sm">
            <div class="overflow-x-auto">
                <table class="w-full min-w-[800px] text-left text-sm">
                    <thead class="border-b border-border bg-muted/40">
                        <tr>
                            <th class="h-10 px-4 font-medium text-muted-foreground">ID</th>
                            <th class="h-10 px-4 font-medium text-muted-foreground">Identifiant</th>
                            <th class="h-10 px-4 font-medium text-muted-foreground">E-mail</th>
                            <th class="h-10 px-4 font-medium text-muted-foreground">Nom</th>
                            <th class="h-10 px-4 font-medium text-muted-foreground">Rôle</th>
                            <th class="h-10 px-4 font-medium text-muted-foreground">Créé le</th>
                            <th class="h-10 px-4 font-medium text-muted-foreground">Vérifié</th>
                            <th class="h-10 px-4 font-medium text-muted-foreground">Actif</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border">
                        {% for u in users %}
                            <tr class="hover:bg-muted/30 transition-colors">
                                <td class="px-4 py-3 tabular-nums text-muted-foreground">{{ u.id }}</td>
                                <td class="px-4 py-3 font-medium">{{ u.username }}</td>
                                <td class="px-4 py-3">{{ u.email ?? '—' }}</td>
                                <td class="px-4 py-3">{{ u.fullName }}</td>
                                <td class="px-4 py-3">
                                    <span class="inline-flex rounded-full bg-secondary px-2.5 py-0.5 text-xs font-medium">{{ u.role }}</span>
                                </td>
                                <td class="px-4 py-3 text-muted-foreground text-xs whitespace-nowrap">{{ u.createdAt ? u.createdAt|date('d/m/Y H:i') : '—' }}</td>
                                <td class="px-4 py-3">
                                    <span class="text-xs font-medium {{ u.isVerified ? 'text-green-600 dark:text-green-400' : 'text-muted-foreground' }}">
                                        {{ u.isVerified ? 'Oui' : 'Non' }}
                                    </span>
                                </td>
                                <td class="px-4 py-3">
                                    <span class="text-xs font-medium {{ u.isActive ? 'text-green-600 dark:text-green-400' : 'text-destructive' }}">
                                        {{ u.isActive ? 'Oui' : 'Non' }}
                                    </span>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        <p class="text-xs text-muted-foreground">{{ users|length }} ligne(s) affichée(s) (limite requête).</p>
    {% endif %}
</div>
{% endblock %}
