{% extends 'layouts/app.html.twig' %}

{% block page_title %}Add New User{% endblock %}

{% block content %}
    <div class="mb-6 flex items-center justify-between space-y-2">
        <div>
            <h2 class="text-3xl font-bold tracking-tight">Add New User</h2>
            <p class="text-muted-foreground">Create a new user account.</p>
        </div>
        <div>
            {{ include('components/button.html.twig', {
                label: 'Back to Users',
                variant: 'outline',
                size: 'sm',
                attrs: 'onclick="window.location.href=\'' ~ path('app_admin_user_index') ~ '\'"'
            }) }}
        </div>
    </div>

    {% set form_content %}
        {% if errors is defined and errors %}
            {% for err in errors %}
                {{ include('components/alert.html.twig', {
                    variant: 'destructive',
                    body: err,
                }) }}
            {% endfor %}
        {% endif %}

        <form method="post" action="{{ path('app_admin_user_new') }}" class="space-y-6">
            <div class="grid grid-cols-2 gap-4">
                <div class="space-y-2">
                    {{ include('components/label.html.twig', { for: 'full_name', text: 'Full Name', required: true }) }}
                    {{ include('components/input.html.twig', {
                        type: 'text',
                        name: 'full_name',
                        id: 'full_name',
                        placeholder: 'Enter full name',
                        required: true,
                    }) }}
                </div>
                <div class="space-y-2">
                    {{ include('components/label.html.twig', { for: 'username', text: 'Username', required: true }) }}
                    {{ include('components/input.html.twig', {
                        type: 'text',
                        name: 'username',
                        id: 'username',
                        placeholder: 'Choose a username',
                        required: true,
                    }) }}
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div class="space-y-2">
                    {{ include('components/label.html.twig', { for: 'email', text: 'Email Address', required: true }) }}
                    {{ include('components/input.html.twig', {
                        type: 'email',
                        name: 'email',
                        id: 'email',
                        placeholder: 'user@example.com',
                        required: true,
                    }) }}
                </div>
                <div class="space-y-2">
                    {{ include('components/label.html.twig', { for: 'password', text: 'Password', required: true }) }}
                    {{ include('components/password-input.html.twig', {
                        name: 'password',
                        id: 'password',
                        placeholder: '••••••••',
                        required: true,
                    }) }}
                </div>
            </div>

            <div class="space-y-2">
                {{ include('components/label.html.twig', { text: 'Role', required: true }) }}
                <div class="flex items-center gap-4">
                    <label class="flex items-center gap-2 text-sm font-medium leading-none">
                        <input type="radio" name="role" value="USER" class="text-primary focus:ring-primary" checked>
                        User
                    </label>
                    <label class="flex items-center gap-2 text-sm font-medium leading-none">
                        <input type="radio" name="role" value="ADMIN" class="text-primary focus:ring-primary">
                        Admin
                    </label>
                </div>
            </div>

            <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                    {{ include('components/checkbox.html.twig', {
                        name: 'is_active',
                        id: 'is_active',
                        checked: true,
                    }) }}
                    {{ include('components/label.html.twig', { for: 'is_active', text: 'Active Account' }) }}
                </div>
            </div>

            <div class="flex justify-end gap-2 border-t pt-4">
                {{ include('components/button.html.twig', {
                    label: 'Create User',
                    variant: 'default',
                    type: 'submit'
                }) }}
            </div>
        </form>
    {% endset %}

    {{ include('components/card.html.twig', {
        title: 'User Details',
        description: 'Enter the details for the new user account.',
        content: form_content
    }) }}
{% endblock %}