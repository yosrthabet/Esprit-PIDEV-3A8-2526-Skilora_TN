{# admin/user/_form.html.twig — User form fragment (loaded inside edit-dialog) #}
{% set is_edit = user is not null %}
{% set action_url = is_edit
    ? path('app_admin_user_edit', { id: user.id })
    : path('app_admin_user_new')
%}

<form method="post"
      action="{{ action_url }}"
      x-data="{ submitting: false }"
      @submit.prevent="
          submitting = true;
          const fd = new FormData($el);
          const res = await fetch($el.action, {
              method: 'POST',
              headers: { 'X-Requested-With': 'XMLHttpRequest' },
              body: fd
          });
          const data = await res.json();
          submitting = false;
          if (data.success) {
              Alpine.store('toast').success(data.message);
              $dispatch('close-edit-dialog');
              document.querySelector('#user-table-container')?.dispatchEvent(new CustomEvent('refresh-table'));
          } else {
              Alpine.store('toast').error(data.message || 'Something went wrong.');
          }
      "
      class="space-y-4">

    <div class="grid grid-cols-2 gap-4">
        <div class="space-y-2">
            {{ include('components/label.html.twig', { for: 'full_name', text: 'Full Name', required: true }) }}
            {{ include('components/input.html.twig', {
                type: 'text',
                name: 'full_name',
                id: 'full_name',
                placeholder: 'John Doe',
                value: is_edit ? user.fullName|default('') : '',
                required: true,
            }) }}
        </div>
        <div class="space-y-2">
            {{ include('components/label.html.twig', { for: 'username', text: 'Username', required: true }) }}
            {{ include('components/input.html.twig', {
                type: 'text',
                name: 'username',
                id: 'username',
                placeholder: 'johndoe',
                value: is_edit ? user.username : '',
                required: true,
            }) }}
        </div>
    </div>

    <div class="grid grid-cols-2 gap-4">
        <div class="space-y-2">
            {{ include('components/label.html.twig', { for: 'email', text: 'Email', required: true }) }}
            {{ include('components/input.html.twig', {
                type: 'email',
                name: 'email',
                id: 'email',
                placeholder: 'john@example.com',
                value: is_edit ? user.email|default('') : '',
                required: true,
            }) }}
        </div>
        <div class="space-y-2">
            {{ include('components/label.html.twig', { for: 'password', text: is_edit ? 'Password (leave blank to keep)' : 'Password', required: not is_edit }) }}
            {{ include('components/password-input.html.twig', {
                name: 'password',
                id: 'password',
                placeholder: '••••••••',
                required: not is_edit,
            }) }}
        </div>
    </div>

    <div class="space-y-2">
        {{ include('components/label.html.twig', { text: 'Role', required: true }) }}
        <div class="flex items-center gap-4 flex-wrap">
            {% for role_value, role_label in { 'USER': 'User', 'EMPLOYER': 'Employer', 'TRAINER': 'Trainer', 'ADMIN': 'Admin' } %}
            <label class="flex items-center gap-2 text-sm font-medium leading-none cursor-pointer">
                <input type="radio" name="role" value="{{ role_value }}"
                       class="text-primary focus:ring-primary"
                       {{ is_edit and user.role == role_value ? 'checked' : '' }}
                       {{ not is_edit and role_value == 'USER' ? 'checked' : '' }}>
                {{ role_label }}
            </label>
            {% endfor %}
        </div>
    </div>

    <div class="flex items-center gap-2">
        {{ include('components/checkbox.html.twig', {
            name: 'is_active',
            id: 'is_active',
            checked: is_edit ? user.isActive : true,
        }) }}
        {{ include('components/label.html.twig', { for: 'is_active', text: 'Active Account' }) }}
    </div>

    <div class="flex justify-end gap-2 border-t border-border pt-4">
        <button type="button" @click="$dispatch('close-edit-dialog')"
                class="inline-flex items-center justify-center rounded-md border border-input bg-background px-4 py-2 text-sm font-medium shadow-sm hover:bg-accent hover:text-accent-foreground transition-colors">
            Cancel
        </button>
        <button type="submit" :disabled="submitting"
                class="inline-flex items-center justify-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground shadow hover:bg-primary/90 transition-colors disabled:opacity-50">
            <template x-if="submitting">
                <svg class="h-4 w-4 mr-2 animate-spin" viewBox="0 0 24 24" fill="none"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
            </template>
            {{ is_edit ? 'Save Changes' : 'Create User' }}
        </button>
    </div>
</form>
