{% extends 'layouts/app.html.twig' %}

{% block page_title %}Edit User{% endblock %}

{% block content %}
    <div class="flex items-center justify-between space-y-2 mb-6">
        <div>
            <h2 class="text-3xl font-bold tracking-tight">Edit User</h2>
            <p class="text-muted-foreground">Update details for {{ user.displayName }}</p>
        </div>
        <div>
            {{ include('components/button.html.twig', {
                label: 'Back to Users',
                variant: 'outline',
                size: 'sm',
                attrs: 'onclick="window.location.href=\'' ~ path('app_admin_user_index') ~ '\'"'
            }) }}
        </div>
    </div>

    {% set form_content %}
        {% if errors is defined and errors %}
            {% for err in errors %}
                {{ include('components/alert.html.twig', {
                    variant: 'destructive',
                    body: err,
                }) }}
            {% endfor %}
        {% endif %}

        <form method="post" action="{{ path('app_admin_user_edit', { 'id': user.id }) }}" class="space-y-6">
            <div class="grid grid-cols-2 gap-4">
                <div class="space-y-2">
                    {{ include('components/label.html.twig', { for: 'full_name', text: 'Full Name', required: true }) }}
                    {{ include('components/input.html.twig', {
                        type: 'text',
                        name: 'full_name',
                        id: 'full_name',
                        value: user.fullName|default(''),
                        required: true,
                    }) }}
                </div>
                <div class="space-y-2">
                    {{ include('components/label.html.twig', { for: 'username', text: 'Username', required: true }) }}
                    {{ include('components/input.html.twig', {
                        type: 'text',
                        name: 'username',
                        id: 'username',
                        value: user.username,
                        required: true,
                    }) }}
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div class="space-y-2">
                    {{ include('components/label.html.twig', { for: 'email', text: 'Email', required: true }) }}
                    {{ include('components/input.html.twig', {
                        type: 'email',
                        name: 'email',
                        id: 'email',
                        value: user.email,
                        required: true,
                    }) }}
                </div>
                <div class="space-y-2">
                    {{ include('components/label.html.twig', { for: 'password', text: 'Password (leave blank to keep current)' }) }}
                    {{ include('components/password-input.html.twig', {
                        name: 'password',
                        id: 'password',
                        placeholder: '••••••••',
                    }) }}
                </div>
            </div>

            <div class="space-y-2">
                {{ include('components/label.html.twig', { text: 'Role', required: true }) }}
                <div class="flex items-center gap-4">
                    <label class="flex items-center gap-2 text-sm font-medium leading-none">
                        <input type="radio" name="role" value="USER" class="text-primary focus:ring-primary" {% if user.role == 'USER' %}checked{% endif %}>
                        User
                    </label>
                    <label class="flex items-center gap-2 text-sm font-medium leading-none">
                        <input type="radio" name="role" value="ADMIN" class="text-primary focus:ring-primary" {% if user.role == 'ADMIN' %}checked{% endif %}>
                        Admin
                    </label>
                </div>
            </div>

            <div class="flex items-center gap-2">
                {{ include('components/checkbox.html.twig', {
                    name: 'is_active',
                    id: 'is_active',
                    checked: user.isActive,
                }) }}
                {{ include('components/label.html.twig', { for: 'is_active', text: 'Is Active' }) }}
            </div>

            <div class="flex justify-end gap-2 border-t pt-4">
                {{ include('components/button.html.twig', {
                    label: 'Save Changes',
                    variant: 'default',
                    type: 'submit'
                }) }}
            </div>
        </form>
    {% endset %}

    {{ include('components/card.html.twig', {
        title: 'Edit Account',
        description: 'Update the user\'s details below.',
        content: form_content
    }) }}
{% endblock %}