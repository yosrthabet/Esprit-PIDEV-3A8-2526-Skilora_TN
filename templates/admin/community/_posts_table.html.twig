<div class="rounded-3xl border border-border/70 bg-card overflow-hidden shadow-sm">

    {# ── Mobile card view (< md) ── #}
    <div class="md:hidden divide-y divide-border/50">
        {% for post in posts %}
        <div class="p-4 space-y-3">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-2.5">
                    <div class="flex items-center justify-center h-8 w-8 rounded-full bg-primary/10 text-primary font-bold text-xs border border-primary/20">
                        {{ post.author ? post.author.displayName|first|upper : '?' }}
                    </div>
                    <div>
                        <span class="font-semibold text-sm text-foreground">{{ post.author ? post.author.displayName : 'Deleted user' }}</span>
                        <p class="text-[11px] text-muted-foreground">{{ post.createdAt|date('M d, Y H:i') }}</p>
                    </div>
                </div>
                {% if post.imageUrl %}
                <a href="{{ post.imageUrl }}" target="_blank" class="inline-flex items-center gap-1 rounded-full bg-primary/10 px-2 py-0.5 text-[10px] font-bold text-primary">
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/></svg>
                    Media
                </a>
                {% endif %}
            </div>
            <p class="text-sm text-muted-foreground leading-relaxed">{{ post.content|length > 120 ? post.content|slice(0, 120) ~ '…' : post.content }}</p>
            <div class="flex items-center gap-2 pt-1">
                <a href="{{ path('app_community_posts') }}" target="_blank"
                   class="inline-flex items-center gap-1 rounded-lg border border-primary/20 bg-primary/10 px-2.5 py-1 text-[11px] font-bold text-primary">
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                    View
                </a>
                <form method="post" action="{{ path('admin_community_delete', { id: post.id }) }}" onsubmit="return confirm('Delete this post?');" class="inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('post_delete_' ~ post.id) }}">
                    <button type="submit" class="inline-flex items-center gap-1 rounded-lg border border-red-200/50 bg-red-50/50 dark:bg-red-900/10 px-2.5 py-1 text-[11px] font-bold text-red-600 dark:text-red-400">
                        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                        Delete
                    </button>
                </form>
            </div>
        </div>
        {% else %}
        <div class="px-4 py-12 text-center">
            <div class="flex flex-col items-center justify-center text-muted-foreground">
                <div class="h-12 w-12 rounded-full bg-muted/50 flex items-center justify-center mb-3">
                    <svg class="w-6 h-6 text-muted-foreground/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                </div>
                <span class="font-medium text-sm">No community posts found.</span>
            </div>
        </div>
        {% endfor %}
    </div>

    {# ── Desktop table view (md+) ── #}
    <div class="hidden md:block overflow-x-auto">
        <table class="min-w-full divide-y divide-border/50 text-sm">
            <thead class="bg-muted/20 text-xs font-semibold uppercase tracking-wider text-muted-foreground">
                <tr>
                    <th scope="col" class="px-6 py-4 text-left">Author</th>
                    <th scope="col" class="px-6 py-4 text-left">Content</th>
                    <th scope="col" class="px-6 py-4 text-left">Image</th>
                    <th scope="col" class="px-6 py-4 text-left">Created</th>
                    <th scope="col" class="px-6 py-4 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border/50 bg-card">
                {% for post in posts %}
                <tr class="transition hover:bg-muted/10 group">
                    <td class="px-6 py-4 align-middle">
                        <div class="flex items-center gap-3">
                            <div class="flex-shrink-0 flex items-center justify-center h-8 w-8 rounded-full bg-primary/10 text-primary font-bold text-xs group-hover:scale-105 transition-transform border border-primary/20">
                                {{ post.author ? post.author.displayName|first|upper : '?' }}
                            </div>
                            <span class="font-semibold text-foreground">{{ post.author ? post.author.displayName : 'Deleted user' }}</span>
                        </div>
                    </td>
                    <td class="px-6 py-4 align-middle max-w-md">
                        <p class="truncate text-muted-foreground font-medium">{{ post.content|length > 100 ? post.content|slice(0, 100) ~ '…' : post.content }}</p>
                    </td>
                    <td class="px-6 py-4 align-middle">
                        {% if post.imageUrl %}
                            <a href="{{ post.imageUrl }}" target="_blank" class="inline-flex items-center gap-1.5 rounded-full bg-primary/10 px-2.5 py-1 text-[11px] font-bold text-primary hover:bg-primary/20 transition-colors">
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/></svg>
                                View Media
                            </a>
                        {% else %}
                            <span class="text-muted-foreground/50 text-xs font-semibold uppercase tracking-wider">None</span>
                        {% endif %}
                    </td>
                    <td class="px-6 py-4 align-middle text-xs font-medium text-muted-foreground">
                        {{ post.createdAt|date('M d, Y H:i') }}
                    </td>
                    <td class="px-6 py-4 align-middle text-right">
                        <div class="flex items-center justify-end gap-2">
                            <a href="{{ path('app_community_posts') }}" target="_blank"
                                    class="inline-flex items-center gap-1.5 rounded-xl border border-primary/20 bg-primary/10 px-3 py-1.5 text-xs font-bold text-primary hover:bg-primary/20 transition-all focus:ring-2 focus:ring-primary/20">
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                                View Feed
                            </a>
                            <form method="post"
                                  action="{{ path('admin_community_delete', { id: post.id }) }}"
                                  onsubmit="return confirm('Delete this post?');"
                                  class="inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('post_delete_' ~ post.id) }}">
                            <button type="submit"
                                    class="inline-flex items-center gap-1.5 rounded-xl border border-red-200/50 bg-red-50/50 dark:bg-red-900/10 px-3 py-1.5 text-xs font-bold text-red-600 dark:text-red-400 hover:bg-red-100 dark:hover:bg-red-900/20 transition-all focus:ring-2 focus:ring-red-500/20">
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                Delete
                            </button>
                        </form>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="5" class="px-6 py-16 text-center">
                        <div class="flex flex-col items-center justify-center text-muted-foreground">
                            <div class="h-12 w-12 rounded-full bg-muted/50 flex items-center justify-center mb-3">
                                <svg class="w-6 h-6 text-muted-foreground/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                            </div>
                            <span class="font-medium text-sm">No community posts found matching your search.</span>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {# Pagination #}
    {% if totalPages > 1 %}
    <div class="flex items-center justify-between border-t border-border/70 px-4 sm:px-6 py-3 sm:py-4 bg-muted/5">
        <p class="text-xs font-medium text-muted-foreground">Page <span class="font-bold text-foreground">{{ currentPage }}</span> of <span class="font-bold border px-1 rounded-sm">{{ totalPages }}</span></p>
        <div class="flex items-center gap-2">
            {% if currentPage > 1 %}
                <button data-page="{{ currentPage - 1 }}"
                        class="rounded-xl flex items-center justify-center border border-border px-3 py-1.5 text-xs font-semibold hover:bg-muted shadow-sm transition-colors text-foreground gap-1">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg> Prev
                </button>
            {% endif %}
            {% if currentPage < totalPages %}
                <button data-page="{{ currentPage + 1 }}"
                        class="rounded-xl flex items-center justify-center border border-border px-3 py-1.5 text-xs font-semibold hover:bg-muted shadow-sm transition-colors text-foreground gap-1">
                    Next <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </button>
            {% endif %}
        </div>
    </div>
    {% endif %}
</div>
