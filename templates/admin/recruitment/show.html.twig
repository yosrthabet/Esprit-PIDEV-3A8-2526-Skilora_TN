{% extends 'layouts/app.html.twig' %}

{% block page_title %}Offer: {{ offer.title }}{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('admin_recruitment_index') }}"
       class="inline-flex items-center gap-1.5 rounded-lg border border-border px-3 py-1.5 text-sm font-medium hover:bg-muted transition-colors">
        <i data-lucide="arrow-left" class="h-4 w-4"></i> Back to list
    </a>
{% endblock %}

{% block content %}
<div class="space-y-6">
    {# Flash messages #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="rounded-lg border px-4 py-3 text-sm
                {{ label == 'success' ? 'border-green-200 bg-green-50 text-green-800 dark:border-green-800 dark:bg-green-900/20 dark:text-green-400' : '' }}
                {{ label == 'error' ? 'border-red-200 bg-red-50 text-red-800 dark:border-red-800 dark:bg-red-900/20 dark:text-red-400' : '' }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
        {# Main info #}
        <div class="lg:col-span-2 space-y-6">
            {# Offer details card #}
            <div class="rounded-xl border border-border bg-card p-6 space-y-4">
                <div class="flex items-start justify-between">
                    <div>
                        <h2 class="text-xl font-semibold">{{ offer.title }}</h2>
                        <p class="text-muted-foreground">
                            {{ offer.company ? offer.company.name : (offer.companyName ?? 'Unknown Company') }}
                            {% if offer.location %} · {{ offer.location }}{% endif %}
                        </p>
                    </div>
                    {% set status_colors = {
                        'OPEN': 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400',
                        'CLOSED': 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400',
                        'DRAFT': 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300',
                        'FROZEN': 'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400',
                    } %}
                    <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-medium {{ status_colors[offer.status] | default('bg-gray-100 text-gray-800') }}">
                        {{ offer.status }}
                    </span>
                </div>

                <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
                    <div>
                        <p class="text-xs text-muted-foreground">Work Type</p>
                        <p class="text-sm font-medium">{{ offer.workType ?? '—' }}</p>
                    </div>
                    <div>
                        <p class="text-xs text-muted-foreground">Experience</p>
                        <p class="text-sm font-medium">{{ offer.experienceLevel ?? '—' }}</p>
                    </div>
                    <div>
                        <p class="text-xs text-muted-foreground">Salary</p>
                        <p class="text-sm font-medium">
                            {% if offer.minSalary and offer.maxSalary %}
                                {{ offer.minSalary|number_format(0, '.', ',') }} – {{ offer.maxSalary|number_format(0, '.', ',') }} {{ offer.currency }}
                            {% elseif offer.minSalary %}
                                From {{ offer.minSalary|number_format(0, '.', ',') }} {{ offer.currency }}
                            {% else %}
                                —
                            {% endif %}
                        </p>
                    </div>
                    <div>
                        <p class="text-xs text-muted-foreground">Deadline</p>
                        <p class="text-sm font-medium">{{ offer.deadline ? offer.deadline|date('M d, Y') : '—' }}</p>
                    </div>
                </div>

                {% if offer.description %}
                <div>
                    <h3 class="mb-1 text-sm font-semibold text-muted-foreground">Description</h3>
                    <div class="prose prose-sm dark:prose-invert max-w-none text-sm text-foreground/80">{{ offer.description|nl2br }}</div>
                </div>
                {% endif %}

                {% if offer.requirements %}
                <div>
                    <h3 class="mb-1 text-sm font-semibold text-muted-foreground">Requirements</h3>
                    <div class="prose prose-sm dark:prose-invert max-w-none text-sm text-foreground/80">{{ offer.requirements|nl2br }}</div>
                </div>
                {% endif %}

                {% if offer.skillsRequired %}
                <div>
                    <h3 class="mb-1 text-sm font-semibold text-muted-foreground">Skills Required</h3>
                    <div class="text-sm text-foreground/80">{{ offer.skillsRequired }}</div>
                </div>
                {% endif %}

                {% if offer.benefits %}
                <div>
                    <h3 class="mb-1 text-sm font-semibold text-muted-foreground">Benefits</h3>
                    <div class="text-sm text-foreground/80">{{ offer.benefits|nl2br }}</div>
                </div>
                {% endif %}
            </div>

            {# Applications #}
            <div class="rounded-xl border border-border bg-card p-6">
                <h3 class="mb-4 text-lg font-semibold">Applications ({{ applications|length }})</h3>
                {% if applications|length > 0 %}
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b border-border">
                                <th class="pb-2 text-left font-medium text-muted-foreground">ID</th>
                                <th class="pb-2 text-left font-medium text-muted-foreground">Status</th>
                                <th class="pb-2 text-left font-medium text-muted-foreground">Match %</th>
                                <th class="pb-2 text-left font-medium text-muted-foreground">Score</th>
                                <th class="pb-2 text-left font-medium text-muted-foreground">Applied</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-border">
                            {% for app in applications %}
                            <tr class="hover:bg-muted/30 transition-colors">
                                <td class="py-2">#{{ app.id }}</td>
                                <td class="py-2">
                                    {% set app_status_colors = {
                                        'PENDING': 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400',
                                        'ACCEPTED': 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400',
                                        'REJECTED': 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400',
                                        'REVIEWING': 'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400',
                                    } %}
                                    <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium {{ app_status_colors[app.statusRaw] | default('bg-gray-100 text-gray-800') }}">
                                        {{ app.statusRaw }}
                                    </span>
                                </td>
                                <td class="py-2">{{ app.matchPercentage ? app.matchPercentage ~ '%' : '—' }}</td>
                                <td class="py-2">{{ app.candidateScore ?? '—' }}</td>
                                <td class="py-2 text-muted-foreground">{{ app.appliedDate ? app.appliedDate|date('M d, Y') : '—' }}</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% else %}
                    <p class="text-muted-foreground text-sm">No applications for this offer yet.</p>
                {% endif %}
            </div>
        </div>

        {# Sidebar actions #}
        <div class="space-y-6">
            {# Quick info #}
            <div class="rounded-xl border border-border bg-card p-6 space-y-3">
                <h3 class="text-sm font-semibold text-muted-foreground uppercase tracking-wider">Quick Info</h3>
                <div class="space-y-2 text-sm">
                    <div class="flex justify-between">
                        <span class="text-muted-foreground">Posted</span>
                        <span>{{ offer.postedDate ? offer.postedDate|date('M d, Y') : '—' }}</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-muted-foreground">Updated</span>
                        <span>{{ offer.updatedAt ? offer.updatedAt|date('M d, Y') : '—' }}</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-muted-foreground">Views</span>
                        <span>{{ offer.viewsCount }}</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-muted-foreground">Applications</span>
                        <span>{{ offer.applicationsCount }}</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-muted-foreground">Featured</span>
                        <span>{{ offer.isFeatured ? 'Yes' : 'No' }}</span>
                    </div>
                </div>
            </div>

            {# Admin Actions #}
            <div class="rounded-xl border border-border bg-card p-6 space-y-3">
                <h3 class="text-sm font-semibold text-muted-foreground uppercase tracking-wider">Admin Actions</h3>

                {# Change status #}
                <form method="post" action="{{ path('admin_recruitment_update_status', { id: offer.id }) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('offer_status_' ~ offer.id) }}">
                    <label class="block text-sm text-muted-foreground mb-1">Change Status</label>
                    <div class="flex gap-2">
                        <select name="status" class="flex-1 rounded-lg border border-input bg-background px-3 py-1.5 text-sm">
                            <option value="OPEN" {{ offer.status == 'OPEN' ? 'selected' }}>Open</option>
                            <option value="CLOSED" {{ offer.status == 'CLOSED' ? 'selected' }}>Closed</option>
                            <option value="DRAFT" {{ offer.status == 'DRAFT' ? 'selected' }}>Draft</option>
                            <option value="FROZEN" {{ offer.status == 'FROZEN' ? 'selected' }}>Frozen</option>
                        </select>
                        <button type="submit"
                                class="rounded-lg bg-primary px-3 py-1.5 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors">
                            Update
                        </button>
                    </div>
                </form>

                {# Toggle featured #}
                <form method="post" action="{{ path('admin_recruitment_toggle_featured', { id: offer.id }) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('offer_feature_' ~ offer.id) }}">
                    <button type="submit"
                            class="flex w-full items-center justify-center gap-2 rounded-lg border border-border px-3 py-2 text-sm font-medium hover:bg-muted transition-colors">
                        <i data-lucide="star" class="h-4 w-4 {{ offer.isFeatured ? 'fill-yellow-400 text-yellow-400' : '' }}"></i>
                        {{ offer.isFeatured ? 'Remove Featured' : 'Mark as Featured' }}
                    </button>
                </form>

                {# Delete #}
                <form method="post"
                      action="{{ path('admin_recruitment_delete', { id: offer.id }) }}"
                      onsubmit="return confirm('Are you sure you want to delete this offer? This action cannot be undone.');">
                    <input type="hidden" name="_token" value="{{ csrf_token('offer_delete_' ~ offer.id) }}">
                    <button type="submit"
                            class="flex w-full items-center justify-center gap-2 rounded-lg border border-red-300 bg-red-50 px-3 py-2 text-sm font-medium text-red-700 hover:bg-red-100 dark:border-red-800 dark:bg-red-900/20 dark:text-red-400 dark:hover:bg-red-900/40 transition-colors">
                        <i data-lucide="trash-2" class="h-4 w-4"></i>
                        Delete Offer
                    </button>
                </form>
            </div>

            {# Company info #}
            {% if offer.company %}
            <div class="rounded-xl border border-border bg-card p-6 space-y-3">
                <h3 class="text-sm font-semibold text-muted-foreground uppercase tracking-wider">Company</h3>
                <div class="space-y-2 text-sm">
                    <p class="font-medium">{{ offer.company.name }}</p>
                    {% if offer.company.industry %}
                        <div class="flex justify-between">
                            <span class="text-muted-foreground">Industry</span>
                            <span>{{ offer.company.industry }}</span>
                        </div>
                    {% endif %}
                    {% if offer.company.country %}
                        <div class="flex justify-between">
                            <span class="text-muted-foreground">Country</span>
                            <span>{{ offer.company.country }}</span>
                        </div>
                    {% endif %}
                    {% if offer.company.size %}
                        <div class="flex justify-between">
                            <span class="text-muted-foreground">Size</span>
                            <span>{{ offer.company.size }}</span>
                        </div>
                    {% endif %}
                    <div class="flex justify-between">
                        <span class="text-muted-foreground">Verified</span>
                        <span>{{ offer.company.verified ? '✓ Yes' : '✗ No' }}</span>
                    </div>
                </div>
            </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
