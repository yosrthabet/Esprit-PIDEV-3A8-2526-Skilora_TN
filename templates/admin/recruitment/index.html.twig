{% extends 'layouts/app.html.twig' %}

{% block page_title %}Recruitment Management{% endblock %}

{% block content %}
<div class="space-y-6">
    {# Stats cards #}
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-border bg-card p-4">
            <p class="text-sm text-muted-foreground">Total Offers</p>
            <p class="text-2xl font-bold">{{ stats.total }}</p>
        </div>
        <div class="rounded-xl border border-border bg-card p-4">
            <p class="text-sm text-muted-foreground">Open</p>
            <p class="text-2xl font-bold text-green-600 dark:text-green-400">{{ stats.status_counts['OPEN'] | default(0) }}</p>
        </div>
        <div class="rounded-xl border border-border bg-card p-4">
            <p class="text-sm text-muted-foreground">Closed</p>
            <p class="text-2xl font-bold text-red-600 dark:text-red-400">{{ stats.status_counts['CLOSED'] | default(0) }}</p>
        </div>
        <div class="rounded-xl border border-border bg-card p-4">
            <p class="text-sm text-muted-foreground">Companies</p>
            <p class="text-2xl font-bold">{{ stats.companies }}</p>
        </div>
    </div>

    {# Search & filters #}
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div class="flex flex-1 items-center gap-3">
            <div class="relative flex-1 max-w-md">
                <svg class="absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <input type="text"
                       id="searchInput"
                       value="{{ searchQuery }}"
                       placeholder="Search offers..."
                       class="w-full rounded-lg border border-input bg-background py-2 pl-9 pr-4 text-sm focus:outline-none focus:ring-2 focus:ring-ring">
            </div>
            <select id="statusFilter"
                    class="rounded-lg border border-input bg-background px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring">
                <option value="all" {{ statusFilter == 'all' ? 'selected' }}>All Status</option>
                <option value="open" {{ statusFilter == 'open' ? 'selected' }}>Open</option>
                <option value="closed" {{ statusFilter == 'closed' ? 'selected' }}>Closed</option>
                <option value="draft" {{ statusFilter == 'draft' ? 'selected' }}>Draft</option>
                <option value="frozen" {{ statusFilter == 'frozen' ? 'selected' }}>Frozen</option>
            </select>
        </div>
    </div>

    {# Offers table #}
    <div id="offersTableWrapper">
        {% include 'admin/recruitment/_offers_table.html.twig' %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
(function() {
    const searchInput = document.getElementById('searchInput');
    const statusFilter = document.getElementById('statusFilter');
    const wrapper = document.getElementById('offersTableWrapper');
    let debounceTimer;

    function loadOffers(page) {
        page = page || 1;
        const q = searchInput.value;
        const status = statusFilter.value;
        const url = '{{ path("admin_recruitment_index") }}?q=' + encodeURIComponent(q) + '&status=' + encodeURIComponent(status) + '&page=' + page;

        fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(r => r.text())
            .then(html => {
                wrapper.innerHTML = html;
                if (typeof lucide !== 'undefined') lucide.createIcons();
                bindPagination();
            });
    }

    function bindPagination() {
        wrapper.querySelectorAll('[data-page]').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                loadOffers(this.dataset.page);
            });
        });
    }

    searchInput.addEventListener('input', function() {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => loadOffers(1), 300);
    });

    statusFilter.addEventListener('change', function() {
        loadOffers(1);
    });

    bindPagination();
})();
</script>
{% endblock %}
