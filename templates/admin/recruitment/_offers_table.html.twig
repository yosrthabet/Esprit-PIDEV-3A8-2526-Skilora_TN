<div class="rounded-xl border border-border bg-card overflow-hidden shadow-sm">
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-border bg-muted/50">
                    <th class="px-5 py-3.5 text-left font-medium text-muted-foreground whitespace-nowrap">Title</th>
                    <th class="px-5 py-3.5 text-left font-medium text-muted-foreground whitespace-nowrap">Company</th>
                    <th class="px-5 py-3.5 text-left font-medium text-muted-foreground whitespace-nowrap">Location</th>
                    <th class="px-5 py-3.5 text-left font-medium text-muted-foreground whitespace-nowrap">Type</th>
                    <th class="px-5 py-3.5 text-left font-medium text-muted-foreground whitespace-nowrap">Status</th>
                    <th class="px-5 py-3.5 text-left font-medium text-muted-foreground whitespace-nowrap">Posted</th>
                    <th class="px-5 py-3.5 text-center font-medium text-muted-foreground whitespace-nowrap">Apps</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border">
                {% for offer in offers %}
                <tr onclick="window.location.href='{{ path("admin_recruitment_show", { id: offer.id }) }}'"
                    class="group hover:bg-muted/30 cursor-pointer transition-colors">
                    <td class="px-5 py-4 max-w-[300px]">
                        <p class="font-medium text-foreground truncate group-hover:text-primary transition-colors">
                            {{ offer.title }}
                        </p>
                        {% if offer.isFeatured %}
                            <span class="mt-1 inline-flex/items-center rounded-full bg-yellow-500/10 px-1.5 py-0.5 text-[10px] font-medium text-yellow-600 dark:text-yellow-400 ring-1 ring-inset ring-yellow-500/20">
                                <svg class="mr-0.5 h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 004.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.380-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
                                </svg>
                                Featured
                            </span>
                        {% endif %}
                    </td>
                    <td class="px-5 py-4 text-muted-foreground whitespace-nowrap">{{ offer.company ? offer.company.name : (offer.companyName|default('—')) }}</td>
                    <td class="px-5 py-4 text-muted-foreground whitespace-nowrap">{{ offer.location|default('—') }}</td>
                    <td class="px-5 py-4 text-muted-foreground whitespace-nowrap">
                        <span class="inline-flex items-center rounded-md border border-border bg-background px-2.5 py-0.5 text-xs font-medium text-muted-foreground shadow-sm">
                            {{ offer.workType ? offer.workType|replace({'_': ' '})|capitalize : '—' }}
                        </span>
                    </td>
                    <td class="px-5 py-4 whitespace-nowrap">
                        <span class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-0.5 text-xs font-medium ring-1 ring-inset
                            {% if offer.status == 'OPEN' %}bg-green-500/10 text-green-700 dark:text-green-400 ring-green-500/20
                            {% elseif offer.status == 'CLOSED' %}bg-red-500/10 text-red-700 dark:text-red-400 ring-red-500/20
                            {% elseif offer.status == 'DRAFT' %}bg-zinc-500/10 text-zinc-700 dark:text-zinc-400 ring-zinc-500/20
                            {% elseif offer.status == 'FROZEN' %}bg-blue-500/10 text-blue-700 dark:text-blue-400 ring-blue-500/20
                            {% else %}bg-zinc-500/10 text-zinc-700 dark:text-zinc-400 ring-zinc-500/20{% endif %}
                        ">
                            <span class="h-1.5 w-1.5 rounded-full
                                {% if offer.status == 'OPEN' %}bg-green-500
                                {% elseif offer.status == 'CLOSED' %}bg-red-500
                                {% elseif offer.status == 'DRAFT' %}bg-zinc-500
                                {% elseif offer.status == 'FROZEN' %}bg-blue-500
                                {% else %}bg-zinc-500{% endif %}
                            "></span>
                            {{ offer.status|capitalize }}
                        </span>
                    </td>
                    <td class="px-5 py-4 text-muted-foreground whitespace-nowrap">{{ offer.postedDate ? offer.postedDate|date('M d, Y') : '—' }}</td>
                    <td class="px-5 py-4 text-center whitespace-nowrap">
                        <span class="inline-flex h-6 min-w-[24px] items-center justify-center rounded-full {% if offer.applicationsCount > 0 %}bg-primary/10 text-primary font-semibold{% else %}bg-muted text-muted-foreground border border-border{% endif %} px-2 text-[11px]">
                            {{ offer.applicationsCount }}
                        </span>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="7" class="px-5 py-16 text-center text-muted-foreground">
                        <div class="flex flex-col items-center justify-center">
                            <div class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-muted">
                                <svg class="h-8 w-8 text-muted-foreground/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z" />
                                </svg>
                            </div>
                            <p class="text-base font-medium text-foreground">No job offers found</p>
                            <p class="text-sm">Try adjusting your search or filters to find what you're looking for.</p>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {# Pagination #}
    {% if totalPages > 1 %}
    <div class="flex items-center justify-between border-t border-border bg-muted/20 px-5 py-3">
        <p class="text-sm text-muted-foreground">
            Page <span class="font-medium text-foreground">{{ currentPage }}</span> of <span class="font-medium text-foreground">{{ totalPages }}</span>
        </p>
        <div class="flex items-center gap-2">
            {% if currentPage > 1 %}
                <button data-page="{{ currentPage - 1 }}"
                        class="inline-flex h-8 items-center gap-1 rounded-md border border-border bg-background px-3 text-xs font-medium text-muted-foreground hover:bg-muted hover:text-foreground transition-colors shadow-sm">
                    <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
                    Previous
                </button>
            {% endif %}
            {% if currentPage < totalPages %}
                <button data-page="{{ currentPage + 1 }}"
                        class="inline-flex h-8 items-center gap-1 rounded-md border border-border bg-background px-3 text-xs font-medium text-muted-foreground hover:bg-muted hover:text-foreground transition-colors shadow-sm">
                    Next
                    <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </button>
            {% endif %}
        </div>
    </div>
    {% endif %}
</div>
