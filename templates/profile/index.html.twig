{# templates/profile/index.html.twig — Own profile edit page #}
{% extends 'layouts/app.html.twig' %}

{% block page_title %}My Profile{% endblock %}

{% block content %}
<div class="grid gap-6 lg:grid-cols-3">

    {# ===== LEFT COLUMN (2/3) ===== #}
    <div class="lg:col-span-2 space-y-6">

        {# --- Profile Info Card --- #}
        <div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm">
            <div class="flex flex-col space-y-1.5 p-6">
                <h3 class="font-semibold leading-none tracking-tight">Profile Information</h3>
                <p class="text-sm text-muted-foreground">Update your personal details</p>
            </div>
            <div class="p-6 pt-0">
                <form action="{{ path('app_profile_update') }}" method="post" class="space-y-4">
                    <input type="hidden" name="_token" value="{{ csrf_token('profile_update') }}">

                    <div class="grid gap-4 sm:grid-cols-2">
                        {{ include('components/input.html.twig', {
                            name: 'first_name', label: 'First Name', type: 'text',
                            placeholder: 'John', value: profile.firstName
                        }) }}
                        {{ include('components/input.html.twig', {
                            name: 'last_name', label: 'Last Name', type: 'text',
                            placeholder: 'Doe', value: profile.lastName
                        }) }}
                    </div>

                    {{ include('components/input.html.twig', {
                        name: 'headline', label: 'Headline', type: 'text',
                        placeholder: 'Full-Stack Developer | Open Source Enthusiast',
                        value: profile.headline
                    }) }}

                    <div class="space-y-2">
                        {{ include('components/label.html.twig', { for: 'bio', text: 'Bio' }) }}
                        <textarea
                            id="bio" name="bio" rows="4"
                            placeholder="Tell us about yourself..."
                            class="flex min-h-[80px] w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm shadow-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
                        >{{ profile.bio }}</textarea>
                    </div>

                    <div class="grid gap-4 sm:grid-cols-2">
                        {{ include('components/input.html.twig', {
                            name: 'phone', label: 'Phone', type: 'tel',
                            placeholder: '+216 XX XXX XXX', value: profile.phone
                        }) }}
                        {{ include('components/input.html.twig', {
                            name: 'location', label: 'Location', type: 'text',
                            placeholder: 'Tunis, Tunisia', value: profile.location
                        }) }}
                    </div>

                    <div class="grid gap-4 sm:grid-cols-2">
                        {{ include('components/input.html.twig', {
                            name: 'website', label: 'Website', type: 'url',
                            placeholder: 'https://yoursite.com', value: profile.website
                        }) }}
                        {{ include('components/input.html.twig', {
                            name: 'birth_date', label: 'Date of Birth', type: 'date',
                            value: profile.birthDate ? profile.birthDate|date('Y-m-d') : ''
                        }) }}
                    </div>

                    <div class="flex justify-end">
                        {{ include('components/button.html.twig', { label: 'Save Changes', type: 'submit', variant: 'default' }) }}
                    </div>
                </form>
            </div>
        </div>

        {# --- Skills Section --- #}
        <div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm">
            <div class="flex flex-col space-y-1.5 p-6">
                <h3 class="font-semibold leading-none tracking-tight">Skills</h3>
                <p class="text-sm text-muted-foreground">Manage your technical and professional skills</p>
            </div>
            <div class="p-6 pt-0 space-y-4">
                {# Existing skills #}
                {% if skills|length > 0 %}
                <div class="flex flex-wrap gap-2">
                    {% for skill in skills %}
                    <div class="inline-flex items-center gap-1.5 rounded-md border border-border bg-secondary/50 px-2.5 py-1 text-xs font-medium">
                        <span>{{ skill.skillName }}</span>
                        {% if skill.proficiencyLevel %}
                            <span class="text-muted-foreground">· {{ skill.proficiencyLevel|lower|capitalize }}</span>
                        {% endif %}
                        {% if skill.yearsExperience %}
                            <span class="text-muted-foreground">· {{ skill.yearsExperience }}y</span>
                        {% endif %}
                        <form action="{{ path('app_profile_skill_delete', { id: skill.id }) }}" method="post" class="inline">
                            <button type="submit" class="ml-1 text-muted-foreground hover:text-destructive transition-colors" title="Remove skill">
                                <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                                </svg>
                            </button>
                        </form>
                    </div>
                    {% endfor %}
                </div>
                {% else %}
                <p class="text-sm text-muted-foreground">No skills added yet.</p>
                {% endif %}

                {# Add skill form #}
                <div class="shrink-0 bg-border h-[1px] w-full"></div>
                <form action="{{ path('app_profile_skill_add') }}" method="post" class="space-y-3">
                    <p class="text-sm font-medium">Add a Skill</p>
                    <div class="grid gap-3 sm:grid-cols-3">
                        {{ include('components/input.html.twig', {
                            name: 'skill_name', type: 'text',
                            placeholder: 'e.g. PHP, React, Docker', required: true
                        }) }}
                        {{ include('components/select.html.twig', {
                            name: 'proficiency_level',
                            placeholder: 'Level',
                            options: [
                                { value: 'BEGINNER', label: 'Beginner' },
                                { value: 'INTERMEDIATE', label: 'Intermediate' },
                                { value: 'ADVANCED', label: 'Advanced' },
                                { value: 'EXPERT', label: 'Expert' },
                            ]
                        }) }}
                        {{ include('components/input.html.twig', {
                            name: 'years_experience', type: 'number',
                            placeholder: 'Years'
                        }) }}
                    </div>
                    <div class="flex justify-end">
                        {{ include('components/button.html.twig', { label: 'Add Skill', type: 'submit', variant: 'outline', size: 'sm' }) }}
                    </div>
                </form>
            </div>
        </div>

        {# --- Experience Section --- #}
        <div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm">
            <div class="flex flex-col space-y-1.5 p-6">
                <h3 class="font-semibold leading-none tracking-tight">Experience</h3>
                <p class="text-sm text-muted-foreground">Your work history and professional experience</p>
            </div>
            <div class="p-6 pt-0 space-y-4">
                {# Existing experiences #}
                {% if experiences|length > 0 %}
                <div class="space-y-3">
                    {% for exp in experiences %}
                    <div class="flex items-start justify-between rounded-lg border border-border p-4">
                        <div class="space-y-1">
                            <p class="font-medium text-sm">{{ exp.position }}</p>
                            <p class="text-sm text-muted-foreground">{{ exp.company }}</p>
                            <p class="text-xs text-muted-foreground">
                                {{ exp.startDate ? exp.startDate|date('M Y') : '?' }}
                                —
                                {{ exp.currentJob ? 'Present' : (exp.endDate ? exp.endDate|date('M Y') : '?') }}
                            </p>
                            {% if exp.description %}
                                <p class="text-sm text-muted-foreground mt-1">{{ exp.description|length > 150 ? exp.description|slice(0, 150) ~ '…' : exp.description }}</p>
                            {% endif %}
                        </div>
                        <form action="{{ path('app_profile_experience_delete', { id: exp.id }) }}" method="post">
                            {{ include('components/button.html.twig', { label: '✕', type: 'submit', variant: 'ghost', size: 'icon', class: 'h-7 w-7 text-muted-foreground hover:text-destructive' }) }}
                        </form>
                    </div>
                    {% endfor %}
                </div>
                {% else %}
                <p class="text-sm text-muted-foreground">No experience added yet.</p>
                {% endif %}

                {# Add experience form #}
                <div class="shrink-0 bg-border h-[1px] w-full"></div>
                <form action="{{ path('app_profile_experience_add') }}" method="post" class="space-y-3">
                    <p class="text-sm font-medium">Add Experience</p>
                    <div class="grid gap-3 sm:grid-cols-2">
                        {{ include('components/input.html.twig', {
                            name: 'company', type: 'text',
                            placeholder: 'Company name', required: true
                        }) }}
                        {{ include('components/input.html.twig', {
                            name: 'position', type: 'text',
                            placeholder: 'Job title', required: true
                        }) }}
                    </div>
                    <div class="grid gap-3 sm:grid-cols-2">
                        {{ include('components/input.html.twig', {
                            name: 'start_date', label: 'Start Date', type: 'date', required: true
                        }) }}
                        {{ include('components/input.html.twig', {
                            name: 'end_date', label: 'End Date', type: 'date'
                        }) }}
                    </div>
                    <div class="space-y-2">
                        <textarea
                            id="description" name="description" rows="3"
                            placeholder="Describe your responsibilities and achievements..."
                            class="flex min-h-[80px] w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm shadow-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
                        ></textarea>
                    </div>
                    {{ include('components/checkbox.html.twig', { name: 'current_job', label: 'I currently work here' }) }}
                    <div class="flex justify-end">
                        {{ include('components/button.html.twig', { label: 'Add Experience', type: 'submit', variant: 'outline', size: 'sm' }) }}
                    </div>
                </form>
            </div>
        </div>

        {# --- Portfolio Section --- #}
        <div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm">
            <div class="flex flex-col space-y-1.5 p-6">
                <h3 class="font-semibold leading-none tracking-tight">Portfolio</h3>
                <p class="text-sm text-muted-foreground">Showcase your best work</p>
            </div>
            <div class="p-6 pt-0 space-y-4">
                {# Existing portfolio items #}
                {% if portfolioItems|length > 0 %}
                <div class="grid gap-4 sm:grid-cols-2">
                    {% for item in portfolioItems %}
                    <div class="rounded-lg border border-border overflow-hidden">
                        {% if item.imageUrl %}
                        <div class="aspect-video bg-muted overflow-hidden">
                            <img src="{{ item.imageUrl }}" alt="{{ item.title }}" class="h-full w-full object-cover">
                        </div>
                        {% endif %}
                        <div class="p-4 space-y-2">
                            <div class="flex items-start justify-between">
                                <div>
                                    <p class="font-medium text-sm">{{ item.title }}</p>
                                    {% if item.description %}
                                        <p class="text-xs text-muted-foreground mt-0.5">{{ item.description|length > 100 ? item.description|slice(0, 100) ~ '…' : item.description }}</p>
                                    {% endif %}
                                </div>
                                <form action="{{ path('app_profile_portfolio_delete', { id: item.id }) }}" method="post">
                                    <button type="submit" class="text-muted-foreground hover:text-destructive transition-colors">
                                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                                        </svg>
                                    </button>
                                </form>
                            </div>
                            {% if item.technologies %}
                            <div class="flex flex-wrap gap-1">
                                {% for tech in item.technologies|split(',') %}
                                    {{ include('components/badge.html.twig', { label: tech|trim, variant: 'secondary' }) }}
                                {% endfor %}
                            </div>
                            {% endif %}
                            {% if item.projectUrl %}
                            <a href="{{ item.projectUrl }}" target="_blank" rel="noopener noreferrer"
                               class="inline-flex items-center gap-1 text-xs text-primary hover:underline">
                                View Project →
                            </a>
                            {% endif %}
                        </div>
                    </div>
                    {% endfor %}
                </div>
                {% else %}
                <p class="text-sm text-muted-foreground">No portfolio items yet.</p>
                {% endif %}

                {# Add portfolio form #}
                <div class="shrink-0 bg-border h-[1px] w-full"></div>
                <form action="{{ path('app_profile_portfolio_add') }}" method="post" class="space-y-3">
                    <p class="text-sm font-medium">Add Portfolio Item</p>
                    <div class="grid gap-3 sm:grid-cols-2">
                        {{ include('components/input.html.twig', {
                            name: 'title', type: 'text',
                            placeholder: 'Project title', required: true
                        }) }}
                        {{ include('components/input.html.twig', {
                            name: 'project_url', type: 'url',
                            placeholder: 'https://github.com/...'
                        }) }}
                    </div>
                    <div class="space-y-2">
                        <textarea
                            id="portfolio_description" name="description" rows="2"
                            placeholder="Brief description of the project..."
                            class="flex min-h-[80px] w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm shadow-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
                        ></textarea>
                    </div>
                    <div class="grid gap-3 sm:grid-cols-2">
                        {{ include('components/input.html.twig', {
                            name: 'image_url', type: 'url',
                            placeholder: 'Image URL (optional)'
                        }) }}
                        {{ include('components/input.html.twig', {
                            name: 'technologies', type: 'text',
                            placeholder: 'PHP, Symfony, React (comma-separated)'
                        }) }}
                    </div>
                    <div class="flex justify-end">
                        {{ include('components/button.html.twig', { label: 'Add Portfolio Item', type: 'submit', variant: 'outline', size: 'sm' }) }}
                    </div>
                </form>
            </div>
        </div>
    </div>

    {# ===== RIGHT COLUMN (1/3) — Profile Preview ===== #}
    <div class="space-y-6">
        <div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm sticky top-6">
            <div class="p-6 space-y-4">
                {# Avatar + name #}
                <div class="flex flex-col items-center space-y-3">
                    {% set initials = ((profile.firstName ?? '')|first|upper) ~ ((profile.lastName ?? '')|first|upper) %}
                    {{ include('components/avatar.html.twig', {
                        initials: initials ?: '?',
                        src: profile.photoUrl,
                        size: 'lg'
                    }) }}
                    <div class="text-center">
                        <p class="font-semibold">{{ profile.fullName ?: app.user.displayName }}</p>
                        {% if profile.headline %}
                            <p class="text-sm text-muted-foreground">{{ profile.headline }}</p>
                        {% endif %}
                    </div>
                </div>

                <div class="shrink-0 bg-border h-[1px] w-full"></div>

                {# Location #}
                {% if profile.location %}
                <div class="flex items-center gap-2 text-sm text-muted-foreground">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z"/>
                    </svg>
                    {{ profile.location }}
                </div>
                {% endif %}

                {# Bio preview #}
                {% if profile.bio %}
                <p class="text-sm text-muted-foreground">{{ profile.bio|length > 120 ? profile.bio|slice(0, 120) ~ '…' : profile.bio }}</p>
                {% endif %}

                {# Skill badges #}
                {% if skills|length > 0 %}
                <div class="flex flex-wrap gap-1.5">
                    {% for skill in skills|slice(0, 8) %}
                        {{ include('components/badge.html.twig', { label: skill.skillName, variant: 'secondary' }) }}
                    {% endfor %}
                    {% if skills|length > 8 %}
                        <span class="text-xs text-muted-foreground self-center">+{{ skills|length - 8 }} more</span>
                    {% endif %}
                </div>
                {% endif %}

                {# View public profile link #}
                <a href="{{ path('app_profile_public', { username: app.user.username }) }}"
                   class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium transition-colors focus-ring border border-input bg-background shadow-sm hover:bg-accent hover:text-accent-foreground h-9 px-4 py-2 w-full">
                    View Public Profile
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
