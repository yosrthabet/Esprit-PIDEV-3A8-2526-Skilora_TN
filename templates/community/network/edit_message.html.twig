{% extends 'layouts/app.html.twig' %}

{% block page_title %}Modifier le message{% endblock %}

{% block content %}
<div class="mx-auto max-w-2xl animate-fade-in pb-8">
    {% include 'community/_subnav.html.twig' %}

    {% set other = message.conversation.otherParticipant(app.user) %}
    {% set oi = other.fullName|default(other.username)|split(' ')|map(w => w|first)|join('')|upper|slice(0, 2) %}

    {# Breadcrumb / back link #}
    <div class="mb-5">
        <a href="{{ path('app_community_network', { c: message.conversation.id }) }}"
           class="inline-flex items-center gap-2 rounded-lg px-3 py-1.5 text-sm font-medium text-muted-foreground transition-colors hover:bg-muted hover:text-foreground">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
            Retour à la discussion
        </a>
    </div>

    {# Edit card #}
    <div class="overflow-hidden rounded-2xl border border-border bg-card shadow-sm">
        {# Header #}
        <div class="flex items-center gap-4 border-b border-border bg-gradient-to-r from-primary/5 to-transparent px-6 py-5">
            <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-primary/10">
                <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            </div>
            <div>
                <h1 class="text-lg font-bold text-foreground">Modifier le message</h1>
                <p class="text-xs text-muted-foreground">
                    Conversation avec
                    <span class="inline-flex items-center gap-1">
                        {{ include('components/avatar.html.twig', { initials: oi, size: 'sm', class: 'inline-flex h-4 w-4 text-[8px]' }) }}
                        <span class="font-medium text-foreground">{{ other.fullName|default(other.username) }}</span>
                    </span>
                </p>
            </div>
        </div>

        {# Original message preview #}
        <div class="border-b border-border bg-muted/20 px-6 py-3">
            <div class="flex items-center gap-2">
                <svg class="h-3.5 w-3.5 text-muted-foreground/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <p class="text-xs text-muted-foreground">Envoyé le {{ message.createdAt|date('d/m/Y à H:i') }} · Les participants verront la mention « modifié »</p>
            </div>
        </div>

        {# Form #}
        <div class="p-6 sm:p-8">
            {{ form_start(form, { attr: { class: 'space-y-5' } }) }}
                <div class="space-y-2">
                    {{ form_label(form.body, 'Message', { label_attr: { class: 'text-sm font-semibold text-foreground' } }) }}
                    {{ form_widget(form.body, { attr: {
                        class: 'min-h-[140px] w-full rounded-xl border border-input bg-background px-4 py-3 text-sm leading-relaxed shadow-sm transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring',
                        rows: 6,
                        maxlength: 4000,
                        placeholder: 'Votre message…',
                    } }) }}
                    {{ form_errors(form.body) }}
                    <p class="text-right text-[10px] tabular-nums text-muted-foreground/60">4 000 caractères max.</p>
                </div>
                <div class="flex items-center gap-3 border-t border-border pt-5">
                    <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-primary px-5 py-2.5 text-sm font-semibold text-primary-foreground shadow-sm transition-all hover:bg-primary/90 active:scale-[0.98]">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                        Enregistrer
                    </button>
                    <a href="{{ path('app_community_network', { c: message.conversation.id }) }}"
                       class="inline-flex items-center rounded-lg border border-input bg-background px-4 py-2.5 text-sm font-medium text-muted-foreground shadow-sm transition-colors hover:bg-muted hover:text-foreground">
                        Annuler
                    </a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
