{% extends 'layouts/app.html.twig' %}

{% block page_title %}{{ event.title }}{% endblock %}

{% block content %}
<div class="mx-auto max-w-3xl space-y-6 animate-fade-in pb-8">
    {% include 'community/_subnav.html.twig' %}

    <article class="overflow-hidden rounded-xl border border-border bg-card shadow-sm">
        {% if event.imageUrl %}
            <div class="aspect-[21/9] overflow-hidden bg-muted">
                <img src="{{ event.imageUrl }}" alt="" class="h-full w-full object-cover" loading="lazy" referrerpolicy="no-referrer">
            </div>
        {% endif %}

        <div class="p-6 sm:p-8">
            <div class="flex flex-wrap items-center gap-2">
                <span class="inline-block rounded-full bg-green-500/10 px-2.5 py-0.5 text-xs font-medium text-green-600">{{ event.eventTypeLabel }}</span>
                <span class="inline-block rounded-full {{ event.status == 'UPCOMING' ? 'bg-blue-500/10 text-blue-600' : (event.status == 'ONGOING' ? 'bg-green-500/10 text-green-600' : (event.status == 'CANCELLED' ? 'bg-red-500/10 text-red-600' : 'bg-muted text-muted-foreground')) }} px-2.5 py-0.5 text-xs font-medium">{{ event.statusLabel }}</span>
                {% if event.isOnline %}
                    <span class="inline-block rounded-full bg-purple-500/10 px-2.5 py-0.5 text-xs font-medium text-purple-600">En ligne</span>
                {% endif %}
            </div>

            <h1 class="mt-4 text-3xl font-bold tracking-tight">{{ event.title }}</h1>

            <div class="mt-4 grid gap-4 sm:grid-cols-2">
                <div class="flex items-start gap-3 rounded-lg border border-border bg-muted/30 p-3">
                    <svg class="mt-0.5 h-5 w-5 shrink-0 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    <div>
                        <p class="text-xs font-medium text-muted-foreground">Date</p>
                        <p class="text-sm">{{ event.startDate|date('d/m/Y H:i') }}{% if event.endDate %} — {{ event.endDate|date('d/m/Y H:i') }}{% endif %}</p>
                    </div>
                </div>
                {% if event.location %}
                    <div class="flex items-start gap-3 rounded-lg border border-border bg-muted/30 p-3">
                        <svg class="mt-0.5 h-5 w-5 shrink-0 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
                        <div>
                            <p class="text-xs font-medium text-muted-foreground">Lieu</p>
                            <p class="text-sm">{{ event.location }}</p>
                        </div>
                    </div>
                {% endif %}
                <div class="flex items-start gap-3 rounded-lg border border-border bg-muted/30 p-3">
                    <svg class="mt-0.5 h-5 w-5 shrink-0 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
                    <div>
                        <p class="text-xs font-medium text-muted-foreground">Participants</p>
                        <p class="text-sm">{{ event.currentAttendees }}{% if event.maxAttendees %} / {{ event.maxAttendees }}{% endif %}</p>
                    </div>
                </div>
                <div class="flex items-start gap-3 rounded-lg border border-border bg-muted/30 p-3">
                    <svg class="mt-0.5 h-5 w-5 shrink-0 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
                    <div>
                        <p class="text-xs font-medium text-muted-foreground">Organisateur</p>
                        <p class="text-sm">{{ event.organizer.fullName|default(event.organizer.username) }}</p>
                    </div>
                </div>
            </div>

            {% if event.isOnline and event.onlineLink %}
                <div class="mt-4 rounded-lg border border-purple-200 bg-purple-50/50 p-3 dark:border-purple-800 dark:bg-purple-900/20">
                    <p class="text-xs font-medium text-purple-600">Lien de la réunion en ligne</p>
                    <a href="{{ event.onlineLink }}" target="_blank" rel="noopener noreferrer"
                       class="mt-1 text-sm text-primary underline">{{ event.onlineLink }}</a>
                </div>
            {% endif %}

            <div class="mt-6 whitespace-pre-wrap text-sm leading-relaxed">{{ event.description }}</div>

            {# RSVP / Actions #}
            <div class="mt-6 flex flex-wrap items-center gap-3 border-t border-border pt-4">
                {% if event.organizer.id == app.user.id %}
                    <a href="{{ path('app_community_event_edit', { id: event.id }) }}"
                       class="inline-flex items-center gap-2 rounded-lg border border-border px-4 py-2 text-sm font-medium hover:bg-muted/50">
                        Modifier
                    </a>
                    <form method="post" action="{{ path('app_community_event_delete', { id: event.id }) }}"
                          onsubmit="return confirm('Supprimer cet événement ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_event_' ~ event.id) }}">
                        <button type="submit" class="inline-flex items-center gap-2 rounded-lg border border-destructive/30 px-4 py-2 text-sm font-medium text-destructive hover:bg-destructive/5">
                            Supprimer
                        </button>
                    </form>
                {% endif %}

                {% if event.status in ['UPCOMING', 'ONGOING'] %}
                    {% set current_rsvp = null %}
                    {% for rsvp in event.rsvps %}
                        {% if rsvp.user.id == app.user.id %}
                            {% set current_rsvp = rsvp %}
                        {% endif %}
                    {% endfor %}

                    <div class="ml-auto flex gap-2">
                        {% for status in ['GOING', 'MAYBE', 'NOT_GOING'] %}
                            {% set labels = { 'GOING': 'Je participe', 'MAYBE': 'Peut-être', 'NOT_GOING': 'Pas dispo' } %}
                            {% set colors = {
                                'GOING': current_rsvp and current_rsvp.status == 'GOING' ? 'bg-green-600 text-white' : 'border border-border hover:bg-muted/50',
                                'MAYBE': current_rsvp and current_rsvp.status == 'MAYBE' ? 'bg-yellow-500 text-white' : 'border border-border hover:bg-muted/50',
                                'NOT_GOING': current_rsvp and current_rsvp.status == 'NOT_GOING' ? 'bg-red-500 text-white' : 'border border-border hover:bg-muted/50'
                            } %}
                            <form method="post" action="{{ path('app_community_event_rsvp', { id: event.id }) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('rsvp_event_' ~ event.id) }}">
                                <input type="hidden" name="status" value="{{ status }}">
                                <button type="submit" class="inline-flex items-center rounded-lg px-3 py-1.5 text-xs font-medium {{ colors[status] }}">
                                    {{ labels[status] }}
                                </button>
                            </form>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </article>

    <a href="{{ path('app_community_events') }}" class="inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-foreground">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        Retour aux événements
    </a>
</div>
{% endblock %}
