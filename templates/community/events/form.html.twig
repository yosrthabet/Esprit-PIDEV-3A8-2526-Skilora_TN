{% extends 'layouts/app.html.twig' %}

{% block page_title %}{{ is_new ? 'Nouvel événement' : 'Modifier l\'événement' }}{% endblock %}

{% block content %}
<div class="mx-auto max-w-2xl space-y-6 animate-fade-in pb-8">
    {% include 'community/_subnav.html.twig' %}

    <div>
        <h2 class="text-2xl font-semibold tracking-tight">{{ is_new ? 'Nouvel événement' : 'Modifier l\'événement' }}</h2>
        <p class="mt-1 text-sm text-muted-foreground">{{ is_new ? 'Créez un événement pour la communauté.' : 'Mettez à jour les détails de l\'événement.' }}</p>
    </div>

    <div class="rounded-xl border border-border bg-card p-6 shadow-sm">
        {{ form_start(form, { attr: { class: 'space-y-5' } }) }}
            {{ form_errors(form) }}

            <div class="space-y-1">
                {{ form_label(form.title, null, { label_attr: { class: 'text-sm font-medium' } }) }}
                {{ form_widget(form.title) }}
                {{ form_errors(form.title) }}
            </div>

            <div class="space-y-1">
                {{ form_label(form.description, null, { label_attr: { class: 'text-sm font-medium' } }) }}
                {{ form_widget(form.description, { attr: { rows: 6 } }) }}
                {{ form_errors(form.description) }}
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
                <div class="space-y-1">
                    {{ form_label(form.eventType, null, { label_attr: { class: 'text-sm font-medium' } }) }}
                    {{ form_widget(form.eventType) }}
                    {{ form_errors(form.eventType) }}
                </div>
                <div class="space-y-1">
                    {{ form_label(form.status, null, { label_attr: { class: 'text-sm font-medium' } }) }}
                    {{ form_widget(form.status) }}
                    {{ form_errors(form.status) }}
                </div>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
                <div class="space-y-1">
                    {{ form_label(form.startDate, null, { label_attr: { class: 'text-sm font-medium' } }) }}
                    {{ form_widget(form.startDate) }}
                    {{ form_errors(form.startDate) }}
                </div>
                <div class="space-y-1">
                    {{ form_label(form.endDate, null, { label_attr: { class: 'text-sm font-medium' } }) }}
                    {{ form_widget(form.endDate) }}
                    {{ form_errors(form.endDate) }}
                </div>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
                <div class="space-y-1">
                    {{ form_label(form.location, null, { label_attr: { class: 'text-sm font-medium' } }) }}
                    {{ form_widget(form.location) }}
                    {{ form_errors(form.location) }}
                </div>
                <div class="space-y-1">
                    {{ form_label(form.maxAttendees, null, { label_attr: { class: 'text-sm font-medium' } }) }}
                    {{ form_widget(form.maxAttendees) }}
                    {{ form_errors(form.maxAttendees) }}
                </div>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
                <div class="space-y-1">
                    {{ form_label(form.isOnline, null, { label_attr: { class: 'text-sm font-medium' } }) }}
                    {{ form_widget(form.isOnline) }}
                </div>
                <div class="space-y-1">
                    {{ form_label(form.onlineLink, null, { label_attr: { class: 'text-sm font-medium' } }) }}
                    {{ form_widget(form.onlineLink) }}
                    {{ form_errors(form.onlineLink) }}
                </div>
            </div>

            <div class="space-y-1">
                {{ form_label(form.imageUrl, null, { label_attr: { class: 'text-sm font-medium' } }) }}
                {{ form_widget(form.imageUrl) }}
                {{ form_errors(form.imageUrl) }}
            </div>

            <div class="flex gap-3 pt-2">
                {{ include('components/button.html.twig', { label: is_new ? 'Créer' : 'Enregistrer', type: 'submit', variant: 'default' }) }}
                <a href="{{ path('app_community_events') }}" class="inline-flex items-center rounded-lg border border-border px-4 py-2.5 text-sm font-medium text-muted-foreground hover:bg-muted/50">
                    Annuler
                </a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
