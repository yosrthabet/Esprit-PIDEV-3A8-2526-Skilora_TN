{% extends 'layouts/app.html.twig' %}

{% block page_title %}&Eacute;v&eacute;nements{% endblock %}

{% block content %}
<div class="mx-auto max-w-5xl space-y-6 pb-8">
    {% include 'community/_subnav.html.twig' %}

    <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
            <h2 class="text-2xl font-bold tracking-tight">&Eacute;v&eacute;nements</h2>
            <p class="mt-1.5 text-sm text-muted-foreground">Meetups, webinaires, ateliers et conf&eacute;rences de la communaut&eacute;.</p>
        </div>
        <a href="{{ path('app_community_event_new') }}"
           class="inline-flex items-center gap-2 rounded-xl bg-primary px-5 py-2.5 text-sm font-semibold text-primary-foreground shadow-md transition-all duration-200 hover:shadow-lg hover:scale-[1.02] active:scale-[0.98]">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
            Nouvel &eacute;v&eacute;nement
        </a>
    </div>

    {% if events|length > 0 %}
        <div class="grid gap-5 sm:grid-cols-2">
            {% for event in events %}
                <a href="{{ path('app_community_event_show', { id: event.id }) }}"
                   class="group relative overflow-hidden rounded-2xl border border-border bg-card text-card-foreground shadow-sm transition-all duration-300 hover:border-green-500/30 hover:shadow-xl hover:-translate-y-1 animate-fade-in"
                   style="animation-delay:{{ loop.index0 * 0.05 }}s">

                    {# Date badge - overlay on top-left #}
                    <div class="absolute left-4 top-4 z-10 flex flex-col items-center rounded-xl bg-card/90 px-3 py-2 shadow-lg backdrop-blur-sm border border-border/50">
                        <span class="text-[11px] font-semibold uppercase text-primary leading-none">{{ event.startDate|date('M') }}</span>
                        <span class="text-2xl font-extrabold leading-tight text-foreground">{{ event.startDate|date('d') }}</span>
                    </div>

                    {% if event.imageUrl %}
                        <div class="aspect-video overflow-hidden bg-muted">
                            <img src="{{ event.imageUrl }}" alt="" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" referrerpolicy="no-referrer">
                        </div>
                    {% else %}
                        <div class="relative flex aspect-video items-center justify-center bg-gradient-to-br from-green-500/5 via-card to-primary/5 overflow-hidden">
                            <div class="absolute -right-6 -top-6 h-24 w-24 rounded-full bg-green-500/10 blur-2xl"></div>
                            <svg class="h-14 w-14 text-muted-foreground/20 transition-transform duration-500 group-hover:scale-110" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
                        </div>
                    {% endif %}
                    <div class="p-5">
                        <div class="flex flex-wrap items-center gap-1.5">
                            <span class="inline-block rounded-lg bg-green-500/10 px-2.5 py-0.5 text-[11px] font-semibold text-green-600 dark:text-green-400">{{ event.eventTypeLabel }}</span>
                            <span class="inline-block rounded-lg {{ event.status == 'UPCOMING' ? 'bg-blue-500/10 text-blue-600 dark:text-blue-400' : (event.status == 'ONGOING' ? 'bg-green-500/10 text-green-600 dark:text-green-400' : (event.status == 'CANCELLED' ? 'bg-red-500/10 text-red-600 dark:text-red-400' : 'bg-muted text-muted-foreground')) }} px-2.5 py-0.5 text-[11px] font-semibold">{{ event.statusLabel }}</span>
                            {% if event.isOnline %}
                                <span class="inline-flex items-center gap-1 rounded-lg bg-purple-500/10 px-2 py-0.5 text-[11px] font-semibold text-purple-600 dark:text-purple-400">
                                    <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5l4.72-4.72a.75.75 0 011.28.53v11.38a.75.75 0 01-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 002.25-2.25v-9a2.25 2.25 0 00-2.25-2.25h-9A2.25 2.25 0 002.25 7.5v9a2.25 2.25 0 002.25 2.25z"/></svg>
                                    En ligne
                                </span>
                            {% endif %}
                        </div>
                        <h3 class="mt-3 text-lg font-bold tracking-tight transition-colors duration-200 group-hover:text-green-600 dark:group-hover:text-green-400">{{ event.title }}</h3>
                        <div class="mt-3 space-y-1.5 text-xs text-muted-foreground">
                            <div class="flex items-center gap-2">
                                <svg class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                {{ event.startDate|date('d/m/Y H:i') }}
                            </div>
                            {% if event.location %}
                                <div class="flex items-center gap-2">
                                    <svg class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
                                    {{ event.location }}
                                </div>
                            {% endif %}
                        </div>
                        <div class="mt-4 flex items-center justify-between text-xs text-muted-foreground">
                            <div class="flex items-center gap-1.5">
                                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
                                {{ event.currentAttendees }}{% if event.maxAttendees %}/{{ event.maxAttendees }}{% endif %} participant{{ event.currentAttendees != 1 ? 's' : '' }}
                            </div>
                            <span class="opacity-0 font-semibold text-green-600 dark:text-green-400 transition-all duration-300 group-hover:opacity-100 flex items-center gap-1">
                                D&eacute;tails
                                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
                            </span>
                        </div>
                    </div>
                </a>
            {% endfor %}
        </div>
    {% else %}
        <div class="flex flex-col items-center justify-center rounded-2xl border border-dashed border-border/80 bg-muted/5 py-16 text-center">
            <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-green-500/10">
                <svg class="h-8 w-8 text-green-500/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
            </div>
            <p class="mt-4 text-sm font-semibold text-foreground">Aucun &eacute;v&eacute;nement</p>
            <p class="mt-1.5 max-w-xs text-xs text-muted-foreground">Organisez le premier &eacute;v&eacute;nement de la communaut&eacute; !</p>
            <a href="{{ path('app_community_event_new') }}" class="mt-4 inline-flex items-center gap-1.5 rounded-lg bg-primary px-4 py-2 text-sm font-medium text-primary-foreground shadow-sm hover:bg-primary/90 transition-colors">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                Cr&eacute;er un &eacute;v&eacute;nement
            </a>
        </div>
    {% endif %}
</div>
{% endblock %}
