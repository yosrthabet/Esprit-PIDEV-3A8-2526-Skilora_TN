{% extends 'layouts/app.html.twig' %}

{% block page_title %}{{ group.name }}{% endblock %}

{% block content %}
<div class="mx-auto max-w-3xl space-y-6 pb-8">
    {% include 'community/_subnav.html.twig' %}

    <div class="overflow-hidden rounded-2xl border border-border bg-card shadow-lg animate-fade-in">
        {# Cover image / gradient #}
        {% if group.coverImageUrl %}
            <div class="relative aspect-[21/8] overflow-hidden bg-muted">
                <img src="{{ group.coverImageUrl }}" alt="" class="h-full w-full object-cover" loading="lazy" referrerpolicy="no-referrer">
                <div class="absolute inset-0 bg-gradient-to-t from-card/80 to-transparent"></div>
            </div>
        {% else %}
            <div class="relative h-32 overflow-hidden bg-gradient-to-br from-purple-500/10 via-card to-primary/5">
                <div class="absolute -right-8 -top-8 h-40 w-40 rounded-full bg-purple-500/10 blur-3xl"></div>
                <div class="absolute -bottom-8 -left-8 h-32 w-32 rounded-full bg-primary/10 blur-2xl"></div>
            </div>
        {% endif %}

        <div class="p-6 sm:p-8">
            <div class="flex flex-wrap items-center gap-2">
                {% if group.category %}
                    <span class="inline-block rounded-lg bg-purple-500/10 px-3 py-1 text-xs font-semibold text-purple-600 dark:text-purple-400">{{ group.category }}</span>
                {% endif %}
                {% if not group.isPublic %}
                    <span class="inline-flex items-center gap-1 rounded-lg bg-yellow-500/10 px-2.5 py-1 text-xs font-semibold text-yellow-600 dark:text-yellow-400">
                        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>
                        Priv&eacute;
                    </span>
                {% endif %}
            </div>

            <h1 class="mt-4 text-3xl font-extrabold tracking-tight">{{ group.name }}</h1>

            <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-muted-foreground">
                <span class="flex items-center gap-1.5">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
                    <strong class="text-foreground">{{ group.creator.fullName|default(group.creator.username) }}</strong>
                </span>
                <span class="flex items-center gap-1.5">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
                    {{ group.memberCount }} membre{{ group.memberCount != 1 ? 's' : '' }}
                </span>
                <span class="flex items-center gap-1.5">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
                    {{ group.createdAt|date('d/m/Y') }}
                </span>
            </div>

            {% if group.description %}
                <div class="mt-5 rounded-xl bg-muted/30 p-4">
                    <p class="whitespace-pre-wrap text-sm leading-relaxed text-foreground/90">{{ group.description }}</p>
                </div>
            {% endif %}

            {# Actions #}
            <div class="mt-6 flex flex-wrap items-center gap-3 border-t border-border pt-5">
                {% if group.creator.id == app.user.id %}
                    <a href="{{ path('app_community_group_edit', { id: group.id }) }}"
                       class="inline-flex items-center gap-2 rounded-xl border border-border px-4 py-2.5 text-sm font-medium shadow-sm transition-all hover:bg-muted/50 hover:shadow-md">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z"/></svg>
                        Modifier
                    </a>
                    <form method="post" action="{{ path('app_community_group_delete', { id: group.id }) }}"
                          onsubmit="return confirm('Supprimer ce groupe et tous ses membres ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_group_' ~ group.id) }}">
                        <button type="submit" class="inline-flex items-center gap-2 rounded-xl border border-destructive/30 px-4 py-2.5 text-sm font-medium text-destructive shadow-sm transition-all hover:bg-destructive/5 hover:shadow-md">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                            Supprimer
                        </button>
                    </form>
                {% endif %}

                {% if membership %}
                    {% if group.creator.id != app.user.id %}
                        <form method="post" action="{{ path('app_community_group_leave', { id: group.id }) }}" class="ml-auto">
                            <input type="hidden" name="_token" value="{{ csrf_token('leave_group_' ~ group.id) }}">
                            <button type="submit" class="inline-flex items-center gap-2 rounded-xl border border-border px-4 py-2.5 text-sm font-medium text-muted-foreground shadow-sm transition-all hover:bg-muted/50">
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9"/></svg>
                                Quitter le groupe
                            </button>
                        </form>
                    {% endif %}
                {% else %}
                    <form method="post" action="{{ path('app_community_group_join', { id: group.id }) }}" class="ml-auto">
                        <input type="hidden" name="_token" value="{{ csrf_token('join_group_' ~ group.id) }}">
                        <button type="submit" class="inline-flex items-center gap-2 rounded-xl bg-primary px-5 py-2.5 text-sm font-semibold text-primary-foreground shadow-md transition-all duration-200 hover:shadow-lg hover:scale-[1.02] active:scale-[0.98]">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                            Rejoindre
                        </button>
                    </form>
                {% endif %}
            </div>
        </div>
    </div>

    {# Members list #}
    {% if members|length > 0 %}
        <div class="overflow-hidden rounded-2xl border border-border bg-card shadow-sm animate-fade-in" style="animation-delay:.1s">
            <div class="flex items-center justify-between border-b border-border px-6 py-4">
                <div class="flex items-center gap-3">
                    <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-purple-500/10">
                        <svg class="h-5 w-5 text-purple-600 dark:text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
                    </div>
                    <div>
                        <h3 class="text-sm font-bold text-foreground">Membres</h3>
                        <p class="text-xs text-muted-foreground">{{ members|length }} membre{{ members|length != 1 ? 's' : '' }}</p>
                    </div>
                </div>
            </div>
            <div class="divide-y divide-border/60">
                {% for gm in members %}
                    {% set member_user = gm.user %}
                    {% set m_initials = member_user.fullName|default(member_user.username)|split(' ')|map(w => w|first)|join('')|upper|slice(0, 2) %}
                    <div class="flex items-center gap-3.5 px-6 py-3.5 transition-colors hover:bg-muted/20">
                        {% if member_user.photoUrl %}
                            {{ include('components/avatar.html.twig', { src: member_user.photoUrl, alt: member_user.fullName, initials: m_initials, size: 'sm' }) }}
                        {% else %}
                            {{ include('components/avatar.html.twig', { initials: m_initials, size: 'sm' }) }}
                        {% endif %}
                        <div class="min-w-0 flex-1">
                            <p class="text-sm font-semibold text-foreground">{{ member_user.fullName|default(member_user.username) }}</p>
                            <p class="text-xs text-muted-foreground">@{{ member_user.username }}</p>
                        </div>
                        <span class="rounded-lg {{ gm.role == 'ADMIN' ? 'bg-primary/10 text-primary' : (gm.role == 'MODERATOR' ? 'bg-yellow-500/10 text-yellow-600 dark:text-yellow-400' : 'bg-muted text-muted-foreground') }} px-2.5 py-1 text-[11px] font-semibold">
                            {{ gm.role == 'ADMIN' ? 'Admin' : (gm.role == 'MODERATOR' ? 'Mod&eacute;rateur' : 'Membre') }}
                        </span>
                    </div>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    <a href="{{ path('app_community_groups') }}" class="inline-flex items-center gap-1.5 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        Retour aux groupes
    </a>
</div>
{% endblock %}
