{% extends 'layouts/app.html.twig' %}

{% block page_title %}{{ is_new ? 'Nouveau groupe' : 'Modifier le groupe' }}{% endblock %}

{% block content %}
<div class="mx-auto max-w-2xl space-y-6 animate-fade-in pb-8">
    {% include 'community/_subnav.html.twig' %}

    <div>
        <h2 class="text-2xl font-semibold tracking-tight">{{ is_new ? 'Nouveau groupe' : 'Modifier le groupe' }}</h2>
        <p class="mt-1 text-sm text-muted-foreground">{{ is_new ? 'Créez un groupe thématique pour la communauté.' : 'Mettez à jour les informations du groupe.' }}</p>
    </div>

    <div class="rounded-xl border border-border bg-card p-6 shadow-sm">
        {{ form_start(form, { attr: { class: 'space-y-5' } }) }}
            {{ form_errors(form) }}

            <div class="space-y-1">
                {{ form_label(form.name, null, { label_attr: { class: 'text-sm font-medium' } }) }}
                {{ form_widget(form.name) }}
                {{ form_errors(form.name) }}
            </div>

            <div class="space-y-1">
                {{ form_label(form.description, null, { label_attr: { class: 'text-sm font-medium' } }) }}
                {{ form_widget(form.description, { attr: { rows: 5 } }) }}
                {{ form_errors(form.description) }}
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
                <div class="space-y-1">
                    {{ form_label(form.category, null, { label_attr: { class: 'text-sm font-medium' } }) }}
                    {{ form_widget(form.category) }}
                    {{ form_errors(form.category) }}
                </div>
                <div class="space-y-1">
                    {{ form_label(form.isPublic, null, { label_attr: { class: 'text-sm font-medium' } }) }}
                    {{ form_widget(form.isPublic) }}
                </div>
            </div>

            <div class="space-y-1">
                {{ form_label(form.coverImageUrl, null, { label_attr: { class: 'text-sm font-medium' } }) }}
                {{ form_widget(form.coverImageUrl) }}
                {{ form_errors(form.coverImageUrl) }}
            </div>

            <div class="flex gap-3 pt-2">
                {{ include('components/button.html.twig', { label: is_new ? 'Créer' : 'Enregistrer', type: 'submit', variant: 'default' }) }}
                <a href="{{ path('app_community_groups') }}" class="inline-flex items-center rounded-lg border border-border px-4 py-2.5 text-sm font-medium text-muted-foreground hover:bg-muted/50">
                    Annuler
                </a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
