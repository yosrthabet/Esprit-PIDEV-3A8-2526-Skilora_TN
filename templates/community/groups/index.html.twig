{% extends 'layouts/app.html.twig' %}

{% block page_title %}Groupes{% endblock %}

{% block content %}
<div class="mx-auto max-w-4xl space-y-6 animate-fade-in pb-8">
    {% include 'community/_subnav.html.twig' %}

    <div class="flex flex-wrap items-center justify-between gap-4">
        <div>
            <h2 class="text-2xl font-semibold tracking-tight">Groupes</h2>
            <p class="mt-1 text-sm text-muted-foreground">Rejoignez des groupes thématiques pour collaborer.</p>
        </div>
        <a href="{{ path('app_community_group_new') }}"
           class="inline-flex items-center gap-2 rounded-lg bg-primary px-4 py-2.5 text-sm font-medium text-primary-foreground shadow-sm transition-colors hover:bg-primary/90">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
            Nouveau groupe
        </a>
    </div>

    {% if groups|length > 0 %}
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {% for group in groups %}
                <a href="{{ path('app_community_group_show', { id: group.id }) }}"
                   class="group overflow-hidden rounded-xl border border-border bg-card text-card-foreground shadow-sm transition-all duration-300 hover:border-primary/30 hover:shadow-md">
                    {% if group.coverImageUrl %}
                        <div class="aspect-video overflow-hidden bg-muted">
                            <img src="{{ group.coverImageUrl }}" alt="" class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" referrerpolicy="no-referrer">
                        </div>
                    {% else %}
                        <div class="flex aspect-video items-center justify-center bg-gradient-to-br from-purple-500/5 to-primary/10">
                            <svg class="h-12 w-12 text-muted-foreground/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>
                        </div>
                    {% endif %}
                    <div class="p-5">
                        <div class="flex items-center gap-2">
                            {% if group.category %}
                                <span class="inline-block rounded-full bg-purple-500/10 px-2.5 py-0.5 text-xs font-medium text-purple-600">{{ group.category }}</span>
                            {% endif %}
                            {% if not group.isPublic %}
                                <span class="inline-block rounded-full bg-yellow-500/10 px-2.5 py-0.5 text-xs font-medium text-yellow-600">Privé</span>
                            {% endif %}
                        </div>
                        <h3 class="mt-2 text-lg font-semibold tracking-tight transition-colors group-hover:text-primary">{{ group.name }}</h3>
                        {% if group.description %}
                            <p class="mt-1 line-clamp-2 text-sm text-muted-foreground">{{ group.description }}</p>
                        {% endif %}
                        <div class="mt-3 flex items-center gap-3 text-xs text-muted-foreground">
                            <span>{{ group.memberCount }} membre{{ group.memberCount != 1 ? 's' : '' }}</span>
                            <span>·</span>
                            <span>Par {{ group.creator.fullName|default(group.creator.username) }}</span>
                        </div>
                    </div>
                </a>
            {% endfor %}
        </div>
    {% else %}
        <p class="rounded-xl border border-dashed border-border bg-muted/10 py-12 text-center text-sm text-muted-foreground">
            Aucun groupe pour le moment. Créez le premier !
        </p>
    {% endif %}
</div>
{% endblock %}
