{% extends 'layouts/app.html.twig' %}

{% block page_title %}Notifications{% endblock %}

{% block content %}
<div class="mx-auto max-w-2xl space-y-6 animate-fade-in pb-8">
    {% include 'community/_subnav.html.twig' %}

    <div class="flex flex-wrap items-center justify-between gap-4">
        <div>
            <h2 class="text-2xl font-semibold tracking-tight">Notifications</h2>
            <p class="mt-1 text-sm text-muted-foreground">{{ unreadCount }} non-lue{{ unreadCount != 1 ? 's' : '' }}</p>
        </div>
        {% if unreadCount > 0 %}
            <button type="button" id="mark-all-read"
                    class="inline-flex items-center gap-2 rounded-lg border border-border px-4 py-2 text-sm font-medium text-muted-foreground hover:bg-muted/50"
                    data-url="{{ path('app_community_notifications_read_all') }}">
                Tout marquer comme lu
            </button>
        {% endif %}
    </div>

    <div class="space-y-2">
        {% for notif in notifications %}
            <div class="flex items-start gap-3 rounded-xl border {{ notif.isRead ? 'border-border bg-card' : 'border-primary/20 bg-primary/[0.02]' }} p-4 shadow-sm transition-colors"
                 data-notif-id="{{ notif.id }}">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full {{ notif.isRead ? 'bg-muted' : 'bg-primary/10' }}">
                    {% if notif.icon %}
                        <span class="text-sm">{{ notif.icon }}</span>
                    {% else %}
                        <svg class="h-4 w-4 {{ notif.isRead ? 'text-muted-foreground' : 'text-primary' }}" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/></svg>
                    {% endif %}
                </div>
                <div class="min-w-0 flex-1">
                    <p class="text-sm font-medium {{ notif.isRead ? '' : 'text-foreground' }}">{{ notif.title }}</p>
                    <p class="mt-0.5 text-xs text-muted-foreground">{{ notif.message }}</p>
                    <p class="mt-1 text-xs text-muted-foreground/70">{{ notif.createdAt|date('d/m/Y H:i') }}</p>
                </div>
                {% if not notif.isRead %}
                    <button type="button" class="btn-mark-read shrink-0 rounded-lg p-1.5 text-muted-foreground hover:bg-muted/50 hover:text-foreground"
                            data-url="{{ path('app_community_notification_read', { id: notif.id }) }}" title="Marquer comme lu">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                    </button>
                {% endif %}
            </div>
        {% else %}
            <p class="rounded-xl border border-dashed border-border bg-muted/10 py-12 text-center text-sm text-muted-foreground">
                Aucune notification pour le moment.
            </p>
        {% endfor %}
    </div>
</div>

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Mark single notification as read
    document.querySelectorAll('.btn-mark-read').forEach(function(btn) {
        btn.addEventListener('click', async function() {
            const url = btn.dataset.url;
            await fetch(url, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            const card = btn.closest('[data-notif-id]');
            card.classList.remove('border-primary/20', 'bg-primary/[0.02]');
            card.classList.add('border-border', 'bg-card');
            btn.remove();
        });
    });

    // Mark all as read
    const markAll = document.getElementById('mark-all-read');
    if (markAll) {
        markAll.addEventListener('click', async function() {
            await fetch(markAll.dataset.url, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            location.reload();
        });
    }
});
</script>
{% endblock %}
{% endblock %}
