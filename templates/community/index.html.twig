{% extends 'layouts/app.html.twig' %}

{% block page_title %}Communaut&eacute;{% endblock %}

{% block content %}
<div class="mx-auto max-w-5xl space-y-8 pb-8">
    {% include 'community/_subnav.html.twig' %}

    {# Hero header #}
    <div class="relative isolate overflow-hidden rounded-3xl border border-border bg-card shadow-lg">
        <div class="pointer-events-none absolute -right-20 -top-20 h-72 w-72 rounded-full bg-primary/[0.07] blur-3xl"></div>
        <div class="pointer-events-none absolute -bottom-16 -left-16 h-56 w-56 rounded-full bg-accent/[0.12] blur-3xl"></div>
        <div class="pointer-events-none absolute right-1/3 top-1/2 h-40 w-40 rounded-full bg-primary/[0.04] blur-2xl"></div>

        <div class="relative flex flex-col gap-6 px-8 py-10 sm:flex-row sm:items-center sm:px-12 sm:py-14">
            <div class="flex-1 space-y-5">
                <div class="inline-flex items-center gap-2.5 rounded-full border border-border/60 bg-background/70 px-3.5 py-1.5 text-xs font-medium text-muted-foreground backdrop-blur-md">
                    <span class="relative flex h-2 w-2">
                        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"></span>
                        <span class="relative inline-flex h-2 w-2 rounded-full bg-green-500"></span>
                    </span>
                    Communaut&eacute; active
                </div>
                <h2 class="text-4xl font-extrabold tracking-tight text-foreground sm:text-5xl animate-fade-in" style="animation-delay:.05s">
                    Espace<br class="hidden sm:block"> communaut&eacute;
                </h2>
                <p class="max-w-lg text-base leading-relaxed text-muted-foreground animate-fade-in" style="animation-delay:.1s">
                    Connectez-vous avec les membres Skilora, partagez vos id&eacute;es et collaborez sur vos projets professionnels.
                </p>
                <div class="flex flex-wrap gap-3 pt-1 animate-fade-in" style="animation-delay:.15s">
                    <a href="{{ path('app_community_posts') }}" class="inline-flex items-center gap-2 rounded-xl bg-primary px-5 py-2.5 text-sm font-semibold text-primary-foreground shadow-md transition-all duration-200 hover:shadow-lg hover:scale-[1.02] active:scale-[0.98]">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                        Publier
                    </a>
                    <a href="{{ path('app_community_network') }}" class="inline-flex items-center gap-2 rounded-xl border border-border bg-background/80 px-5 py-2.5 text-sm font-semibold text-foreground shadow-sm backdrop-blur-sm transition-all duration-200 hover:bg-muted/60 hover:shadow-md">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                        Messagerie
                    </a>
                </div>
            </div>

            <div class="hidden shrink-0 sm:block">
                <div class="grid grid-cols-2 gap-3 opacity-80">
                    <div class="flex h-20 w-20 items-center justify-center rounded-2xl border border-border/40 bg-background/50 shadow-sm backdrop-blur-sm transition-transform duration-300 hover:-translate-y-1 hover:shadow-md">
                        <svg class="h-8 w-8 text-primary/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/></svg>
                    </div>
                    <div class="flex h-20 w-20 items-center justify-center rounded-2xl border border-border/40 bg-background/50 shadow-sm backdrop-blur-sm transition-transform duration-300 hover:-translate-y-1 hover:shadow-md">
                        <svg class="h-8 w-8 text-blue-500/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                    </div>
                    <div class="flex h-20 w-20 items-center justify-center rounded-2xl border border-border/40 bg-background/50 shadow-sm backdrop-blur-sm transition-transform duration-300 hover:-translate-y-1 hover:shadow-md">
                        <svg class="h-8 w-8 text-green-500/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    </div>
                    <div class="flex h-20 w-20 items-center justify-center rounded-2xl border border-border/40 bg-background/50 shadow-sm backdrop-blur-sm transition-transform duration-300 hover:-translate-y-1 hover:shadow-md">
                        <svg class="h-8 w-8 text-purple-500/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Feature cards #}
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {% set features = [
            { route: 'app_community_posts', title: 'Publications', desc: 'Partagez vos actualit&eacute;s, publiez des articles et interagissez avec le fil.', icon_path: 'M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z', accent_bg: 'bg-primary/10', accent_text: 'text-primary', accent_ring: 'ring-primary/10', accent_border: 'hover:border-primary/30', accent_shadow: 'group-hover:shadow-primary/5' },
            { route: 'app_community_network', title: 'R&eacute;seau & messagerie', desc: 'Envoyez des invitations, g&eacute;rez vos contacts et &eacute;changez en priv&eacute;.', icon_path: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z', accent_bg: 'bg-primary/10', accent_text: 'text-primary', accent_ring: 'ring-primary/10', accent_border: 'hover:border-primary/30', accent_shadow: 'group-hover:shadow-primary/5' },
            { route: 'app_community_blog', title: 'Blog', desc: 'R&eacute;digez et partagez des articles approfondis avec r&eacute;sum&eacute; IA.', icon_path: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253', accent_bg: 'bg-blue-500/10', accent_text: 'text-blue-600 dark:text-blue-400', accent_ring: 'ring-blue-500/10', accent_border: 'hover:border-blue-500/30', accent_shadow: 'group-hover:shadow-blue-500/5' },
            { route: 'app_community_events', title: '&Eacute;v&eacute;nements', desc: 'D&eacute;couvrez et organisez des meetups, webinaires et conf&eacute;rences.', icon_path: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', accent_bg: 'bg-green-500/10', accent_text: 'text-green-600 dark:text-green-400', accent_ring: 'ring-green-500/10', accent_border: 'hover:border-green-500/30', accent_shadow: 'group-hover:shadow-green-500/5' },
            { route: 'app_community_groups', title: 'Groupes', desc: 'Rejoignez des groupes th&eacute;matiques et collaborez avec des communaut&eacute;s.', icon_path: 'M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z', accent_bg: 'bg-purple-500/10', accent_text: 'text-purple-600 dark:text-purple-400', accent_ring: 'ring-purple-500/10', accent_border: 'hover:border-purple-500/30', accent_shadow: 'group-hover:shadow-purple-500/5' },
            { route: 'app_community_notifications', title: 'Notifications', desc: 'Consultez vos mentions, r&eacute;actions et activit&eacute; communautaire.', icon_path: 'M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0', accent_bg: 'bg-orange-500/10', accent_text: 'text-orange-600 dark:text-orange-400', accent_ring: 'ring-orange-500/10', accent_border: 'hover:border-orange-500/30', accent_shadow: 'group-hover:shadow-orange-500/5' }
        ] %}

        {% for f in features %}
            <a href="{{ path(f.route) }}"
               class="group relative isolate overflow-hidden rounded-2xl border border-border bg-card p-6 text-card-foreground shadow-sm transition-all duration-300 {{ f.accent_border }} hover:shadow-xl hover:-translate-y-1 animate-fade-in"
               style="animation-delay:{{ loop.index0 * 0.06 }}s">
                <div class="pointer-events-none absolute inset-0 -z-10 bg-gradient-to-br from-card via-transparent to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
                <div class="flex h-12 w-12 items-center justify-center rounded-2xl {{ f.accent_bg }} {{ f.accent_text }} ring-1 {{ f.accent_ring }} transition-all duration-300 group-hover:scale-110 group-hover:shadow-lg {{ f.accent_shadow }}">
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="{{ f.icon_path }}"/></svg>
                </div>
                <h3 class="mt-5 text-lg font-bold tracking-tight">{{ f.title }}</h3>
                <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{{ f.desc }}</p>
                <div class="mt-5 flex items-center gap-1.5 text-sm font-semibold {{ f.accent_text }} opacity-0 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-1">
                    Acc&eacute;der
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
                </div>
            </a>
        {% endfor %}
    </div>
</div>
{% endblock %}
