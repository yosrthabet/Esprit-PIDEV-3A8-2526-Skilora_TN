{% extends 'layouts/app.html.twig' %}

{% block page_title %}Blog communautaire{% endblock %}

{% block content %}
<div class="mx-auto max-w-4xl space-y-6 animate-fade-in pb-8">
    {% include 'community/_subnav.html.twig' %}

    <div class="flex flex-wrap items-center justify-between gap-4">
        <div>
            <h2 class="text-2xl font-semibold tracking-tight">Blog communautaire</h2>
            <p class="mt-1 text-sm text-muted-foreground">Articles et publications rédigés par les membres.</p>
        </div>
        <a href="{{ path('app_community_blog_new') }}"
           class="inline-flex items-center gap-2 rounded-lg bg-primary px-4 py-2.5 text-sm font-medium text-primary-foreground shadow-sm transition-colors hover:bg-primary/90">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
            Nouvel article
        </a>
    </div>

    {% if articles|length > 0 %}
        <div class="grid gap-5 sm:grid-cols-2">
            {% for article in articles %}
                <a href="{{ path('app_community_blog_show', { id: article.id }) }}"
                   class="group overflow-hidden rounded-xl border border-border bg-card text-card-foreground shadow-sm transition-all duration-300 hover:border-primary/30 hover:shadow-md">
                    {% if article.coverImageUrl %}
                        <div class="aspect-video overflow-hidden bg-muted">
                            <img src="{{ article.coverImageUrl }}" alt="" class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" referrerpolicy="no-referrer">
                        </div>
                    {% else %}
                        <div class="flex aspect-video items-center justify-center bg-gradient-to-br from-primary/5 to-accent/10">
                            <svg class="h-12 w-12 text-muted-foreground/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                        </div>
                    {% endif %}
                    <div class="p-5">
                        {% if article.category %}
                            <span class="inline-block rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary">{{ article.category }}</span>
                        {% endif %}
                        <h3 class="mt-2 text-lg font-semibold tracking-tight transition-colors group-hover:text-primary">{{ article.title }}</h3>
                        {% if article.summary %}
                            <p class="mt-2 line-clamp-3 text-sm text-muted-foreground">{{ article.summary }}</p>
                        {% else %}
                            <p class="mt-2 line-clamp-3 text-sm text-muted-foreground">{{ article.content|slice(0, 200) }}{% if article.content|length > 200 %}…{% endif %}</p>
                        {% endif %}
                        <div class="mt-4 flex items-center gap-3 text-xs text-muted-foreground">
                            <span>{{ article.author.fullName|default(article.author.username) }}</span>
                            <span>·</span>
                            <span>{{ article.createdAt|date('d/m/Y') }}</span>
                            <span>·</span>
                            <span>{{ article.viewsCount }} vue{{ article.viewsCount != 1 ? 's' : '' }}</span>
                        </div>
                    </div>
                </a>
            {% endfor %}
        </div>
    {% else %}
        <p class="rounded-xl border border-dashed border-border bg-muted/10 py-12 text-center text-sm text-muted-foreground">
            Aucun article pour le moment. Soyez le premier à rédiger un article !
        </p>
    {% endif %}
</div>
{% endblock %}
