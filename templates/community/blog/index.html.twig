{% extends 'layouts/app.html.twig' %}

{% block page_title %}Blog communautaire{% endblock %}

{% block content %}
<div class="mx-auto max-w-5xl space-y-6 pb-8">
    {% include 'community/_subnav.html.twig' %}

    <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
            <h2 class="text-2xl font-bold tracking-tight">Blog communautaire</h2>
            <p class="mt-1.5 text-sm text-muted-foreground">Articles et publications r&eacute;dig&eacute;s par les membres.</p>
        </div>
        <a href="{{ path('app_community_blog_new') }}"
           class="inline-flex items-center gap-2 rounded-xl bg-primary px-5 py-2.5 text-sm font-semibold text-primary-foreground shadow-md transition-all duration-200 hover:shadow-lg hover:scale-[1.02] active:scale-[0.98]">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
            Nouvel article
        </a>
    </div>

    {% if articles|length > 0 %}
        <div class="grid gap-5 sm:grid-cols-2">
            {% for article in articles %}
                <a href="{{ path('app_community_blog_show', { id: article.id }) }}"
                   class="group relative overflow-hidden rounded-2xl border border-border bg-card text-card-foreground shadow-sm transition-all duration-300 hover:border-primary/30 hover:shadow-xl hover:-translate-y-1 animate-fade-in"
                   style="animation-delay:{{ loop.index0 * 0.05 }}s">
                    {% if article.coverImageUrl %}
                        <div class="aspect-video overflow-hidden bg-muted">
                            <img src="{{ article.coverImageUrl }}" alt="" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" referrerpolicy="no-referrer">
                        </div>
                    {% else %}
                        <div class="relative flex aspect-video items-center justify-center bg-gradient-to-br from-primary/5 via-card to-accent/5 overflow-hidden">
                            <div class="absolute -right-6 -top-6 h-24 w-24 rounded-full bg-primary/5 blur-2xl"></div>
                            <svg class="h-14 w-14 text-muted-foreground/20 transition-transform duration-500 group-hover:scale-110" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                        </div>
                    {% endif %}
                    <div class="p-5">
                        {% if article.category %}
                            <span class="inline-block rounded-lg bg-primary/10 px-2.5 py-0.5 text-[11px] font-semibold text-primary">{{ article.category }}</span>
                        {% endif %}
                        <h3 class="mt-3 text-lg font-bold tracking-tight transition-colors duration-200 group-hover:text-primary">{{ article.title }}</h3>
                        {% if article.summary %}
                            <p class="mt-2 line-clamp-3 text-sm leading-relaxed text-muted-foreground">{{ article.summary }}</p>
                        {% else %}
                            <p class="mt-2 line-clamp-3 text-sm leading-relaxed text-muted-foreground">{{ article.content|slice(0, 200) }}{% if article.content|length > 200 %}&hellip;{% endif %}</p>
                        {% endif %}
                        <div class="mt-4 flex items-center justify-between text-xs text-muted-foreground">
                            <div class="flex items-center gap-3">
                                <span class="font-medium text-foreground/70">{{ article.author.fullName|default(article.author.username) }}</span>
                                <span>&middot;</span>
                                <span>{{ article.createdAt|date('d/m/Y') }}</span>
                                <span>&middot;</span>
                                <span class="flex items-center gap-1">
                                    <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                    {{ article.viewsCount }}
                                </span>
                            </div>
                            <span class="opacity-0 font-semibold text-primary transition-all duration-300 group-hover:opacity-100 flex items-center gap-1">
                                Lire
                                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
                            </span>
                        </div>
                    </div>
                </a>
            {% endfor %}
        </div>
    {% else %}
        <div class="flex flex-col items-center justify-center rounded-2xl border border-dashed border-border/80 bg-muted/5 py-16 text-center">
            <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-primary/10">
                <svg class="h-8 w-8 text-primary/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
            </div>
            <p class="mt-4 text-sm font-semibold text-foreground">Aucun article</p>
            <p class="mt-1.5 max-w-xs text-xs text-muted-foreground">Soyez le premier &agrave; r&eacute;diger un article !</p>
            <a href="{{ path('app_community_blog_new') }}" class="mt-4 inline-flex items-center gap-1.5 rounded-lg bg-primary px-4 py-2 text-sm font-medium text-primary-foreground shadow-sm hover:bg-primary/90 transition-colors">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                &Eacute;crire un article
            </a>
        </div>
    {% endif %}
</div>
{% endblock %}
