{% extends 'layouts/app.html.twig' %}

{% block page_title %}{{ article.title }}{% endblock %}

{% block content %}
<div class="mx-auto max-w-3xl space-y-6 pb-8">
    {% include 'community/_subnav.html.twig' %}

    <article class="overflow-hidden rounded-2xl border border-border bg-card shadow-lg animate-fade-in">
        {# Cover image / gradient #}
        {% if article.coverImageUrl %}
            <div class="relative aspect-[21/8] overflow-hidden bg-muted">
                <img src="{{ article.coverImageUrl }}" alt="" class="h-full w-full object-cover" loading="lazy" referrerpolicy="no-referrer">
                <div class="absolute inset-0 bg-gradient-to-t from-card/80 to-transparent"></div>
            </div>
        {% else %}
            <div class="relative h-32 overflow-hidden bg-gradient-to-br from-primary/10 via-card to-accent/5">
                <div class="absolute -right-8 -top-8 h-40 w-40 rounded-full bg-primary/10 blur-3xl"></div>
                <div class="absolute -bottom-8 -left-8 h-32 w-32 rounded-full bg-accent/10 blur-2xl"></div>
            </div>
        {% endif %}

        <div class="p-6 sm:p-8">
            {# Badges #}
            <div class="flex flex-wrap items-center gap-2">
                {% if article.category %}
                    <span class="inline-block rounded-lg bg-primary/10 px-3 py-1 text-xs font-semibold text-primary">{{ article.category }}</span>
                {% endif %}
                {% if not article.isPublished %}
                    <span class="inline-flex items-center gap-1 rounded-lg bg-yellow-500/10 px-2.5 py-1 text-xs font-semibold text-yellow-600 dark:text-yellow-400">
                        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z"/></svg>
                        Brouillon
                    </span>
                {% endif %}
            </div>

            <h1 class="mt-4 text-3xl font-extrabold tracking-tight">{{ article.title }}</h1>

            <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-muted-foreground">
                <span class="flex items-center gap-1.5">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
                    <strong class="text-foreground">{{ article.author.fullName|default(article.author.username) }}</strong>
                </span>
                <span class="flex items-center gap-1.5">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
                    {{ article.createdAt|date('d/m/Y H:i') }}
                </span>
                <span class="flex items-center gap-1.5">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    {{ article.viewsCount }} vue{{ article.viewsCount != 1 ? 's' : '' }}
                </span>
            </div>

            {# AI Summary #}
            {% if article.summary %}
                <div class="mt-6 overflow-hidden rounded-xl border border-primary/20 bg-primary/5">
                    <div class="flex items-center gap-2 border-b border-primary/10 px-4 py-2.5">
                        <div class="flex h-7 w-7 items-center justify-center rounded-lg bg-primary/10">
                            <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
                        </div>
                        <span class="text-xs font-bold uppercase tracking-wider text-primary">R&eacute;sum&eacute; IA</span>
                    </div>
                    <div class="px-4 py-3">
                        <p class="text-sm leading-relaxed text-foreground/90">{{ article.summary }}</p>
                    </div>
                </div>
            {% endif %}

            {# Content #}
            <div class="prose prose-sm mt-6 max-w-none whitespace-pre-wrap text-foreground leading-relaxed">{{ article.content }}</div>

            {# Tags #}
            {% if article.tags %}
                <div class="mt-6 flex flex-wrap gap-2">
                    {% for tag in article.tagsArray %}
                        <span class="inline-flex items-center gap-1 rounded-lg border border-border bg-muted/30 px-3 py-1 text-xs font-medium text-muted-foreground transition-colors hover:bg-muted/60">
                            <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z"/><path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z"/></svg>
                            {{ tag }}
                        </span>
                    {% endfor %}
                </div>
            {% endif %}

            {# Actions #}
            {% if article.author.id == app.user.id %}
                <div class="mt-6 flex flex-wrap items-center gap-3 border-t border-border pt-5">
                    <a href="{{ path('app_community_blog_edit', { id: article.id }) }}"
                       class="inline-flex items-center gap-2 rounded-xl border border-border px-4 py-2.5 text-sm font-medium shadow-sm transition-all hover:bg-muted/50 hover:shadow-md">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z"/></svg>
                        Modifier
                    </a>
                    <form method="post" action="{{ path('app_community_blog_delete', { id: article.id }) }}"
                          onsubmit="return confirm('Supprimer cet article ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_article_' ~ article.id) }}">
                        <button type="submit" class="inline-flex items-center gap-2 rounded-xl border border-destructive/30 px-4 py-2.5 text-sm font-medium text-destructive shadow-sm transition-all hover:bg-destructive/5 hover:shadow-md">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                            Supprimer
                        </button>
                    </form>
                    <button type="button" id="btn-summarize"
                            class="inline-flex items-center gap-2 rounded-xl bg-primary/10 px-4 py-2.5 text-sm font-semibold text-primary shadow-sm transition-all hover:bg-primary/20 hover:shadow-md"
                            data-url="{{ path('app_community_blog_summarize', { id: article.id }) }}">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
                        G&eacute;n&eacute;rer r&eacute;sum&eacute; IA
                    </button>
                </div>
            {% endif %}
        </div>
    </article>

    <a href="{{ path('app_community_blog') }}" class="inline-flex items-center gap-1.5 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        Retour au blog
    </a>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const btn = document.getElementById('btn-summarize');
    if (!btn) return;
    btn.addEventListener('click', async function() {
        const origHTML = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<svg class="h-4 w-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg> G&eacute;n&eacute;ration en cours&hellip;';
        try {
            const resp = await fetch(btn.dataset.url, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            const data = await resp.json();
            if (data.summary) {
                location.reload();
            } else {
                alert(data.error || 'Erreur lors de la g&eacute;n&eacute;ration du r&eacute;sum&eacute;');
            }
        } catch (e) {
            alert('Erreur de connexion');
        }
        btn.disabled = false;
        btn.innerHTML = origHTML;
    });
});
</script>
{% endblock %}
