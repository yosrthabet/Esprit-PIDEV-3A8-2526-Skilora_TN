{% extends 'layouts/app.html.twig' %}

{% block page_title %}{{ article.title }}{% endblock %}

{% block content %}
<div class="mx-auto max-w-3xl space-y-6 animate-fade-in pb-8">
    {% include 'community/_subnav.html.twig' %}

    <article class="overflow-hidden rounded-xl border border-border bg-card shadow-sm">
        {% if article.coverImageUrl %}
            <div class="aspect-[21/9] overflow-hidden bg-muted">
                <img src="{{ article.coverImageUrl }}" alt="" class="h-full w-full object-cover" loading="lazy" referrerpolicy="no-referrer">
            </div>
        {% endif %}

        <div class="p-6 sm:p-8">
            <div class="flex flex-wrap items-center gap-2">
                {% if article.category %}
                    <span class="inline-block rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary">{{ article.category }}</span>
                {% endif %}
                {% if not article.isPublished %}
                    <span class="inline-block rounded-full bg-yellow-500/10 px-2.5 py-0.5 text-xs font-medium text-yellow-600">Brouillon</span>
                {% endif %}
            </div>

            <h1 class="mt-4 text-3xl font-bold tracking-tight">{{ article.title }}</h1>

            <div class="mt-3 flex items-center gap-3 text-sm text-muted-foreground">
                <span>Par <strong class="text-foreground">{{ article.author.fullName|default(article.author.username) }}</strong></span>
                <span>·</span>
                <span>{{ article.createdAt|date('d/m/Y H:i') }}</span>
                <span>·</span>
                <span>{{ article.viewsCount }} vue{{ article.viewsCount != 1 ? 's' : '' }}</span>
            </div>

            {% if article.summary %}
                <div class="mt-6 rounded-lg border border-border bg-muted/30 p-4">
                    <p class="text-xs font-medium uppercase tracking-wider text-muted-foreground">Résumé IA</p>
                    <p class="mt-1 text-sm leading-relaxed">{{ article.summary }}</p>
                </div>
            {% endif %}

            <div class="prose prose-sm mt-6 max-w-none whitespace-pre-wrap text-foreground">{{ article.content }}</div>

            {% if article.tags %}
                <div class="mt-6 flex flex-wrap gap-2">
                    {% for tag in article.tagsArray %}
                        <span class="inline-block rounded-full border border-border bg-muted/50 px-2.5 py-0.5 text-xs text-muted-foreground">{{ tag }}</span>
                    {% endfor %}
                </div>
            {% endif %}

            {# Actions #}
            {% if article.author.id == app.user.id %}
                <div class="mt-6 flex items-center gap-3 border-t border-border pt-4">
                    <a href="{{ path('app_community_blog_edit', { id: article.id }) }}"
                       class="inline-flex items-center gap-2 rounded-lg border border-border px-4 py-2 text-sm font-medium hover:bg-muted/50">
                        Modifier
                    </a>
                    <form method="post" action="{{ path('app_community_blog_delete', { id: article.id }) }}"
                          onsubmit="return confirm('Supprimer cet article ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_article_' ~ article.id) }}">
                        <button type="submit" class="inline-flex items-center gap-2 rounded-lg border border-destructive/30 px-4 py-2 text-sm font-medium text-destructive hover:bg-destructive/5">
                            Supprimer
                        </button>
                    </form>
                    <button type="button" id="btn-summarize"
                            class="inline-flex items-center gap-2 rounded-lg bg-primary/10 px-4 py-2 text-sm font-medium text-primary hover:bg-primary/20"
                            data-url="{{ path('app_community_blog_summarize', { id: article.id }) }}">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
                        Générer résumé IA
                    </button>
                </div>
            {% endif %}
        </div>
    </article>

    <a href="{{ path('app_community_blog') }}" class="inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-foreground">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        Retour au blog
    </a>
</div>

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const btn = document.getElementById('btn-summarize');
    if (!btn) return;
    btn.addEventListener('click', async function() {
        btn.disabled = true;
        btn.textContent = 'Génération en cours…';
        try {
            const resp = await fetch(btn.dataset.url, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            const data = await resp.json();
            if (data.summary) {
                location.reload();
            } else {
                alert(data.error || 'Erreur lors de la génération du résumé');
            }
        } catch (e) {
            alert('Erreur de connexion');
        }
        btn.disabled = false;
        btn.textContent = 'Générer résumé IA';
    });
});
</script>
{% endblock %}
{% endblock %}
