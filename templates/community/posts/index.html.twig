{% extends 'layouts/app.html.twig' %}

{% block page_title %}Publications{% endblock %}

{% block content %}
<div class="mx-auto max-w-2xl space-y-6 pb-8">
    {% include 'community/_subnav.html.twig' %}

    {# Page header #}
    <div class="flex items-end justify-between">
        <div>
            <h2 class="text-2xl font-bold tracking-tight">Fil d'actualit&eacute;</h2>
            <p class="mt-1.5 text-sm text-muted-foreground">Partagez, r&eacute;agissez et &eacute;changez avec la communaut&eacute;.</p>
        </div>
    </div>

    {# Moderation flash #}
    {% for message in app.flashes('moderation') %}
    <div class="animate-fade-in overflow-hidden rounded-2xl border border-red-200 dark:border-red-800/50 bg-red-50/80 dark:bg-red-950/20 p-4 shadow-sm backdrop-blur-sm">
        <div class="flex items-start gap-3">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-red-100 dark:bg-red-900/40">
                <svg class="h-5 w-5 text-red-600 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
                </svg>
            </div>
            <div>
                <p class="font-semibold text-red-700 dark:text-red-400">Publication bloqu&eacute;e par la mod&eacute;ration AI</p>
                <p class="text-sm text-red-600/80 dark:text-red-300/80 mt-1">{{ message }}</p>
            </div>
        </div>
    </div>
    {% endfor %}

    {# Composer #}
    <div class="overflow-hidden rounded-2xl border border-border bg-card shadow-sm transition-shadow duration-300 hover:shadow-md" x-data="{ expanded: false, showEmoji: false, imagePreview: null, imageName: null }">
        {{ form_start(form, { attr: { class: '', enctype: 'multipart/form-data' } }) }}
        {{ form_errors(form) }}

        {# Input area with avatar #}
        <div class="flex items-start gap-3.5 px-5 pt-5 pb-3">
            {% set u = app.user %}
            {% set initials = u.fullName|default(u.username)|split(' ')|map(w => w|first)|join('')|upper|slice(0, 2) %}
            <div class="shrink-0 pt-0.5">
                {{ include('components/avatar.html.twig', { initials: initials, size: 'default' }) }}
            </div>
            <div class="flex-1 relative">
                {{ form_widget(form.content, { id: 'post-content-field', attr: {
                    class: 'w-full resize-none rounded-2xl bg-muted/40 border-0 px-4 py-3 text-sm placeholder:text-muted-foreground/70 focus:ring-2 focus:ring-primary/20 focus:bg-background transition-all duration-200',
                    placeholder: 'Quoi de neuf, ' ~ u.fullName|default(u.username)|split(' ')|first ~ ' ?',
                    rows: '1',
                    '@focus': 'expanded = true',
                    '@input': '$el.style.height = "auto"; $el.style.height = $el.scrollHeight + "px"'
                } }) }}
            </div>
        </div>

        {# Expanded area #}
        <div x-show="expanded" x-collapse x-cloak class="px-5 pb-3 space-y-3">
            {{ form_errors(form.content) }}

            {# Emoji picker #}
            <div class="relative">
                <button type="button" @click="showEmoji = !showEmoji"
                        class="text-muted-foreground hover:text-foreground transition-colors p-1.5 rounded-lg hover:bg-muted"
                        title="Emoji">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 01-6.364 0M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z"/></svg>
                </button>
                <div x-show="showEmoji" @click.away="showEmoji = false" x-transition
                     class="absolute bottom-10 left-0 z-20 grid grid-cols-8 gap-1 rounded-2xl border border-border bg-popover p-3 shadow-xl">
                    {% for emoji in ['&#x1F600;','&#x1F602;','&#x1F60D;','&#x1F973;','&#x1F44D;','&#x1F44F;','&#x1F525;','&#x1F4A1;','&#x1F389;','&#x2764;&#xFE0F;','&#x1F44B;','&#x1F914;','&#x1F60E;','&#x1F64C;','&#x2728;','&#x1F4AA;','&#x1F680;','&#x1F3AF;','&#x1F4BC;','&#x1F4DA;','&#x1F3C6;','&#x1F4AC;','&#x1F4E3;','&#x1F91D;','&#x1F60A;','&#x1F64F;','&#x2B50;','&#x1F48E;','&#x1F31F;','&#x1F4DD;','&#x1F393;','&#x1F4B0;'] %}
                    <button type="button" class="flex h-9 w-9 items-center justify-center rounded-xl text-lg transition-all hover:bg-muted hover:scale-125"
                            @click="const f = document.getElementById('post-content-field'); f.value += '{{ emoji }}'; f.focus(); showEmoji = false">{{ emoji }}</button>
                    {% endfor %}
                </div>
            </div>

            {# Image preview #}
            <div x-show="imagePreview" x-transition class="relative">
                <div class="relative overflow-hidden rounded-2xl border border-border bg-muted/20">
                    <img :src="imagePreview" class="w-full max-h-64 object-cover" alt="Aper&ccedil;u">
                    <button type="button"
                            @click="imagePreview = null; imageName = null; document.getElementById('{{ form.imageFile.vars.id }}').value = ''"
                            class="absolute top-3 right-3 flex h-8 w-8 items-center justify-center rounded-full bg-black/50 text-white backdrop-blur-sm transition-colors hover:bg-black/70">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                    </button>
                </div>
                <p x-show="imageName" class="text-xs text-muted-foreground mt-1.5 pl-1" x-text="imageName"></p>
            </div>

            {# Hidden file input #}
            <div class="hidden">
                {{ form_widget(form.imageFile, { id: form.imageFile.vars.id, attr: {
                    '@change': "const file = $event.target.files[0]; if(file) { imagePreview = URL.createObjectURL(file); imageName = file.name; expanded = true; }"
                } }) }}
            </div>
            {{ form_errors(form.imageFile) }}

            <div class="space-y-1">
                {{ form_widget(form.postType, { attr: {
                    class: 'w-full rounded-xl border border-border bg-background px-3 py-2.5 text-sm shadow-sm focus:ring-2 focus:ring-primary/20 focus:outline-none transition-all'
                } }) }}
                {{ form_errors(form.postType) }}
            </div>
        </div>

        {# Bottom action bar #}
        <div class="flex items-center justify-between border-t border-border/60 px-5 py-3">
            <div class="flex items-center gap-0.5">
                <button type="button" @click="document.getElementById('{{ form.imageFile.vars.id }}').click()"
                        class="flex items-center gap-1.5 rounded-xl px-3 py-2 text-sm font-medium text-muted-foreground transition-all hover:bg-green-500/10 hover:text-green-600 dark:hover:text-green-400">
                    <svg class="h-5 w-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z"/></svg>
                    Photos
                </button>
                <button type="button" @click="expanded = true; showEmoji = !showEmoji"
                        class="flex items-center gap-1.5 rounded-xl px-3 py-2 text-sm font-medium text-muted-foreground transition-all hover:bg-yellow-500/10 hover:text-yellow-600 dark:hover:text-yellow-400">
                    <svg class="h-5 w-5 text-yellow-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 01-6.364 0M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z"/></svg>
                    Humeur
                </button>
                <button type="button" @click="expanded = !expanded"
                        class="flex h-9 w-9 items-center justify-center rounded-xl text-muted-foreground transition-all hover:bg-muted hover:text-foreground">
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><circle cx="5" cy="12" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="19" cy="12" r="2"/></svg>
                </button>
            </div>
            <button type="submit"
                    class="rounded-xl bg-primary px-6 py-2 text-sm font-semibold text-primary-foreground shadow-sm transition-all duration-200 hover:bg-primary/90 hover:shadow-md active:scale-[0.97]">
                Publier
            </button>
        </div>
        {{ form_end(form) }}
    </div>

    {# Feed #}
    <div class="space-y-5">
        {% for post in posts %}
            {% set author = post.author %}
            {% set a_initials = author.fullName|default(author.username)|split(' ')|map(w => w|first)|join('')|upper|slice(0, 2) %}
            <article id="post-{{ post.id }}" class="group/post overflow-hidden rounded-2xl border border-border bg-card text-card-foreground shadow-sm transition-all duration-300 hover:shadow-md animate-fade-in" style="animation-delay:{{ loop.index0 * 0.04 }}s">
                {# Author header #}
                <div class="flex gap-3.5 px-5 pt-5 pb-2">
                    {% if author.photoUrl %}
                        {{ include('components/avatar.html.twig', { src: author.photoUrl, alt: author.fullName, initials: a_initials, size: 'default' }) }}
                    {% else %}
                        {{ include('components/avatar.html.twig', { initials: a_initials, size: 'default' }) }}
                    {% endif %}
                    <div class="min-w-0 flex-1">
                        <div class="flex flex-wrap items-start justify-between gap-2">
                            <div>
                                <div class="flex items-center gap-2">
                                    <p class="font-bold leading-none text-foreground">{{ author.fullName|default(author.username) }}</p>
                                    {% if post.postType != 'STATUS' %}
                                        <span class="inline-flex items-center rounded-lg bg-primary/10 px-2 py-0.5 text-[10px] font-semibold text-primary">{{ post.postTypeLabel }}</span>
                                    {% endif %}
                                </div>
                                <p class="mt-1.5 text-xs text-muted-foreground">
                                    @{{ author.username }} &middot; {{ post.createdAt|date('d/m/Y H:i') }}
                                    {% if post.updatedAt > post.createdAt %}
                                        <span class="italic">&middot; modifi&eacute;</span>
                                    {% endif %}
                                </p>
                            </div>
                            {% if author.id == app.user.id %}
                                <div class="flex shrink-0 items-center gap-1 opacity-0 transition-opacity duration-200 group-hover/post:opacity-100">
                                    <a href="{{ path('app_community_post_edit', { id: post.id }) }}"
                                       class="flex h-8 w-8 items-center justify-center rounded-lg text-muted-foreground transition-all hover:bg-primary/10 hover:text-primary" title="Modifier">
                                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z"/></svg>
                                    </a>
                                    <form method="post" action="{{ path('app_community_post_delete', { id: post.id }) }}" class="inline" onsubmit="return confirm('Supprimer cette publication ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_post_' ~ post.id) }}">
                                        <button type="submit" class="flex h-8 w-8 items-center justify-center rounded-lg text-muted-foreground transition-all hover:bg-destructive/10 hover:text-destructive" title="Supprimer">
                                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                        </button>
                                    </form>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>

                {# Content #}
                <div class="px-5 pb-3">
                    <div class="whitespace-pre-wrap text-[15px] leading-relaxed text-foreground/90">{{ post.content }}</div>
                </div>

                {# Image #}
                {% if post.imageUrl %}
                    <div class="mx-3 mb-3 overflow-hidden rounded-xl border border-border/50">
                        <img src="{{ post.imageUrl }}" alt="" class="max-h-96 w-full object-cover transition-transform duration-500 group-hover/post:scale-[1.01]" loading="lazy" referrerpolicy="no-referrer">
                    </div>
                {% endif %}

                {# Action bar #}
                <div class="flex items-center gap-1 border-t border-border/50 px-3 py-1.5">
                    <button type="button"
                            class="btn-like flex flex-1 items-center justify-center gap-2 rounded-xl py-2 text-sm font-medium transition-all duration-200 {{ post.isLikedBy(app.user) ? 'text-red-500' : 'text-muted-foreground hover:bg-red-500/5 hover:text-red-500' }}"
                            data-post-id="{{ post.id }}"
                            data-url="{{ path('app_community_post_like', { id: post.id }) }}"
                            data-token="{{ csrf_token('like_post_' ~ post.id) }}">
                        <svg class="h-[18px] w-[18px] transition-transform duration-200 hover:scale-110" fill="{{ post.isLikedBy(app.user) ? 'currentColor' : 'none' }}" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>
                        <span class="like-count">{{ post.likesCount }}</span>
                    </button>

                    <button type="button"
                            class="btn-toggle-comments flex flex-1 items-center justify-center gap-2 rounded-xl py-2 text-sm font-medium text-muted-foreground transition-all duration-200 hover:bg-primary/5 hover:text-primary"
                            data-post-id="{{ post.id }}">
                        <svg class="h-[18px] w-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/></svg>
                        <span class="comment-count">{{ post.commentsCount }}</span>
                    </button>

                    <button type="button"
                            class="btn-share flex flex-1 items-center justify-center gap-2 rounded-xl py-2 text-sm font-medium text-muted-foreground transition-all duration-200 hover:bg-primary/5 hover:text-primary"
                            data-post-id="{{ post.id }}" title="Copier le lien">
                        <svg class="h-[18px] w-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0 0a2.25 2.25 0 103.935 2.186 2.25 2.25 0 00-3.935-2.186zm0-12.814a2.25 2.25 0 103.933-2.185 2.25 2.25 0 00-3.933 2.185z"/></svg>
                        <span class="share-count">{{ post.sharesCount }}</span>
                    </button>

                    {# Translate #}
                    <div class="relative flex-1" x-data="{ open: false }">
                        <button type="button" @click="open = !open"
                                class="flex w-full items-center justify-center gap-2 rounded-xl py-2 text-sm font-medium text-muted-foreground transition-all duration-200 hover:bg-primary/5 hover:text-primary">
                            <svg class="h-[18px] w-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 21l5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 016-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 01-3.827-5.802"/></svg>
                            Traduire
                        </button>
                        <div x-show="open" @click.away="open = false" x-transition
                             class="absolute right-0 bottom-full z-50 mb-2 w-40 overflow-hidden rounded-xl border border-border bg-popover p-1.5 shadow-xl">
                            {% for lang, label in { fr: 'Fran&ccedil;ais', en: 'English', ar: '&#x0627;&#x0644;&#x0639;&#x0631;&#x0628;&#x064A;&#x0629;', es: 'Espa&ntilde;ol', de: 'Deutsch' } %}
                                <button type="button"
                                        class="btn-translate flex w-full items-center rounded-lg px-3 py-2 text-left text-sm transition-colors hover:bg-muted"
                                        data-post-id="{{ post.id }}"
                                        data-lang="{{ lang }}"
                                        data-url="{{ path('app_community_post_translate', { id: post.id }) }}"
                                        @click="open = false">
                                    {{ label }}
                                </button>
                            {% endfor %}
                        </div>
                    </div>
                </div>

                {# Translation result #}
                <div class="translation-result hidden mx-5 mb-4 rounded-xl border border-border bg-muted/30 p-4 text-sm" data-post-id="{{ post.id }}"></div>

                {# Comments section #}
                <div class="comments-section hidden border-t border-border/50 bg-muted/10 px-5 py-4 space-y-3" data-post-id="{{ post.id }}">
                    {% if post.comments|length > 0 %}
                        <div class="space-y-3">
                            {% for comment in post.comments %}
                                <div class="flex gap-2.5 text-sm" data-comment-id="{{ comment.id }}">
                                    <div class="shrink-0">
                                        {% set c_initials = comment.author.fullName|default(comment.author.username)|split(' ')|map(w => w|first)|join('')|upper|slice(0, 2) %}
                                        {{ include('components/avatar.html.twig', { initials: c_initials, size: 'sm', class: 'h-7 w-7 text-[10px]' }) }}
                                    </div>
                                    <div class="min-w-0 flex-1">
                                        <div class="inline-block rounded-2xl bg-muted/60 px-3.5 py-2">
                                            <span class="font-semibold text-foreground">{{ comment.author.fullName|default(comment.author.username) }}</span>
                                            <span class="ml-1.5 text-foreground/80">{{ comment.content }}</span>
                                        </div>
                                        <div class="mt-1 flex items-center gap-3 pl-2 text-xs text-muted-foreground">
                                            <span>{{ comment.createdAt|date('d/m H:i') }}</span>
                                            {% if comment.author.id == app.user.id %}
                                                <form method="post" action="{{ path('app_community_comment_delete', { id: comment.id }) }}" class="inline">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_comment_' ~ comment.id) }}">
                                                    <button type="submit" class="font-medium text-destructive/60 transition-colors hover:text-destructive">Supprimer</button>
                                                </form>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}

                    {# New comment form #}
                    <form class="comment-form flex gap-2.5 items-center" data-post-id="{{ post.id }}" data-url="{{ path('app_community_post_comment', { id: post.id }) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('comment_post_' ~ post.id) }}">
                        {% set cu = app.user %}
                        {% set c_initials = cu.fullName|default(cu.username)|split(' ')|map(w => w|first)|join('')|upper|slice(0, 2) %}
                        {{ include('components/avatar.html.twig', { initials: c_initials, size: 'sm', class: 'h-8 w-8 text-[10px] shrink-0' }) }}
                        <input type="text" name="content" placeholder="&Eacute;crire un commentaire&hellip;" required maxlength="2000"
                               class="min-w-0 flex-1 rounded-2xl border-0 bg-muted/50 px-4 py-2.5 text-sm placeholder:text-muted-foreground/60 focus:bg-background focus:ring-2 focus:ring-primary/20 transition-all">
                        <button type="submit" class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-primary text-primary-foreground shadow-sm transition-all hover:bg-primary/90 hover:shadow-md active:scale-95">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
                        </button>
                    </form>
                </div>
            </article>
        {% else %}
            <div class="flex flex-col items-center justify-center rounded-2xl border border-dashed border-border/80 bg-muted/5 py-16 text-center">
                <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-muted">
                    <svg class="h-8 w-8 text-muted-foreground/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/></svg>
                </div>
                <p class="mt-4 text-sm font-semibold text-foreground">Aucune publication</p>
                <p class="mt-1.5 max-w-xs text-xs text-muted-foreground">Soyez le premier &agrave; publier quelque chose dans la communaut&eacute; !</p>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.btn-like').forEach(function(btn) {
        btn.addEventListener('click', async function() {
            try {
                const formData = new FormData();
                formData.append('_token', btn.dataset.token);
                const resp = await fetch(btn.dataset.url, { method: 'POST', body: formData });
                if (!resp.ok) return;
                const data = await resp.json();
                if (data.likesCount !== undefined) {
                    btn.querySelector('.like-count').textContent = data.likesCount;
                    const svg = btn.querySelector('svg');
                    if (data.liked) {
                        btn.classList.remove('text-muted-foreground');
                        btn.classList.add('text-red-500');
                        svg.setAttribute('fill', 'currentColor');
                        svg.style.transform = 'scale(1.3)';
                        setTimeout(() => svg.style.transform = '', 200);
                    } else {
                        btn.classList.add('text-muted-foreground');
                        btn.classList.remove('text-red-500');
                        svg.setAttribute('fill', 'none');
                    }
                }
            } catch (e) { console.error('Like error:', e); }
        });
    });
    document.querySelectorAll('.btn-toggle-comments').forEach(function(btn) {
        btn.addEventListener('click', function() {
            const section = document.querySelector('.comments-section[data-post-id="' + btn.dataset.postId + '"]');
            section.classList.toggle('hidden');
        });
    });
    document.querySelectorAll('.comment-form').forEach(function(form) {
        form.addEventListener('submit', async function(e) {
            e.preventDefault();
            var submitBtn = form.querySelector('button[type="submit"]');
            submitBtn.disabled = true;
            try {
                const formData = new FormData(form);
                const resp = await fetch(form.dataset.url, { method: 'POST', body: formData });
                const data = await resp.json();
                if (data.success) {
                    const input = form.querySelector('input[name="content"]');
                    input.value = '';
                    const postId = form.dataset.postId;
                    const countEl = document.querySelector('.btn-toggle-comments[data-post-id="' + postId + '"] .comment-count');
                    if (countEl) countEl.textContent = data.commentsCount;
                    const commentHtml = '<div class="flex gap-2.5 text-sm"><div class="shrink-0"><div class="flex h-7 w-7 items-center justify-center rounded-full bg-muted text-[10px] font-medium">' + data.comment.author.charAt(0) + '</div></div><div class="min-w-0 flex-1"><div class="inline-block rounded-2xl bg-muted/60 px-3.5 py-2"><span class="font-semibold text-foreground">' + data.comment.author + '</span><span class="ml-1.5 text-foreground/80">' + data.comment.content.replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</span></div><div class="mt-1 pl-2 text-xs text-muted-foreground">' + data.comment.createdAt + '</div></div></div>';
                    form.insertAdjacentHTML('beforebegin', commentHtml);
                }
            } catch (e) { console.error('Comment error:', e); }
            submitBtn.disabled = false;
        });
    });
    document.addEventListener('click', async function(e) {
        const btn = e.target.closest('.btn-translate');
        if (!btn) return;
        const postId = btn.dataset.postId;
        const lang = btn.dataset.lang;
        const url = btn.dataset.url;
        if (!postId || !lang || !url) return;
        const resultDiv = document.querySelector('.translation-result[data-post-id="' + postId + '"]');
        if (!resultDiv) return;
        resultDiv.innerHTML = '<span class="text-muted-foreground italic">Traduction en cours&hellip;</span>';
        resultDiv.classList.remove('hidden');
        try {
            const resp = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
                body: 'lang=' + encodeURIComponent(lang),
            });
            if (!resp.ok) {
                let errMsg = 'Erreur ' + resp.status;
                try { const errData = await resp.json(); errMsg = errData.error || errMsg; } catch(x) {}
                resultDiv.innerHTML = '<span class="text-red-500 text-xs">' + errMsg + '</span>';
                return;
            }
            const data = await resp.json();
            if (data.translatedContent) {
                resultDiv.innerHTML = '<div class="flex items-center justify-between"><span>' + data.translatedContent.replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</span><button type="button" class="btn-revert-translate ml-2 text-xs font-medium text-primary hover:underline" data-post-id="' + postId + '">Original</button></div>';
            } else if (data.error) {
                resultDiv.innerHTML = '<span class="text-red-500 text-xs">' + data.error + '</span>';
            }
        } catch (err) {
            resultDiv.innerHTML = '<span class="text-red-500 text-xs">Erreur r&eacute;seau</span>';
        }
    });
    document.addEventListener('click', function(e) {
        const btn = e.target.closest('.btn-revert-translate');
        if (!btn) return;
        const resultDiv = document.querySelector('.translation-result[data-post-id="' + btn.dataset.postId + '"]');
        if (resultDiv) { resultDiv.classList.add('hidden'); resultDiv.innerHTML = ''; }
    });
    document.querySelectorAll('.btn-share').forEach(function(btn) {
        btn.addEventListener('click', function() {
            const url = window.location.origin + '/community/posts#post-' + btn.dataset.postId;
            navigator.clipboard.writeText(url).then(function() {
                const countEl = btn.querySelector('.share-count');
                if (countEl) { const orig = countEl.textContent; countEl.textContent = '\u2713'; setTimeout(function() { countEl.textContent = orig; }, 1500); }
            });
        });
    });
});
</script>
{% endblock %}
