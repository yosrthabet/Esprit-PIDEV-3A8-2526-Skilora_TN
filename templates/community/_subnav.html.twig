{# Community section sub-navigation #}
{% set current_route = app.request.attributes.get('_route') %}
{% set net_routes = [
    'app_community_network', 'app_community_dm_edit',
    'app_community_invitation_send', 'app_community_invitation_accept', 'app_community_invitation_decline', 'app_community_invitation_cancel',
    'app_community_dm_start', 'app_community_dm_send', 'app_community_dm_delete',
] %}
{% set blog_routes = ['app_community_blog', 'app_community_blog_new', 'app_community_blog_show', 'app_community_blog_edit'] %}
{% set event_routes = ['app_community_events', 'app_community_event_new', 'app_community_event_show', 'app_community_event_edit'] %}
{% set group_routes = ['app_community_groups', 'app_community_group_new', 'app_community_group_show', 'app_community_group_edit'] %}

{% macro nav_link(href, label, icon, is_active, badge) %}
    <a href="{{ href }}"
       class="relative inline-flex items-center gap-2 whitespace-nowrap rounded-xl px-4 py-2.5 text-sm font-medium transition-all duration-200
              {{ is_active
                  ? 'bg-background text-foreground shadow-md ring-1 ring-border/60 scale-[1.02]'
                  : 'text-muted-foreground hover:bg-background/60 hover:text-foreground hover:shadow-sm' }}">
        <span class="transition-transform duration-200 {{ is_active ? 'scale-110' : 'group-hover:scale-105' }}">{{ icon|raw }}</span>
        <span>{{ label }}</span>
        {% if is_active %}
            <span class="absolute -bottom-[5px] left-1/2 h-1 w-6 -translate-x-1/2 rounded-full bg-primary"></span>
        {% endif %}
    </a>
{% endmacro %}

<nav class="mb-6 flex items-center gap-1.5 overflow-x-auto rounded-2xl border border-border bg-muted/30 p-1.5 shadow-sm backdrop-blur-md scrollbar-none">
    {{ _self.nav_link(
        path('app_community'),
        'Accueil',
        '<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>',
        current_route == 'app_community'
    ) }}
    {{ _self.nav_link(
        path('app_community_posts'),
        'Publications',
        '<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>',
        current_route in ['app_community_posts', 'app_community_post_edit']
    ) }}
    {{ _self.nav_link(
        path('app_community_network'),
        'R&eacute;seau',
        '<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>',
        current_route in net_routes
    ) }}
    {{ _self.nav_link(
        path('app_community_blog'),
        'Blog',
        '<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>',
        current_route in blog_routes
    ) }}
    {{ _self.nav_link(
        path('app_community_events'),
        '&Eacute;v&eacute;nements',
        '<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>',
        current_route in event_routes
    ) }}
    {{ _self.nav_link(
        path('app_community_groups'),
        'Groupes',
        '<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>',
        current_route in group_routes
    ) }}
</nav>
