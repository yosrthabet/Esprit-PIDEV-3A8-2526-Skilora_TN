{# Community section sub-navigation #}
{% set net_routes = [
    'app_community_network', 'app_community_dm_edit',
    'app_community_invitation_send', 'app_community_invitation_accept', 'app_community_invitation_decline', 'app_community_invitation_cancel',
    'app_community_dm_start', 'app_community_dm_send', 'app_community_dm_delete',
] %}
<nav class="mb-6 flex items-center gap-1 rounded-xl border border-border bg-muted/40 p-1 backdrop-blur-sm">
    <a href="{{ path('app_community') }}"
       class="inline-flex items-center gap-2 rounded-lg px-4 py-2.5 text-sm font-medium transition-all duration-200
              {{ app.request.attributes.get('_route') == 'app_community'
                 ? 'bg-background text-foreground shadow-sm ring-1 ring-border/50'
                 : 'text-muted-foreground hover:bg-background/60 hover:text-foreground' }}">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        Accueil
    </a>
    <a href="{{ path('app_community_posts') }}"
       class="inline-flex items-center gap-2 rounded-lg px-4 py-2.5 text-sm font-medium transition-all duration-200
              {{ app.request.attributes.get('_route') in ['app_community_posts', 'app_community_post_edit']
                 ? 'bg-background text-foreground shadow-sm ring-1 ring-border/50'
                 : 'text-muted-foreground hover:bg-background/60 hover:text-foreground' }}">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
        Publications
    </a>
    <a href="{{ path('app_community_network') }}"
       class="inline-flex items-center gap-2 rounded-lg px-4 py-2.5 text-sm font-medium transition-all duration-200
              {{ app.request.attributes.get('_route') in net_routes
                 ? 'bg-background text-foreground shadow-sm ring-1 ring-border/50'
                 : 'text-muted-foreground hover:bg-background/60 hover:text-foreground' }}">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
        Réseau & messagerie
    </a>
</nav>
