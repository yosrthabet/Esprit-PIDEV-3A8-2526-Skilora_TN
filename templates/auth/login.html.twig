{# auth/login.html.twig — Login page using ShadCN components #}
{% extends 'layouts/auth.html.twig' %}

{% block title %}Sign In — Skilora{% endblock %}

{% block auth_quote %}"The platform that changed how I find freelance work in Tunisia."{% endblock %}
{% block auth_attribution %}— Ahmed, Senior Developer{% endblock %}

{% block content %}
<div class="space-y-6">
    <div class="space-y-2">
        <h1 class="text-2xl font-bold tracking-tight">Welcome back</h1>
        <p class="text-sm text-muted-foreground">Enter your credentials to access your account</p>
    </div>

    {% if login_error %}
        {{ include('components/alert.html.twig', {
            variant: 'destructive',
            title: 'Authentication failed',
            body: login_error|trans({}, 'security'),
        }) }}
    {% endif %}

    <form method="post" action="{{ path('app_login') }}" class="space-y-4">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <div class="space-y-2">
            {{ include('components/label.html.twig', { for: '_username', text: 'Username', required: true }) }}
            {{ include('components/input.html.twig', {
                type: 'text',
                name: '_username',
                id: '_username',
                placeholder: 'Enter your username',
                value: last_username,
                required: true,
                autofocus: true,
            }) }}
        </div>

        <div class="space-y-2">
            {{ include('components/label.html.twig', { for: '_password', text: 'Password', required: true }) }}
            {{ include('components/password-input.html.twig', {
                name: '_password',
                id: '_password',
                placeholder: 'Enter your password',
                required: true,
            }) }}
        </div>

        <div class="flex items-center justify-between">
            <label class="flex items-center gap-2 text-sm">
                <input type="checkbox" name="_remember_me" class="h-4 w-4 rounded border-input text-primary focus:ring-primary">
                <span class="text-muted-foreground">Remember me</span>
            </label>
            <a href="{{ path('app_forgot_password') }}" class="text-sm font-medium text-primary hover:underline">Forgot password?</a>
        </div>

        {{ include('components/button.html.twig', {
            type: 'submit',
            label: 'Sign In',
            variant: 'default',
            size: 'lg',
            class: 'w-full',
        }) }}
    </form>

    <div class="relative">
        <div class="absolute inset-0 flex items-center">
            <span class="w-full border-t border-border"></span>
        </div>
        <div class="relative flex justify-center text-xs uppercase">
            <span class="bg-background px-2 text-muted-foreground">Or continue with</span>
        </div>
    </div>

    <div class="grid grid-cols-2 gap-3">
        <a href="{{ path('app_oauth_connect', {provider: 'github'}) }}"
           class="inline-flex h-10 w-full items-center justify-center gap-2 rounded-md border border-input bg-background text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
            GitHub
        </a>

        <button type="button" id="passkey-login-btn"
                class="inline-flex h-10 w-full items-center justify-center gap-2 rounded-md border border-input bg-background text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground disabled:opacity-50"
                style="display:none;">
            <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7.864 4.243A7.5 7.5 0 0 1 19.5 10.5c0 2.92-.556 5.709-1.568 8.268M5.742 6.364A7.465 7.465 0 0 0 4.5 10.5a48.667 48.667 0 0 0-6 0c0 1.97-.153 3.897-.447 5.767m.75-9.284a6.97 6.97 0 0 0-1.5 4.281 5.507 5.507 0 0 1 0 10.723M12 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm-1.5 0a1.5 1.5 0 1 0-3 0 1.5 1.5 0 0 0 3 0Z"/>
            </svg>
            Passkey
        </button>
    </div>

    <div id="passkey-error" class="hidden text-sm text-destructive text-center"></div>

    <p class="text-center text-sm text-muted-foreground">
        Don't have an account?
        <a href="{{ path('app_register') }}" class="font-medium text-primary hover:underline">Create account</a>
    </p>
</div>

<script>
(function() {
    const btn = document.getElementById('passkey-login-btn');
    const errorEl = document.getElementById('passkey-error');

    // Only show if browser supports WebAuthn
    if (window.PublicKeyCredential) {
        btn.style.display = '';

        // Check if conditional mediation (autofill) is available
        if (PublicKeyCredential.isConditionalMediationAvailable) {
            PublicKeyCredential.isConditionalMediationAvailable().then(function(ok) {
                if (ok) btn.title = 'Sign in with Face ID, Touch ID, Windows Hello, or your security key';
            });
        }
    }

    btn.addEventListener('click', async function() {
        btn.disabled = true;
        btn.textContent = 'Waiting for device…';
        errorEl.classList.add('hidden');

        try {
            // 1. Get challenge from server
            const optRes = await fetch('{{ path("passkey_auth_options") }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
            });
            const options = await optRes.json();

            // 2. Convert base64url challenge to ArrayBuffer
            options.challenge = base64urlToBuffer(options.challenge);

            // Convert allowCredentials if any
            if (options.allowCredentials) {
                options.allowCredentials = options.allowCredentials.map(function(c) {
                    c.id = base64urlToBuffer(c.id);
                    return c;
                });
            }

            // 3. Prompt biometric / passkey
            const assertion = await navigator.credentials.get({ publicKey: options });

            // 4. Send response to server
            const credential = {
                id: assertion.id,
                rawId: bufferToBase64url(assertion.rawId),
                type: assertion.type,
                response: {
                    authenticatorData: bufferToBase64url(assertion.response.authenticatorData),
                    clientDataJSON: bufferToBase64url(assertion.response.clientDataJSON),
                    signature: bufferToBase64url(assertion.response.signature),
                    userHandle: assertion.response.userHandle ? bufferToBase64url(assertion.response.userHandle) : null,
                },
            };

            const verifyRes = await fetch('{{ path("passkey_auth_verify") }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ credential: credential }),
            });

            const result = await verifyRes.json();

            if (result.success && result.redirect) {
                window.location.href = result.redirect;
            } else {
                throw new Error(result.error || 'Authentication failed');
            }
        } catch (e) {
            if (e.name === 'NotAllowedError') {
                // User cancelled — just reset
            } else {
                errorEl.textContent = e.message || 'Passkey authentication failed';
                errorEl.classList.remove('hidden');
            }
            btn.disabled = false;
            btn.innerHTML = '<svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M7.864 4.243A7.5 7.5 0 0 1 19.5 10.5c0 2.92-.556 5.709-1.568 8.268M5.742 6.364A7.465 7.465 0 0 0 4.5 10.5a48.667 48.667 0 0 0-6 0c0 1.97-.153 3.897-.447 5.767m.75-9.284a6.97 6.97 0 0 0-1.5 4.281 5.507 5.507 0 0 1 0 10.723M12 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm-1.5 0a1.5 1.5 0 1 0-3 0 1.5 1.5 0 0 0 3 0Z"/></svg> Passkey';
        }
    });

    function base64urlToBuffer(b64url) {
        const b64 = b64url.replace(/-/g, '+').replace(/_/g, '/');
        const pad = b64.length % 4 === 0 ? '' : '='.repeat(4 - (b64.length % 4));
        const bin = atob(b64 + pad);
        const buf = new Uint8Array(bin.length);
        for (let i = 0; i < bin.length; i++) buf[i] = bin.charCodeAt(i);
        return buf.buffer;
    }

    function bufferToBase64url(buf) {
        const bytes = new Uint8Array(buf);
        let binary = '';
        for (let i = 0; i < bytes.length; i++) binary += String.fromCharCode(bytes[i]);
        return btoa(binary).replace(/\+/g, '-').replace(/\//g, '_').replace(/=/g, '');
    }
})();
</script>
{% endblock %}
