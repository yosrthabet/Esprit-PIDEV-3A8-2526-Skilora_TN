{% extends 'layouts/auth.html.twig' %}

{% block title %}Choose New Password — Skilora{% endblock %}

{% block auth_quote %}"A secure recovery flow builds trust."{% endblock %}
{% block auth_attribution %}— Skilora Security Team{% endblock %}

{% block content %}
<div class="space-y-6">
    <div class="space-y-2">
        <h1 class="text-2xl font-bold tracking-tight">Set a new password</h1>
        <p class="text-sm text-muted-foreground">Enter your new password below</p>
    </div>

    {% if errors is defined and errors %}
        {% for err in errors %}
            {{ include('components/alert.html.twig', {
                variant: 'destructive',
                body: err,
            }) }}
        {% endfor %}
    {% endif %}

    <form method="post" action="{{ path('app_reset_password', { token: token }) }}" class="space-y-4">
        <div class="space-y-2">
            {{ include('components/label.html.twig', { for: 'password', text: 'New Password', required: true }) }}
            {{ include('components/password-input.html.twig', {
                name: 'password',
                id: 'password',
                placeholder: '••••••••',
                required: true,
            }) }}
        </div>

        <div class="space-y-2">
            {{ include('components/label.html.twig', { for: 'confirm_password', text: 'Confirm Password', required: true }) }}
            {{ include('components/password-input.html.twig', {
                name: 'confirm_password',
                id: 'confirm_password',
                placeholder: '••••••••',
                required: true,
            }) }}
        </div>

        {{ include('components/button.html.twig', {
            type: 'submit',
            label: 'Reset Password',
            variant: 'default',
            size: 'lg',
            class: 'w-full',
        }) }}
    </form>
</div>
{% endblock %}
