{% extends 'recruitment/employer/base.html.twig' %}

{% block employer_title %}Planifier un entretien · Skilora{% endblock %}
{% block page_title %}Planifier un entretien{% endblock %}

{% block employer_content %}
<div class="max-w-xl space-y-6">
    <div>
        <p class="text-sm text-muted-foreground">
            <a href="{{ path('app_employer_interviews') }}" class="hover:text-foreground hover:underline">Entretiens</a>
            <span class="mx-1">/</span>
            <span>Planification</span>
        </p>
        <h2 class="mt-2 text-2xl font-bold tracking-tight text-foreground">Planifier l’entretien</h2>
        <p class="mt-1 text-sm text-muted-foreground">
            <span class="font-medium text-foreground">{{ candidature.candidateName }}</span>
            {% if candidature.candidateEmail %} · {{ candidature.candidateEmail }}{% endif %}
        </p>
        <p class="mt-1 text-sm text-muted-foreground">{{ job_offer.title }}</p>
    </div>

    {{ form_start(form, { attr: { class: 'space-y-5', novalidate: 'novalidate' } }) }}

    <div class="grid gap-4 sm:grid-cols-2">
        <div class="space-y-2">
            {{ form_label(form.interviewDate, null, { label_attr: { class: 'text-sm font-medium leading-none' } }) }}
            {{ form_widget(form.interviewDate) }}
            {{ form_errors(form.interviewDate) }}
        </div>
        <div class="space-y-2">
            {{ form_label(form.interviewTime, null, { label_attr: { class: 'text-sm font-medium leading-none' } }) }}
            {{ form_widget(form.interviewTime) }}
            {{ form_errors(form.interviewTime) }}
        </div>
    </div>

    <div class="rounded-xl border border-border bg-muted/30 p-4 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-wide text-muted-foreground">Aperçu</p>
        <p id="js-interview-recap-datetime" class="mt-2 text-sm font-medium text-foreground">—</p>
        <p id="js-interview-recap-location" class="mt-1 text-sm text-muted-foreground">—</p>
        <p class="mt-3 text-xs font-medium text-muted-foreground">Temps restant</p>
        <p id="js-interview-preview-countdown"
           class="mt-1 text-sm font-medium tabular-nums text-sky-800 dark:text-sky-200"
           data-interview-countdown
           data-locale="fr"
           data-empty-label="Choisissez une date et une heure"
           data-at=""></p>
    </div>

    <div class="space-y-2">
        {{ form_label(form.format, null, { label_attr: { class: 'text-sm font-medium leading-none' } }) }}
        {{ form_widget(form.format, { attr: { 'data-format-select': '1' } }) }}
        {{ form_errors(form.format) }}
    </div>

    <div id="interview-location-wrap" class="space-y-2">
        {{ form_label(form.location, null, { label_attr: { class: 'text-sm font-medium leading-none' } }) }}
        {{ form_widget(form.location) }}
        {{ form_errors(form.location) }}
        {{ form_help(form.location) }}
    </div>

    <div class="space-y-2">
        {{ form_label(form.notes, null, { label_attr: { class: 'text-sm font-medium leading-none' } }) }}
        {{ form_widget(form.notes) }}
        {{ form_errors(form.notes) }}
        {{ form_help(form.notes) }}
    </div>

    <div class="flex flex-wrap gap-3 pt-2">
        <button type="submit"
                class="inline-flex h-9 items-center justify-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow-sm transition hover:bg-primary/90 focus-ring">
            Enregistrer
        </button>
        <a href="{{ path('app_employer_interviews') }}"
           class="inline-flex h-9 items-center justify-center rounded-md border border-input bg-background px-4 text-sm font-medium shadow-sm transition hover:bg-accent hover:text-accent-foreground">
            Annuler
        </a>
    </div>
    {{ form_end(form) }}
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% include 'recruitment/components/_interview_countdown_script.html.twig' %}
    <script>
        (function () {
            var dateEl = document.getElementById({{ form.interviewDate.vars.id|json_encode|raw }});
            var timeEl = document.getElementById({{ form.interviewTime.vars.id|json_encode|raw }});
            var formatEl = document.getElementById({{ form.format.vars.id|json_encode|raw }});
            var loc = document.getElementById({{ form.location.vars.id|json_encode|raw }});
            var locWrap = document.getElementById('interview-location-wrap');
            var recapDt = document.getElementById('js-interview-recap-datetime');
            var recapLoc = document.getElementById('js-interview-recap-location');
            var cd = document.getElementById('js-interview-preview-countdown');
            if (!dateEl || !timeEl || !recapDt || !cd) {
                return;
            }
            function combineLocalIso() {
                var d = dateEl.value;
                var t = timeEl.value;
                if (!d || !t) {
                    return null;
                }
                return d + 'T' + t;
            }
            function fmtLocal(iso) {
                if (!iso) {
                    return '';
                }
                var dt = new Date(iso);
                if (isNaN(dt.getTime())) {
                    return iso;
                }
                try {
                    return dt.toLocaleString('fr-FR', {
                        weekday: 'short',
                        day: '2-digit',
                        month: 'short',
                        year: 'numeric',
                        hour: '2-digit',
                        minute: '2-digit',
                    });
                } catch (e) {
                    return dt.toISOString();
                }
            }
            function isOnsite() {
                return formatEl && formatEl.value === 'ONSITE';
            }
            function sync() {
                var iso = combineLocalIso();
                if (iso) {
                    var dt = new Date(iso);
                    recapDt.textContent = fmtLocal(iso);
                    if (!isNaN(dt.getTime())) {
                        cd.setAttribute('data-at', dt.toISOString());
                        cd.setAttribute('data-at-ms', String(dt.getTime()));
                    } else {
                        cd.removeAttribute('data-at');
                        cd.removeAttribute('data-at-ms');
                    }
                } else {
                    recapDt.textContent = '—';
                    cd.removeAttribute('data-at');
                    cd.removeAttribute('data-at-ms');
                }
                var l = loc && loc.value ? loc.value.trim() : '';
                if (isOnsite()) {
                    recapLoc.textContent = l ? ('📍 ' + l) : 'Lieu obligatoire (présentiel)';
                } else {
                    recapLoc.textContent = 'En ligne — lieu facultatif (ignoré à l’enregistrement)';
                }
                if (typeof window.initInterviewCountdowns === 'function') {
                    window.initInterviewCountdowns();
                }
            }
            dateEl.addEventListener('input', sync);
            dateEl.addEventListener('change', sync);
            timeEl.addEventListener('input', sync);
            timeEl.addEventListener('change', sync);
            if (formatEl) {
                formatEl.addEventListener('change', sync);
            }
            if (loc) {
                loc.removeAttribute('readonly');
                loc.removeAttribute('disabled');
                loc.addEventListener('input', sync);
                loc.addEventListener('change', sync);
            }
            sync();
        })();
    </script>
{% endblock %}
