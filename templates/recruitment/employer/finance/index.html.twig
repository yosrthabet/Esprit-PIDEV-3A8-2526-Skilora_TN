{% extends 'layouts/app.html.twig' %}

{% block page_title %}Finance{% endblock %}

{% block content %}
<script>window.__EMP_PORTAL__ = {{ employer_portal_json|raw }};</script>
<script>
function employerFinanceInit() {
    var portal = window.__EMP_PORTAL__ || { kpis: { headcount: 0, payroll_mass: 0, total_disbursed: 0, bank_alerts: 0 }, members: [], details: {} };
    var pdfExportUrl = {{ employer_pdf_export_url|json_encode|raw }};
    var nf = new Intl.NumberFormat('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    return {
        portal: portal,
        search: '',
        selectedId: portal.members.length ? portal.members[0].userId : null,
        pdfStatus: '',
        pdfStatusError: false,
        fmtMoney: function (v) { return nf.format(Number(v) || 0); },
        get filteredMembers() {
            var q = this.search.trim().toLowerCase();
            if (!q) return this.portal.members;
            return this.portal.members.filter(function (m) {
                return (m.fullName || '').toLowerCase().includes(q) || String(m.userId).includes(q);
            });
        },
        get current() {
            if (this.selectedId == null) return null;
            return this.portal.details[this.selectedId] || null;
        },
        async downloadFinancePdf() {
            if (this.selectedId == null) {
                this.pdfStatus = 'Veuillez choisir un employé.';
                this.pdfStatusError = true;
                return;
            }
            this.pdfStatus = 'Génération du PDF…';
            this.pdfStatusError = false;
            var url = pdfExportUrl + '?user=' + encodeURIComponent(String(this.selectedId));
            try {
                var res = await fetch(url, { credentials: 'same-origin', headers: { 'Accept': 'application/pdf', 'X-Requested-With': 'XMLHttpRequest' } });
                if (!res.ok) throw new Error('HTTP ' + res.status);
                var blob = await res.blob();
                var name = 'rapport_finance_employe_' + this.selectedId + '.pdf';
                var a = document.createElement('a');
                a.href = URL.createObjectURL(blob);
                a.download = name;
                document.body.appendChild(a);
                a.click();
                a.remove();
                URL.revokeObjectURL(a.href);
                this.pdfStatus = 'Téléchargement lancé.';
            } catch (e) {
                this.pdfStatus = 'Échec du téléchargement PDF.';
                this.pdfStatusError = true;
            }
        }
    };
}
</script>

<div x-data="employerFinanceInit()" class="space-y-6 pb-6">
    <div class="rounded-2xl border border-border bg-gradient-to-r from-sky-500/10 via-primary/5 to-transparent p-6">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div>
                <h2 class="text-2xl font-bold tracking-tight text-foreground">{{ employer_greeting }}, {{ employer_user_display }}</h2>
                <p class="mt-1 text-sm text-muted-foreground">Tableau de bord financier employeur · {{ employer_date_label }}</p>
            </div>
            <button type="button" @click="downloadFinancePdf()" class="inline-flex items-center gap-2 rounded-xl bg-primary px-4 py-2.5 text-sm font-semibold text-primary-foreground shadow-sm hover:opacity-95">
                <i data-lucide="file-text" class="h-4 w-4"></i>
                Export PDF employé
            </button>
        </div>
        <p class="mt-3 text-xs" :class="pdfStatusError ? 'text-destructive' : 'text-muted-foreground'" x-show="pdfStatus" x-text="pdfStatus"></p>
    </div>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-2xl border border-border bg-card p-5 shadow-sm"><p class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Effectif</p><p class="mt-3 text-2xl font-bold text-foreground" x-text="portal.kpis.headcount">0</p></div>
        <div class="rounded-2xl border border-border bg-card p-5 shadow-sm"><p class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Masse salariale</p><p class="mt-3 text-2xl font-bold text-foreground"><span x-text="fmtMoney(portal.kpis.payroll_mass)">0,00</span> TND</p></div>
        <div class="rounded-2xl border border-border bg-card p-5 shadow-sm"><p class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Total déboursé</p><p class="mt-3 text-2xl font-bold text-foreground"><span x-text="fmtMoney(portal.kpis.total_disbursed)">0,00</span> TND</p></div>
        <div class="rounded-2xl border border-border bg-card p-5 shadow-sm"><p class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Alertes bancaires</p><p class="mt-3 text-2xl font-bold text-foreground" x-text="portal.kpis.bank_alerts">0</p></div>
    </div>

    <div class="grid gap-6 xl:grid-cols-[0.95fr,1.35fr]">
        <section class="rounded-2xl border border-border bg-card p-6 shadow-sm">
            <div class="mb-4 flex items-center justify-between gap-3">
                <h3 class="text-lg font-semibold text-foreground">Équipe finance</h3>
                <span class="text-xs text-muted-foreground" x-text="filteredMembers.length + ' employé(s)'">0 employé(s)</span>
            </div>
            <div class="relative mb-4">
                <i data-lucide="search" class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-muted-foreground"></i>
                <input type="search" x-model="search" placeholder="Rechercher un employé…" class="w-full rounded-xl border border-input bg-background py-2.5 pl-10 pr-3 text-sm text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring" />
            </div>
            <div class="space-y-2">
                <template x-for="member in filteredMembers" :key="member.userId">
                    <button type="button" @click="selectedId = member.userId"
                            class="flex w-full items-center justify-between rounded-xl border px-4 py-3 text-left transition"
                            :class="selectedId === member.userId ? 'border-primary bg-primary/5' : 'border-border bg-muted/20 hover:bg-muted/40'">
                        <div>
                            <p class="font-semibold text-foreground" x-text="member.fullName"></p>
                            <p class="text-xs text-muted-foreground" x-text="'#' + member.userId + (member.roleHint ? ' · ' + member.roleHint : '')"></p>
                        </div>
                        <p class="text-sm font-semibold text-foreground"><span x-text="fmtMoney(member.latestEstimatedNet)"></span> TND</p>
                    </button>
                </template>
            </div>
        </section>

        <section class="rounded-2xl border border-border bg-card p-6 shadow-sm">
            <template x-if="current">
                <div class="space-y-6">
                    <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                        <div>
                            <h3 class="text-lg font-semibold text-foreground" x-text="current.member.fullName"></h3>
                            <p class="text-sm text-muted-foreground" x-text="current.contract ? (current.contract.position || 'Poste non renseigné') : 'Aucun contrat'"></p>
                        </div>
                        <div class="rounded-xl border border-border bg-muted/20 px-4 py-3 text-right">
                            <p class="text-xs uppercase tracking-wider text-muted-foreground">Dernier net</p>
                            <p class="text-xl font-bold text-foreground"><span x-text="fmtMoney(current.member.latestEstimatedNet)"></span> TND</p>
                        </div>
                    </div>

                    <div class="grid gap-4 md:grid-cols-2">
                        <div class="rounded-xl border border-border bg-muted/20 p-4">
                            <p class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Contrat</p>
                            <template x-if="current.contract">
                                <div class="mt-3 space-y-2 text-sm">
                                    <p><span class="text-muted-foreground">Type :</span> <span class="font-medium text-foreground" x-text="current.contract.type || '—'"></span></p>
                                    <p><span class="text-muted-foreground">Statut :</span> <span class="font-medium text-foreground" x-text="current.contract.status || '—'"></span></p>
                                    <p><span class="text-muted-foreground">Ancienneté :</span> <span class="font-medium text-foreground" x-text="current.contract.tenure_label || '—'"></span></p>
                                    <p><span class="text-muted-foreground">Salaire :</span> <span class="font-medium text-foreground"><span x-text="fmtMoney(current.contract.salary)"></span> TND</span></p>
                                </div>
                            </template>
                        </div>
                        <div class="rounded-xl border border-border bg-muted/20 p-4">
                            <p class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Comptes bancaires</p>
                            <div class="mt-3 space-y-2 text-sm">
                                <template x-for="account in current.bank_accounts" :key="account.iban + (account.bank_name || '')">
                                    <div class="rounded-lg border border-border bg-background px-3 py-2">
                                        <p class="font-medium text-foreground" x-text="account.bank_name || 'Banque'"></p>
                                        <p class="text-muted-foreground" x-text="'IBAN : ' + (account.iban || '—')"></p>
                                    </div>
                                </template>
                            </div>
                        </div>
                    </div>

                    <div class="grid gap-4 md:grid-cols-2">
                        <div>
                            <h4 class="mb-3 text-sm font-semibold text-foreground">Bulletins récents</h4>
                            <div class="space-y-2">
                                <template x-for="payslip in current.payslips.slice(0, 4)" :key="payslip.period">
                                    <div class="rounded-xl border border-border bg-muted/20 px-4 py-3 text-sm">
                                        <div class="flex items-center justify-between gap-3">
                                            <span class="font-medium text-foreground" x-text="payslip.period"></span>
                                            <span class="font-semibold text-foreground"><span x-text="fmtMoney(payslip.net_estimated)"></span> TND</span>
                                        </div>
                                        <p class="mt-1 text-xs text-muted-foreground" x-text="'Brut : ' + fmtMoney(payslip.gross_estimated) + ' TND · ' + (payslip.status || 'DRAFT')"></p>
                                    </div>
                                </template>
                            </div>
                        </div>
                        <div>
                            <h4 class="mb-3 text-sm font-semibold text-foreground">Primes</h4>
                            <div class="space-y-2">
                                <template x-for="bonus in current.bonuses.slice(0, 4)" :key="(bonus.reason || '') + (bonus.date_awarded || '') + bonus.amount">
                                    <div class="rounded-xl border border-border bg-muted/20 px-4 py-3 text-sm">
                                        <div class="flex items-center justify-between gap-3">
                                            <span class="font-medium text-foreground" x-text="bonus.reason || 'Prime'"></span>
                                            <span class="font-semibold text-foreground"><span x-text="fmtMoney(bonus.amount)"></span> TND</span>
                                        </div>
                                        <p class="mt-1 text-xs text-muted-foreground" x-text="bonus.date_awarded || 'Date indisponible'"></p>
                                    </div>
                                </template>
                            </div>
                        </div>
                    </div>
                </div>
            </template>
        </section>
    </div>

    <section class="rounded-2xl border border-border bg-card p-6 shadow-sm">
        <h3 class="text-lg font-semibold text-foreground">Calculateur de taxes tunisiennes</h3>
        <div class="mt-4 grid gap-6 xl:grid-cols-2">
            <form method="get" class="space-y-3 rounded-xl border border-border bg-muted/20 p-4">
                <div>
                    <label class="mb-1 block text-xs font-medium text-muted-foreground">Salaire brut</label>
                    <input type="number" step="0.01" min="0" name="simp_gross" value="{{ simp_gross_input }}" class="w-full rounded-xl border border-input bg-background px-3 py-2.5 text-sm text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring" />
                </div>
                <div>
                    <label class="mb-1 block text-xs font-medium text-muted-foreground">Devise</label>
                    <select name="simp_currency" class="w-full rounded-xl border border-input bg-background px-3 py-2.5 text-sm text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                        <option value="TND"{% if simp_currency == 'TND' %} selected{% endif %}>TND</option>
                        <option value="EUR"{% if simp_currency == 'EUR' %} selected{% endif %}>EUR</option>
                        <option value="USD"{% if simp_currency == 'USD' %} selected{% endif %}>USD</option>
                    </select>
                </div>
                <button type="submit" class="inline-flex items-center gap-2 rounded-xl bg-primary px-4 py-2.5 text-sm font-semibold text-primary-foreground shadow-sm hover:opacity-95">
                    <i data-lucide="calculator" class="h-4 w-4"></i>
                    Calculer
                </button>
            </form>

            <div class="rounded-xl border border-border bg-muted/20 p-4">
                {% if simp_tax %}
                    <div class="grid gap-3 sm:grid-cols-2">
                        <div><p class="text-xs uppercase tracking-wider text-muted-foreground">CNSS</p><p class="mt-1 text-lg font-bold text-foreground">{{ simp_tax.cnss|number_format(2, ',', ' ') }} {{ simp_currency }}</p></div>
                        <div><p class="text-xs uppercase tracking-wider text-muted-foreground">IRPP</p><p class="mt-1 text-lg font-bold text-foreground">{{ simp_tax.irpp|number_format(2, ',', ' ') }} {{ simp_currency }}</p></div>
                        <div><p class="text-xs uppercase tracking-wider text-muted-foreground">Déductions</p><p class="mt-1 text-lg font-bold text-foreground">{{ simp_tax.total_deductions|number_format(2, ',', ' ') }} {{ simp_currency }}</p></div>
                        <div><p class="text-xs uppercase tracking-wider text-muted-foreground">Net</p><p class="mt-1 text-lg font-bold text-foreground">{{ simp_tax.net|number_format(2, ',', ' ') }} {{ simp_currency }}</p></div>
                    </div>
                {% else %}
                    <p class="text-sm text-muted-foreground">Saisissez un salaire brut pour obtenir une estimation CNSS/IRPP.</p>
                {% endif %}
            </div>
        </div>
    </section>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    if (window.lucide) lucide.createIcons();
});
</script>
{% endblock %}
