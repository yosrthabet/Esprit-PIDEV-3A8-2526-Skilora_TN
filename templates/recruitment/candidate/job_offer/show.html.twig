{% extends 'recruitment/candidate/base.html.twig' %}

{% block candidate_title %}{{ job_offer.title }}{% endblock %}
{% block candidate_page_title %}Détail de l'offre{% endblock %}

{% set wt = job_offer.workType %}
{% set company_label = job_offer.companyName|default(job_offer.company.name|default('')) %}

{% block candidate_content %}
<div class="space-y-6 pb-6">

    {# ── BREADCRUMB ── #}
    <nav class="flex items-center gap-2 text-sm font-medium text-muted-foreground">
        <a href="{{ path('app_candidate_offres_index') }}" class="inline-flex items-center gap-1.5 rounded-lg px-2 py-1 hover:bg-muted/50 hover:text-foreground transition-colors">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            Retour aux offres
        </a>
    </nav>

    {# ── HERO HEADER ── #}
    <div class="rounded-2xl border border-border bg-gradient-to-r from-primary/10 via-primary/5 to-transparent p-6">
        <div class="flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between">
            <div class="flex items-center gap-5">
                {% if company_label %}
                    <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-xl font-bold text-primary">
                        {{ company_label|slice(0, 1)|upper }}
                    </div>
                {% endif %}
                <div>
                    <div class="flex flex-wrap items-center gap-2 mb-2">
                        {% if wt %}
                            <span class="rounded-full bg-primary/10 px-3 py-1 text-[11px] font-semibold uppercase tracking-wider text-primary">{{ wt|work_type_label }}</span>
                        {% endif %}
                        {% if job_offer.postedDate %}
                            <span class="rounded-full border border-border bg-muted/50 px-3 py-1 text-[11px] font-medium text-muted-foreground">Publiée le {{ job_offer.postedDate|date('d/m/Y') }}</span>
                        {% endif %}
                    </div>
                    <h1 class="text-2xl font-bold tracking-tight text-foreground sm:text-3xl">{{ job_offer.title }}</h1>
                    <div class="mt-2 flex flex-wrap items-center gap-3 text-sm text-muted-foreground">
                        {% if company_label %}
                            <span class="flex items-center gap-1.5">
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                                {{ company_label }}
                            </span>
                        {% endif %}
                        {% if job_offer.location %}
                            <span class="flex items-center gap-1.5">
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                {{ job_offer.location }}
                            </span>
                        {% endif %}
                    </div>
                </div>
            </div>
            <div class="flex flex-wrap gap-3">
                {% if not is_employer %}
                    <a href="#candidature-section" class="inline-flex items-center gap-2 rounded-xl bg-primary px-5 py-2.5 text-sm font-semibold text-primary-foreground shadow-sm hover:opacity-95">
                        Postuler à cette offre
                    </a>
                {% endif %}
            </div>
        </div>
    </div>

    {# ── METRICS ── #}
    <div class="grid gap-4 md:grid-cols-3">
        <div class="rounded-2xl border border-border bg-card p-5 shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Rémunération</p>
            <p class="mt-3 text-lg font-bold text-foreground">
                {% if job_offer.minSalary or job_offer.maxSalary %}
                    {% if job_offer.minSalary and job_offer.maxSalary %}{{ job_offer.minSalary }} – {{ job_offer.maxSalary }}{% elseif job_offer.minSalary %}Dès {{ job_offer.minSalary }}{% else %}Jusqu'à {{ job_offer.maxSalary }}{% endif %} {{ job_offer.currency }}
                {% else %}
                    <span class="text-muted-foreground font-medium">Non spécifiée</span>
                {% endif %}
            </p>
        </div>
        <div class="rounded-2xl border border-border bg-card p-5 shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Expérience</p>
            <p class="mt-3 text-lg font-bold text-foreground">{{ job_offer.experienceLevel|default('Non spécifiée') }}</p>
        </div>
        <div class="rounded-2xl border border-border bg-card p-5 shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Date limite</p>
            <p class="mt-3 text-lg font-bold text-foreground">{{ job_offer.deadline ? job_offer.deadline|date('d/m/Y') : 'En continu' }}</p>
        </div>
    </div>

    {# ── MAIN CONTENT + SIDEBAR ── #}
    <div class="grid gap-6 xl:grid-cols-[1fr,320px]">

        {# LEFT: Content Sections #}
        <div class="space-y-6">
            {% if job_offer.description %}
                <section class="rounded-2xl border border-border bg-card p-6 shadow-sm">
                    <h2 class="text-lg font-semibold text-foreground">Description du poste</h2>
                    <div class="mt-4 text-sm leading-7 text-muted-foreground">
                        {{ job_offer.description|nl2br }}
                    </div>
                </section>
            {% endif %}

            {% if job_offer.requirements %}
                <section class="rounded-2xl border border-border bg-card p-6 shadow-sm">
                    <h2 class="text-lg font-semibold text-foreground">Exigences & Qualifications</h2>
                    <div class="mt-4 rounded-xl border border-border bg-muted/30 p-4 text-sm leading-7 text-foreground">
                        {{ job_offer.requirements|nl2br }}
                    </div>
                </section>
            {% endif %}

            {% if job_offer.skillsRequired %}
                <section class="rounded-2xl border border-border bg-card p-6 shadow-sm">
                    <h2 class="text-lg font-semibold text-foreground">Compétences Attendues</h2>
                    <div class="mt-4">
                        {% if ',' in job_offer.skillsRequired or ';' in job_offer.skillsRequired %}
                            <div class="flex flex-wrap gap-2">
                                {% set skills = job_offer.skillsRequired|replace({';': ','})|split(',') %}
                                {% for skill in skills %}
                                    {% if skill|trim is not empty %}
                                        <span class="rounded-lg border border-border bg-muted/40 px-3 py-1.5 text-sm font-medium text-foreground">{{ skill|trim }}</span>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        {% else %}
                            <div class="rounded-xl border border-border bg-muted/30 px-4 py-3 font-mono text-sm text-muted-foreground">{{ job_offer.skillsRequired|nl2br }}</div>
                        {% endif %}
                    </div>
                </section>
            {% endif %}

            {% if job_offer.benefits %}
                <section class="rounded-2xl border border-border bg-card p-6 shadow-sm">
                    <h2 class="text-lg font-semibold text-foreground">Ce que nous offrons</h2>
                    <ul class="mt-4 space-y-3">
                        {% set benefits = job_offer.benefits|split("\n") %}
                        {% for ben in benefits %}
                            {% if ben|trim is not empty %}
                                <li class="flex items-start gap-3 text-sm text-foreground">
                                    <svg class="mt-0.5 h-4 w-4 shrink-0 text-emerald-600 dark:text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                                    {{ ben|replace({'-': '', '*': ''})|trim }}
                                </li>
                            {% endif %}
                        {% endfor %}
                    </ul>
                </section>
            {% endif %}
        </div>

        {# RIGHT: Sidebar #}
        <aside id="candidature-section" class="xl:sticky xl:top-6 space-y-4">
            <section class="rounded-2xl border border-border bg-card p-6 shadow-sm">
                <h3 class="text-lg font-semibold text-foreground">Candidature</h3>
                <ul class="mt-4 space-y-2 text-sm text-muted-foreground">
                    <li class="flex items-center gap-2">
                        <svg class="h-4 w-4 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                        Préparez votre CV (PDF/Word)
                    </li>
                    <li class="flex items-center gap-2">
                        <svg class="h-4 w-4 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                        Limite de 5 Mo
                    </li>
                    <li class="flex items-center gap-2">
                        <svg class="h-4 w-4 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                        Lettre de motif facultative
                    </li>
                </ul>

                {% if not is_employer %}
                    {% if my_application %}
                        <div class="mt-5 rounded-xl border border-emerald-500/30 bg-emerald-500/10 p-4 text-sm text-emerald-700 dark:text-emerald-400 font-medium">
                            Candidature envoyée · {{ my_application.status|default('En attente') }}
                        </div>
                    {% else %}
                        <a href="{{ path('app_candidate_offres_apply', {id: job_offer.id}) }}"
                           class="mt-5 flex w-full items-center justify-center gap-2 rounded-xl bg-primary px-4 py-3 text-sm font-semibold text-primary-foreground shadow-sm hover:opacity-95">
                            Postuler maintenant →
                        </a>
                    {% endif %}
                {% else %}
                    <p class="mt-5 text-xs text-muted-foreground text-center">Mode Employeur — postulation désactivée.</p>
                {% endif %}
            </section>

            <section class="rounded-2xl border border-border bg-card p-6 shadow-sm">
                <p class="text-xs font-semibold uppercase tracking-wider text-muted-foreground mb-4">Partager cette offre</p>
                <div class="flex items-center gap-3">
                    <button onclick="navigator.clipboard.writeText(window.location.href)" type="button" class="inline-flex items-center gap-2 rounded-lg border border-border bg-muted/40 px-3 py-2 text-xs font-medium text-foreground hover:bg-muted">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
                        Copier le lien
                    </button>
                    <a href="https://www.linkedin.com/sharing/share-offsite/?url={{ app.request.uri|url_encode }}"
                       target="_blank" rel="noopener"
                       class="inline-flex items-center gap-2 rounded-lg border border-border bg-muted/40 px-3 py-2 text-xs font-medium text-foreground hover:bg-muted">
                        LinkedIn
                    </a>
                </div>
            </section>
        </aside>
    </div>

</div>
{% endblock %}
