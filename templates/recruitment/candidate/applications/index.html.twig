{% extends 'recruitment/candidate/base.html.twig' %}

{% block candidate_title %}Mes candidatures · Skilora{% endblock %}
{% block candidate_page_title %}Mes candidatures{% endblock %}

{% block candidate_content %}
<div class="mx-auto max-w-3xl space-y-8">
    <header class="candidate-stagger space-y-4">
        <div>
            <h1 class="candidate-font-display text-3xl font-semibold tracking-tight text-foreground sm:text-4xl">
                Mes candidatures
            </h1>
            <p class="mt-1 max-w-lg text-sm leading-relaxed text-muted-foreground">
                Suivi de vos dossiers : statut défini par le recruteur, score de correspondance CV / offre, et entretien après acceptation.
            </p>
        </div>
        <div class="flex flex-wrap items-center justify-between gap-3">
            <p class="text-sm font-medium tabular-nums text-muted-foreground">
                {{ applications|length }} candidature{{ applications|length > 1 ? 's' : '' }}
            </p>
            <div class="flex flex-wrap gap-2">
                <a href="{{ path('app_candidate_cv_builder') }}"
                   class="inline-flex h-9 shrink-0 items-center justify-center rounded-xl border border-input bg-background px-4 text-sm font-medium text-foreground shadow-sm transition hover:bg-accent hover:text-accent-foreground">
                    Générer mon CV
                </a>
                <a href="{{ path('app_candidate_area_applications') }}"
                   class="inline-flex h-9 shrink-0 items-center justify-center rounded-xl border border-border bg-background px-4 text-sm font-medium text-foreground shadow-sm transition hover:bg-accent hover:text-accent-foreground">
                    Actualiser
                </a>
            </div>
        </div>
    </header>

    {% if applications is empty %}
        <div class="candidate-stagger rounded-3xl border border-dashed border-border bg-card/70 px-8 py-14 text-center backdrop-blur-sm">
            <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-muted text-primary" aria-hidden="true">
                <svg class="h-8 w-8 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75M19.5 6.75L12 13.5 4.5 6.75"/></svg>
            </div>
            <h2 class="candidate-font-display mt-6 text-xl font-semibold text-foreground">Aucune candidature pour l’instant</h2>
            <p class="mx-auto mt-2 max-w-md text-sm text-muted-foreground">
                Explorez les offres ouvertes et envoyez votre premier dossier en quelques minutes.
            </p>
            <a href="{{ path('app_candidate_offres_index') }}"
               class="candidate-font-display mt-8 inline-flex items-center justify-center gap-2 rounded-2xl bg-primary px-8 py-3 text-sm font-semibold text-primary-foreground shadow-md transition hover:bg-primary/90">
                Parcourir les offres
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
        </div>
    {% else %}
        <ul class="candidate-stagger flex flex-col gap-3">
            {% for item in applications %}
                {% set candidature = item.application %}
                {% set job = item.job %}
                {% set iv = item.interview %}
                {% set display_title = item.display_title %}
                {% set company_name = item.company_name %}
                {% set job_location = item.job_location %}
                {% if candidature.status == 'ACCEPTED' %}
                    {% set st_class = 'border-blue-500/40 bg-blue-500/15 text-blue-800 dark:border-blue-400/35 dark:bg-blue-500/20 dark:text-blue-200' %}
                {% elseif candidature.status == 'REJECTED' %}
                    {% set st_class = 'border-rose-500/40 bg-rose-500/15 text-rose-800 dark:border-rose-400/35 dark:bg-rose-500/15 dark:text-rose-200' %}
                {% elseif candidature.status == 'INTERVIEW' or candidature.status == 'OFFER' %}
                    {% set st_class = 'border-border bg-background text-foreground' %}
                {% else %}
                    {% set st_class = 'border-sky-500/35 bg-sky-500/10 text-sky-800 dark:text-sky-200' %}
                {% endif %}
                {% set cs = 0 %}
                {% if candidature.candidateScore is defined and candidature.candidateScore is not null %}
                    {% set cs = candidature.candidateScore + 0 %}
                {% endif %}
                {% set lieu_entretien = iv and iv.location ? iv.location : (job_location ?? (job and job.location ? job.location : null)) %}
                {% set interview_passed = iv and iv.scheduledAt and (iv.lifecycleStatus == 'COMPLETED' or (iv.scheduledAt|date('U') < 'now'|date('U'))) %}
                <li class="list-none">
                    <div class="overflow-hidden rounded-2xl border border-border/90 bg-card shadow-sm transition hover:border-border">
                        <div class="space-y-3 border-b border-border/60 p-4 sm:p-5">
                            {# Ligne type JavaFX : titre | badge | supprimer #}
                            <div class="flex flex-wrap items-start gap-3">
                                <div class="min-w-0 flex-1">
                                    {% if job %}
                                        <a href="{{ path('app_candidate_offres_show', {id: job.id}) }}"
                                           class="group flex items-start gap-2 text-foreground hover:text-primary">
                                            <svg class="mt-0.5 h-4 w-4 shrink-0 text-muted-foreground group-hover:text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M3 6h18"/></svg>
                                            <span class="candidate-font-display font-semibold leading-snug">{{ display_title }}</span>
                                        </a>
                                    {% else %}
                                        <p class="candidate-font-display font-semibold leading-snug text-foreground">{{ display_title }}</p>
                                        <p class="mt-1 text-xs text-muted-foreground">Cette offre n’est plus disponible.</p>
                                    {% endif %}
                                    {% if company_name or job_location %}
                                        <p class="mt-1 text-xs text-muted-foreground">
                                            {% if company_name %}{{ company_name }}{% endif %}
                                            {% if company_name and job_location %} · {% endif %}
                                            {% if job_location %}{{ job_location }}{% endif %}
                                        </p>
                                    {% endif %}
                                </div>
                                <div class="flex shrink-0 items-center gap-2">
                                    <span class="inline-flex w-fit items-center rounded-lg border px-2.5 py-1 text-xs font-semibold {{ st_class }}">
                                        {% if candidature.status == 'ACCEPTED' %}Accepted{% else %}{{ candidature.statusLabelFr }}{% endif %}
                                    </span>
                                    <form method="post"
                                          action="{{ path('app_candidate_area_applications_delete', {id: candidature.id}) }}"
                                          class="inline"
                                          onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette candidature ? Cette action est irréversible.');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_candidate_application_' ~ candidature.id) }}"/>
                                        <button type="submit"
                                                class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-transparent text-base text-muted-foreground transition hover:bg-destructive/10 hover:text-destructive"
                                                title="Supprimer cette candidature"
                                                aria-label="Supprimer cette candidature">
                                            🗑️
                                        </button>
                                    </form>
                                </div>
                            </div>

                            <p class="text-xs text-muted-foreground">
                                Match Score : {% if candidature.matchPercentage is defined and candidature.matchPercentage is not null and candidature.matchPercentage != '' %}{{ (candidature.matchPercentage + 0)|number_format(0) }}%{% else %}—{% endif %}
                                <span class="text-border">|</span>
                                Score : {{ cs > 0 ? cs : '—' }}
                            </p>

                            {% if candidature.coverLetter is defined and candidature.coverLetter %}
                                <div class="rounded-xl border border-border/70 bg-muted/20 px-3 py-2.5">
                                    <p class="text-xs font-semibold uppercase tracking-wide text-muted-foreground">Lettre de motivation</p>
                                    <div class="mt-1.5 max-h-40 overflow-y-auto whitespace-pre-wrap text-sm leading-relaxed text-foreground">{{ candidature.coverLetter }}</div>
                                </div>
                            {% endif %}

                            <p class="flex items-start gap-2 text-xs text-muted-foreground">
                                <svg class="mt-0.5 h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/></svg>
                                <span>Envoyée le <span class="font-medium text-foreground/90">{{ candidature.appliedAt|date('d/m/Y H:i') }}</span></span>
                            </p>
                        </div>

                        {% if candidature.status == 'ACCEPTED' %}
                            {% if iv and iv.scheduledAt %}
                                <div class="space-y-3 border-b border-border/60 bg-muted/25 px-4 py-3 sm:px-5">
                                    <p class="text-xs font-semibold uppercase tracking-wide text-muted-foreground">Entretien</p>
                                    <div class="grid gap-1 text-sm text-foreground sm:grid-cols-2">
                                        <p><span class="text-muted-foreground">Date</span> <span class="font-semibold tabular-nums">{{ iv.scheduledAt|date('d/m/Y') }}</span></p>
                                        <p><span class="text-muted-foreground">Heure</span> <span class="font-semibold tabular-nums">{{ iv.scheduledAt|date('H:i') }}</span></p>
                                    </div>
                                    {% if lieu_entretien and iv.format != 'ONLINE' %}
                                        <p class="text-sm"><span class="text-muted-foreground">Lieu</span> <span>{{ lieu_entretien }}</span></p>
                                    {% endif %}
                                    <p class="text-xs text-muted-foreground">Format · {{ iv.formatLabelFr }}</p>
                                    {% if iv.notes %}
                                        <p class="mt-1 rounded-md border border-border/60 bg-muted/30 px-2 py-1.5 text-xs text-foreground">{{ iv.notes }}</p>
                                    {% endif %}
                                    <div class="rounded-lg bg-muted/40 px-3 py-2.5">
                                        <p class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Temps restant avant l’entretien</p>
                                        {% if not interview_passed %}
                                            <p class="mt-1 text-sm font-semibold tabular-nums text-sky-800 dark:text-sky-200"
                                               data-interview-countdown
                                               data-locale="fr"
                                               data-at-ms="{{ (iv.scheduledAt|date('U') + 0) * 1000 }}"
                                               data-at="{{ iv.scheduledAt|date('c') }}"
                                               aria-live="polite"
                                               aria-atomic="true"></p>
                                        {% else %}
                                            <p class="mt-1 text-sm font-semibold tabular-nums text-muted-foreground">Entretien passé</p>
                                        {% endif %}
                                    </div>
                                </div>
                                <div class="flex items-center justify-between gap-2 px-4 py-3 sm:px-5">
                                    {% if interview_passed or iv.lifecycleStatus == 'COMPLETED' %}
                                        <span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-muted/50 px-3 py-1 text-xs font-medium text-muted-foreground">
                                            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                            Entretien passé
                                        </span>
                                    {% else %}
                                        <span class="inline-flex items-center gap-1.5 rounded-full border border-sky-500/35 bg-sky-500/10 px-3 py-1 text-xs font-medium text-sky-800 dark:text-sky-200">
                                            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                            Planifié
                                        </span>
                                    {% endif %}
                                    {% if job %}
                                    <a href="{{ path('app_candidate_offres_show', {id: job.id}) }}" class="text-xs font-medium text-primary hover:underline">Voir l’offre</a>
                                    {% endif %}
                                </div>
                            {% else %}
                                <div class="space-y-2 border-b border-border/60 bg-blue-500/[0.06] px-4 py-3 sm:px-5 dark:bg-blue-500/10">
                                    <p class="text-sm font-semibold text-foreground">Application accepted</p>
                                    <p class="text-sm leading-relaxed text-muted-foreground">
                                        The employer has not scheduled an interview yet. When a slot is set, the date, time, place, and remaining time will appear here.
                                    </p>
                                </div>
                                <div class="flex justify-end px-4 py-2.5 sm:px-5">
                                    {% if job %}
                                    <a href="{{ path('app_candidate_offres_show', {id: job.id}) }}" class="text-xs font-medium text-primary hover:underline">Voir l’offre</a>
                                    {% endif %}
                                </div>
                            {% endif %}
                        {% else %}
                            <div class="flex justify-end px-4 py-2.5 sm:px-5">
                                {% if job %}
                                <a href="{{ path('app_candidate_offres_show', {id: job.id}) }}" class="text-xs font-medium text-primary hover:underline">Voir l’offre</a>
                                {% endif %}
                            </div>
                        {% endif %}
                    </div>
                </li>
            {% endfor %}
        </ul>
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% include 'recruitment/components/_interview_countdown_script.html.twig' %}
{% endblock %}
