{# Recherche + filtres catalogue #}
<form method="get" action="{{ path('app_formation_index') }}" class="f-container">
    <div class="f-toolbar">
        <div class="f-toolbar__row">
            <div class="f-field">
                <label for="catalog-q" class="f-label">Recherche</label>
                <div class="f-input-wrap">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
                    </svg>
                    <input type="search" name="q" id="catalog-q" value="{{ filter_q }}" placeholder="Titre, mot-clé, description…" class="f-input" autocomplete="off">
                </div>
            </div>
            <div class="f-toolbar__filters">
                <div class="f-field">
                    <label for="catalog-cat" class="f-label">Catégorie</label>
                    <select name="cat" id="catalog-cat" class="f-select">
                        <option value="">Toutes</option>
                        {% for key, label in category_labels %}
                            <option value="{{ key }}" {{ filter_cat == key ? 'selected' : '' }}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="f-field">
                    <label for="catalog-lvl" class="f-label">Niveau</label>
                    <select name="lvl" id="catalog-lvl" class="f-select">
                        <option value="">Tous</option>
                        {% for opt in level_options %}
                            <option value="{{ opt.value }}" {{ filter_lvl == opt.value ? 'selected' : '' }}>{{ opt.label }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>
            <div class="f-toolbar__actions">
                <button type="submit" class="f-btn f-btn--primary">Appliquer</button>
                <a href="{{ path('app_formation_index') }}" class="f-btn f-btn--ghost">Réinitialiser</a>
            </div>
        </div>
    </div>
</form>
