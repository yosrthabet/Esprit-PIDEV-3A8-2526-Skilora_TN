{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/formations.css') }}?v=2">
{% endblock %}

{% block body_class %}body--formation{% endblock %}

{% block title %}{{ formation.title }} · Skilora{% endblock %}

{% block body %}
{% set lvl = formation.level.value %}
{% set levelMod = lvl == 'BEGINNER' ? 'beginner' : (lvl == 'INTERMEDIATE' ? 'intermediate' : 'advanced') %}
{% set catSlug = formation.category|lower|replace({'_': '-'}) %}
<div class="f-page">
    {% include 'formation/_public_header.html.twig' %}

    <section class="f-show-hero f-show-hero--{{ catSlug }}">
        <div class="f-show-hero__bg" aria-hidden="true"></div>
        <div class="f-show-hero__overlay" aria-hidden="true"></div>
        <div class="f-container f-show-hero__content">
            <nav class="f-breadcrumb" aria-label="Fil d’Ariane">
                <a href="{{ path('app_formation_index') }}">Formations</a>
                <span> / </span>
                <span>{{ formation.title }}</span>
            </nav>
            <div class="f-show-badges">
                <span class="fc-badge fc-badge--on-hero">{{ formation.categoryLabelFr }}</span>
                <span class="fc-badge fc-badge--{{ levelMod }}">{{ formation.levelLabelFr }}</span>
            </div>
            <h1 class="f-show-title">{{ formation.title }}</h1>
        </div>
    </section>

    <div class="f-container f-show-main">
        <div class="f-stats">
            <div class="f-stat">
                <div class="f-stat__label">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    Durée
                </div>
                <p class="f-stat__value">{{ formation.duration }}&nbsp;<span class="f-stat__unit">h</span></p>
            </div>
            <div class="f-stat">
                <div class="f-stat__label">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                    Leçons
                </div>
                <p class="f-stat__value">{{ formation.lessonsCount }}</p>
            </div>
            <div class="f-stat">
                <div class="f-stat__label">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
                    Catégorie
                </div>
                <p class="f-stat__value f-stat__value--sm">{{ formation.categoryLabelFr }}</p>
            </div>
            <div class="f-stat f-stat--price">
                <div class="f-stat__label">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    Tarif
                </div>
                <p class="f-stat__value f-stat__value--price">
                    {% if formation.price is null %}
                        <span class="f-stat__muted">—</span>
                    {% elseif formation.price <= 0 %}
                        <span class="f-stat__free">Gratuit</span>
                    {% else %}
                        <span class="fc-price--num">{{ formation.priceDisplayFr }}</span>
                        <span class="fc-price--cur">TND</span>
                    {% endif %}
                </p>
            </div>
        </div>

        <div class="f-show-layout">
            <section class="f-prose">
                <h2>À propos de cette formation</h2>
                <div class="f-prose__body f-prose__body--pre">
                    {{ formation.description }}
                </div>
            </section>
            <aside class="f-sidebar">
                <div class="f-sidebar-card">
                    {% if app.user %}
                        {% if enrollment %}
                            {% if enrollment.completed %}
                                <div class="fc-enrolled fc-enrolled--block">
                                    <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                                    Formation completed
                                </div>
                                {% if certificate %}
                                    <a href="{{ path('app_certificate_pdf', { id: certificate.id }) }}" class="f-btn f-btn--primary f-btn--lg f-mt-md">Download PDF</a>
                                {% endif %}
                            {% else %}
                                <p class="f-sidebar-status">Already enrolled</p>
                                <form method="post" action="{{ path('app_formation_complete', { id: formation.id }) }}" class="f-complete-form">
                                    <input type="hidden" name="_token" value="{{ csrf_token('formation_complete_' ~ formation.id) }}">
                                    <button type="submit" class="f-btn f-btn--primary f-btn--lg">Mark as Completed</button>
                                </form>
                            {% endif %}
                        {% else %}
                            <form method="post" action="{{ path('app_formation_enroll', { id: formation.id }) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('formation_enroll_' ~ formation.id) }}">
                                <button type="submit" class="f-btn f-btn--primary f-btn--lg">Enroll Now</button>
                            </form>
                        {% endif %}
                    {% else %}
                        <a href="{{ path('app_login') }}" class="f-btn f-btn--ghost f-btn--block-dash">
                            Sign in to enroll
                        </a>
                    {% endif %}
                    <a href="{{ path('app_formation_index') }}" class="f-btn f-btn--ghost">
                        ← Back to catalog
                    </a>
                    {% if app.user %}
                        <a href="{{ path('app_my_formations') }}" class="f-btn f-btn--ghost f-mt-sm">My formations</a>
                    {% endif %}
                </div>
            </aside>
        </div>
    </div>
</div>
{% endblock %}
