{% extends 'layouts/app.html.twig' %}

{% block title %}{{ formation.title }} · Skilora{% endblock %}
{% block page_title %}{{ formation.title }}{% endblock %}
{% block head %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <style>
        .grid-layout-main { display: grid; grid-template-columns: minmax(0, 2fr) minmax(0, 1fr); gap: 1.5rem; align-items: start; }
        @media (max-width: 768px) { .grid-layout-main { grid-template-columns: 1fr; } }
    </style>
{% endblock %}

{% block content %}
{% set lvl = formation.level.value %}
{% set levelMod = lvl == 'BEGINNER' ? 'beginner' : (lvl == 'INTERMEDIATE' ? 'intermediate' : 'advanced') %}
{% set levelColor = {
    'beginner':     'bg-secondary text-foreground ring-border',
    'intermediate': 'bg-secondary text-foreground ring-border',
    'advanced':     'bg-secondary text-foreground ring-border',
} %}
{% set fwConfig = {
    id: formation.id,
    lessonsCount: formation.lessonsCount ?? 0,
    title: formation.title,
    userId: app.user ? app.user.id : null,
} %}

<div x-data="formationWorkspace({{ fwConfig|json_encode|raw }})"
     x-init="init()"
     class="space-y-6 animate-fade-in">
    {# ── Breadcrumb + title ── #}
    <div class="rounded-xl border border-border bg-card text-card-foreground p-6 shadow-sm">
        <nav class="mb-4 flex items-center gap-1.5 text-xs text-muted-foreground" aria-label="Fil d'Ariane">
            <a href="{{ path('app_formation_index') }}" class="hover:text-foreground hover:underline transition-colors">Formations</a>
            <span class="text-border">/</span>
            <span class="truncate text-foreground font-medium">{{ formation.title }}</span>
        </nav>
        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
            <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                    <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold ring-1 ring-inset bg-secondary text-secondary-foreground ring-border">{{ formation.categoryLabelFr }}</span>
                    <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold ring-1 ring-inset {{ levelColor[levelMod] }}">{{ formation.levelLabelFr }}</span>
                </div>
                <h1 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl leading-tight">{{ formation.title }}</h1>
            </div>
            <a href="{{ path('app_formation_index') }}"
               class="shrink-0 inline-flex h-10 items-center justify-center rounded-xl border border-input bg-background px-5 text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground">
                <i data-lucide="arrow-left" class="mr-2 h-4 w-4"></i> Retour au catalogue
            </a>
        </div>
    </div>

    {# ── Stats + live progress ── #}
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-border bg-card text-card-foreground p-6 shadow-sm" style="border-top: 3px solid hsl(var(--primary));">
            <div class="flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-muted-foreground">
                <i data-lucide="clock" class="h-4 w-4"></i> Durée totale
            </div>
            <p class="mt-3 text-3xl font-bold text-card-foreground tabular-nums">{{ formation.duration ?? '—' }}<span class="ml-1 text-base font-normal text-muted-foreground">h</span></p>
            <p class="mt-1 text-xs text-muted-foreground">estimées</p>
        </div>
        <div class="rounded-xl border border-border bg-card text-card-foreground p-6 shadow-sm" style="border-top: 3px solid hsl(var(--primary));">
            <div class="flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-muted-foreground">
                <i data-lucide="book-open" class="h-4 w-4"></i> Leçons
            </div>
            <p class="mt-3 text-3xl font-bold text-card-foreground tabular-nums">{{ formation.lessonsCount ?? '—' }}</p>
            <p class="mt-1 text-xs text-muted-foreground">modules de contenu</p>
        </div>
        <div class="rounded-xl border border-border bg-card text-card-foreground p-6 shadow-sm" style="border-top: 3px solid hsl(var(--primary));">
            <div class="flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-muted-foreground">
                <i data-lucide="folder" class="h-4 w-4"></i> Catégorie
            </div>
            <p class="mt-3 text-base font-bold text-card-foreground leading-snug">{{ formation.categoryLabelFr }}</p>
            <p class="mt-1 text-xs text-muted-foreground">domaine principal</p>
        </div>
        <div class="rounded-xl border border-border bg-card text-card-foreground p-6 shadow-sm" style="border-top: 3px solid hsl(var(--primary));">
            <div class="flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-muted-foreground">
                <i data-lucide="banknote" class="h-4 w-4"></i> Tarif
            </div>
            <p class="mt-3 text-3xl font-bold text-card-foreground tabular-nums">
                {% if formation.price is null %}
                    <span class="text-muted-foreground text-2xl">—</span>
                {% elseif formation.price <= 0 %}
                    <span class="text-emerald-600">Gratuit</span>
                {% else %}
                    {{ formation.priceDisplayFr }} <span class="ml-1 text-base font-normal text-muted-foreground">TND</span>
                {% endif %}
            </p>
            <p class="mt-1 text-xs text-muted-foreground">accès complet</p>
        </div>
    </div>

    </div>

    {# ── Content + sidebar ── #}
    <div class="grid-layout-main">
        {# LEFT: Description, technical notes, and reviews #}
        <div class="space-y-4">
            
            <div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm overflow-hidden">
                <div class="flex flex-col space-y-1.5 p-6">
                    <h2 class="text-2xl font-semibold leading-none tracking-tight flex items-center gap-2">
                        <i data-lucide="info" class="h-4 w-4 text-muted-foreground"></i>
                        À propos de cette formation
                    </h2>
                </div>
                <div class="p-6 pt-0 text-sm leading-relaxed text-muted-foreground whitespace-pre-line">{{ formation.description }}</div>
            </div>

            <div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm overflow-hidden">
                <div class="flex flex-col space-y-1.5 p-6">
                    <div>
                        <h3 class="text-2xl font-semibold leading-none tracking-tight flex items-center gap-2">
                            <i data-lucide="layout-dashboard" class="h-4 w-4 text-muted-foreground"></i>
                            Détails techniques
                        </h3>
                        <p class="mt-1.5 text-sm text-muted-foreground">Structure du cursus et paramètres pédagogiques.</p>
                    </div>
                </div>
                <div class="p-6 pt-0">
                <dl class="grid divide-x divide-y sm:divide-y-0 divide-border sm:grid-cols-3 rounded-lg border border-border bg-secondary/20">
                    <div class="p-6">
                        <dt class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Durée totale</dt>
                        <dd class="mt-2 text-xl font-bold text-foreground tabular-nums">{{ formation.duration ?? '—' }}<span class="text-sm font-normal text-muted-foreground ml-1">h</span></dd>
                        <dd class="mt-0.5 text-xs text-muted-foreground">estimées</dd>
                    </div>
                    <div class="p-6">
                        <dt class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Nombre de leçons</dt>
                        <dd class="mt-2 text-xl font-bold text-foreground tabular-nums">{{ formation.lessonsCount ?? '—' }}</dd>
                        <dd class="mt-0.5 text-xs text-muted-foreground">leçons disponibles</dd>
                    </div>
                    <div class="p-6">
                        <dt class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Fournisseur</dt>
                        <dd class="mt-2 text-base font-bold text-foreground">{{ formation.provider ?? 'Skilora' }}</dd>
                        <dd class="mt-0.5 text-xs text-muted-foreground">contenu vérifié</dd>
                    </div>
                </dl>
                </div>
            </div>

            {# ── Rating analytics (formation reviews) ── #}
            {% set rs = review_stats %}
            {% set dist = rs.distribution %}
            <div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm overflow-hidden">
                {# Header #}
                <div class="flex items-center justify-between gap-4 p-6">
                    <div class="flex items-center gap-3">
                        <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-secondary">
                            <i data-lucide="star" class="h-4 w-4 text-amber-500 dark:text-amber-500"></i>
                        </div>
                        <div>
                            <h3 class="text-2xl font-semibold leading-none tracking-tight">Avis apprenants</h3>
                            <p class="mt-1.5 text-sm text-muted-foreground">Basé sur les retours des apprenants inscrits.</p>
                        </div>
                    </div>
                    <div class="shrink-0 flex items-center gap-3 rounded-xl border border-border bg-secondary px-3 py-2">
                        <span class="text-xl font-bold tabular-nums text-foreground">{{ rs.average|number_format(1, ',', ' ') }}</span>
                        <div>
                            <div class="flex items-center gap-0.5">
                                {% for i in 1..5 %}
                                    <svg class="h-3 w-3 {{ i <= rs.average|round ? 'text-amber-500' : 'text-muted-foreground opacity-30' }}" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                {% endfor %}
                            </div>
                            <p class="text-xs text-muted-foreground leading-none mt-0.5">{{ rs.total }} avis</p>
                        </div>
                    </div>
                </div>

                {# Stats grid #}
                {% if rs.total > 0 %}
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0; border-bottom: 1px solid hsl(var(--border));">
                        {# Recommendation score #}
                        <div class="px-6 py-5" style="border-right: 1px solid hsl(var(--border));">
                            <p class="text-xs font-bold uppercase tracking-wider text-muted-foreground mb-3">Recommandation</p>
                            <div class="flex items-center gap-3">
                                <span class="text-3xl font-black tabular-nums text-foreground">{{ rs.likePercentage }}%</span>
                                <span class="text-xs text-muted-foreground">des apprenants recommandent cette formation (4★–5★)</span>
                            </div>
                            <div class="mt-3 h-2 w-full overflow-hidden rounded-full bg-border">
                                <div class="h-full rounded-full transition-all duration-700"
                                     style="width: {{ rs.likePercentage }}%; background: linear-gradient(90deg, #34d399, #10b981);"></div>
                            </div>
                        </div>

                        {# Star distribution #}
                        <div class="p-6">
                            <p class="text-xs font-bold uppercase tracking-wider text-muted-foreground mb-3">Répartition</p>
                            <div class="space-y-2">
                                {% for stars in [5, 4, 3, 2, 1] %}
                                    {% set cnt = dist[stars] %}
                                    {% set pct = rs.total > 0 ? (100 * cnt / rs.total) : 0 %}
                                    <div class="flex items-center gap-3 text-xs">
                                        <span class="w-6 shrink-0 font-bold text-foreground tabular-nums text-right">{{ stars }}</span>
                                        <svg class="h-3 w-3 shrink-0 text-amber-500" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                        <div class="flex-1 h-1.5 overflow-hidden rounded-full bg-secondary">
                                            <div class="h-full rounded-full bg-amber-500 transition-all duration-700"
                                                 style="width: {{ pct }}%;"></div>
                                        </div>
                                        <span class="w-4 shrink-0 text-right tabular-nums font-medium text-muted-foreground">{{ cnt }}</span>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                {% endif %}

                {# Review form #}
                {% if app.user and enrollment and enrollment.completed %}
                    <div class="px-6 py-5 border-b border-border bg-secondary"
                         x-data="{ rating: {{ my_review ? my_review.rating : 0 }}, hover: 0 }">
                        <h3 class="text-sm font-bold text-foreground mb-1">{{ my_review ? 'Modifier mon avis' : 'Laisser un avis' }}</h3>
                        <p class="text-xs text-muted-foreground mb-4">Votre retour aide les autres apprenants.</p>
                        <form class="space-y-3" method="post" action="{{ path('app_formation_review_submit', { id: formation.id }) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('formation_review_' ~ formation.id) }}">
                            <input type="hidden" name="rating" :value="rating">
                            <div class="flex items-center gap-1">
                                {% for star in [1, 2, 3, 4, 5] %}
                                    <button type="button"
                                            @mouseenter="hover = {{ star }}"
                                            @mouseleave="hover = 0"
                                            @click="rating = {{ star }}"
                                            class="p-0.5 transition-transform hover:scale-110">
                                        <svg class="h-8 w-8 transition-colors duration-150" viewBox="0 0 20 20"
                                             :fill="(hover >= {{ star }} || rating >= {{ star }}) ? '#FBBF24' : 'none'"
                                             :stroke="(hover >= {{ star }} || rating >= {{ star }}) ? '#FBBF24' : 'currentColor'"
                                             :class="(hover >= {{ star }} || rating >= {{ star }}) ? 'text-amber-500' : 'text-muted-foreground opacity-40'"
                                             stroke-width="1.5">
                                            <path stroke-linejoin="round" d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                        </svg>
                                    </button>
                                {% endfor %}
                                <span class="ml-2 text-sm text-muted-foreground" x-text="rating > 0 ? rating + '/5' : 'Choisir une note'"></span>
                            </div>
                            <textarea name="comment" rows="3" maxlength="1500"
                                      class="w-full rounded-xl border border-input bg-background px-4 py-3 text-sm text-foreground placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
                                      placeholder="Partagez votre expérience avec cette formation...">{{ my_review and my_review.comment ? my_review.comment : '' }}</textarea>
                            <button type="submit"
                                    class="inline-flex h-10 items-center justify-center rounded-xl bg-primary px-6 text-sm font-bold text-primary-foreground shadow-sm transition-colors hover:bg-primary">
                                {{ my_review ? 'Mettre à jour mon avis' : 'Publier mon avis' }}
                            </button>
                        </form>
                    </div>
                {% elseif app.user and enrollment and not enrollment.completed %}
                    <div class="px-6 py-4 border-b border-border bg-secondary">
                        <p class="text-sm text-muted-foreground flex items-center gap-2">
                            <i data-lucide="lock" class="h-4 w-4 shrink-0"></i>
                            Terminez la formation pour laisser un avis.
                        </p>
                    </div>
                {% endif %}

                {# Review list #}
                <div class="divide-y divide-border">
                    {% if reviews is not empty %}
                        {% for review in reviews %}
                            {% set initials = review.user.displayName|slice(0,1)|upper %}
                            <article class="px-6 py-5"
                                     x-data="{
                                        useful: {{ review.usefulCount }},
                                        notUseful: {{ review.notUsefulCount }},
                                        userVote: {{ review_votes[review.id]|default(0) }},
                                        pending: false,
                                        debounceTimer: null,
                                        voteDebounced(type) {
                                            clearTimeout(this.debounceTimer);
                                            this.debounceTimer = setTimeout(() => this.vote(type), 280);
                                        },
                                        async vote(type) {
                                            if (this.pending) return;
                                            this.pending = true;
                                            const fd = new FormData();
                                            fd.append('_token', '{{ csrf_token('formation_review_vote_' ~ review.id) }}');
                                            fd.append('vote', type);
                                            const res = await fetch('{{ path('app_formation_review_vote', { id: review.id }) }}', {
                                                method: 'POST',
                                                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                                                body: fd,
                                            });
                                            this.pending = false;
                                            if (!res.ok) return;
                                            const data = await res.json();
                                            this.useful = data.usefulCount;
                                            this.notUseful = data.notUsefulCount;
                                            this.userVote = data.userVote;
                                        }
                                     }">
                                <div class="flex items-start gap-4">
                                    {# Avatar #}
                                    <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-full bg-primary text-primary-foreground text-sm font-bold">
                                        {{ initials }}
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <div class="flex items-start justify-between gap-2">
                                            <div>
                                                <p class="text-sm font-bold text-foreground">{{ review.user.displayName }}</p>
                                                <div class="mt-1 flex items-center gap-0.5">
                                                    {% for i in 1..5 %}
                                                        <svg class="h-3.5 w-3.5 {{ i <= review.rating ? 'text-amber-500' : 'text-muted-foreground opacity-30' }}" fill="currentColor" viewBox="0 0 20 20">
                                                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                                        </svg>
                                                    {% endfor %}
                                                </div>
                                            </div>
                                            <span class="shrink-0 text-xs text-muted-foreground">{{ review.createdAt ? review.createdAt|date('d/m/Y') : '' }}</span>
                                        </div>

                                        {% if review.comment %}
                                            <p class="mt-3 text-sm text-muted-foreground leading-relaxed">{{ review.comment }}</p>
                                        {% endif %}

                                        <div class="mt-4 flex items-center gap-2">
                                            <span class="text-xs text-muted-foreground mr-1">Utile ?</span>
                                            <button type="button"
                                                    @click="voteDebounced('helpful')"
                                                    :disabled="pending"
                                                    :class="userVote === 1 ? 'border-primary bg-primary opacity-10 text-primary font-bold' : 'border-input bg-background text-foreground hover:bg-accent'"
                                                    class="inline-flex items-center gap-1.5 rounded-lg border px-3 py-1.5 text-xs font-medium transition-colors disabled:opacity-60">
                                                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5"/></svg>
                                                Oui <span class="tabular-nums" x-text="useful"></span>
                                            </button>
                                            <button type="button"
                                                    @click="voteDebounced('not_helpful')"
                                                    :disabled="pending"
                                                    :class="userVote === -1 ? 'border-destructive bg-destructive text-destructive-foreground text-destructive font-bold' : 'border-input bg-background text-foreground hover:bg-accent'"
                                                    class="inline-flex items-center gap-1.5 rounded-lg border px-3 py-1.5 text-xs font-medium transition-colors disabled:opacity-60">
                                                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 14H5.236a2 2 0 01-1.789-2.894l3.5-7A2 2 0 018.736 3h4.018a2 2 0 01.485.06l3.76.94m-7 10v5a2 2 0 002 2h.096c.5 0 .905-.405.905-.904 0-.715.211-1.413.608-2.008L17 13V4m-7 10h2m5-10h2a2 2 0 012 2v6a2 2 0 01-2 2h-2.5"/></svg>
                                                Non <span class="tabular-nums" x-text="notUseful"></span>
                                            </button>
                                            <span class="ml-auto text-xs text-muted-foreground tabular-nums"
                                                  x-text="(useful + notUseful) > 0 ? ((100 * useful / (useful + notUseful)).toFixed(0) + '% positif') : ''"></span>
                                        </div>
                                    </div>
                                </div>
                            </article>
                        {% endfor %}
                    {% else %}
                        <div class="px-6 py-10 text-center">
                            <i data-lucide="message-square" class="mx-auto h-8 w-8 text-muted-foreground opacity-30 mb-3"></i>
                            <p class="text-sm font-medium text-foreground">Aucun avis pour le moment.</p>
                            <p class="text-xs text-muted-foreground mt-1">Soyez le premier à partager votre expérience.</p>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        {# RIGHT: sidebar #}
        <aside class="space-y-4" style="position: sticky; top: 1.5rem;">

            {# ① Enrollment CTA — most important, always on top #}
            <section class="rounded-xl border border-border bg-card text-card-foreground shadow-sm overflow-hidden">
                <div class="flex flex-col space-y-1.5 p-6">
                    <h3 class="text-lg font-semibold leading-none tracking-tight flex items-center gap-2">
                        <i data-lucide="play-circle" class="h-4 w-4 text-muted-foreground"></i>
                        Votre inscription
                    </h3>
                </div>
                <div class="p-6 pt-0 space-y-4">
                {% if app.user %}
                    {% if enrollment %}
                        {% if enrollment.completed %}
                            <div class="flex items-center gap-3 rounded-xl border border-border bg-secondary px-4 py-3.5 text-sm font-semibold text-foreground">
                                <i data-lucide="check-circle" class="h-5 w-5 shrink-0"></i>
                                Formation terminée avec succès
                            </div>
                            {% if certificate %}
                                <a href="{{ path('app_certificate_pdf', { id: certificate.id }) }}"
                                   class="inline-flex h-11 w-full items-center justify-center rounded-xl bg-primary px-4 text-sm font-bold text-primary-foreground shadow-sm transition-colors hover:bg-primary">
                                    <i data-lucide="download" class="mr-2 h-4 w-4"></i> Télécharger le certificat
                                </a>
                            {% endif %}
                        {% else %}
                            <div class="flex items-center gap-2 rounded-xl border border-border bg-secondary px-4 py-3 text-sm font-semibold text-foreground">
                                <i data-lucide="user-check" class="h-4 w-4 text-primary shrink-0"></i>
                                Déjà inscrit à cette formation
                            </div>
                            <form method="post" action="{{ path('app_formation_complete', { id: formation.id }) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('formation_complete_' ~ formation.id) }}">
                                <button type="submit"
                                        class="inline-flex h-11 w-full items-center justify-center rounded-xl bg-primary px-4 text-sm font-bold text-primary-foreground shadow-sm transition-colors hover:bg-primary">
                                    Marquer comme terminée
                                </button>
                            </form>
                        {% endif %}
                    {% else %}
                        <form method="post" action="{{ path('app_formation_enroll', { id: formation.id }) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('formation_enroll_' ~ formation.id) }}">
                            <button type="submit"
                                    class="inline-flex h-11 w-full items-center justify-center rounded-xl bg-primary px-4 text-sm font-bold text-primary-foreground shadow-sm transition-colors hover:bg-primary">
                                S'inscrire maintenant
                            </button>
                        </form>
                    {% endif %}
                {% else %}
                    <a href="{{ path('app_login') }}"
                       class="inline-flex h-11 w-full items-center justify-center rounded-xl bg-primary px-4 text-sm font-bold text-primary-foreground shadow-sm transition-colors hover:bg-primary">
                        Se connecter pour s'inscrire
                    </a>
                {% endif %}

                <div class="pt-2 space-y-2 border-t border-border">
                    <a href="{{ path('app_formation_index') }}"
                       class="inline-flex h-9 w-full items-center justify-center rounded-lg border border-input bg-background px-4 text-sm font-medium text-foreground transition-colors hover:bg-accent hover:text-accent-foreground">
                        <i data-lucide="arrow-left" class="mr-2 h-3.5 w-3.5"></i> Retour au catalogue
                    </a>
                    {% if app.user %}
                        <a href="{{ path('app_my_formations') }}"
                           class="inline-flex h-9 w-full items-center justify-center rounded-lg border border-input bg-background px-4 text-sm font-medium text-foreground transition-colors hover:bg-accent hover:text-accent-foreground">
                            Mes formations
                        </a>
                    {% endif %}
                </div>
                </div>
            </section>

            {# ② Progress tracker #}
            <section class="rounded-xl border border-border bg-card text-card-foreground shadow-sm overflow-hidden">
                <div class="px-5 py-4 border-b border-border">
                    <div class="flex items-center justify-between gap-3">
                        <h2 class="text-sm font-bold text-card-foreground flex items-center gap-2">
                            <i data-lucide="zap" class="h-4 w-4 text-muted-foreground"></i>
                            Progression
                        </h2>
                        <p class="text-lg font-bold text-card-foreground tabular-nums" x-text="progressPercentLabel"></p>
                    </div>
                </div>
                <div class="px-5 py-4">
                    <div class="h-2 w-full overflow-hidden rounded-full bg-muted">
                        <div class="h-full rounded-full transition-all duration-500 ease-out"
                             style="background: linear-gradient(90deg, #34d399, #38bdf8, #818cf8);"
                             :style="`width: ${progressPercent}%;`"></div>
                    </div>
                    <p class="mt-2 text-xs text-muted-foreground">
                        <span class="font-bold text-foreground" x-text="completedLessons ?? 0"></span>
                        / <span class="tabular-nums" x-text="totalLessons ?? 0"></span> leçons terminées
                        <span x-show="totalLessons > 0" class="ml-1 font-semibold text-foreground" x-text="'· ' + progressPercentLabel"></span>
                    </p>
                </div>
            </section>

            {# ③ Curriculum #}
            <section class="rounded-xl border border-border bg-card text-card-foreground shadow-sm overflow-hidden">
                <div class="px-5 py-4 border-b border-border flex items-center justify-between gap-2">
                    <div>
                        <h3 class="text-sm font-bold text-card-foreground flex items-center gap-2">
                            <i data-lucide="list" class="h-4 w-4 text-muted-foreground"></i>
                            Curriculum
                        </h3>
                        <p class="mt-0.5 text-xs text-muted-foreground">Découpage modulaire généré automatiquement.</p>
                    </div>
                    <button type="button"
                            class="inline-flex items-center rounded-lg border border-input bg-background px-3 py-1.5 text-xs font-semibold text-foreground shadow-sm hover:bg-accent hover:text-accent-foreground transition-colors"
                            @click="resetProgress">
                        Réinitialiser
                    </button>
                </div>

                <div class="px-4 py-3 max-h-[320px] space-y-2 overflow-y-auto text-xs"
                     x-show="sections.length > 0"
                     x-collapse>
                    <template x-for="(section, sIndex) in sections" :key="section.id">
                        <div class="rounded-lg border border-border bg-background p-3">
                            <div class="flex items-center justify-between gap-2">
                                <div>
                                    <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-muted-foreground opacity-80" x-text="section.label"></p>
                                    <p class="mt-0.5 text-[11px] text-muted-foreground">
                                        <span class="tabular-nums" x-text="section.completedCount"></span>
                                        / <span class="tabular-nums" x-text="section.lessons.length"></span> leçons
                                    </p>
                                </div>
                                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold"
                                      :class="section.completedCount === section.lessons.length && section.lessons.length > 0
                                              ? 'bg-secondary text-emerald-400 border border-border'
                                              : 'bg-secondary text-slate-200 border border-border'">
                                    <span x-text="section.completedCount === section.lessons.length && section.lessons.length > 0 ? 'Terminé' : 'En cours'"></span>
                                </span>
                            </div>
                            <ul class="mt-3 space-y-1.5">
                                <template x-for="(lesson, lIndex) in section.lessons" :key="lesson.id">
                                    <li>
                                        <button type="button"
                                                class="flex w-full items-center justify-between gap-2 rounded-md px-2 py-1.5 text-left transition-colors hover:bg-accent hover:text-accent-foreground"
                                                @click="toggleLesson(section.id, lesson.id)">
                                            <div class="flex items-center gap-2">
                                                <span class="inline-flex h-4 w-4 items-center justify-center rounded border text-[9px] font-semibold"
                                                      :class="lesson.completed ? 'border-emerald-400 bg-secondary text-emerald-300' : 'border-border text-muted-foreground'">
                                                    <span x-text="lesson.index"></span>
                                                </span>
                                                <span class="truncate" x-text="lesson.label"></span>
                                            </div>
                                            <span class="inline-flex h-5 w-5 items-center justify-center rounded-full border border-border text-[10px]"
                                                  :class="lesson.completed ? 'bg-secondary border-emerald-400 text-emerald-300' : 'bg-background text-muted-foreground'">
                                                <i :data-lucide="lesson.completed ? 'check' : 'circle'" class="h-3 w-3"></i>
                                            </span>
                                        </button>
                                    </li>
                                </template>
                            </ul>
                        </div>
                    </template>
                </div>

                <p class="px-5 py-3 text-xs text-muted-foreground" x-show="sections.length === 0">
                    Aucun découpage disponible pour cette formation.
                </p>
            </section>
        </aside>
    </div>
</div>

<script>
    window.formationWorkspace = function formationWorkspace(config) {
        const totalLessons = Math.max(0, config.lessonsCount || 0);
        const storageKey = [
            'skilora_fw_progress',
            config.userId || 'guest',
            config.id
        ].join(':');

        // Simple modularisation of lessons into sections, respecting ordering
        const sections = [];
        if (totalLessons > 0) {
            const targetSections = Math.min(6, Math.max(2, Math.round(totalLessons / 4)));
            const baseSize = Math.max(1, Math.floor(totalLessons / targetSections));
            let remaining = totalLessons;
            let currentIndex = 1;

            for (let i = 0; i < targetSections; i++) {
                const size = i === targetSections - 1 ? remaining : Math.min(baseSize, remaining);
                if (size <= 0) {
                    continue;
                }
                const lessons = [];
                for (let j = 0; j < size; j++) {
                    const absoluteIndex = currentIndex++;
                    lessons.push({
                        id: `L${absoluteIndex}`,
                        index: absoluteIndex,
                        label: `Leçon ${absoluteIndex}`,
                        completed: false
                    });
                }
                remaining -= size;
                sections.push({
                    id: `S${i + 1}`,
                    label: `Module ${i + 1}`,
                    lessons,
                    completedCount: 0
                });
                if (remaining <= 0) {
                    break;
                }
            }
        }

        return {
            config,
            storageKey,
            sections,
            completedLessons: 0,
            totalLessons: totalLessons,

            get progressPercent() {
                if (!this.totalLessons) {
                    return 0;
                }
                return Math.min(100, Math.round((this.completedLessons / this.totalLessons) * 100));
            },

            get progressPercentLabel() {
                return this.totalLessons ? `${this.progressPercent}%` : 'N/A';
            },

            init() {
                this.restore();
                this.recomputeSectionCounts();
            },

            restore() {
                try {
                    const raw = window.localStorage.getItem(this.storageKey);
                    if (!raw) {
                        this.completedLessons = 0;
                        return;
                    }
                    const payload = JSON.parse(raw);
                    const completedSet = new Set(payload.completedIds || []);
                    let count = 0;
                    this.sections.forEach((section) => {
                        section.lessons.forEach((lesson) => {
                            lesson.completed = completedSet.has(lesson.id);
                            if (lesson.completed) {
                                count++;
                            }
                        });
                    });
                    this.completedLessons = count;
                } catch (e) {
                    this.completedLessons = 0;
                }
            },

            persist() {
                try {
                    const completedIds = [];
                    this.sections.forEach((section) => {
                        section.lessons.forEach((lesson) => {
                            if (lesson.completed) {
                                completedIds.push(lesson.id);
                            }
                        });
                    });
                    const payload = {
                        v: 1,
                        formationId: this.config.id,
                        userId: this.config.userId || null,
                        completedIds
                    };
                    window.localStorage.setItem(this.storageKey, JSON.stringify(payload));
                } catch (e) {
                    // ignore persistence errors (e.g., private browsing)
                }
            },

            recomputeSectionCounts() {
                let total = 0;
                this.sections.forEach((section) => {
                    let sectionCount = 0;
                    section.lessons.forEach((lesson) => {
                        if (lesson.completed) {
                            sectionCount++;
                        }
                    });
                    section.completedCount = sectionCount;
                    total += sectionCount;
                });
                this.completedLessons = total;
            },

            toggleLesson(sectionId, lessonId) {
                for (const section of this.sections) {
                    if (section.id !== sectionId) continue;
                    for (const lesson of section.lessons) {
                        if (lesson.id !== lessonId) continue;
                        lesson.completed = !lesson.completed;
                        break;
                    }
                }
                this.recomputeSectionCounts();
                this.persist();
            },

            resetProgress() {
                this.sections.forEach((section) => {
                    section.lessons.forEach((lesson) => {
                        lesson.completed = false;
                    });
                    section.completedCount = 0;
                });
                this.completedLessons = 0;
                try {
                    window.localStorage.removeItem(this.storageKey);
                } catch (e) {
                    // ignore
                }
            }
        };
    };
</script>
{% endblock %}
