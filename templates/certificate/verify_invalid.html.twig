{% extends 'base.html.twig' %}

{% block title %}Invalid Certificate · Skilora{% endblock %}

{% block body %}
<main class="min-h-screen bg-background text-foreground flex items-center justify-center px-4 py-10">
    <section class="w-full max-w-2xl rounded-2xl border border-destructive/30 bg-card p-8 shadow-xl text-center">
        <h1 class="text-2xl font-bold tracking-tight text-destructive">Invalid Certificate ❌</h1>
        <p class="mt-3 text-sm text-muted-foreground">
            The provided verification ID is not valid or no longer exists.
        </p>
        <p class="mt-4 text-xs text-muted-foreground">
            Verification ID:
            <span class="font-mono">{{ verificationId }}</span>
        </p>
    </section>
</main>
{% endblock %}
