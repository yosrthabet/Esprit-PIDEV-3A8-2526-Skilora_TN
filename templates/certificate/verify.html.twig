{% extends 'base.html.twig' %}

{% block title %}Certificate Verification · Skilora{% endblock %}

{% block body %}
<main class="min-h-screen bg-background text-foreground flex flex-col items-center justify-center px-4 py-10 gap-6">
    <div class="flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center rounded-full bg-emerald-500/15 px-4 py-1.5 text-sm font-semibold text-emerald-400 ring-1 ring-emerald-500/40">
            Verified Certificate ✅
        </span>
    </div>

    {# Render the same SVG certificate as preview and PDF #}
    <div class="w-full max-w-5xl rounded-2xl border border-indigo-500/30 bg-card p-4 shadow-xl overflow-auto">
        {% include 'certificate/_certificate_core.html.twig' with {
            certificate: certificate,
            qrCodeDataUri: null,
            formationDirectorSignatureDataUri: formationDirectorSignatureDataUri|default(null),
        } %}
    </div>

    <p class="text-sm text-muted-foreground">
        Verification ID:
        <span class="font-mono text-foreground">{{ certificate.verificationId }}</span>
    </p>
</main>
{% endblock %}
