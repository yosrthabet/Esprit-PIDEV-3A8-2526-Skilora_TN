{% extends 'layouts/app.html.twig' %}

{% block title %}Certificate QR · Skilora{% endblock %}
{% block page_title %}Certificate QR{% endblock %}

{% block content %}
<div class="mx-auto max-w-2xl">
    <div class="rounded-2xl border border-border bg-card p-8 shadow-xl text-center">
        <h2 class="text-2xl font-bold tracking-tight text-foreground">Scan to verify</h2>
        <p class="mt-2 text-sm text-muted-foreground">Use this QR code to open the public verification page.</p>

        <div class="mx-auto mt-6 w-fit rounded-2xl border border-border bg-white p-4 shadow">
            <img src="{{ qrCodeDataUri }}" alt="Certificate verification QR code" class="h-[320px] w-[320px] max-w-full">
        </div>

        <p class="mt-5 text-xs text-muted-foreground">Verification URL</p>
        <a href="{{ verificationUrl }}" target="_blank" rel="noopener noreferrer"
           class="mt-1 block break-all rounded-lg border border-border bg-background px-4 py-2 font-mono text-xs text-indigo-300 underline-offset-2 hover:underline">
            {{ verificationUrl }}
        </a>
        <p class="mt-3 text-xs text-muted-foreground">
            If scanning fails, open this link manually.
        </p>
    </div>
</div>
{% endblock %}
