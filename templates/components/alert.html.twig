{# components/alert.html.twig — ShadCN Alert

   Usage: include('components/alert.html.twig', {
       variant: 'default',   (default|destructive)
       title: 'Heads up!',
       body: 'You can add components to your app using the cli.',
   })
#}
{% set variant = variant|default('default') %}

{% set variant_classes = {
    'default': 'bg-background text-foreground [&>svg]:text-foreground',
    'destructive': 'border-destructive/50 text-destructive dark:border-destructive [&>svg]:text-destructive',
} %}

<div role="alert" class="relative w-full rounded-lg border px-4 py-3 text-sm {{ variant_classes[variant] }} {{ class|default('') }}">
    {% if title is defined and title %}
        <h5 class="mb-1 font-medium leading-none tracking-tight">{{ title }}</h5>
    {% endif %}
    {% if body is defined and body %}
        <div class="text-sm [&_p]:leading-relaxed">{{ body|raw }}</div>
    {% endif %}
</div>
