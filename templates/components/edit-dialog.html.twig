{# components/edit-dialog.html.twig — Reusable edit/update dialog (aligned with formation1: scroll = outer overlay). #}
{#
  A universal dialog that fetches its form content dynamically via AJAX.
  Works across all modules (users, recruitment, formations, etc.).
  Respects the current theme (dark/light) automatically via CSS variables.

  Scroll behaviour: same as formation1 — `fixed inset-0 … overflow-y-auto` on the overlay
  so tall forms scroll with the page; modal card has no max-height trap.

  Usage (trigger):
    <button @click="$dispatch('open-edit-dialog', {
        title: 'Edit User',
        description: 'Update your details.',
        url: '/admin/users/5/edit-form',
        size: 'lg'
    })">Edit</button>

  The URL endpoint should return ONLY the <form> HTML fragment (no layout).

  Usage (inline content — no AJAX):
    <button @click="$dispatch('open-edit-dialog', {
        title: 'Confirm Action',
        description: 'Are you sure?',
        content: '<form>...</form>',
        size: 'sm'
    })">Delete</button>
#}
<div
    x-data="{
        open: false,
        loading: false,
        title: '',
        description: '',
        formContent: '',
        size: 'lg',
        async loadContent(url) {
            this.loading = true;
            this.formContent = '';
            try {
                const res = await fetch(url, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                if (!res.ok) throw new Error('Failed to load');
                this.formContent = await res.text();
            } catch (e) {
                this.formContent = '<div class=\'p-4 text-center text-destructive\'>Failed to load content. Please try again.</div>';
            } finally {
                this.loading = false;
                this.$nextTick(() => {
                    this.$nextTick(() => {
                        if (window.Alpine && typeof Alpine.initTree === 'function' && this.$refs.dialogBody) {
                            Alpine.initTree(this.$refs.dialogBody);
                        }
                        if (window.lucide) {
                            lucide.createIcons({ nodes: this.$refs.dialogBody.querySelectorAll('[data-lucide]') });
                        }
                    });
                });
            }
        }
    }"
    @open-edit-dialog.window="
        title = $event.detail.title || 'Edit';
        description = $event.detail.description || '';
        size = $event.detail.size || 'lg';
        open = true;
        if ($event.detail.url) {
            loadContent($event.detail.url);
        } else if ($event.detail.content) {
            formContent = $event.detail.content;
            loading = false;
            $nextTick(() => {
                $nextTick(() => {
                    if (window.Alpine && typeof Alpine.initTree === 'function' && $refs.dialogBody) {
                        Alpine.initTree($refs.dialogBody);
                    }
                    if (window.lucide) {
                        lucide.createIcons({ nodes: $refs.dialogBody.querySelectorAll('[data-lucide]') });
                    }
                });
            });
        }
    "
    @close-edit-dialog.window="open = false"
    @keydown.escape.window="open = false"
    x-show="open"
    x-cloak
    class="relative z-50"
>
    {# Backdrop #}
    <div
        x-show="open"
        x-transition:enter="ease-out duration-200"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="ease-in duration-150"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        @click="open = false"
        class="fixed inset-0 bg-black/80"
    ></div>

    {# Dialog: outer scroll + inner flex min-h-full = tall forms scroll (Tailwind UI pattern; formation1 single-div can clip on some viewports). #}
    <div class="fixed inset-0 z-50 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4 sm:p-6">
        <div
            x-show="open"
            x-transition:enter="ease-out duration-200"
            x-transition:enter-start="opacity-0 scale-95 translate-y-4"
            x-transition:enter-end="opacity-100 scale-100 translate-y-0"
            x-transition:leave="ease-in duration-150"
            x-transition:leave-start="opacity-100 scale-100 translate-y-0"
            x-transition:leave-end="opacity-0 scale-95 translate-y-4"
            @click.stop
            :class="{
                'max-w-sm': size === 'sm',
                'max-w-lg': size === 'md',
                'max-w-2xl': size === 'lg',
                'max-w-4xl': size === 'xl',
            }"
            class="relative w-full rounded-lg border border-border bg-background text-foreground shadow-lg"
        >
            {# Close button #}
            <button @click="open = false" class="absolute right-4 top-4 rounded-sm opacity-70 ring-offset-background transition-opacity hover:opacity-100 focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 z-10">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>

            {# Header #}
            <div class="flex flex-col space-y-1.5 p-6 pb-0 pr-14">
                <h2 class="text-lg font-semibold leading-none tracking-tight" x-text="title"></h2>
                <p class="text-sm text-muted-foreground" x-show="description" x-text="description"></p>
            </div>

            {# Content — data-edit-dialog-body for AJAX validation swap (replaces innerHTML of this node) #}
            <div class="p-6" x-ref="dialogBody" data-edit-dialog-body>
                {# Loading spinner #}
                <template x-if="loading">
                    <div class="flex items-center justify-center py-12">
                        <svg class="h-8 w-8 animate-spin text-muted-foreground" viewBox="0 0 24 24" fill="none">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                        </svg>
                    </div>
                </template>
                {# Loaded content #}
                <template x-if="!loading">
                    <div x-html="formContent"></div>
                </template>
            </div>
        </div>
        </div>
    </div>
</div>
{{ include('admin/formation/_signature_zone_script.html.twig') }}
