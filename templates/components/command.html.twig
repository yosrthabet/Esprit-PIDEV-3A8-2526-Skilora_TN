{# components/command.html.twig — ShadCN Command (search palette / cmdk)

   Usage: Include once in layout. Open with Cmd+K or dispatch.
   {{ include('components/command.html.twig', {
       id: 'command-palette',
       placeholder: 'Type a command or search...',
       groups: [
           {
               label: 'Suggestions',
               items: [
                   { label: 'Dashboard', href: '/dashboard', icon: '<svg>...</svg>' },
                   { label: 'Settings', href: '/settings' },
               ]
           },
       ],
   }) }}

   Open via: @keydown.cmd.k.window.prevent="$dispatch('open-command')"
#}
{% set id = id|default('command-palette') %}
{% set placeholder = placeholder|default('Type a command or search...') %}

<div
    x-data="{
        open: false,
        search: '',
        get filtered() {
            if (!this.search) return true;
            return true;
        },
        matches(label) {
            return !this.search || label.toLowerCase().includes(this.search.toLowerCase());
        }
    }"
    @open-command.window="open = true; $nextTick(() => $refs.searchInput.focus())"
    @keydown.cmd.k.window.prevent="open = !open; if(open) $nextTick(() => $refs.searchInput.focus())"
    @keydown.ctrl.k.window.prevent="open = !open; if(open) $nextTick(() => $refs.searchInput.focus())"
    @keydown.escape.window="open = false"
    x-show="open"
    x-cloak
    class="relative z-50"
>
    {# Backdrop #}
    <div
        x-show="open"
        x-transition:enter="ease-out duration-200"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="ease-in duration-150"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        @click="open = false"
        class="fixed inset-0 bg-black/50"
    ></div>

    {# Command dialog #}
    <div class="fixed inset-0 z-50 flex items-start justify-center pt-[15vh] px-4">
        <div
            x-show="open"
            x-transition:enter="ease-out duration-200"
            x-transition:enter-start="opacity-0 scale-95 translate-y-4"
            x-transition:enter-end="opacity-100 scale-100 translate-y-0"
            x-transition:leave="ease-in duration-150"
            x-transition:leave-start="opacity-100 scale-100"
            x-transition:leave-end="opacity-0 scale-95"
            @click.stop
            class="w-full max-w-lg overflow-hidden rounded-xl border border-border bg-popover text-popover-foreground shadow-2xl"
        >
            {# Search input #}
            <div class="flex items-center border-b border-border px-3">
                <svg class="mr-2 h-4 w-4 shrink-0 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
                </svg>
                <input
                    x-ref="searchInput"
                    x-model="search"
                    type="text"
                    placeholder="{{ placeholder }}"
                    class="flex h-11 w-full rounded-md bg-transparent py-3 text-sm outline-none placeholder:text-muted-foreground disabled:cursor-not-allowed disabled:opacity-50"
                />
            </div>

            {# Results #}
            <div class="max-h-[300px] overflow-y-auto p-1">
                {% for group in groups|default([]) %}
                    <div x-show="[{% for item in group.items %}'{{ item.label|lower }}'{{ not loop.last ? ',' : '' }}{% endfor %}].some(l => matches(l))">
                        {% if group.label is defined %}
                            <p class="px-2 py-1.5 text-xs font-medium text-muted-foreground">{{ group.label }}</p>
                        {% endif %}
                        {% for item in group.items %}
                            <a
                                href="{{ item.href|default('#') }}"
                                x-show="matches('{{ item.label|e('js') }}')"
                                @click="open = false"
                                class="relative flex cursor-pointer select-none items-center gap-2 rounded-sm px-2 py-1.5 text-sm outline-none hover:bg-accent hover:text-accent-foreground"
                            >
                                {% if item.icon is defined %}
                                    <span class="[&>svg]:h-4 [&>svg]:w-4 text-muted-foreground">{{ item.icon|raw }}</span>
                                {% endif %}
                                {{ item.label }}
                                {% if item.shortcut is defined %}
                                    <span class="ml-auto text-xs tracking-widest text-muted-foreground">{{ item.shortcut }}</span>
                                {% endif %}
                            </a>
                        {% endfor %}
                    </div>
                {% endfor %}

                <p x-show="search && !$el.querySelector('[style*=\\'\\']')" class="py-6 text-center text-sm text-muted-foreground">
                    No results found.
                </p>
            </div>
        </div>
    </div>
</div>
