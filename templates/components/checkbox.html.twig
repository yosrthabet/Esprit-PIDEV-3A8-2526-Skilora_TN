{# components/checkbox.html.twig — ShadCN Checkbox #}
{% set checked = checked|default(false) %}
{% set disabled = disabled|default(false) %}

<div class="flex items-center space-x-2">
    <input
        type="checkbox"
        id="{{ name }}"
        name="{{ name }}"
        value="{{ value|default('1') }}"
        {{ checked ? 'checked' : '' }}
        {{ disabled ? 'disabled' : '' }}
        class="peer h-4 w-4 shrink-0 rounded-sm border border-primary shadow-sm focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:cursor-not-allowed disabled:opacity-50 accent-primary"
    />
    {% if label is defined and label %}
        <label for="{{ name }}" class="text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70">
            {{ label }}
        </label>
    {% endif %}
</div>
