{# components/accordion.html.twig — ShadCN Accordion

   Usage: include('components/accordion.html.twig', {
       items: [
           { id: 'item-1', title: 'Is it accessible?', content: 'Yes. It uses Alpine.js.' },
           { id: 'item-2', title: 'Is it styled?', content: 'Yes. Tailwind + ShadCN tokens.' },
       ],
       type: 'single',  (single|multiple)
   })
#}
{% set type = type|default('single') %}

<div x-data="{ openItems: [] }" class="w-full {{ class|default('') }}">
    {% for item in items %}
    {% set item_id = item.id|default('accordion-' ~ loop.index) %}
    <div class="border-b border-border">
        <h3>
            <button
                type="button"
                @click="
                    {% if type == 'single' %}
                        openItems = openItems.includes('{{ item_id }}') ? [] : ['{{ item_id }}']
                    {% else %}
                        openItems.includes('{{ item_id }}')
                            ? openItems = openItems.filter(i => i !== '{{ item_id }}')
                            : openItems.push('{{ item_id }}')
                    {% endif %}
                "
                class="flex w-full items-center justify-between py-4 text-sm font-medium transition-all hover:underline [&[aria-expanded=true]>svg]:rotate-180"
                :aria-expanded="openItems.includes('{{ item_id }}')"
            >
                {{ item.title }}
                <svg
                    class="h-4 w-4 shrink-0 text-muted-foreground transition-transform duration-200"
                    :class="openItems.includes('{{ item_id }}') && 'rotate-180'"
                    fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
                >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
            </button>
        </h3>
        <div
            x-show="openItems.includes('{{ item_id }}')"
            x-collapse
            class="overflow-hidden text-sm"
        >
            <div class="pb-4 pt-0">{{ item.content|raw }}</div>
        </div>
    </div>
    {% endfor %}
</div>
