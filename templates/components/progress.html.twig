{# components/progress.html.twig — ShadCN Progress Bar #}
{% set value = value|default(0) %}
{% set max = max|default(100) %}
{% set percentage = max > 0 ? (value / max * 100)|round : 0 %}

<div class="relative h-2 w-full overflow-hidden rounded-full bg-primary/20 {{ class|default('') }}">
    <div
        class="h-full bg-primary transition-all duration-300"
        style="width: {{ percentage }}%"
        role="progressbar"
        aria-valuenow="{{ value }}"
        aria-valuemin="0"
        aria-valuemax="{{ max }}"
    ></div>
</div>
{% if show_label is defined and show_label %}
    <p class="mt-1 text-xs text-muted-foreground">{{ percentage }}%</p>
{% endif %}
