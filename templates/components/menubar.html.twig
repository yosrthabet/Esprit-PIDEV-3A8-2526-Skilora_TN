{# components/menubar.html.twig — ShadCN-style Menubar

   Usage: {{ include('components/menubar.html.twig', {
       menus: [
           { label: 'File', items: [
               { label: 'New Tab', shortcut: '⌘T' },
               { label: 'New Window', shortcut: '⌘N' },
               { type: 'separator' },
               { label: 'Print', shortcut: '⌘P' },
           ]},
           { label: 'Edit', items: [
               { label: 'Undo', shortcut: '⌘Z' },
               { label: 'Redo', shortcut: '⇧⌘Z' },
           ]},
       ]
   }) }}
#}

<div class="flex h-9 items-center space-x-1 rounded-md border border-border bg-background p-1 shadow-sm {{ class|default('') }}" x-data="{ activeMenu: null }">
    {% for menu in menus %}
        <div class="relative" @mouseleave="activeMenu = null">
            <button
                @click="activeMenu = activeMenu === {{ loop.index }} ? null : {{ loop.index }}"
                @mouseenter="activeMenu !== null ? activeMenu = {{ loop.index }} : null"
                :class="activeMenu === {{ loop.index }} ? 'bg-accent text-accent-foreground' : ''"
                class="flex cursor-default select-none items-center rounded-sm px-3 py-1 text-sm font-medium outline-none hover:bg-accent hover:text-accent-foreground"
            >
                {{ menu.label }}
            </button>

            <div
                x-show="activeMenu === {{ loop.index }}"
                x-transition:enter="transition ease-out duration-100"
                x-transition:enter-start="opacity-0 scale-95"
                x-transition:enter-end="opacity-100 scale-100"
                x-transition:leave="transition ease-in duration-75"
                x-transition:leave-start="opacity-100 scale-100"
                x-transition:leave-end="opacity-0 scale-95"
                class="absolute left-0 top-full z-50 mt-1 min-w-[12rem] overflow-hidden rounded-md border border-border bg-popover p-1 text-popover-foreground shadow-md"
                @click.outside="activeMenu = null"
            >
                {% for item in menu.items %}
                    {% if item.type|default('') == 'separator' %}
                        <div class="-mx-1 my-1 h-px bg-border"></div>
                    {% else %}
                        <button
                            @click="activeMenu = null; {% if item.action is defined %}{{ item.action }}{% endif %}"
                            class="relative flex w-full cursor-default select-none items-center rounded-sm px-2 py-1.5 text-sm outline-none hover:bg-accent hover:text-accent-foreground {{ item.disabled|default(false) ? 'pointer-events-none opacity-50' : '' }}"
                        >
                            <span class="flex-1 text-left">{{ item.label }}</span>
                            {% if item.shortcut is defined %}
                                <span class="ml-auto text-xs tracking-widest text-muted-foreground">{{ item.shortcut }}</span>
                            {% endif %}
                        </button>
                    {% endif %}
                {% endfor %}
            </div>
        </div>
    {% endfor %}
</div>
