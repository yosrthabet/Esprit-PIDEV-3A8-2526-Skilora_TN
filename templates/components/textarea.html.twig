{# components/textarea.html.twig — ShadCN Textarea #}
{% set rows = rows|default(4) %}
{% set required = required|default(false) %}
{% set disabled = disabled|default(false) %}
{% set extra_class = class|default('') %}

<div class="space-y-2">
    {% if label is defined and label %}
        <label for="{{ name }}" class="text-sm font-medium leading-none">
            {{ label }}{% if required %} <span class="text-destructive">*</span>{% endif %}
        </label>
    {% endif %}

    <textarea
        id="{{ name }}"
        name="{{ name }}"
        rows="{{ rows }}"
        {% if placeholder is defined %}placeholder="{{ placeholder }}"{% endif %}
        {{ required ? 'required' : '' }}
        {{ disabled ? 'disabled' : '' }}
        class="flex min-h-[60px] w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm shadow-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:cursor-not-allowed disabled:opacity-50 {{ error is defined and error ? 'border-destructive' : '' }} {{ extra_class }}"
    >{{ value|default('') }}</textarea>

    {% if error is defined and error %}
        <p class="text-[0.8rem] font-medium text-destructive">{{ error }}</p>
    {% endif %}
</div>
