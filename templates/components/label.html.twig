{# components/label.html.twig — ShadCN Label

   Usage: {{ include('components/label.html.twig', {
       for: 'email',
       text: 'Email Address',
       required: true,
   }) }}
#}
{% set required = required|default(false) %}

<label
    {% if for is defined %}for="{{ for }}"{% endif %}
    class="text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70 {{ class|default('') }}"
>
    {{ text }}{% if required %} <span class="text-destructive">*</span>{% endif %}
</label>
