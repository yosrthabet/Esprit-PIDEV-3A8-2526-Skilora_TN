{# components/drawer.html.twig — ShadCN Drawer (bottom sheet)

   Usage: {{ include('components/drawer.html.twig', {
       id: 'filters-drawer',
       title: 'Filters',
       description: 'Narrow down your search results.',
       content: '<form>...</form>',
   }) }}

   Open via: @click="$dispatch('open-drawer', { id: 'filters-drawer' })"
#}
{% set id = id|default('drawer') %}

<div
    x-data="{ open: false }"
    @open-drawer.window="if ($event.detail.id === '{{ id }}') open = true"
    @keydown.escape.window="open = false"
    x-show="open"
    x-cloak
    class="relative z-50"
>
    {# Backdrop #}
    <div
        x-show="open"
        x-transition:enter="ease-out duration-300"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="ease-in duration-200"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        @click="open = false"
        class="fixed inset-0 bg-black/80"
    ></div>

    {# Drawer panel #}
    <div class="fixed inset-x-0 bottom-0 z-50">
        <div
            x-show="open"
            x-transition:enter="ease-out duration-300"
            x-transition:enter-start="translate-y-full"
            x-transition:enter-end="translate-y-0"
            x-transition:leave="ease-in duration-200"
            x-transition:leave-start="translate-y-0"
            x-transition:leave-end="translate-y-full"
            @click.stop
            class="mx-auto w-full max-w-lg rounded-t-xl border border-border bg-background {{ class|default('') }}"
        >
            {# Handle #}
            <div class="mx-auto mt-4 h-1.5 w-12 rounded-full bg-muted"></div>

            {# Header #}
            <div class="p-6 pb-0">
                {% if title is defined and title %}
                    <h2 class="text-lg font-semibold text-foreground">{{ title }}</h2>
                {% endif %}
                {% if description is defined and description %}
                    <p class="text-sm text-muted-foreground mt-1">{{ description }}</p>
                {% endif %}
            </div>

            {# Content #}
            <div class="p-6 max-h-[60vh] overflow-y-auto">
                {{ content|default('')|raw }}
            </div>

            {# Footer #}
            {% if footer is defined and footer %}
            <div class="border-t border-border p-4 flex gap-2 justify-end">
                {{ footer|raw }}
            </div>
            {% endif %}
        </div>
    </div>
</div>
