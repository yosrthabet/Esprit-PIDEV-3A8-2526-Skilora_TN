{# components/resizable.html.twig — ShadCN Resizable panels

   Usage: {{ include('components/resizable.html.twig', {
       direction: 'horizontal',
       panels: [
           { content: '<div class="p-4">Panel 1</div>', default_size: '50%' },
           { content: '<div class="p-4">Panel 2</div>', default_size: '50%' },
       ],
   }) }}
#}
{% set direction = direction|default('horizontal') %}

<div class="flex {{ direction == 'vertical' ? 'flex-col' : '' }} h-full w-full overflow-hidden rounded-lg border border-border {{ class|default('') }}">
    {% for panel in panels|default([]) %}
        {% if not loop.first %}
            {# Resize handle #}
            <div class="{{ direction == 'vertical' ? 'h-1.5 w-full cursor-row-resize' : 'w-1.5 h-full cursor-col-resize' }} bg-border hover:bg-primary/50 transition-colors flex items-center justify-center shrink-0">
                <div class="{{ direction == 'vertical' ? 'h-1 w-8' : 'w-1 h-8' }} rounded-full bg-muted-foreground/30"></div>
            </div>
        {% endif %}

        <div
            class="overflow-auto {{ direction == 'vertical' ? 'w-full' : 'h-full' }}"
            style="{{ direction == 'vertical' ? 'height' : 'width' }}: {{ panel.default_size|default('auto') }}; flex: 1 1 0%;"
        >
            {{ panel.content|default('')|raw }}
        </div>
    {% endfor %}
</div>
