{# components/empty-state.html.twig — Empty state placeholder #}
{#
  Usage: {{ include('components/empty-state.html.twig', {
      icon: '<svg ...>...</svg>',
      title: 'No results found',
      description: 'Try adjusting your search or filters.',
      action_label: 'Create new',
      action_href: '/create',
  }) }}
#}

<div class="flex flex-col items-center justify-center py-12 text-center {{ class|default('') }}">
    {% if icon is defined %}
        <div class="mb-4 text-muted-foreground">
            {{ icon|raw }}
        </div>
    {% endif %}

    {% if title is defined and title %}
        <h3 class="text-lg font-semibold">{{ title }}</h3>
    {% endif %}

    {% if description is defined and description %}
        <p class="mt-1 text-sm text-muted-foreground max-w-sm">{{ description }}</p>
    {% endif %}

    {% if action_label is defined and action_label %}
        <a href="{{ action_href|default('#') }}" class="mt-4 inline-flex items-center justify-center gap-2 rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground shadow-sm hover:bg-primary/90 transition-colors">
            {{ action_label }}
        </a>
    {% endif %}
</div>
