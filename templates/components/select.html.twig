{# components/select.html.twig — ShadCN Select #}
{% set required = required|default(false) %}
{% set disabled = disabled|default(false) %}
{% set extra_class = class|default('') %}
{% set selected = selected|default('') %}

<div class="space-y-2">
    {% if label is defined and label %}
        <label for="{{ name }}" class="text-sm font-medium leading-none">
            {{ label }}{% if required %} <span class="text-destructive">*</span>{% endif %}
        </label>
    {% endif %}

    <select
        id="{{ name }}"
        name="{{ name }}"
        {{ required ? 'required' : '' }}
        {{ disabled ? 'disabled' : '' }}
        class="flex h-9 w-full items-center justify-between whitespace-nowrap rounded-md border border-input bg-transparent px-3 py-2 text-sm shadow-sm ring-offset-background placeholder:text-muted-foreground focus:outline-none focus:ring-1 focus:ring-ring disabled:cursor-not-allowed disabled:opacity-50 {{ extra_class }}"
    >
        {% if placeholder is defined %}
            <option value="" disabled {{ selected == '' ? 'selected' : '' }}>{{ placeholder }}</option>
        {% endif %}
        {% for option in options|default([]) %}
            <option
                value="{{ option.value }}"
                {{ selected == option.value ? 'selected' : '' }}
            >{{ option.label }}</option>
        {% endfor %}
    </select>

    {% if error is defined and error %}
        <p class="text-[0.8rem] font-medium text-destructive">{{ error }}</p>
    {% endif %}
</div>
