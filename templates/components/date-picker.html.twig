{# components/date-picker.html.twig — Simple date input with ShadCN styling #}
{#
  Usage: {{ include('components/date-picker.html.twig', {
      name: 'start_date',
      label: 'Start Date',
      value: '2026-01-15',
      min: '2026-01-01',
      max: '2026-12-31',
  }) }}
#}
{% set required = required|default(false) %}
{% set disabled = disabled|default(false) %}

<div class="space-y-2">
    {% if label is defined and label %}
        <label for="{{ name }}" class="text-sm font-medium leading-none">
            {{ label }}{% if required %} <span class="text-destructive">*</span>{% endif %}
        </label>
    {% endif %}

    <input
        type="date"
        id="{{ name }}"
        name="{{ name }}"
        value="{{ value|default('') }}"
        {% if min is defined %}min="{{ min }}"{% endif %}
        {% if max is defined %}max="{{ max }}"{% endif %}
        {{ required ? 'required' : '' }}
        {{ disabled ? 'disabled' : '' }}
        class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:cursor-not-allowed disabled:opacity-50 {{ class|default('') }}"
    />

    {% if error is defined and error %}
        <p class="text-[0.8rem] font-medium text-destructive">{{ error }}</p>
    {% endif %}
</div>
