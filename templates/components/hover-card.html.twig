{# components/hover-card.html.twig — ShadCN Hover Card

   Usage: {{ include('components/hover-card.html.twig', {
       trigger: '<a href="#">@username</a>',
       content: '<div>Profile preview...</div>',
       width: 'w-80',
   }) }}
#}
{% set width = width|default('w-80') %}

<div x-data="{ show: false, timeout: null }" class="relative inline-block {{ class|default('') }}"
     @mouseenter="clearTimeout(timeout); timeout = setTimeout(() => show = true, 200)"
     @mouseleave="clearTimeout(timeout); timeout = setTimeout(() => show = false, 100)">

    {{ trigger|default('')|raw }}

    <div
        x-show="show"
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="opacity-0 scale-95 translate-y-1"
        x-transition:enter-end="opacity-100 scale-100 translate-y-0"
        x-transition:leave="transition ease-in duration-150"
        x-transition:leave-start="opacity-100 scale-100"
        x-transition:leave-end="opacity-0 scale-95"
        x-cloak
        class="absolute z-50 {{ width }} top-full left-0 mt-2 rounded-md border border-border bg-popover p-4 text-popover-foreground shadow-md outline-none"
    >
        {{ content|default('')|raw }}
    </div>
</div>
