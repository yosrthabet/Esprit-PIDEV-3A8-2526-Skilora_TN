{# components/star-rating.html.twig — Interactive star rating

   Usage: include('components/star-rating.html.twig', {
       name: 'rating',
       value: 3,
       max: 5,
       readonly: false,
       size: 'default',  (sm|default|lg)
   })
#}
{% set value = value|default(0) %}
{% set max = max|default(5) %}
{% set readonly = readonly|default(false) %}
{% set size = size|default('default') %}

{% set size_classes = {
    'sm': 'h-4 w-4',
    'default': 'h-5 w-5',
    'lg': 'h-6 w-6',
} %}

<div class="flex items-center gap-0.5 {{ class|default('') }}"
     {% if not readonly %}
     x-data="{ rating: {{ value }}, hover: 0 }"
     {% endif %}
>
    {% if not readonly %}
        <input type="hidden" name="{{ name }}" :value="rating">
    {% endif %}

    {% for i in 1..max %}
        {% if readonly %}
            <svg class="{{ size_classes[size] }} {{ i <= value ? 'text-yellow-400 fill-yellow-400' : 'text-muted-foreground/30' }}"
                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.562.562 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
            </svg>
        {% else %}
            <button
                type="button"
                @click="rating = {{ i }}"
                @mouseenter="hover = {{ i }}"
                @mouseleave="hover = 0"
                class="cursor-pointer transition-colors"
            >
                <svg class="{{ size_classes[size] }} transition-colors"
                     :class="(hover || rating) >= {{ i }} ? 'text-yellow-400 fill-yellow-400' : 'text-muted-foreground/30'"
                     viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.562.562 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
                </svg>
            </button>
        {% endif %}
    {% endfor %}

    {% if show_value is defined and show_value %}
        <span class="ml-1 text-sm text-muted-foreground"
              {% if not readonly %}x-text="rating + '/{{ max }}'"{% endif %}
        >{{ value }}/{{ max }}</span>
    {% endif %}
</div>
