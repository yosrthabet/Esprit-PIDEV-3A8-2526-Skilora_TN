{# components/breadcrumb.html.twig — ShadCN Breadcrumb

   Usage: {{ include('components/breadcrumb.html.twig', {
       items: [
           { label: 'Home', href: '/' },
           { label: 'Products', href: '/products' },
           { label: 'Details' },
       ],
   }) }}
#}

<nav aria-label="Breadcrumb" class="{{ class|default('') }}">
    <ol class="flex flex-wrap items-center gap-1.5 break-words text-sm text-muted-foreground sm:gap-2.5">
        {% for item in items|default([]) %}
            {% if not loop.first %}
                <li role="presentation" aria-hidden="true" class="[&>svg]:h-3.5 [&>svg]:w-3.5">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </li>
            {% endif %}

            <li class="inline-flex items-center gap-1.5">
                {% if item.href is defined and not loop.last %}
                    <a href="{{ item.href }}" class="transition-colors hover:text-foreground">
                        {{ item.label }}
                    </a>
                {% else %}
                    <span class="font-normal text-foreground" aria-current="page">
                        {{ item.label }}
                    </span>
                {% endif %}
            </li>
        {% endfor %}
    </ol>
</nav>
