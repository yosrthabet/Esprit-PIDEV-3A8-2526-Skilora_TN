{# components/input.html.twig — ShadCN Input #}
{#
  Usage: {{ include('components/input.html.twig', {
      name: 'email',
      label: 'Email',
      type: 'text',
      placeholder: 'you@example.com',
      value: '',
      required: false,
      disabled: false,
      error: '',
      class: '',
  }) }}
#}
{% set type = type|default('text') %}
{% set value = value|default('') %}
{% set required = required|default(false) %}
{% set disabled = disabled|default(false) %}
{% set extra_class = class|default('') %}

<div class="space-y-2">
    {% if label is defined and label %}
        <label for="{{ name }}" class="text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70">
            {{ label }}{% if required %} <span class="text-destructive">*</span>{% endif %}
        </label>
    {% endif %}

    <input
        type="{{ type }}"
        id="{{ name }}"
        name="{{ name }}"
        value="{{ value }}"
        {% if placeholder is defined %}placeholder="{{ placeholder }}"{% endif %}
        {{ required ? 'required' : '' }}
        {{ disabled ? 'disabled' : '' }}
        class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm transition-colors file:border-0 file:bg-transparent file:text-sm file:font-medium file:text-foreground placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:cursor-not-allowed disabled:opacity-50 {{ error is defined and error ? 'border-destructive focus-visible:ring-destructive' : '' }} {{ extra_class }}"
    />

    {% if error is defined and error %}
        <p class="text-[0.8rem] font-medium text-destructive">{{ error }}</p>
    {% endif %}
</div>
