{# components/aspect-ratio.html.twig — ShadCN Aspect Ratio

   Usage: {{ include('components/aspect-ratio.html.twig', {
       ratio: '16/9',
       content: '<img src="/photo.jpg" class="h-full w-full object-cover" />',
   }) }}
#}
{% set ratio = ratio|default('16/9') %}

<div class="relative w-full overflow-hidden rounded-md {{ class|default('') }}" style="aspect-ratio: {{ ratio }};">
    {{ content|default('')|raw }}
</div>
