{# components/calendar.html.twig — ShadCN-style Calendar grid

   Usage: {{ include('components/calendar.html.twig', {
       name: 'date',
       selected: '2025-01-15',
   }) }}
#}
{% set selected = selected|default('') %}

<div class="p-3 {{ class|default('') }}" x-data="{
    month: {{ selected ? 'new Date(\'' ~ selected ~ '\').getMonth()' : 'new Date().getMonth()' }},
    year: {{ selected ? 'new Date(\'' ~ selected ~ '\').getFullYear()' : 'new Date().getFullYear()' }},
    selected: '{{ selected }}',
    today: new Date().toISOString().split('T')[0],

    get daysInMonth() {
        return new Date(this.year, this.month + 1, 0).getDate();
    },
    get firstDayOfWeek() {
        return new Date(this.year, this.month, 1).getDay();
    },
    get monthName() {
        return new Date(this.year, this.month).toLocaleString('default', { month: 'long', year: 'numeric' });
    },
    get days() {
        let d = [];
        for (let i = 0; i < this.firstDayOfWeek; i++) d.push(null);
        for (let i = 1; i <= this.daysInMonth; i++) d.push(i);
        return d;
    },
    dateStr(day) {
        if (!day) return '';
        let m = String(this.month + 1).padStart(2, '0');
        let dd = String(day).padStart(2, '0');
        return this.year + '-' + m + '-' + dd;
    },
    prevMonth() {
        if (this.month === 0) { this.month = 11; this.year--; }
        else { this.month--; }
    },
    nextMonth() {
        if (this.month === 11) { this.month = 0; this.year++; }
        else { this.month++; }
    },
    select(day) {
        this.selected = this.dateStr(day);
        this.$dispatch('calendar-select', { date: this.selected });
    }
}">
    <input type="hidden" name="{{ name|default('date') }}" :value="selected" />

    {# Header #}
    <div class="flex items-center justify-between mb-2">
        <button @click="prevMonth()" type="button" class="inline-flex h-7 w-7 items-center justify-center rounded-md hover:bg-accent hover:text-accent-foreground">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <div class="text-sm font-medium" x-text="monthName"></div>
        <button @click="nextMonth()" type="button" class="inline-flex h-7 w-7 items-center justify-center rounded-md hover:bg-accent hover:text-accent-foreground">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>
    </div>

    {# Day headers #}
    <div class="grid grid-cols-7 mb-1">
        <template x-for="d in ['Su','Mo','Tu','We','Th','Fr','Sa']">
            <div class="text-center text-[0.8rem] text-muted-foreground font-medium py-1" x-text="d"></div>
        </template>
    </div>

    {# Day grid #}
    <div class="grid grid-cols-7">
        <template x-for="(day, i) in days" :key="i">
            <div class="p-0 text-center">
                <template x-if="day">
                    <button
                        type="button"
                        @click="select(day)"
                        :class="{
                            'bg-primary text-primary-foreground hover:bg-primary/90': selected === dateStr(day),
                            'bg-accent': today === dateStr(day) && selected !== dateStr(day),
                            'hover:bg-accent hover:text-accent-foreground': selected !== dateStr(day)
                        }"
                        class="inline-flex h-8 w-8 items-center justify-center rounded-md text-sm transition-colors"
                        x-text="day"
                    ></button>
                </template>
            </div>
        </template>
    </div>
</div>
