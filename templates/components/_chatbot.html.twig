{% set _endpoint = endpoint|default(path('app_chatbot_ask')) %}
{% set _activeCategory = activeCategory|default('') %}
{% set _searchQuery = searchQuery|default('') %}
{% set _filterLevel = filterLevel|default('') %}
{% set _formations = formations|default([]) %}

<style>
    #formations-chatbot-messages {
        -webkit-overflow-scrolling: touch;
        overscroll-behavior: contain;
        touch-action: pan-y;
    }
    #formations-chatbot-messages::-webkit-scrollbar {
        width: 8px;
    }
    #formations-chatbot-messages::-webkit-scrollbar-track {
        background: hsl(var(--muted) / 0.5);
        border-radius: 9999px;
    }
    #formations-chatbot-messages::-webkit-scrollbar-thumb {
        background: hsl(var(--muted-foreground) / 0.35);
        border-radius: 9999px;
    }
    #formations-chatbot-messages::-webkit-scrollbar-thumb:hover {
        background: hsl(var(--muted-foreground) / 0.5);
    }
    @keyframes skilora-chatbot-dot {
        0%, 80%, 100% { opacity: 0.35; transform: translateY(0); }
        40% { opacity: 1; transform: translateY(-2px); }
    }
    .skilora-chatbot-typing span {
        display: inline-block;
        width: 6px;
        height: 6px;
        margin: 0 2px;
        border-radius: 9999px;
        background: hsl(var(--primary));
        animation: skilora-chatbot-dot 1.2s infinite ease-in-out;
    }
    .skilora-chatbot-typing span:nth-child(2) { animation-delay: 0.15s; }
    .skilora-chatbot-typing span:nth-child(3) { animation-delay: 0.3s; }
    #formations-chatbot-messages .skilora-chatbot-msg-row {
        min-width: 0;
    }
    /* Full width of the chat column — long text wraps to new lines (no fixed max-width). */
    #formations-chatbot-messages .skilora-chatbot-msg--assistant {
        display: block;
        width: 100%;
        box-sizing: border-box;
        overflow-wrap: anywhere;
        word-break: break-word;
    }
    #formations-chatbot-messages .skilora-chatbot-msg--user {
        display: block;
        box-sizing: border-box;
        width: fit-content;
        max-width: 100%;
        margin-left: auto;
        overflow-wrap: anywhere;
        word-break: break-word;
    }
    #formations-chatbot-messages .skilora-chatbot-msg--assistant p {
        margin: 0;
    }
</style>

<div id="formations-chatbot-root" class="fixed bottom-4 right-4 z-[9999] w-[min(380px,calc(100vw-1.25rem))] pointer-events-none sm:bottom-6 sm:right-6">
    <div class="pointer-events-auto">
        <div id="formations-chatbot-greeting" class="hidden mb-2 rounded-xl border border-border bg-card px-3 py-2 text-xs text-muted-foreground shadow-md">
            Parcourez le catalogue : je peux filtrer par prix, durée, avis ou catégorie.
        </div>

        <button id="formations-chatbot-fab"
                type="button"
                class="ml-auto flex h-14 w-14 items-center justify-center rounded-full bg-primary text-primary-foreground shadow-lg ring-1 ring-border transition hover:bg-primary/90 hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
                aria-label="Ouvrir l’assistant formations">
            <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
            </svg>
        </button>

        <section id="formations-chatbot-window" class="hidden mt-2 grid h-[min(520px,calc(100dvh-6rem))] max-h-[min(520px,calc(100dvh-6rem))] grid-rows-[auto_minmax(0,1fr)_auto] overflow-hidden rounded-2xl border border-border bg-card text-card-foreground shadow-xl">
            <header class="flex shrink-0 items-center justify-between border-b border-border px-4 py-3">
                <div class="min-w-0">
                    <p class="text-sm font-semibold text-foreground">Assistant formations</p>
                    <p class="text-[11px] text-muted-foreground">Questions sur le catalogue et vos inscriptions</p>
                </div>
                <button id="formations-chatbot-close" type="button" class="rounded-md p-1.5 text-muted-foreground hover:bg-muted hover:text-foreground" aria-label="Fermer">
                    <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </header>

            <div id="formations-chatbot-messages"
                 class="min-h-0 space-y-3 overflow-y-scroll overflow-x-hidden bg-muted/30 px-3 py-3 text-xs [scrollbar-gutter:stable] [scrollbar-width:thin]"></div>

            <form id="formations-chatbot-form" class="border-t border-border bg-card px-3 py-3">
                <div class="flex items-center gap-2">
                    <input id="formations-chatbot-input"
                           type="text"
                           placeholder="Ex. formations gratuites, mieux notées…"
                           autocomplete="off"
                           class="h-9 flex-1 rounded-md border border-input bg-background px-3 text-xs text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 focus:ring-offset-background">
                    <button type="submit" class="inline-flex h-9 shrink-0 items-center justify-center rounded-md bg-primary px-3 text-xs font-medium text-primary-foreground hover:bg-primary/90">
                        Envoyer
                    </button>
                </div>
            </form>
        </section>
    </div>
</div>

<script>
(function() {
    const root = document.getElementById('formations-chatbot-root');
    if (!root) return;

    const fab = document.getElementById('formations-chatbot-fab');
    const win = document.getElementById('formations-chatbot-window');
    const closeBtn = document.getElementById('formations-chatbot-close');
    const greeting = document.getElementById('formations-chatbot-greeting');
    const form = document.getElementById('formations-chatbot-form');
    const input = document.getElementById('formations-chatbot-input');
    const messagesEl = document.getElementById('formations-chatbot-messages');

    const ENDPOINT = '{{ _endpoint|e('js') }}';
    const SESSION_CLOSED_KEY = 'skilora.chatbot.formations.closed';
    const SESSION_HISTORY_KEY = 'skilora.chatbot.formations.history';
    const WELCOME_ASSISTANT =
        'Bonjour ! Posez votre question sur les formations (prix, durée, avis, niveau…).';

    const COURSE_CATALOG = [
        {% for f in _formations %}
        {
            id: {{ f.id }},
            title: '{{ f.title|e('js') }}',
            category: '{{ f.category|e('js') }}',
            categoryLabel: '{{ f.categoryLabelFr|e('js') }}',
            level: '{{ f.levelLabelFr|e('js') }}',
            duration: {{ f.duration ?? 0 }},
            price: '{{ f.priceDisplayFr|e('js') }}'
        }{{ not loop.last ? ',' : '' }}
        {% endfor %}
    ];

    function readDomFilters() {
        const page = document.querySelector('[data-formation-page="catalog"]');
        return {
            active_category: page ? (page.getAttribute('data-filter-cat') || '') : '{{ _activeCategory|e('js') }}',
            search_query: page ? (page.getAttribute('data-filter-q') || '') : '{{ _searchQuery|e('js') }}',
            filter_level: page ? (page.getAttribute('data-filter-lvl') || '') : '{{ _filterLevel|e('js') }}',
        };
    }

    function scrapeVisibleCards() {
        const cards = document.querySelectorAll('[data-formation-card][data-formation-id]');
        const out = [];
        cards.forEach((el) => {
            out.push({
                id: parseInt(el.getAttribute('data-formation-id'), 10),
                title: el.getAttribute('data-formation-title') || '',
                category: el.getAttribute('data-formation-category') || '',
                categoryLabel: el.getAttribute('data-formation-category-label') || '',
                level: el.getAttribute('data-formation-level') || ''
            });
        });
        return out;
    }

    function buildContext() {
        const f = readDomFilters();
        return {
            active_category: f.active_category,
            search_query: f.search_query,
            filter_level: f.filter_level,
            course_catalog: COURSE_CATALOG,
            visible_formations: scrapeVisibleCards()
        };
    }

    let isOpen = false;
    let history = readHistory();

    function readHistory() {
        try {
            const raw = sessionStorage.getItem(SESSION_HISTORY_KEY);
            if (!raw) return [];
            const parsed = JSON.parse(raw);
            return Array.isArray(parsed) ? parsed : [];
        } catch (_) {
            return [];
        }
    }

    function persistHistory() {
        try {
            sessionStorage.setItem(SESSION_HISTORY_KEY, JSON.stringify(history.slice(-20)));
        } catch (_) {}
    }

    function scrollMessages() {
        requestAnimationFrame(function() {
            messagesEl.scrollTop = messagesEl.scrollHeight;
            requestAnimationFrame(function() {
                messagesEl.scrollTop = messagesEl.scrollHeight;
            });
        });
    }

    function renderUserBubble(content) {
        const wrap = document.createElement('div');
        wrap.className = 'skilora-chatbot-msg-row flex justify-end';
        const inner = document.createElement('div');
        inner.className = 'skilora-chatbot-msg--user rounded-2xl rounded-br-md border border-primary/25 bg-primary px-3 py-2 text-xs text-primary-foreground shadow-sm';
        inner.textContent = content;
        wrap.appendChild(inner);
        messagesEl.appendChild(wrap);
        scrollMessages();
    }

    function renderAssistantBubble(text, formations) {
        const wrap = document.createElement('div');
        wrap.className = 'skilora-chatbot-msg-row flex justify-start';
        const inner = document.createElement('div');
        inner.className = 'skilora-chatbot-msg--assistant rounded-2xl rounded-bl-md border border-border bg-background px-3 py-2 text-xs text-foreground shadow-sm';

        const p = document.createElement('div');
        p.className = 'whitespace-pre-wrap leading-relaxed';
        p.textContent = text;
        inner.appendChild(p);

        if (Array.isArray(formations) && formations.length) {
            const list = document.createElement('ul');
            list.className = 'mt-2 max-w-full space-y-1.5 border-t border-border pt-2 break-words';
            formations.forEach((item) => {
                const li = document.createElement('li');
                const a = document.createElement('a');
                a.href = item.url || '#';
                a.className = 'font-medium text-primary hover:underline';
                a.textContent = item.title;
                const meta = document.createElement('span');
                meta.className = 'ml-1 text-[10px] font-normal text-muted-foreground';
                const rating = typeof item.averageRating === 'number' ? item.averageRating.toFixed(1) : '—';
                const rc = item.reviewCount != null ? item.reviewCount : 0;
                const dur = item.durationHours != null ? item.durationHours + ' h' : '—';
                const enr = item.enrollmentCount != null ? item.enrollmentCount : 0;
                const pop = enr > 0 ? ' · ' + enr + ' insc.' : '';
                meta.textContent = ' · ' + (item.categoryLabel || '') + ' · ' + dur + ' · ★ ' + rating + ' (' + rc + ' avis)' + pop + ' · ' + (item.priceLabel || '');
                li.appendChild(a);
                li.appendChild(meta);
                list.appendChild(li);
            });
            inner.appendChild(list);
        }

        wrap.appendChild(inner);
        messagesEl.appendChild(wrap);
        scrollMessages();
    }

    function renderTypingIndicator() {
        const wrap = document.createElement('div');
        wrap.className = 'skilora-chatbot-msg-row skilora-chatbot-typing flex justify-start';
        wrap.setAttribute('data-typing', '1');
        const inner = document.createElement('div');
        inner.className = 'rounded-2xl border border-border bg-muted/80 px-4 py-3';
        inner.innerHTML = '<span></span><span></span><span></span>';
        wrap.appendChild(inner);
        messagesEl.appendChild(wrap);
        scrollMessages();
        return wrap;
    }

    function redrawHistory() {
        messagesEl.innerHTML = '';
        history.forEach((m) => {
            if (m.role === 'user') {
                renderUserBubble(m.content);
            } else {
                renderAssistantBubble(m.content, m.formations || []);
            }
        });
    }

    function openChat() {
        isOpen = true;
        win.classList.remove('hidden');
        greeting.classList.add('hidden');
        sessionStorage.removeItem(SESSION_CLOSED_KEY);
        history = [{ role: 'assistant', content: WELCOME_ASSISTANT, formations: [] }];
        try {
            sessionStorage.removeItem(SESSION_HISTORY_KEY);
        } catch (_) {}
        redrawHistory();
        scrollMessages();
        input.value = '';
        input.focus();
    }

    function closeChat() {
        isOpen = false;
        win.classList.add('hidden');
        sessionStorage.setItem(SESSION_CLOSED_KEY, '1');
    }

    function isSpamOrEmpty(text) {
        if (!text || !text.trim()) return true;
        const hasAlnum = /[a-z0-9]/i.test(text);
        if (!hasAlnum) return true;
        const compact = text.replace(/\s+/g, '');
        return compact.length < 2;
    }

    async function askAssistant(message) {
        const payload = { message, context: buildContext() };
        const res = await fetch(ENDPOINT, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest',
                'X-Chat-Origin-Path': window.location.pathname
            },
            body: JSON.stringify(payload)
        });
        if (res.status === 503) {
            return { reply: 'Le service assistant est momentanément indisponible. Réessayez dans un instant.', formations: [] };
        }
        if (!res.ok) {
            return { reply: 'Assistant indisponible. Réessayez dans un moment.', formations: [] };
        }
        return res.json();
    }

    fab.addEventListener('click', openChat);
    closeBtn.addEventListener('click', closeChat);

    form.addEventListener('submit', async function(e) {
        e.preventDefault();
        const msg = input.value.trim();
        if (isSpamOrEmpty(msg)) return;
        history.push({ role: 'user', content: msg, formations: [] });
        renderUserBubble(msg);
        input.value = '';
        persistHistory();

        const typingEl = renderTypingIndicator();
        try {
            const data = await askAssistant(msg);
            typingEl.remove();
            const reply = data.reply || 'Réponse indisponible.';
            const formations = Array.isArray(data.formations)
                ? data.formations
                : (Array.isArray(data.results) ? data.results : []);
            history.push({ role: 'assistant', content: reply, formations: formations });
            renderAssistantBubble(reply, formations);
            persistHistory();
        } catch (_) {
            typingEl.remove();
            const fallback = 'Impossible de joindre le serveur. Vérifiez votre connexion et réessayez.';
            history.push({ role: 'assistant', content: fallback, formations: [] });
            renderAssistantBubble(fallback, []);
            persistHistory();
        }
    });

    const grid = document.querySelector('[data-formation-grid]');
    if (grid && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver((entries) => {
            entries.forEach((en) => {
                if (en.isIntersecting && sessionStorage.getItem(SESSION_CLOSED_KEY) !== '1' && !isOpen) {
                    greeting.classList.remove('hidden');
                }
            });
        }, { threshold: 0.15 });
        io.observe(grid);
    }

    if (sessionStorage.getItem(SESSION_CLOSED_KEY) !== '1') {
        setTimeout(() => {
            if (isOpen) return;
            greeting.classList.remove('hidden');
        }, 2800);
    }

    let idleTimer = null;
    function resetIdleExpand() {
        if (idleTimer) clearTimeout(idleTimer);
        idleTimer = setTimeout(() => {
            if (isOpen || sessionStorage.getItem(SESSION_CLOSED_KEY) === '1') return;
            const name = '{{ app.user ? app.user.userIdentifier|default('')|e('js') : '' }}';
            const hint = name ? ('Besoin d’un coup de pouce, ' + name.split('@')[0] + ' ?') : 'Besoin d’aide pour choisir une formation ?';
            greeting.textContent = hint + ' Ouvrez l’assistant en bas à droite.';
            greeting.classList.remove('hidden');
        }, 10000);
    }
    ['click', 'keydown', 'scroll', 'touchstart'].forEach((ev) => {
        window.addEventListener(ev, resetIdleExpand, { passive: true });
    });
    resetIdleExpand();
})();
</script>
