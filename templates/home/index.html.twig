{% extends 'base.html.twig' %}

{% block title %}Skilora | Unbounded{% endblock %}

{% block body_page %}home-connected{% endblock %}

{# Force light theme — dark/light is for logged-in users only #}
{% block head %}
{{ parent() }}
<script>document.documentElement.classList.remove('dark');</script>
{% endblock %}

{% block body %}
    {# Minimal Loader #}
    <div id="loader" class="fixed inset-0 z-[999] bg-zinc-950 flex justify-center items-center pointer-events-none">
        <div id="loader-dot" class="w-8 h-8 bg-white rounded-full"></div>
    </div>

    <!-- OSMO Exact Navbar -->
    <header class="header-wrapper">
        <div class="nav-container">
            
            <nav class="navbar">
                <div class="navbar-top">
                    <div class="header-left">
                        <div class="menu-btn group transition-opacity hover:opacity-70">
                            <div class="hamburger">
                                <span class="line top-line"></span>
                                <span class="line bottom-line"></span>
                            </div>
                            <span class="menu-text rolling-text" data-text="Menu">Menu</span>
                        </div>
                    </div>
                    
                    <a href="/" class="header-center tracking-[0.2em] font-black uppercase text-xl mt-1 relative h-8 w-32 flex items-center justify-center overflow-hidden">
                        <span class="logo-text absolute transition-all duration-500 ease-in-out text-center">SKILORA</span>
                        <span class="logo-icon absolute opacity-0 translate-y-8 transition-all duration-500 ease-in-out text-center block">
                            <i data-lucide="asterisk" class="w-6 h-6 mx-auto"></i>
                        </span>
                    </a>
                    
                    <div class="header-right">
                        {% if app.user %}
                            <a href="{{ path('app_dashboard') }}" class="pill-btn gray">
                                <span class="rolling-text" data-text="Dashboard">Dashboard</span>
                            </a>
                            <a href="{{ path('app_logout') }}" class="pill-btn lime">
                                <span class="rolling-text" data-text="Logout">Logout</span>
                            </a>
                        {% else %}
                            <a href="{{ path('app_login') }}" class="pill-btn gray"><span class="rolling-text" data-text="Login">Login</span></a>
                            <a href="{{ path('app_register') }}" class="pill-btn lime"><span class="rolling-text" data-text="Join">Join</span></a>
                        {% endif %}
                    </div>
                </div>

                <div class="menu-overlay">
                    <div class="menu-content-grid">
                        
                        <div class="menu-col">
                            <h3 class="menu-label">Our Platform</h3>
                            <ul class="menu-list">
                                <li class="menu-item"><a href="#"><span class="rolling-text" data-text="Find Work">Find Work</span></a></li>
                                <li class="menu-item"><a href="#"><span class="rolling-text" data-text="Hire Talent">Hire Talent</span> <span class="badge lime">NEW</span></a></li>
                                <li class="menu-item"><a href="#"><span class="rolling-text" data-text="Our Approach">Our Approach</span></a></li>
                                <li class="menu-item"><a href="#"><span class="rolling-text" data-text="Community">Community</span></a></li>
                                <li class="menu-item no-border"><a href="#"><span class="rolling-text" data-text="Pricing">Pricing</span></a></li>
                            </ul>
                        </div>

                        <div class="menu-col">
                            <h3 class="menu-label">Explore</h3>
                            <ul class="menu-list">
                                <li class="menu-item"><a href="#"><span class="rolling-text" data-text="Case Studies">Case Studies</span></a></li>
                                <li class="menu-item"><a href="#"><span class="rolling-text" data-text="About Us">About Us</span></a></li>
                                <li class="menu-item no-border"><a href="#"><span class="rolling-text" data-text="Careers">Careers</span></a></li>
                            </ul>
                            
                            <div class="social-icons">
                                <a href="#" class="social-link" aria-label="X (Twitter)">
                                    <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                                </a>
                                <a href="#" class="social-link" aria-label="LinkedIn">
                                    <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                                </a>
                            </div>
                        </div>

                        <div class="menu-col feature-col">
                            <h3 class="menu-label">Available Today</h3>
                            <div class="feature-card">
                                <h1 class="feature-title">Top Tier Talents</h1>
                                <div class="book-wrapper">
                                    <img src="https://images.unsplash.com/photo-1620641788421-7a1c342ea42e?w=600&h=600&fit=crop" alt="3D Book" class="book-img">
                                </div>
                                <a href="#" class="pill-btn lime"><span class="rolling-text" data-text="More Info">More Info</span></a>
                            </div>
                        </div>

                    </div>
                </div>
            </nav>
            
            <div class="marquee-banner">
                <div class="marquee-track">
                    <span>NEW: FIND YOUR NEXT TALENT ✦ WE ARE SKILORA ✦ </span>
                    <span>NEW: FIND YOUR NEXT TALENT ✦ WE ARE SKILORA ✦ </span>
                </div>
            </div>
        </div>
    </header>

    <main id="smooth-wrapper" class="overflow-hidden">
        <div id="smooth-content">
            
            {# 1. Hero Reveal #}
            <section class="relative h-screen w-full flex flex-col justify-center items-center overflow-hidden bg-zinc-950 text-white" id="hero-section">
                <!-- Parallax background element -->
                <div class="absolute inset-0 z-0">
                    <div id="hero-blob" class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[80vw] h-[80vw] max-w-[800px] max-h-[800px] bg-indigo-500/20 rounded-full blur-[120px] mix-blend-screen"></div>
                </div>

                <div class="relative z-10 text-center w-full px-4">
                    <div class="overflow-hidden mb-4">
                        <h1 id="hero-title" class="text-[12vw] leading-none font-black tracking-tighter uppercase whitespace-nowrap px-4 text-transparent bg-clip-text bg-gradient-to-br from-white to-zinc-500 translate-y-full">
                            Connect.
                        </h1>
                    </div>
                    <div class="overflow-hidden">
                        <h1 id="hero-title-2" class="text-[12vw] leading-none font-black tracking-tighter uppercase whitespace-nowrap px-4 text-transparent bg-clip-text bg-gradient-to-bl from-white to-zinc-500 translate-y-full">
                            Hire.
                        </h1>
                    </div>
                </div>

                <div class="absolute bottom-10 whitespace-nowrap overflow-hidden z-10 w-full pointer-events-none">
                    <div id="hero-marquee" class="text-[0.6rem] sm:text-xs uppercase tracking-[0.5em] text-zinc-400">
                        Scroll to explore &nbsp;—&nbsp; We bridge the gap between world-class talent and legendary companies &nbsp;—&nbsp; Scroll to explore &nbsp;—&nbsp; We bridge the gap between world-class talent and legendary companies &nbsp;—&nbsp; Scroll to explore &nbsp;—&nbsp; We bridge the gap between world-class talent and legendary companies
                    </div>
                </div>
            </section>


            {# 3. Massive Horizontal Scroll Section #}
            <section id="horizontal-section" class="relative w-full h-screen bg-white text-zinc-950 flex items-center overflow-hidden">
                <div class="w-full flex items-center overflow-hidden">
                    <div id="horizontal-track" class="flex items-center pl-[50vw] pr-[5vw] gap-32 whitespace-nowrap">
                        <div class="text-[15vw] font-black tracking-tighter uppercase leading-none">Find</div>
                        <div class="w-[40vw] h-[40vw] max-w-[600px] max-h-[600px] flex-shrink-0 rounded-[3rem] overflow-hidden rotate-12 hover:rotate-0 transition-all duration-700 relative group cursor-pointer">
                            <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=800&q=80" alt="Team" class="w-full h-full object-cover scale-110 group-hover:scale-100 transition-transform duration-700">
                        </div>
                        <div class="text-[15vw] font-black tracking-tighter uppercase leading-none">Your</div>
                        <div class="w-[40vw] h-[40vw] max-w-[600px] max-h-[600px] flex-shrink-0 rounded-full border-[10px] border-zinc-900 flex items-center justify-center bg-zinc-900 text-white">
                               <i data-lucide="arrow-right" class="w-32 h-32 md:w-64 md:h-64"></i>
                        </div>
                        <div class="text-[15vw] font-black tracking-tighter uppercase leading-none">Next</div>
                        <div class="text-[15vw] font-black tracking-tighter uppercase leading-none">Hire</div>
                    </div>
                </div>
            </section>

            {# 4. Footer Flow End #}
            <section class="h-screen w-full bg-zinc-950 text-white flex flex-col justify-center items-center text-center px-4 relative overflow-hidden" id="footer-cta">
                <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:100px_100px] [mask-image:radial-gradient(ellipse_at_center,black_40%,transparent_80%)] pointer-events-none"></div>
                <h2 id="cta-title" class="text-5xl md:text-[8vw] font-black tracking-tighter uppercase z-10 mb-8 scale-50 opacity-0">Start Now.</h2>
                <a href="/login" id="cta-btn" class="z-10 group relative inline-flex items-center justify-center px-12 py-6 text-xl font-bold text-white bg-zinc-800 rounded-full overflow-hidden transition-all hover:scale-105 scale-50 opacity-0">
                    <span class="absolute inset-0 w-full h-full -mt-1 rounded-lg opacity-30 bg-gradient-to-b from-transparent via-transparent to-black"></span>
                    <span class="absolute inset-0 w-full h-full bg-indigo-500 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></span>
                    <span class="relative z-10">Join Skilora</span>
                </a>
            </section>

        </div>
    </main>
{% endblock %}
