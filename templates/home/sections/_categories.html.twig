<!-- CATEGORIES -->
<section class="categories-section py-32 relative bg-background overflow-hidden">
    <!-- Decorative Background Blob -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-primary/5 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="container mx-auto px-6 relative z-10">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
            <div class="max-w-2xl space-y-4">
                <h2 class="text-4xl md:text-5xl font-bold tracking-tight text-foreground">Browse talent by category</h2>
                <p class="text-xl text-muted-foreground">Looking for work? Browse jobs instead.</p>
            </div>
            <a href="#" class="group inline-flex items-center text-primary font-semibold hover:gap-2 transition-all">
                All Categories
                <i data-lucide="arrow-right" class="w-5 h-5 ml-1 transition-transform group-hover:translate-x-1"></i>
            </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
             x-data="{ 
                handleHover(e) {
                    for(const card of $el.children) {
                        const rect = card.getBoundingClientRect();
                        const x = e.clientX - rect.left;
                        const y = e.clientY - rect.top;
                        card.style.setProperty('--mouse-x', `${x}px`);
                        card.style.setProperty('--mouse-y', `${y}px`);
                    }
                }
             }"
             @mousemove="handleHover">
            {% for category in categories %}
                <a href="#" class="category-card group relative rounded-[2rem] bg-card border border-border p-[1px] overflow-hidden transition-transform duration-500 hover:-translate-y-1 shadow-sm hover:shadow-xl">
                    
                    <!-- Glow effect following mouse -->
                    <div class="pointer-events-none absolute -inset-px opacity-0 transition duration-300 group-hover:opacity-100" 
                         style="background: radial-gradient(600px circle at var(--mouse-x, 0) var(--mouse-y, 0), hsl(var(--primary) / 0.15), transparent 40%);">
                    </div>
                    <!-- Secondary border glow -->
                    <div class="pointer-events-none absolute -inset-px opacity-0 transition duration-300 group-hover:opacity-100 mix-blend-overlay" 
                         style="background: radial-gradient(400px circle at var(--mouse-x, 0) var(--mouse-y, 0), hsl(var(--foreground) / 0.2), transparent 40%);">
                    </div>

                    <!-- Inner content container -->
                    <div class="relative flex h-full flex-col rounded-[calc(2rem-1px)] bg-card/95 backdrop-blur-md border border-border/50 p-8 z-10 transition-colors duration-500 group-hover:bg-card/80">
                        <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-primary/10 text-primary transition-transform duration-500 group-hover:scale-110">
                            <i data-lucide="{{ category.icon }}" class="h-8 w-8"></i>
                        </div>
                        
                        <h3 class="mb-4 text-2xl font-bold tracking-tight text-foreground transition-colors group-hover:text-primary">{{ category.title }}</h3>
                        
                        <div class="mt-auto flex items-center justify-between pt-4">
                            <span class="text-sm font-medium text-muted-foreground group-hover:text-primary transition-colors">Explore talent</span>
                            <i data-lucide="arrow-right" class="h-5 w-5 text-muted-foreground -translate-x-2 opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100 group-hover:text-primary"></i>
                        </div>
                    </div>
                </a>
            {% endfor %}
        </div>
    </div>
</section>