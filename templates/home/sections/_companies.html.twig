<!-- COMPANIES MARQUEE -->
<section class="companies-section py-16 bg-zinc-950 overflow-hidden border-b border-zinc-800/50">
    <div class="container mx-auto px-4 mb-10">
        <p class="text-center text-xs font-semibold text-zinc-500 uppercase tracking-[0.25em]">Trusted by forward-thinking companies</p>
    </div>
    
    <div class="relative w-full flex items-center overflow-hidden">
        <!-- Gradient masks -->
        <div class="absolute left-0 top-0 bottom-0 w-40 bg-gradient-to-r from-zinc-950 to-transparent z-10"></div>
        <div class="absolute right-0 top-0 bottom-0 w-40 bg-gradient-to-l from-zinc-950 to-transparent z-10"></div>
        
        <div class="companies-track flex items-center gap-20" style="width: max-content;">
            {% for i in 1..3 %}
                {% for company in companies %}
                    <div class="flex items-center gap-3 opacity-40 hover:opacity-100 transition-opacity duration-500 select-none cursor-pointer group flex-shrink-0">
                        <img src="{{ company.logo }}" alt="{{ company.name }}" class="h-8 w-8 object-contain grayscale group-hover:grayscale-0 transition-all duration-500" loading="lazy">
                        <span class="text-xl font-bold text-white tracking-tight hidden md:block">{{ company.name }}</span>
                    </div>
                {% endfor %}
            {% endfor %}
        </div>
    </div>
</section>