{% extends 'recrutement/employer/base.html.twig' %}

{% block employer_title %}Mes offres · Skilora{% endblock %}
{% block page_title %}Mes offres{% endblock %}

{% block employer_content %}
{% set filter = filter|default('all') %}
{% set search = search|default(null) %}
{% set work_type = work_type|default('all') %}
{% set work_fr = {
    'ONSITE': 'Sur site',
    'REMOTE': 'Télétravail',
    'PART_TIME': 'Temps partiel',
    'FREELANCE': 'Freelance',
    'INTERNSHIP': 'Stage',
} %}

<div class="mx-auto max-w-5xl space-y-6">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div>
            <p class="text-3xl font-semibold tracking-tight text-foreground">
                {% set n_offers = job_offers|length %}
                {{ n_offers }} offre{{ n_offers == 1 ? '' : 's' }}
            </p>
            <p class="mt-1 text-sm text-muted-foreground">
                {% if employer_sees_all_offers|default(false) %}
                    Vue globale des offres (toutes entreprises).
                {% elseif company %}
                    {{ company.name }}
                {% else %}
                    Aucune entreprise liée
                {% endif %}
            </p>
        </div>
        <div class="flex flex-wrap gap-2">
            {% if company %}
                <a href="{{ path('app_employer_job_offer_new') }}"
                   class="inline-flex h-10 items-center justify-center rounded-md bg-primary px-5 text-sm font-semibold text-primary-foreground shadow-sm transition-colors hover:bg-primary/90">
                    Nouvelle offre
                </a>
            {% endif %}
            {% set refresh_q = {filter: filter}|merge(search ? {q: search} : {})|merge(work_type != 'all' ? {work_type: work_type} : {}) %}
            <a href="{{ path('app_employer_job_offer_index', refresh_q) }}"
               class="inline-flex h-10 items-center justify-center rounded-md border border-input bg-background px-5 text-sm font-semibold text-foreground shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground">
                Actualiser
            </a>
        </div>
    </div>

    {% if company is null and not (employer_sees_all_offers|default(false)) %}
        <div class="rounded-lg border border-amber-500/40 bg-amber-500/10 px-4 py-3 text-sm text-amber-900 dark:text-amber-100">
            Liez une entreprise à votre compte pour gérer des offres.
        </div>
    {% else %}
        <div class="flex flex-col gap-4 border-b border-border pb-4">
            <div class="flex flex-wrap gap-2">
                {% set tabs = {
                    'all': 'Toutes',
                    'open': 'Ouvertes',
                    'draft': 'Brouillons',
                    'closed': 'Fermées',
                } %}
                {% for key, label in tabs %}
                    {% set qparams = {filter: key}|merge(search ? {q: search} : {})|merge(work_type != 'all' ? {work_type: work_type} : {}) %}
                    <a href="{{ path('app_employer_job_offer_index', qparams) }}"
                       class="rounded-md border px-4 py-2 text-sm font-medium transition
                              {{ filter == key ? 'border-foreground bg-accent text-accent-foreground' : 'border-transparent text-muted-foreground hover:text-foreground' }}">
                        {{ label }}
                    </a>
                {% endfor %}
            </div>
            <form method="get" action="{{ path('app_employer_job_offer_index') }}" class="flex max-w-3xl flex-col gap-2 sm:flex-row sm:flex-wrap sm:items-center">
                <input type="hidden" name="filter" value="{{ filter }}"/>
                <input type="search" name="q" value="{{ search|default('') }}" placeholder="Titre, lieu, entreprise…"
                       class="h-10 min-w-[200px] flex-1 rounded-md border border-input bg-background px-3 text-sm text-foreground placeholder:text-muted-foreground focus:border-ring focus:outline-none focus:ring-1 focus:ring-ring"/>
                <select name="work_type" class="h-10 rounded-md border border-input bg-background px-3 text-sm text-foreground">
                    <option value="all" {{ work_type == 'all' ? 'selected' }}>Tous les modes</option>
                    {% for wt_key, wt_label in work_fr %}
                        <option value="{{ wt_key }}" {{ work_type == wt_key ? 'selected' }}>{{ wt_label }}</option>
                    {% endfor %}
                </select>
                <button type="submit" class="h-10 shrink-0 rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground hover:bg-primary/90">Rechercher</button>
                <a href="{{ path('app_employer_job_offer_index', {filter: filter}) }}" class="h-10 shrink-0 content-center text-sm text-muted-foreground hover:text-foreground">Réinitialiser</a>
            </form>
        </div>

        {% if job_offers is empty %}
            <div class="rounded-xl border border-border bg-muted/30 py-16 text-center text-muted-foreground">
                <p class="text-sm">Aucune offre pour ce filtre.</p>
                <a href="{{ path('app_employer_job_offer_new') }}" class="mt-4 inline-block text-sm font-medium text-primary underline">Créer une offre</a>
            </div>
        {% else %}
            <ul class="space-y-4">
                {% for job in job_offers %}
                    <li class="rounded-xl border border-border bg-card p-5 shadow-sm">
                        <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                            <div class="min-w-0 flex-1 space-y-3">
                                <div class="flex flex-wrap items-center gap-2">
                                    <h3 class="text-lg font-semibold text-card-foreground">{{ job.title }}</h3>
                                    {{ include('components/badge.html.twig', {
                                        label: job.status == 'OPEN' ? 'Ouvert' : (job.status == 'CLOSED' ? 'Fermé' : 'Brouillon'),
                                        variant: job.status == 'OPEN' ? 'success' : 'secondary',
                                    }) }}
                                </div>
                                <div class="flex flex-wrap gap-x-5 gap-y-2 text-xs text-muted-foreground">
                                    <span class="inline-flex items-center gap-1.5">
                                        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                        {{ job.location|default('—') }}
                                    </span>
                                    <span class="inline-flex items-center gap-1.5">
                                        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M3 6h18"/></svg>
                                        {% set wt = job.workType %}
                                        {{ wt ? (work_fr[wt]|default(wt|replace({'_': ' '}))) : '—' }}
                                    </span>
                                    <span class="inline-flex items-center gap-1.5">
                                        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                        {% if job.minSalary or job.maxSalary %}
                                            {{ job.minSalary|default('—') }} – {{ job.maxSalary|default('—') }} {{ job.currency }}
                                        {% else %}
                                            Négociable {{ job.currency }}
                                        {% endif %}
                                    </span>
                                    <span class="inline-flex items-center gap-1.5">
                                        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                        {{ job.postedDate ? job.postedDate|date('d/m/Y') : '—' }}
                                    </span>
                                    <span class="inline-flex items-center gap-1.5">
                                        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                                        {{ job.applicationsCount }} candidature{{ job.applicationsCount > 1 ? 's' : '' }}
                                    </span>
                                </div>
                            </div>
                            <div class="flex flex-wrap items-center gap-2 lg:justify-end">
                                {% if job.status == 'OPEN' %}
                                    <form method="post" action="{{ path('app_employer_job_offer_close', {id: job.id}) }}" class="inline"
                                          onsubmit="return confirm('Fermer cette offre ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('close_job_offer_' ~ job.id) }}"/>
                                        <button type="submit" class="rounded-md border border-input bg-background px-3 py-1.5 text-xs font-medium text-foreground hover:bg-accent hover:text-accent-foreground">
                                            Fermer
                                        </button>
                                    </form>
                                {% endif %}
                                <a href="{{ path('app_employer_job_offer_show', {id: job.id}) }}"
                                   class="rounded-md border border-input bg-background px-3 py-1.5 text-xs font-medium text-foreground hover:bg-accent hover:text-accent-foreground">Voir détails</a>
                                <a href="{{ path('app_employer_job_offer_edit', {id: job.id}) }}"
                                   class="rounded-md border border-input bg-background px-3 py-1.5 text-xs font-medium text-foreground hover:bg-accent hover:text-accent-foreground">Modifier</a>
                                <form method="post" action="{{ path('app_employer_job_offer_delete', {id: job.id}) }}" class="inline"
                                      onsubmit="return confirm('Supprimer définitivement cette offre ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_job_offer_' ~ job.id) }}"/>
                                    <button type="submit" class="text-xs font-medium text-destructive hover:underline">Supprimer</button>
                                </form>
                            </div>
                        </div>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    {% endif %}
</div>
{% endblock %}
