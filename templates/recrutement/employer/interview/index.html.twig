{% extends 'recrutement/employer/base.html.twig' %}

{% block employer_title %}Entretiens · Skilora{% endblock %}
{% block page_title %}Entretiens{% endblock %}

{% block employer_content %}
<div class="space-y-6">
    <div>
        <h2 class="text-2xl font-bold tracking-tight text-foreground">Entretiens</h2>
        <p class="mt-1 text-sm text-muted-foreground">
            Candidatures <strong class="text-foreground">acceptées</strong> : les créneaux saisis sont lus et enregistrés dans la table <strong class="text-foreground">interviews</strong> (jointures candidat / offre). Temps restant mis à jour dans le navigateur.
        </p>
    </div>

    {% if interview_rows is empty %}
        <div class="rounded-xl border border-dashed border-border bg-card p-10 text-center text-sm text-muted-foreground">
            <p>Aucune candidature acceptée pour vos offres pour le moment.</p>
            <p class="mt-2">Acceptez d’abord une candidature depuis <a href="{{ path('app_employer_applications') }}" class="font-medium text-primary hover:underline">Candidatures</a>, puis planifiez un créneau : une ligne sera créée dans <strong class="text-foreground">interviews</strong>.</p>
        </div>
    {% else %}
        <ul class="flex flex-col gap-4">
            {% for row in interview_rows %}
                {% set passed = row.hasInterviewRow and (row.lifecycleStatus == 'COMPLETED' or (row.scheduledAt|date('U') < 'now'|date('U'))) %}
                <li class="list-none">
                    <article class="overflow-hidden rounded-2xl border border-border/90 bg-card shadow-sm">
                        <div class="space-y-3 p-5 sm:p-6">
                            <div class="flex flex-wrap items-start justify-between gap-3">
                                <div>
                                    <p class="text-lg font-semibold leading-tight text-foreground">{{ row.candidateName }}</p>
                                    {% if row.candidateEmail %}
                                        <p class="mt-0.5 text-sm text-muted-foreground">{{ row.candidateEmail }}</p>
                                    {% endif %}
                                    <p class="mt-2 text-xs font-medium text-emerald-700 dark:text-emerald-400">Candidature · Acceptée</p>
                                </div>
                                <a href="{{ path('app_employer_interviews_plan', {id: row.applicationId}) }}"
                                   class="inline-flex h-9 shrink-0 items-center justify-center rounded-lg border border-input bg-background px-3 text-xs font-medium shadow-sm transition hover:bg-accent hover:text-accent-foreground">
                                    {% if row.hasInterviewRow %}Modifier{% else %}Planifier{% endif %}
                                </a>
                            </div>

                            <div class="space-y-2.5 text-sm text-foreground">
                                <p class="flex items-start gap-2.5">
                                    <span class="mt-0.5 shrink-0 text-muted-foreground" aria-hidden="true">
                                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M3 6h18M3 6v10a2 2 0 002 2h14a2 2 0 002-2V6M3 6l2-2h14l2 2"/></svg>
                                    </span>
                                    <span>
                                        <span class="text-muted-foreground">Intitulé du poste</span><br/>
                                        <a href="{{ path('app_employer_job_offer_show', {id: row.jobOfferId}) }}" class="font-medium text-primary hover:underline">{{ row.jobTitle }}</a>
                                    </span>
                                </p>
                                <p class="flex items-start gap-2.5">
                                    <span class="mt-0.5 shrink-0 text-muted-foreground" aria-hidden="true">
                                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                                    </span>
                                    <span>
                                        <span class="text-muted-foreground">Date de candidature</span>
                                        <span class="font-medium tabular-nums"> · {{ row.appliedAt|date('d/m/Y H:i') }}</span>
                                    </span>
                                </p>

                                {% if not row.hasInterviewRow %}
                                    <div class="rounded-lg border border-amber-500/35 bg-amber-500/10 px-3 py-2.5 text-sm text-amber-900 dark:text-amber-100">
                                        <strong>Aucune ligne dans <code class="rounded bg-background/50 px-1">interviews</code> pour cette candidature.</strong>
                                        Cliquez sur « Planifier » pour enregistrer date, lieu et type : une ligne sera insérée dans la table <code class="rounded bg-background/50 px-1">interviews</code>.
                                    </div>
                                {% else %}
                                    <p class="flex items-start gap-2.5">
                                        <span class="mt-0.5 shrink-0 text-muted-foreground" aria-hidden="true">
                                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                        </span>
                                        <span>
                                            <span class="text-muted-foreground">Planifié</span>
                                            <span class="font-medium tabular-nums"> · {{ row.scheduledAt|date('d/m/Y') }} à {{ row.scheduledAt|date('H:i') }}</span>
                                        </span>
                                    </p>
                                    <p class="flex items-start gap-2.5">
                                        <span class="mt-0.5 shrink-0 text-muted-foreground" aria-hidden="true">
                                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                        </span>
                                        <span>
                                            <span class="text-muted-foreground">Lieu</span>
                                            <span class="font-medium"> · {{ row.location ?? '—' }}</span>
                                        </span>
                                    </p>
                                    <p class="flex items-start gap-2.5">
                                        <span class="mt-0.5 shrink-0 text-muted-foreground" aria-hidden="true">
                                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                        </span>
                                        <span>
                                            <span class="text-muted-foreground">Type</span>
                                            <span class="font-medium"> · {{ row.formatLabelFr }}</span>
                                        </span>
                                    </p>
                                {% endif %}
                            </div>

                            {% if row.hasInterviewRow %}
                                <div class="flex flex-wrap items-center justify-between gap-3 border-t border-border/60 pt-4">
                                    <div class="flex flex-wrap items-center gap-2">
                                        {% if passed %}
                                            <span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-muted/80 px-3 py-1.5 text-xs font-medium text-muted-foreground">
                                                <svg class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                                Entretien passé
                                            </span>
                                        {% else %}
                                            <span class="inline-flex items-center gap-1.5 rounded-full border border-emerald-500/40 bg-emerald-500/10 px-3 py-1.5 text-xs font-semibold text-emerald-800 dark:text-emerald-200">
                                                Planifié
                                            </span>
                                        {% endif %}
                                    </div>
                                </div>

                                <div class="rounded-lg bg-muted/40 px-3 py-2.5">
                                    <p class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Temps restant avant l’entretien</p>
                                    {% if not passed %}
                                        <p class="mt-1 text-sm font-semibold tabular-nums text-sky-800 dark:text-sky-200"
                                           data-interview-countdown
                                           data-locale="fr"
                                           data-at-ms="{{ (row.scheduledAt|date('U') + 0) * 1000 }}"
                                           data-at="{{ row.scheduledAt|date('c') }}"
                                           aria-live="polite"
                                           aria-atomic="true"></p>
                                    {% else %}
                                        <p class="mt-1 text-sm font-semibold tabular-nums text-muted-foreground">Entretien passé</p>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </div>
                    </article>
                </li>
            {% endfor %}
        </ul>
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% include 'recrutement/components/_interview_countdown_script.html.twig' %}
{% endblock %}
