{% extends 'recrutement/employer/base.html.twig' %}

{% block employer_title %}Candidatures reçues · Skilora{% endblock %}
{% block page_title %}Candidatures{% endblock %}

{% block employer_content %}
<div class="space-y-6">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div>
            <h2 class="text-2xl font-bold tracking-tight text-foreground">Candidatures reçues</h2>
            <p class="mt-1 text-sm text-muted-foreground">
                {% if company %}
                    Offres publiées par <span class="font-medium text-foreground">{{ company.name }}</span>.
                    {% if employer_sees_all_candidatures %}
                        <span class="mt-1 block text-xs leading-relaxed text-muted-foreground/90">
                            <strong>Vue globale activée</strong> : vous voyez <strong>toutes</strong> les candidatures enregistrées sur le site (toutes offres, tous candidats), pas seulement celles de votre entreprise.
                        </span>
                    {% else %}
                        <span class="mt-1 block text-xs leading-relaxed text-muted-foreground/90">
                            Affichage limité aux candidatures sur <strong>vos</strong> offres (entreprise ci-dessus).
                        </span>
                    {% endif %}
                    {% if applications_total > 0 %}
                        <span class="mt-2 block rounded-lg border border-border bg-muted/40 px-3 py-2 text-xs font-medium text-foreground">
                            {{ distinct_candidates }} candidat{{ distinct_candidates > 1 ? 's' }} distinct{{ distinct_candidates > 1 ? 's' : '' }}
                            · {{ applications_total }} candidature{{ applications_total > 1 ? 's' : '' }} au total
                        </span>
                    {% endif %}
                {% else %}
                    Aucune entreprise associée à votre compte.
                {% endif %}
            </p>
        </div>
        {% if company and applications_total > 0 %}
            <p class="inline-flex shrink-0 items-center rounded-full border border-border bg-muted/50 px-4 py-1.5 text-sm font-medium text-foreground">
                {{ applications_total }} candidature{{ applications_total > 1 ? 's' : '' }}
            </p>
        {% endif %}
    </div>

    {% if company is null %}
        {{ include('components/alert.html.twig', {
            title: 'Profil entreprise manquant',
            body: 'Associez un compte entreprise pour recevoir et gérer les candidatures.',
        }) }}
    {% elseif candidatures is empty %}
        <div class="rounded-xl border border-dashed border-border bg-card p-12 text-center">
            <p class="text-sm font-medium text-foreground">Aucune candidature pour le moment</p>
            <p class="mt-1 text-sm text-muted-foreground">Les envois des candidats apparaîtront ici dès qu’une offre est publiée.</p>
            <a href="{{ path('app_employer_job_offer_index') }}" class="mt-4 inline-block text-sm font-medium text-primary hover:underline">Voir mes offres</a>
        </div>
    {% else %}
        <div class="overflow-x-auto rounded-xl border border-border bg-card shadow-sm">
            <table class="w-full min-w-[720px] text-left text-sm">
                <thead>
                    <tr class="border-b border-border bg-muted/40 text-xs font-semibold uppercase tracking-wider text-muted-foreground">
                        <th class="px-4 py-3">Candidat</th>
                        <th class="px-4 py-3">Offre</th>
                        <th class="px-4 py-3 whitespace-nowrap">Reçue le</th>
                        <th class="px-4 py-3">Statut</th>
                        <th class="px-4 py-3 w-px whitespace-nowrap text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border">
                    {% for c in candidatures %}
                        <tr class="transition-colors hover:bg-muted/25">
                            <td class="px-4 py-4 align-top">
                                <p class="font-medium text-foreground">{{ c.candidateName }}</p>
                                {% if c.candidateEmail %}
                                    <p class="text-xs text-muted-foreground">{{ c.candidateEmail }}</p>
                                {% endif %}
                            </td>
                            <td class="px-4 py-4 align-top">
                                <a href="{{ path('app_employer_job_offer_show', {id: c.jobOfferId}) }}" class="font-medium text-foreground hover:text-primary hover:underline">{{ c.jobTitle }}</a>
                            </td>
                            <td class="px-4 py-4 align-top text-muted-foreground whitespace-nowrap">
                                {{ c.appliedAt|date('d/m/Y H:i') }}
                            </td>
                            <td class="px-4 py-4 align-top">
                                <span class="text-sm text-foreground">{{ c.statusLabelFr }}</span>
                            </td>
                            <td class="px-4 py-4 align-top text-right">
                                {{ include('recrutement/employer/applications/_status_actions.html.twig', {
                                    application: c,
                                    return_to: 'list',
                                    show_profile_link: true,
                                }) }}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
{% endblock %}
