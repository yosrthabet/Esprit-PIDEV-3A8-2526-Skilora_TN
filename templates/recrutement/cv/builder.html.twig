{% extends 'recrutement/candidate/base.html.twig' %}

{% block candidate_title %}Générateur de CV · Skilora{% endblock %}
{% block candidate_page_title %}Générateur de CV{% endblock %}

{% block candidate_content %}
<div class="mx-auto max-w-4xl space-y-8">
    <div class="candidate-stagger space-y-3">
        <h1 class="candidate-font-display text-3xl font-semibold tracking-tight text-foreground">Créer un CV professionnel</h1>
        <p class="text-sm text-muted-foreground">
            Remplissez le formulaire, puis téléchargez votre CV en PDF ou enregistrez-le pour vos prochaines candidatures.
        </p>
        {% if saved_cv_relpath %}
            <p class="text-xs text-emerald-700 dark:text-emerald-400">
                Un CV généré est disponible pour candidature : <span class="font-medium">{{ saved_cv_relpath }}</span>
            </p>
        {% endif %}
    </div>

    <div class="rounded-3xl border border-border/80 bg-card/85 p-6 shadow-lg shadow-primary/5 backdrop-blur-sm sm:p-8">
        {{ form_start(form, { attr: { class: 'space-y-8', enctype: 'multipart/form-data' } }) }}

        <section class="space-y-4">
            <h2 class="candidate-font-display text-lg font-semibold text-foreground">Informations personnelles</h2>
            <div class="grid gap-4 sm:grid-cols-2">
                <div>{{ form_row(form.fullName) }}</div>
                <div>{{ form_row(form.email) }}</div>
                <div>{{ form_row(form.phone) }}</div>
                <div>{{ form_row(form.photo) }}</div>
            </div>
            <div>{{ form_row(form.address) }}</div>
            <div>{{ form_row(form.professionalSummary) }}</div>
        </section>

        <section class="space-y-4">
            <div class="flex items-center justify-between gap-3">
                <h2 class="candidate-font-display text-lg font-semibold text-foreground">Formation</h2>
                <button type="button" class="rounded-lg border border-input px-3 py-1.5 text-xs font-medium hover:bg-accent" data-add-education>+ Ajouter</button>
            </div>
            <div id="education-list" data-prototype="{{ form_widget(form.education.vars.prototype)|e('html_attr') }}" data-index="{{ form.education|length }}">
                {% for edu in form.education %}
                    <div class="mb-4 rounded-xl border border-border p-4">
                        <div class="grid gap-3 sm:grid-cols-3">
                            <div>{{ form_row(edu.degree) }}</div>
                            <div>{{ form_row(edu.institution) }}</div>
                            <div>{{ form_row(edu.year) }}</div>
                        </div>
                        <button type="button" class="mt-2 text-xs font-medium text-destructive" data-remove-entry>Supprimer</button>
                    </div>
                {% endfor %}
            </div>
        </section>

        <section class="space-y-4">
            <div class="flex items-center justify-between gap-3">
                <h2 class="candidate-font-display text-lg font-semibold text-foreground">Expérience</h2>
                <button type="button" class="rounded-lg border border-input px-3 py-1.5 text-xs font-medium hover:bg-accent" data-add-experience>+ Ajouter</button>
            </div>
            <div id="experience-list" data-prototype="{{ form_widget(form.experience.vars.prototype)|e('html_attr') }}" data-index="{{ form.experience|length }}">
                {% for xp in form.experience %}
                    <div class="mb-4 rounded-xl border border-border p-4">
                        <div class="grid gap-3 sm:grid-cols-2">
                            <div>{{ form_row(xp.jobTitle) }}</div>
                            <div>{{ form_row(xp.company) }}</div>
                            <div>{{ form_row(xp.duration) }}</div>
                            <div class="sm:col-span-2">{{ form_row(xp.description) }}</div>
                        </div>
                        <button type="button" class="mt-2 text-xs font-medium text-destructive" data-remove-entry>Supprimer</button>
                    </div>
                {% endfor %}
            </div>
        </section>

        <section class="space-y-4">
            <h2 class="candidate-font-display text-lg font-semibold text-foreground">Compétences & langues</h2>
            <div>{{ form_row(form.skills) }}</div>
            <div>{{ form_row(form.languages) }}</div>
            <div>{{ form_row(form.template) }}</div>
        </section>

        <div class="flex flex-wrap justify-end gap-3">
            {{ form_widget(form.download) }}
            {{ form_widget(form.save) }}
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (function () {
            function setupCollection(listId, addSelector, renderClass) {
                const list = document.getElementById(listId);
                const addBtn = document.querySelector(addSelector);
                if (!list || !addBtn) return;

                addBtn.addEventListener('click', function () {
                    const idx = parseInt(list.getAttribute('data-index') || '0', 10);
                    const proto = list.getAttribute('data-prototype') || '';
                    const html = proto.replace(/__name__/g, String(idx));
                    const wrapper = document.createElement('div');
                    wrapper.className = renderClass;
                    wrapper.innerHTML = html + '<button type="button" class="mt-2 text-xs font-medium text-destructive" data-remove-entry>Supprimer</button>';
                    list.appendChild(wrapper);
                    list.setAttribute('data-index', String(idx + 1));
                });
            }

            document.addEventListener('click', function (e) {
                const target = e.target;
                if (!(target instanceof HTMLElement)) return;
                if (target.hasAttribute('data-remove-entry')) {
                    const block = target.closest('.rounded-xl.border');
                    if (block) block.remove();
                }
            });

            setupCollection('education-list', '[data-add-education]', 'mb-4 rounded-xl border border-border p-4');
            setupCollection('experience-list', '[data-add-experience]', 'mb-4 rounded-xl border border-border p-4');
        })();
    </script>
{% endblock %}
