{# Temps restant = date/heure d’entretien (data-at ISO-8601) − Date.now(). Recalculé chaque seconde côté navigateur. data-locale="fr" pour le libellé français. #}
<script>
(function () {
    function formatRemainingFr(ms) {
        if (ms <= 0) {
            return 'Entretien passé';
        }
        var s = Math.floor(ms / 1000);
        var d = Math.floor(s / 86400);
        var h = Math.floor((s % 86400) / 3600);
        var m = Math.floor((s % 3600) / 60);
        var sec = s % 60;
        if (d > 0) {
            return 'Dans ' + d + ' jour' + (d > 1 ? 's' : '') + ', ' + h + ' h';
        }
        if (h > 0) {
            return 'Dans ' + h + ' h ' + m + ' min';
        }
        if (m > 0) {
            return 'Dans ' + m + ' min ' + sec + ' s';
        }
        return 'Dans ' + sec + ' s';
    }

    function formatRemainingEn(ms) {
        if (ms <= 0) {
            return 'Interview time passed';
        }
        var s = Math.floor(ms / 1000);
        var d = Math.floor(s / 86400);
        var h = Math.floor((s % 86400) / 3600);
        var m = Math.floor((s % 3600) / 60);
        var sec = s % 60;
        if (d > 0) {
            return 'In ' + d + ' day' + (d === 1 ? '' : 's') + ', ' + h + ' hour' + (h === 1 ? '' : 's');
        }
        if (h > 0) {
            return 'In ' + h + ' hour' + (h === 1 ? '' : 's') + ', ' + m + ' min';
        }
        if (m > 0) {
            return 'In ' + m + ' min, ' + sec + ' s';
        }
        return 'In ' + sec + ' s';
    }

    function tick(el) {
        var at = el.getAttribute('data-at');
        var atMs = el.getAttribute('data-at-ms');
        var loc = el.getAttribute('data-locale') || el.dataset.locale || 'en';
        var target;
        if (atMs !== null && atMs !== '') {
            var ms = parseInt(atMs, 10);
            target = new Date(isNaN(ms) ? NaN : ms);
        } else if (at) {
            target = new Date(at);
        } else {
            el.textContent = el.dataset.emptyLabel != null ? el.dataset.emptyLabel : '';
            return;
        }
        if (isNaN(target.getTime())) {
            el.textContent = loc === 'fr' ? 'Date invalide' : 'Invalid date';
            return;
        }
        var ms = target.getTime() - Date.now();
        el.textContent = loc === 'fr' ? formatRemainingFr(ms) : formatRemainingEn(ms);
    }

    window.initInterviewCountdowns = function () {
        document.querySelectorAll('[data-interview-countdown]').forEach(function (el) {
            tick(el);
            if (el._interviewCdId) {
                clearInterval(el._interviewCdId);
            }
            el._interviewCdId = window.setInterval(function () {
                tick(el);
            }, 1000);
        });
    };

    function ready(fn) {
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', fn);
        } else {
            fn();
        }
    }
    ready(function () {
        window.initInterviewCountdowns();
    });
})();
</script>
