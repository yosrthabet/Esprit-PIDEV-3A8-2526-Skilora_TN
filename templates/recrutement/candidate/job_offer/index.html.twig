{% extends 'recrutement/candidate/base.html.twig' %}

{% block candidate_title %}Toutes les offres{% endblock %}
{% block candidate_page_title %}Offres d’emploi{% endblock %}

{% set work_fr = work_type_labels() %}
{% set work_type = work_type|default('all') %}
{% set search = search|default(null) %}
{% set sort = sort|default('posted') %}

{% block candidate_content %}
<div class="mx-auto w-full min-w-0 max-w-6xl space-y-6 pb-2">

    {# ── Header + Search ── #}
    <div class="rounded-2xl border border-border bg-gradient-to-br from-primary/5 via-card to-accent/5 p-6 shadow-sm sm:p-8">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
            <div class="space-y-2">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary/80">Parcourir</p>
                <h1 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">Offres d'emploi</h1>
                <p class="max-w-xl text-sm leading-relaxed text-muted-foreground">
                    Trouvez votre prochaine opportunité parmi <strong class="text-foreground">{{ total }}</strong> offre{{ total > 1 ? 's' : '' }} disponible{{ total > 1 ? 's' : '' }}.
                </p>
                {% if aneti_count|default(0) > 0 %}
                    <p class="text-xs text-muted-foreground">
                        + {{ aneti_count }} offre{{ aneti_count > 1 ? 's' : '' }} externe{{ aneti_count > 1 ? 's' : '' }} (Source: ANETI)
                    </p>
                {% endif %}
                {% if is_employer %}
                    <p class="rounded-lg border border-amber-500/35 bg-amber-500/10 px-3 py-2 text-xs font-medium text-amber-800 dark:text-amber-200">
                        Compte employeur : la candidature est réservée aux profils candidats.
                    </p>
                {% endif %}
            </div>
        </div>

        <form method="get" action="{{ path('app_candidate_offres_index') }}" class="mt-6 space-y-4" role="search" aria-label="Filtrer les offres">
            {# Ligne 1 : champ de recherche pleine largeur (évite le chevauchement des labels en flex row) #}
            <div class="flex flex-col gap-1.5">
                <label for="candidate-offres-q" class="text-xs font-medium leading-none text-muted-foreground">Recherche</label>
                <div class="flex h-11 w-full min-w-0 items-center gap-3 rounded-xl border border-input bg-background px-3 shadow-sm focus-within:ring-2 focus-within:ring-ring">
                    <svg class="h-4 w-4 shrink-0 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                    <input id="candidate-offres-q"
                           type="text"
                           name="q"
                           value="{{ search|default('') }}"
                           placeholder="Titre, ville, entreprise, compétences…"
                           autocomplete="off"
                           inputmode="search"
                           enterkeyhint="search"
                           class="min-w-0 flex-1 border-0 bg-transparent py-0 text-base text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-0 sm:text-sm"
                    />
                </div>
            </div>

            {# Ligne 2 : filtres + tri + actions #}
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-12 lg:items-end">
                <div class="flex flex-col gap-1.5 sm:col-span-1 lg:col-span-3">
                    <label for="candidate-offres-wt" class="text-xs font-medium leading-none text-muted-foreground">Mode de travail</label>
                    <select id="candidate-offres-wt" name="work_type" class="h-11 w-full rounded-xl border border-input bg-background px-3 text-sm text-foreground shadow-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                        <option value="all" {{ work_type == 'all' ? 'selected' }}>Tous les modes</option>
                        {% for wt_key, wt_label in work_fr %}
                            <option value="{{ wt_key }}" {{ work_type == wt_key ? 'selected' }}>{{ wt_label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="flex flex-col gap-1.5 sm:col-span-1 lg:col-span-3">
                    <label for="candidate-offres-sort" class="text-xs font-medium leading-none text-muted-foreground">Tri</label>
                    <select id="candidate-offres-sort" name="sort" class="h-11 w-full rounded-xl border border-input bg-background px-3 text-sm text-foreground shadow-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                        <option value="posted" {{ sort == 'posted' ? 'selected' }}>Plus récentes</option>
                        <option value="salary" {{ sort == 'salary' ? 'selected' }}>Salaire (plus élevé)</option>
                    </select>
                </div>
                <div class="flex flex-wrap items-center gap-2 sm:col-span-2 lg:col-span-6 lg:justify-end">
                    <button type="submit" class="h-11 min-w-[8rem] rounded-xl bg-primary px-5 text-sm font-semibold text-primary-foreground shadow-sm transition-colors hover:bg-primary/90">Rechercher</button>
                    {% if search or work_type != 'all' or sort == 'salary' %}
                        <a href="{{ path('app_candidate_offres_index') }}" class="inline-flex h-11 items-center rounded-xl border border-input bg-background px-4 text-sm font-medium text-foreground shadow-sm transition-colors hover:bg-accent">Réinitialiser</a>
                    {% endif %}
                </div>
            </div>
        </form>
    </div>

    {% if job_offers is empty %}
        {# ── Empty state ── #}
        <div class="rounded-2xl border border-dashed border-border bg-card/60 px-6 py-16 text-center">
            <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-muted text-muted-foreground">
                <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/></svg>
            </div>
            <p class="mt-5 text-lg font-semibold text-foreground">Aucune offre trouvée</p>
            <p class="mx-auto mt-2 max-w-md text-sm text-muted-foreground">Essayez d'élargir vos critères de recherche ou revenez bientôt.</p>
        </div>
    {% else %}
        {# ── Job Cards ── #}
        <div class="space-y-3">
            {% for job in job_offers %}
                {% set company_label = job.companyName|default(job.company.name|default('Entreprise')) %}
                {% set initials = company_label|slice(0, 1)|upper %}
                {% set wt = job.workType %}
                {% set has_salary = job.minSalary or job.maxSalary %}
                {% set is_aneti = job.source is defined and job.source == 'ANETI' %}
                {% set job_href = is_aneti ? (job.externalUrl|default('#')) : path('app_candidate_offres_show', {id: job.id}) %}

                <a href="{{ job_href }}"
                   {% if is_aneti %}target="_blank" rel="noopener noreferrer"{% endif %}
                   class="group block rounded-xl border border-border bg-card shadow-sm transition-all duration-200 hover:border-primary/30 hover:shadow-md">
                    <div class="flex items-start gap-4 p-5 sm:p-6">
                        {# Company avatar #}
                        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-primary/15 to-primary/5 text-base font-bold text-primary ring-1 ring-primary/10 transition-transform duration-200 group-hover:scale-105">
                            {{ initials }}
                        </div>

                        {# Content #}
                        <div class="min-w-0 flex-1">
                            <div class="flex items-start justify-between gap-3">
                                <div class="min-w-0 flex-1">
                                    <h2 class="text-base font-semibold text-foreground transition-colors group-hover:text-primary sm:text-lg">{{ job.title }}</h2>
                                    <p class="mt-0.5 text-sm text-muted-foreground">{{ company_label }}</p>
                                </div>
                                {% if job.isFeatured %}
                                    <span class="shrink-0 inline-flex items-center gap-1 rounded-full bg-amber-500/10 px-2.5 py-1 text-[11px] font-semibold text-amber-600 dark:text-amber-400 ring-1 ring-amber-500/20">
                                        <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                        En vedette
                                    </span>
                                {% endif %}
                                {% if is_aneti %}
                                    <span class="shrink-0 inline-flex items-center rounded-full bg-blue-500/10 px-2.5 py-1 text-[11px] font-semibold text-blue-700 dark:text-blue-300 ring-1 ring-blue-500/20">
                                        Source: ANETI
                                    </span>
                                {% endif %}
                            </div>

                            {# Tags row #}
                            <div class="mt-3 flex flex-wrap items-center gap-2">
                                {% if job.location %}
                                    <span class="inline-flex items-center gap-1.5 rounded-lg bg-muted/60 px-2.5 py-1 text-xs font-medium text-muted-foreground">
                                        <svg class="h-3.5 w-3.5 shrink-0 text-muted-foreground/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                        {{ job.location }}
                                    </span>
                                {% endif %}
                                {% if wt %}
                                    <span class="inline-flex items-center gap-1.5 rounded-lg bg-primary/8 px-2.5 py-1 text-xs font-medium text-primary">
                                        <svg class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                                        {{ wt|work_type_label }}
                                    </span>
                                {% endif %}
                                {% if job.experienceLevel %}
                                    <span class="inline-flex items-center gap-1.5 rounded-lg bg-muted/60 px-2.5 py-1 text-xs font-medium text-muted-foreground">
                                        <svg class="h-3.5 w-3.5 shrink-0 text-muted-foreground/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                                        {{ job.experienceLevel }}
                                    </span>
                                {% endif %}
                                {% if has_salary %}
                                    <span class="inline-flex items-center gap-1.5 rounded-lg bg-emerald-500/10 px-2.5 py-1 text-xs font-semibold text-emerald-600 dark:text-emerald-400">
                                        <svg class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                        {% if job.minSalary and job.maxSalary %}
                                            {{ job.minSalary }} – {{ job.maxSalary }} {{ job.currency }}
                                        {% elseif job.minSalary %}
                                            Dès {{ job.minSalary }} {{ job.currency }}
                                        {% else %}
                                            Jusqu'à {{ job.maxSalary }} {{ job.currency }}
                                        {% endif %}
                                    </span>
                                {% endif %}
                            </div>

                            {# Description preview #}
                            {% if job.description %}
                                <p class="mt-3 line-clamp-2 text-sm leading-relaxed text-muted-foreground">
                                    {{ job.description|striptags|slice(0, 180) }}{% if job.description|striptags|length > 180 %}…{% endif %}
                                </p>
                            {% endif %}

                            {# Footer: date + arrow #}
                            <div class="mt-4 flex items-center justify-between">
                                <div class="flex items-center gap-3 text-xs text-muted-foreground">
                                    {% if job.postedDate %}
                                        <span class="inline-flex items-center gap-1">
                                            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                            {{ job.postedDate|date('d M Y') }}
                                        </span>
                                    {% endif %}
                                    {% if job.deadline %}
                                        <span class="inline-flex items-center gap-1 text-amber-600 dark:text-amber-400">
                                            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                            Limite : {{ job.deadline|date('d/m/Y') }}
                                        </span>
                                    {% endif %}
                                </div>
                                <span class="hidden shrink-0 items-center gap-1 text-sm font-medium text-primary opacity-0 transition-all duration-200 group-hover:opacity-100 sm:inline-flex">
                                    {{ is_aneti ? "Voir l'offre ANETI" : "Voir l'offre" }}
                                    <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                                </span>
                            </div>
                        </div>
                    </div>
                </a>
            {% endfor %}
        </div>

        {# ── Pagination ── #}
        {% if page_count > 1 %}
            {% set base_query = {} %}
            {% if search %}{% set base_query = base_query|merge({q: search}) %}{% endif %}
            {% if work_type != 'all' %}{% set base_query = base_query|merge({work_type: work_type}) %}{% endif %}
            {% if sort is defined and sort == 'salary' %}{% set base_query = base_query|merge({sort: 'salary'}) %}{% endif %}
            <nav class="flex flex-wrap items-center justify-between gap-4 pt-2" aria-label="Pagination">
                <p class="text-sm text-muted-foreground">
                    Page {{ current_page }} sur {{ page_count }} · {{ total }} résultat{{ total > 1 ? 's' : '' }}
                </p>
                <div class="flex items-center gap-1.5">
                    <a href="{{ path('app_candidate_offres_index', base_query|merge({page: current_page - 1})) }}"
                       class="inline-flex h-9 items-center rounded-xl border border-input bg-background px-3.5 text-sm font-medium shadow-sm hover:bg-accent transition-colors {{ current_page <= 1 ? 'pointer-events-none opacity-40' : '' }}">
                        Précédent
                    </a>
                    {% for p in 1..page_count %}
                        {% if p <= 3 or p > page_count - 3 or (p >= current_page - 1 and p <= current_page + 1) %}
                            <a href="{{ path('app_candidate_offres_index', base_query|merge({page: p})) }}"
                               class="inline-flex h-9 w-9 items-center justify-center rounded-xl text-sm font-medium transition-colors {{ p == current_page ? 'bg-primary text-primary-foreground shadow' : 'border border-input bg-background hover:bg-accent' }}">
                                {{ p }}
                            </a>
                        {% elseif p == 4 or p == page_count - 3 %}
                            <span class="inline-flex h-9 w-9 items-center justify-center text-sm text-muted-foreground">…</span>
                        {% endif %}
                    {% endfor %}
                    <a href="{{ path('app_candidate_offres_index', base_query|merge({page: current_page + 1})) }}"
                       class="inline-flex h-9 items-center rounded-xl border border-input bg-background px-3.5 text-sm font-medium shadow-sm hover:bg-accent transition-colors {{ current_page >= page_count ? 'pointer-events-none opacity-40' : '' }}">
                        Suivant
                    </a>
                </div>
            </nav>
        {% endif %}
    {% endif %}
</div>
{% endblock %}
