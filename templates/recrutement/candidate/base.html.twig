{# Espace candidat — même shell que l’app (sidebar + barre du haut) #}
{% extends 'layouts/app.html.twig' %}

{% set current_route = app.request.attributes.get('_route') %}

{% block head %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&family=DM+Sans:ital,opsz@0,9..40,wght@0,400;0,500;0,600;0,700&display=swap" rel="stylesheet">
{% endblock %}

{% block sidebar_home_url %}{{ path('app_candidate_offres_index') }}{% endblock %}

{% block title %}{% block candidate_title %}Offres · Skilora{% endblock %}{% endblock %}

{% block page_title %}{% block candidate_page_title %}Offres d’emploi{% endblock %}{% endblock %}

{% block sidebar_nav %}
<p class="px-3 pb-2 pt-1 text-[11px] font-semibold uppercase tracking-widest text-sidebar-foreground/50">Espace candidat</p>
{% set nav = [
    {
        label: 'Offres d’emploi',
        route: 'app_candidate_offres_index',
        icon: 'briefcase',
        routes: ['app_candidate_offres_index', 'app_candidate_offres_show', 'app_candidate_offres_apply'],
    },
    {
        label: 'Mes candidatures',
        route: 'app_candidate_area_applications',
        icon: 'applications',
        routes: ['app_candidate_area_applications'],
    },
] %}

{% for item in nav %}
    {% set active = current_route in item.routes %}
    <a href="{{ path(item.route) }}"
       class="group candidate-nav-link flex w-full min-h-[2.5rem] items-center gap-3 rounded-xl px-3 py-2.5 text-left text-sm font-medium leading-none transition-all duration-200
              {{ active
                  ? 'bg-sidebar-primary/10 text-sidebar-foreground shadow-sm ring-1 ring-sidebar-primary/20 dark:bg-sidebar-primary/15 dark:ring-sidebar-primary/25'
                  : 'text-sidebar-foreground/75 hover:bg-sidebar-accent hover:text-sidebar-accent-foreground' }}">
        {{ _self.nav_icon(item.icon) }}
        <span class="min-w-0 flex-1 truncate">{{ item.label }}</span>
    </a>
{% endfor %}

{% if is_granted('ROLE_EMPLOYER') %}
    <a href="{{ path('app_employer_dashboard') }}"
       class="flex w-full min-h-[2.5rem] items-center gap-3 rounded-lg px-3 py-2.5 text-left text-sm font-medium text-sidebar-foreground/70 transition-colors hover:bg-sidebar-accent hover:text-sidebar-accent-foreground">
        {{ _self.nav_icon('building') }}
        <span class="min-w-0 flex-1 truncate">Espace employeur</span>
    </a>
{% endif %}

<a href="{{ path('app_logout') }}"
   class="mt-2 flex w-full min-h-[2.5rem] items-center gap-3 rounded-lg px-3 py-2.5 text-left text-sm font-medium text-sidebar-foreground/60 transition-colors hover:bg-sidebar-accent hover:text-sidebar-accent-foreground">
    {{ _self.nav_icon('logout') }}
    <span class="min-w-0 flex-1 truncate">Déconnexion</span>
</a>
{% endblock %}

{% block content %}
<div class="candidate-zone">
    {% block candidate_content %}{% endblock %}
</div>
{% endblock %}

{% macro nav_icon(name) %}
    {% if name == 'applications' %}
        <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
    {% elseif name == 'briefcase' %}
        <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M3 6h18M3 6v10a2 2 0 002 2h14a2 2 0 002-2V6M3 6l2-2h14l2 2"/></svg>
    {% elseif name == 'building' %}
        <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
    {% elseif name == 'logout' %}
        <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
    {% endif %}
{% endmacro %}
